<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: 'Admin Dashboard - helloRun' }) %>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <main class="admin-page">
    <section class="section admin-shell">
      <h2>Admin Dashboard</h2>

      <h3 class="dashboard-section-title">Organizer Applications</h3>
      <div class="dashboard-grid">
        <article class="metric-card">
          <p class="metric-label">Pending Applications</p>
          <p class="metric-value"><%= stats.pendingApplications %></p>
          <a href="/admin/applications?status=pending" class="metric-link">Review Pending</a>
        </article>

        <article class="metric-card">
          <p class="metric-label">Total Applications</p>
          <p class="metric-value"><%= stats.totalApplications %></p>
          <a href="/admin/applications" class="metric-link">View All</a>
        </article>

        <article class="metric-card">
          <p class="metric-label">Approved</p>
          <p class="metric-value"><%= stats.approvedApplications %></p>
          <a href="/admin/applications?status=approved" class="metric-link">View Approved</a>
        </article>

        <article class="metric-card">
          <p class="metric-label">Rejected</p>
          <p class="metric-value"><%= stats.rejectedApplications %></p>
          <a href="/admin/applications?status=rejected" class="metric-link">View Rejected</a>
        </article>

        <article class="metric-card">
          <p class="metric-label">Total Users</p>
          <p class="metric-value"><%= stats.totalUsers %></p>
          <p class="metric-helper">Platform accounts</p>
        </article>
      </div>

      <h3 class="dashboard-section-title">Platform Snapshot</h3>
      <div class="dashboard-grid">
        <article class="metric-card">
          <p class="metric-label">Total Events</p>
          <p class="metric-value"><%= stats.totalEvents %></p>
          <p class="metric-helper">All statuses</p>
        </article>

        <article class="metric-card">
          <p class="metric-label">Published Events</p>
          <p class="metric-value"><%= stats.publishedEvents %></p>
          <a href="/events" class="metric-link">Open Public Events</a>
        </article>

        <article class="metric-card">
          <p class="metric-label">Total Registrations</p>
          <p class="metric-value"><%= stats.totalRegistrations %></p>
          <p class="metric-helper">Runner signups</p>
        </article>

        <article class="metric-card">
          <p class="metric-label">Pending Payment Reviews</p>
          <p class="metric-value"><%= stats.pendingPaymentReviews %></p>
          <p class="metric-helper">Needs organizer action</p>
        </article>

        <article class="metric-card">
          <p class="metric-label">Total Submissions</p>
          <p class="metric-value"><%= stats.totalSubmissions %></p>
          <p class="metric-helper">All result statuses</p>
        </article>

        <article class="metric-card">
          <p class="metric-label">Approved Submissions</p>
          <p class="metric-value"><%= stats.approvedSubmissions %></p>
          <p class="metric-helper">Eligible for certificates</p>
        </article>

        <article class="metric-card">
          <p class="metric-label">Pending Result Reviews</p>
          <p class="metric-value"><%= stats.pendingResultReviews %></p>
          <p class="metric-helper">Needs organizer action</p>
        </article>
      </div>

      <h3 class="dashboard-section-title">Pending Organizer Applications</h3>
      <% if (pendingApplicationsList && pendingApplicationsList.length) { %>
        <table class="admin-table">
          <thead>
            <tr>
              <th>Application ID</th>
              <th>Business</th>
              <th>Applicant</th>
              <th>Status</th>
              <th>Submitted</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% pendingApplicationsList.forEach((item) => { %>
              <tr>
                <td class="mono"><%= item.applicationId %></td>
                <td><%= item.businessName %></td>
                <td>
                  <strong><%= item.applicantName %></strong>
                  <div><small><%= item.applicantEmail %></small></div>
                </td>
                <td>
                  <span class="status-badge status-badge-<%= item.status %>"><%= item.status %></span>
                </td>
                <td><%= item.submittedAt ? new Date(item.submittedAt).toLocaleDateString('en-US') : 'N/A' %></td>
                <td><a href="/admin/applications/<%= item.id %>" class="btn btn-sm">Review</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <p>No pending organizer applications right now.</p>
        </div>
      <% } %>

      <h3 class="dashboard-section-title">Blog Moderation</h3>
      <div class="dashboard-grid">
        <article class="metric-card">
          <p class="metric-label">Pending Blog Reviews</p>
          <p class="metric-value"><%= stats.pendingBlogs %></p>
          <a href="/admin/blog/review?status=pending" class="metric-link">Review Queue</a>
        </article>

        <article class="metric-card">
          <p class="metric-label">Total Blog Posts</p>
          <p class="metric-value"><%= stats.totalBlogs %></p>
          <a href="/admin/blog/review" class="metric-link">View All Blog Statuses</a>
        </article>

        <article class="metric-card">
          <p class="metric-label">Published Blogs</p>
          <p class="metric-value"><%= stats.publishedBlogs %></p>
          <a href="/admin/blog/review?status=published" class="metric-link">View Published</a>
        </article>

        <article class="metric-card">
          <p class="metric-label">Rejected Blogs</p>
          <p class="metric-value"><%= stats.rejectedBlogs %></p>
          <a href="/admin/blog/review?status=rejected" class="metric-link">View Rejected</a>
        </article>

        <article class="metric-card">
          <p class="metric-label">Archived Blogs</p>
          <p class="metric-value"><%= stats.archivedBlogs %></p>
          <a href="/admin/blog/review?status=archived" class="metric-link">View Archived</a>
        </article>
      </div>

      <nav class="admin-menu">
        <a href="/admin/applications" class="btn">Organizer Applications</a>
        <a href="/admin/blog/review" class="btn btn-secondary">Blog Moderation</a>
      </nav>
    </section>
  </main>
  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>
