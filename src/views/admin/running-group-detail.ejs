<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title }) %>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-running-groups.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <main class="admin-page admin-running-groups-page admin-running-group-detail-page">
    <section class="section admin-shell">
      <% const countsMatch = Number(group.memberCount || 0) === actualMemberCount; const creatorName = [group.createdBy?.firstName, group.createdBy?.lastName].filter(Boolean).join(' ').trim() || group.createdBy?.email || 'Unavailable'; %>
      <div class="admin-header-row admin-group-detail-header">
        <div><p class="dashboard-kicker">Running group</p><div class="admin-group-title-row"><h2><%= group.name %></h2><span class="status-badge <%= group.isActive ? 'status-badge-approved' : 'status-badge-archived' %>"><%= group.isActive ? 'Active' : 'Archived' %></span></div><p class="admin-group-stable-slug"><span>Stable URL</span><code><%= group.slug %></code></p></div>
        <div class="admin-group-header-actions"><a href="/admin/running-groups" class="btn btn-secondary"><i data-lucide="arrow-left" aria-hidden="true"></i>All groups</a><% if (group.isActive) { %><a href="/runner/groups/<%= group.slug %>" class="btn btn-secondary"><i data-lucide="external-link" aria-hidden="true"></i>Runner view</a><% } %></div>
      </div>
      <% if (message) { %><div class="admin-alert admin-alert-<%= message.type %>" role="<%= message.type === 'error' ? 'alert' : 'status' %>"><%= message.text %></div><% } %>

      <div class="admin-group-detail-strip" aria-label="Running group overview">
        <article><span>Cached</span><strong><%= Number(group.memberCount || 0) %></strong></article>
        <article class="<%= countsMatch ? 'is-matched' : 'has-mismatch' %>"><span>Actual</span><strong><%= actualMemberCount %></strong><small><%= countsMatch ? 'Counts match' : 'Reconcile needed' %></small></article>
        <article><span>Creator</span><strong title="<%= creatorName %>"><%= creatorName %></strong></article>
        <article><span>Created</span><strong><%= group.createdAt ? new Date(group.createdAt).toLocaleDateString('en-US') : 'N/A' %></strong></article>
        <article><span>Updated</span><strong><%= group.updatedAt ? new Date(group.updatedAt).toLocaleDateString('en-US') : 'N/A' %></strong></article>
      </div>

      <section class="detail-card admin-group-members-section">
        <div class="admin-group-section-heading"><div><h3>Members</h3><p><%= memberPagination.total %> current membership<%= memberPagination.total === 1 ? '' : 's' %></p></div><form method="GET" action="/admin/running-groups/<%= group._id %>" role="search" class="admin-group-member-search"><label class="sr-only" for="memberSearch">Search members</label><input id="memberSearch" type="search" name="q" value="<%= memberFilters.q %>" placeholder="Name, email, runner ID"><button class="btn btn-sm" type="submit">Search</button><% if (memberFilters.q) { %><a class="btn btn-sm btn-secondary" href="/admin/running-groups/<%= group._id %>">Clear</a><% } %></form></div>
        <% if (members.length) { %><div class="admin-users-table-wrap admin-group-table-wrap"><table class="admin-table admin-group-table admin-group-member-table"><thead><tr><th>Runner</th><th>Role</th><th>Account</th><th>Profile created</th><th>Action</th></tr></thead><tbody><% members.forEach((member) => { const memberName = [member.firstName, member.lastName].filter(Boolean).join(' ').trim() || member.email; %><tr><td data-label="Runner"><a href="/admin/users/<%= member._id %>" class="admin-group-member-link"><strong><%= memberName %></strong><small><%= member.userId || member.email %></small></a></td><td data-label="Role"><%= member.role %></td><td data-label="Account"><span class="status-badge"><%= member.accountStatus || 'active' %></span></td><td data-label="Profile created"><%= member.createdAt ? new Date(member.createdAt).toLocaleDateString('en-US') : 'N/A' %></td><td data-label="Action"><details class="admin-group-remove-disclosure"><summary class="btn btn-sm btn-danger">Remove</summary><form method="POST" action="/admin/running-groups/<%= group._id %>/members/<%= member._id %>/remove" class="admin-group-form" data-admin-group-confirm data-confirm-title="Remove this runner?" data-confirm-copy="The runner will be notified and this membership will no longer count."><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><label>Moderation reason<textarea name="reason" required minlength="8" maxlength="500" rows="2"></textarea></label><button class="btn btn-danger btn-sm" type="submit">Confirm removal</button></form></details></td></tr><% }) %></tbody></table></div><% if (memberPagination.totalPages > 1) { %><nav class="pagination" aria-label="Member pages"><% if (memberPagination.page > 1) { %><a class="btn btn-secondary" href="?q=<%= encodeURIComponent(memberFilters.q) %>&memberPage=<%= memberPagination.page - 1 %>">Previous</a><% } %><span>Page <%= memberPagination.page %> of <%= memberPagination.totalPages %></span><% if (memberPagination.page < memberPagination.totalPages) { %><a class="btn btn-secondary" href="?q=<%= encodeURIComponent(memberFilters.q) %>&memberPage=<%= memberPagination.page + 1 %>">Next</a><% } %></nav><% } %><% } else { %><div class="empty-state admin-group-empty-members"><h3>No members found</h3><p><%= memberFilters.q ? 'No current member matches this search.' : 'This group has no current members.' %></p><% if (memberFilters.q) { %><a class="btn btn-secondary" href="/admin/running-groups/<%= group._id %>">Clear search</a><% } %></div><% } %>
      </section>

      <section class="admin-group-settings" aria-labelledby="groupSettingsTitle"><div class="admin-group-section-heading"><div><h3 id="groupSettingsTitle">Management</h3><p>Metadata, attribution, integrity, and visibility controls.</p></div></div><div class="admin-group-management-grid">
        <section class="detail-card admin-group-management-card"><h4>Edit group</h4><form method="POST" action="/admin/running-groups/<%= group._id %>/update" class="admin-group-form"><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><label>Name<input name="name" required minlength="2" maxlength="120" value="<%= group.name %>"></label><small>The public slug remains <code><%= group.slug %></code>.</small><label>Description<textarea name="description" maxlength="400" rows="3"><%= group.description || '' %></textarea></label><button class="btn" type="submit">Save details</button></form></section>
        <section class="detail-card admin-group-management-card"><h4>Creator attribution</h4><p class="admin-group-card-context"><strong><%= creatorName %></strong><small><%= group.createdBy?.userId || group.createdBy?.email || 'Unknown account' %></small></p><form method="POST" action="/admin/running-groups/<%= group._id %>/creator" class="admin-group-form" data-admin-group-confirm data-confirm-title="Transfer creator attribution?" data-confirm-copy="This changes attribution only. Memberships will not change."><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><label>New runner ID or email<input name="creatorIdentifier" required maxlength="200"></label><label>Moderation reason<textarea name="reason" required minlength="8" maxlength="500" rows="2"></textarea></label><button class="btn btn-secondary" type="submit">Transfer creator</button></form></section>
        <section class="detail-card admin-group-management-card admin-group-integrity-card"><h4>Count integrity</h4><div class="admin-group-integrity-state <%= countsMatch ? 'is-matched' : 'has-mismatch' %>"><i data-lucide="<%= countsMatch ? 'circle-check' : 'triangle-alert' %>" aria-hidden="true"></i><div><strong><%= countsMatch ? 'Counts match' : 'Reconciliation needed' %></strong><span>Cached <%= Number(group.memberCount || 0) %> · Actual <%= actualMemberCount %></span></div></div><% if (!countsMatch) { %><form method="POST" action="/admin/running-groups/<%= group._id %>/reconcile"><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><button class="btn btn-secondary" type="submit">Reconcile member count</button></form><% } else { %><p class="admin-group-card-help">No repair action is currently required.</p><% } %></section>
        <section class="detail-card admin-group-management-card admin-group-status-card"><h4>Group status</h4><% if (group.isActive) { %><p>Archiving removes this group from discovery and removes every current membership.</p><form method="POST" action="/admin/running-groups/<%= group._id %>/archive" class="admin-group-form" data-admin-group-confirm data-confirm-title="Archive <%= group.name %>?" data-confirm-copy="This removes <%= actualMemberCount %> current membership<%= actualMemberCount === 1 ? '' : 's' %>. Reactivation will not restore them."><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><label>Moderation reason<textarea name="reason" required minlength="8" maxlength="500" rows="2"></textarea></label><button class="btn btn-danger" type="submit">Archive group</button></form><% } else { %><p>Reactivation makes this empty group discoverable again. Former memberships remain removed.</p><form method="POST" action="/admin/running-groups/<%= group._id %>/reactivate" data-admin-group-confirm data-confirm-title="Reactivate <%= group.name %>?" data-confirm-copy="The group returns with no restored memberships."><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><button class="btn" type="submit">Reactivate group</button></form><% } %></section>
      </div></section>

      <section class="detail-card admin-group-activity-card"><div class="admin-group-section-heading"><div><h3>Recent group activity</h3><p>Latest creation, join, and leave records.</p></div><a class="btn btn-secondary btn-sm" href="/admin/audit?targetType=running_group&targetId=<%= group._id %>">Critical audit</a></div><% if (activity.length) { %><ul class="admin-group-activity"><% activity.forEach((item) => { %><li><div><strong><%= item.message %></strong><small><%= item.type.replaceAll('_', ' ') %> · <%= item.createdAt ? new Date(item.createdAt).toLocaleString('en-US') : 'N/A' %></small></div></li><% }) %></ul><% } else { %><p class="text-muted">No group activity has been recorded.</p><% } %></section>
    </section>
  </main>

  <div class="admin-group-confirm-backdrop" data-admin-group-modal hidden aria-hidden="true"><div class="admin-group-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="adminGroupConfirmTitle" aria-describedby="adminGroupConfirmCopy" tabindex="-1"><i data-lucide="triangle-alert" aria-hidden="true"></i><h3 id="adminGroupConfirmTitle" data-admin-group-modal-title>Confirm action</h3><p id="adminGroupConfirmCopy" data-admin-group-modal-copy></p><div class="admin-group-confirm-actions"><button type="button" class="btn btn-secondary" data-admin-group-modal-cancel>Cancel</button><button type="button" class="btn btn-danger" data-admin-group-modal-confirm>Confirm</button></div></div></div>
  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script><script src="/js/admin-running-groups.js"></script>
</body>
</html>
