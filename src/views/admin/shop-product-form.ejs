<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title }) %>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/shop.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="admin-page admin-shop-product-form-page">
    <section class="admin-shell">
      <header class="manage-header">
        <div class="manage-header-copy">
          <p class="manage-eyebrow">HelloRun Shop</p>
          <h1><%= product ? 'Edit Product' : 'New Product' %></h1>
          <p>Set the name, pricing, category, and delivery options for this platform-owned item.</p>
        </div>
        <div class="header-actions">
          <a href="/admin/shop" class="nav-login-btn detail-nav-btn">Back to Admin Shop</a>
          <% if (product) { %>
            <a href="/admin/shop/products/<%= product.id %>/variants" class="nav-login-btn detail-nav-btn">Manage Variants</a>
          <% } %>
        </div>
      </header>

      <% if (message) { %>
        <div class="page-message page-message-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <form
        id="platformShopProductForm"
        method="POST"
        data-method="<%= product ? 'PATCH' : 'POST' %>"
        action="<%= product ? `/admin/shop/products/${product.id}` : '/admin/shop/products' %>"
        class="detail-card detail-card-full shop-product-form"
      >
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">

        <div class="shop-form-grid">
          <label>
            <span>Name</span>
            <input type="text" name="name" value="<%= product ? product.name : '' %>" minlength="3" maxlength="160" required>
          </label>
          <label>
            <span>Slug</span>
            <input type="text" name="slug" value="<%= product ? product.slug : '' %>" pattern="[a-z0-9]+(-[a-z0-9]+)*" placeholder="auto-generated if left blank">
          </label>
          <label>
            <span>Category</span>
            <input type="text" name="category" value="<%= (product && product.category) || '' %>" maxlength="120" placeholder="e.g. Apparel">
          </label>
          <label>
            <span>Base Price</span>
            <input type="number" name="basePrice" value="<%= product ? product.base_price : '0' %>" min="0" step="0.01" required>
          </label>
          <label>
            <span>Currency</span>
            <input type="text" name="currency" value="<%= (product && product.currency) || 'PHP' %>" maxlength="3" style="text-transform:uppercase">
          </label>
          <label>
            <span>Status</span>
            <select name="status">
              <% ['draft', 'active', 'archived'].forEach((statusOption) => { %>
                <option value="<%= statusOption %>" <%= product && product.status === statusOption ? 'selected' : '' %>><%= statusOption %></option>
              <% }) %>
            </select>
          </label>
          <label>
            <span>Delivery Fee</span>
            <input type="number" name="deliveryFee" value="<%= (product && product.delivery_fee) || '0' %>" min="0" step="0.01">
          </label>
        </div>

        <div class="shop-form-toggles">
          <label class="shop-form-toggle">
            <input type="hidden" name="showInEventShop" value="0">
            <input type="checkbox" name="showInEventShop" value="1" <%= !product || product.show_in_event_shop ? 'checked' : '' %>>
            <span>Show in HelloRun shop</span>
          </label>
          <label class="shop-form-toggle">
            <input type="hidden" name="allowPickup" value="0">
            <input type="checkbox" name="allowPickup" value="1" <%= !product || product.allow_pickup ? 'checked' : '' %>>
            <span>Allow pickup</span>
          </label>
          <label class="shop-form-toggle">
            <input type="hidden" name="allowDelivery" value="0">
            <input type="checkbox" name="allowDelivery" value="1" <%= product && product.allow_delivery ? 'checked' : '' %>>
            <span>Allow delivery</span>
          </label>
        </div>

        <div class="shop-form-footer">
          <button type="submit" class="nav-signup-btn detail-status-btn"><%= product ? 'Save Changes' : 'Create Product' %></button>
        </div>
      </form>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    if (window.lucide) lucide.createIcons();

    (function () {
      const form = document.getElementById('platformShopProductForm');
      if (!form) return;

      const CHECKBOX_FIELDS = ['showInEventShop', 'allowPickup', 'allowDelivery'];

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const method = form.dataset.method;
        const formData = new FormData(form);
        const csrfToken = String(formData.get('_csrf') || '');
        const payload = {};

        formData.forEach((value, key) => {
          if (key === '_csrf') return;
          payload[key] = value;
        });
        CHECKBOX_FIELDS.forEach((key) => { payload[key] = payload[key] === '1'; });

        try {
          const response = await fetch(form.action, {
            method,
            headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
            body: JSON.stringify(payload)
          });
          const data = await response.json().catch(() => ({}));

          if (response.ok && data.success && data.product) {
            const verb = method === 'PATCH' ? 'updated' : 'created';
            window.location.href = `/admin/shop/products/${data.product.id}/edit?type=success&msg=${encodeURIComponent(`Product ${verb}.`)}`;
            return;
          }

          const message = (data && data.message) || 'Unable to save product.';
          window.location.href = `${window.location.pathname}?type=error&msg=${encodeURIComponent(message)}`;
        } catch (error) {
          window.location.href = `${window.location.pathname}?type=error&msg=${encodeURIComponent('Unable to save product. Please try again.')}`;
        }
      });
    })();
  </script>
</body>
</html>
