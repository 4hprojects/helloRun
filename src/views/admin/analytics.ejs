<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: 'Platform Analytics - HelloRun Admin' }) %>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <main class="admin-page">
    <section class="section admin-shell">

      <header class="admin-page-header">
        <div>
          <p class="admin-page-eyebrow">Admin</p>
          <h1>Platform Analytics</h1>
          <p class="admin-page-subtitle">Aggregate platform metrics — Supabase + MongoDB.</p>
        </div>
        <div class="admin-header-actions">
          <a href="/admin/analytics/export.csv?range=<%= range %>" class="btn btn-outline btn-sm">Export CSV</a>
          <a href="/admin/analytics/export.xlsx?range=<%= range %>" class="btn btn-outline btn-sm">Export XLSX</a>
          <a href="/admin" class="btn btn-outline btn-sm">← Dashboard</a>
        </div>
      </header>

      <nav class="analytics-range-tabs" aria-label="Date range">
        <% [['7d','7D'],['30d','30D'],['90d','90D'],['365d','1Y']].forEach(function(opt) { %>
          <a href="/admin/analytics?range=<%= opt[0] %>" class="analytics-range-tab<%= range === opt[0] ? ' active' : '' %>"><%= opt[1] %></a>
        <% }); %>
      </nav>

      <% if (message) { %>
        <div class="page-message page-message-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <% if (!analytics) { %>
        <section class="dashboard-band">
          <article class="metric-card" style="grid-column:1/-1">
            <div class="metric-card-head">
              <p class="metric-label">Analytics unavailable</p>
              <i data-lucide="database-off" class="metric-card-icon-sm" aria-hidden="true"></i>
            </div>
            <p class="metric-value" style="font-size:1rem;font-weight:400;color:#64748b">
              Platform analytics require the Supabase database to be configured.<br>Set <code>DATABASE_URL</code> to enable.
            </p>
          </article>
        </section>
      <% } else { %>

        <%
          const { totals, funnel, growth, topEvents, topOrganisers, revenue } = analytics;
          const hasSupa = !!(totals);
          function fmtNum(n) { return Number(n || 0).toLocaleString('en-US'); }
          function fmtPct(n) { return Number(n || 0).toFixed(1) + '%'; }
          function fmtHrs(n) {
            if (n === null || n === undefined) return 'N/A';
            const h = Number(n);
            if (h < 1) return Math.round(h * 60) + ' min';
            return h.toFixed(1) + ' hrs';
          }
          function fmtMonth(d) {
            if (!d) return '';
            return new Date(d).toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' });
          }
          function fmtCurrency(n) {
            return '$' + Number(n || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
          }
        %>

        <!-- Section 1: Platform Totals -->
        <% if (hasSupa) { %>
        <section class="dashboard-band" aria-labelledby="analytics-totals-title">
          <h2 id="analytics-totals-title" class="dashboard-section-title">Platform Totals</h2>
          <div class="dashboard-grid">
            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Runners</p>
                <i data-lucide="user-check" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtNum(totals.runners) %></p>
              <a href="/admin/users?role=runner" class="metric-link">View runners</a>
            </article>

            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Approved Organisers</p>
                <i data-lucide="building-2" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtNum(totals.organisers) %></p>
              <a href="/admin/users?role=organiser" class="metric-link">View organisers</a>
            </article>

            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Published Events</p>
                <i data-lucide="calendar-check" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtNum(totals.publishedEvents) %></p>
              <p class="metric-helper"><%= fmtNum(totals.closedEvents) %> closed · <%= fmtNum(totals.draftEvents) %> draft</p>
            </article>

            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Certificates Issued</p>
                <i data-lucide="award" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtNum(totals.certificatesIssued) %></p>
              <p class="metric-helper">Approved submissions with cert</p>
            </article>
          </div>
        </section>

        <!-- Section 2: Run Lifecycle Funnel -->
        <section class="dashboard-band" aria-labelledby="analytics-funnel-title">
          <h2 id="analytics-funnel-title" class="dashboard-section-title">Run Lifecycle Funnel</h2>
          <div class="dashboard-grid">
            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Total Registrations</p>
                <i data-lucide="users" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtNum(funnel.totalRegistrations) %></p>
              <p class="metric-helper"><%= fmtNum(funnel.paidRegistrations) %> paid</p>
            </article>

            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Total Submissions</p>
                <i data-lucide="clipboard-list" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtNum(funnel.totalSubmissions) %></p>
              <p class="metric-helper"><%= fmtNum(funnel.pendingSubmissions) %> pending review</p>
            </article>

            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Approved Submissions</p>
                <i data-lucide="check-circle" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtNum(funnel.approvedSubmissions) %></p>
              <p class="metric-helper"><%= fmtNum(funnel.rejectedSubmissions) %> rejected</p>
            </article>

            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Approval Rate</p>
                <i data-lucide="percent" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtPct(funnel.approvalRate) %></p>
              <p class="metric-helper">Of all submitted results</p>
            </article>

            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Avg Review Time</p>
                <i data-lucide="clock" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtHrs(funnel.avgHoursToReview) %></p>
              <p class="metric-helper">Submission to decision</p>
            </article>

            <article class="metric-card">
              <div class="metric-card-head">
                <p class="metric-label">Payment Proof Pending</p>
                <i data-lucide="file-clock" class="metric-card-icon-sm" aria-hidden="true"></i>
              </div>
              <p class="metric-value"><%= fmtNum(funnel.proofPending) %></p>
              <p class="metric-helper"><%= fmtNum(funnel.proofRejected) %> rejected</p>
            </article>
          </div>
        </section>

        <!-- Section 3: Growth -->
        <% if (growth && growth.length) { %>
          <section class="dashboard-band" aria-labelledby="analytics-growth-title">
            <h2 id="analytics-growth-title" class="dashboard-section-title">Growth — Last 12 Months</h2>
            <div class="admin-analytics-table-wrap">
              <table class="admin-analytics-table">
                <thead>
                  <tr>
                    <th>Month</th>
                    <th class="num">New Users</th>
                    <th class="num">Runners</th>
                    <th class="num">Organisers</th>
                  </tr>
                </thead>
                <tbody>
                  <% growth.forEach(function(row) { %>
                    <tr>
                      <td><%= fmtMonth(row.month) %></td>
                      <td class="num"><%= fmtNum(row.total) %></td>
                      <td class="num"><%= fmtNum(row.runners) %></td>
                      <td class="num"><%= fmtNum(row.organisers) %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>

        <!-- Section 4: Top Events -->
        <% if (topEvents && topEvents.length) { %>
          <section class="dashboard-band" aria-labelledby="analytics-events-title">
            <h2 id="analytics-events-title" class="dashboard-section-title">Top 10 Events by Registrations</h2>
            <div class="admin-analytics-table-wrap">
              <table class="admin-analytics-table">
                <thead>
                  <tr>
                    <th class="rank-col">#</th>
                    <th>Event</th>
                    <th class="num">Total</th>
                    <th class="num">Paid</th>
                  </tr>
                </thead>
                <tbody>
                  <% topEvents.forEach(function(ev, i) { %>
                    <tr>
                      <td class="rank-col muted"><%= i + 1 %></td>
                      <td>
                        <a href="/events/<%= ev.slug %>" target="_blank" rel="noopener noreferrer"><%= ev.title %></a>
                        <% if (ev.status !== 'published') { %><span class="status-badge status-badge-<%= ev.status %> analytics-status-chip"><%= ev.status %></span><% } %>
                      </td>
                      <td class="num"><%= fmtNum(ev.totalRegs) %></td>
                      <td class="num"><%= fmtNum(ev.paidRegs) %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>

        <!-- Section 5: Top Organisers -->
        <% if (topOrganisers && topOrganisers.length) { %>
          <section class="dashboard-band" aria-labelledby="analytics-orgs-title">
            <h2 id="analytics-orgs-title" class="dashboard-section-title">Top 10 Organisers by Events</h2>
            <div class="admin-analytics-table-wrap">
              <table class="admin-analytics-table">
                <thead>
                  <tr>
                    <th class="rank-col">#</th>
                    <th>Organiser</th>
                    <th class="num">Events</th>
                    <th class="num">Registrations</th>
                  </tr>
                </thead>
                <tbody>
                  <% topOrganisers.forEach(function(org, i) { %>
                    <tr>
                      <td class="rank-col muted"><%= i + 1 %></td>
                      <td>
                        <% if (org.mongoUserId) { %>
                          <a href="/admin/users/<%= org.mongoUserId %>"><%= org.displayName %></a>
                        <% } else { %>
                          <%= org.displayName %>
                        <% } %>
                      </td>
                      <td class="num"><%= fmtNum(org.eventCount) %></td>
                      <td class="num"><%= fmtNum(org.totalRegistrations) %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>

        <% } /* end hasSupa */ %>

        <!-- Section 6: Revenue -->
        <% if (hasSupa && revenue) { %>
          <section class="dashboard-band" aria-labelledby="analytics-revenue-title">
            <h2 id="analytics-revenue-title" class="dashboard-section-title">Shop Revenue</h2>
            <div class="dashboard-grid" style="margin-bottom:1.5rem">
              <article class="metric-card">
                <div class="metric-card-head">
                  <p class="metric-label">Completed Orders</p>
                  <i data-lucide="shopping-bag" class="metric-card-icon-sm" aria-hidden="true"></i>
                </div>
                <p class="metric-value"><%= fmtNum(revenue.orderCount) %></p>
              </article>
              <article class="metric-card">
                <div class="metric-card-head">
                  <p class="metric-label">Total Revenue</p>
                  <i data-lucide="dollar-sign" class="metric-card-icon-sm" aria-hidden="true"></i>
                </div>
                <p class="metric-value"><%= fmtCurrency(revenue.totalRevenue) %></p>
              </article>
            </div>
            <% if (revenue.monthly && revenue.monthly.length) { %>
              <div class="admin-analytics-table-wrap">
                <table class="admin-analytics-table">
                  <thead>
                    <tr>
                      <th>Month</th>
                      <th class="num">Orders</th>
                      <th class="num">Revenue</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% revenue.monthly.forEach(function(row) { %>
                      <tr>
                        <td><%= fmtMonth(row.month) %></td>
                        <td class="num"><%= fmtNum(row.orderCount) %></td>
                        <td class="num"><%= fmtCurrency(row.revenue) %></td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </section>
        <% } %>

        <!-- MongoDB Sections -->
        <% if (analytics.mongo) { %>
          <%
            const mongo = analytics.mongo;
            function fmtBar(count, total) {
              return total > 0 ? Math.round((count / total) * 100) : 0;
            }
            function fmtMonthLabel(year, month) {
              return new Date(year, month - 1, 1).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
            }
          %>

          <!-- Section 7: User Account Status -->
          <% if (mongo.userBreakdown) { %>
            <% const ub = mongo.userBreakdown; const totalUsers = Object.values(ub.byStatus).reduce((a,b)=>a+b,0); %>
            <section class="dashboard-band" aria-labelledby="analytics-users-title">
              <h2 id="analytics-users-title" class="dashboard-section-title">User Account Status</h2>
              <div class="analytics-split-grid">
                <% [['active','Active'],['restricted','Restricted'],['suspended','Suspended'],['closed','Closed']].forEach(function(s) { %>
                  <div class="analytics-split-card">
                    <p class="analytics-split-label"><%= s[1] %></p>
                    <p class="analytics-split-value"><%= fmtNum(ub.byStatus[s[0]] || 0) %></p>
                    <p class="analytics-split-sub"><%= fmtBar(ub.byStatus[s[0]] || 0, totalUsers) %>% of users</p>
                  </div>
                <% }); %>
                <div class="analytics-split-card">
                  <p class="analytics-split-label">Email Verified</p>
                  <p class="analytics-split-value"><%= fmtNum(ub.emailVerified) %></p>
                  <p class="analytics-split-sub"><%= fmtBar(ub.emailVerified, totalUsers) %>% of users</p>
                </div>
                <div class="analytics-split-card">
                  <p class="analytics-split-label">Google OAuth</p>
                  <p class="analytics-split-value"><%= fmtNum(ub.byAuthProvider.google || 0) %></p>
                  <p class="analytics-split-sub">vs <%= fmtNum(ub.byAuthProvider.local || 0) %> email/password</p>
                </div>
              </div>
            </section>
          <% } %>

          <!-- Section 8: Organiser Application Funnel -->
          <% if (mongo.organiserFunnel) { %>
            <% const of = mongo.organiserFunnel; const totalApps = Object.values(of.byStatus).reduce((a,b)=>a+b,0); %>
            <section class="dashboard-band" aria-labelledby="analytics-orgfunnel-title">
              <h2 id="analytics-orgfunnel-title" class="dashboard-section-title">Organiser Application Funnel</h2>
              <div class="analytics-split-grid" style="margin-bottom:1rem">
                <% [['pending','Pending'],['under_review','Under Review'],['approved','Approved'],['rejected','Rejected']].forEach(function(s) { %>
                  <div class="analytics-split-card">
                    <p class="analytics-split-label"><%= s[1] %></p>
                    <p class="analytics-split-value"><%= fmtNum(of.byStatus[s[0]] || 0) %></p>
                    <p class="analytics-split-sub"><%= fmtBar(of.byStatus[s[0]] || 0, totalApps) %>% of total</p>
                  </div>
                <% }); %>
              </div>
              <% if (of.monthly && of.monthly.length) { %>
                <div class="admin-analytics-table-wrap">
                  <table class="admin-analytics-table">
                    <thead><tr><th>Month</th><th class="num">New Applications</th></tr></thead>
                    <tbody>
                      <% of.monthly.forEach(function(row) { %>
                        <tr>
                          <td><%= fmtMonthLabel(row.year, row.month) %></td>
                          <td class="num"><%= fmtNum(row.count) %></td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </section>
          <% } %>

          <!-- Section 9: Event Breakdown -->
          <% if (mongo.eventBreakdown) { %>
            <% const eb = mongo.eventBreakdown; const totalByType = Object.values(eb.byType).reduce((a,b)=>a+b,0); %>
            <section class="dashboard-band" aria-labelledby="analytics-eventbreakdown-title">
              <h2 id="analytics-eventbreakdown-title" class="dashboard-section-title">Event Breakdown</h2>
              <div class="analytics-split-grid" style="margin-bottom:1rem">
                <% [['virtual','Virtual'],['onsite','Onsite'],['hybrid','Hybrid']].forEach(function(t) { %>
                  <div class="analytics-split-card">
                    <p class="analytics-split-label"><%= t[1] %></p>
                    <p class="analytics-split-value"><%= fmtNum(eb.byType[t[0]] || 0) %></p>
                    <p class="analytics-split-sub"><%= fmtBar(eb.byType[t[0]] || 0, totalByType) %>% of events</p>
                  </div>
                <% }); %>
              </div>
              <% if (eb.monthly && eb.monthly.length) { %>
                <div class="admin-analytics-table-wrap">
                  <table class="admin-analytics-table">
                    <thead><tr><th>Month</th><th class="num">New Events Created</th></tr></thead>
                    <tbody>
                      <% eb.monthly.forEach(function(row) { %>
                        <tr>
                          <td><%= fmtMonthLabel(row.year, row.month) %></td>
                          <td class="num"><%= fmtNum(row.count) %></td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </section>
          <% } %>

          <!-- Section 10: Submission Breakdown -->
          <% if (mongo.submissionBreakdown) { %>
            <% const sb = mongo.submissionBreakdown; const totalSubs = sb.standardCount + sb.accumulatedCount; %>
            <section class="dashboard-band" aria-labelledby="analytics-subbreakdown-title">
              <h2 id="analytics-subbreakdown-title" class="dashboard-section-title">Submission Breakdown</h2>
              <div class="analytics-split-grid">
                <div class="analytics-split-card">
                  <p class="analytics-split-label">Standard Submissions</p>
                  <p class="analytics-split-value"><%= fmtNum(sb.standardCount) %></p>
                  <p class="analytics-split-sub"><%= fmtBar(sb.standardCount, totalSubs) %>% of total</p>
                </div>
                <div class="analytics-split-card">
                  <p class="analytics-split-label">Accumulated Activities</p>
                  <p class="analytics-split-value"><%= fmtNum(sb.accumulatedCount) %></p>
                  <p class="analytics-split-sub"><%= fmtBar(sb.accumulatedCount, totalSubs) %>% of total</p>
                </div>
                <div class="analytics-split-card">
                  <p class="analytics-split-label">Strava Source</p>
                  <p class="analytics-split-value"><%= fmtNum(sb.bySource.strava) %></p>
                  <p class="analytics-split-sub">vs <%= fmtNum(sb.bySource.manual_upload) %> manual</p>
                </div>
                <div class="analytics-split-card">
                  <p class="analytics-split-label">GPS Proof</p>
                  <p class="analytics-split-value"><%= fmtNum(sb.byProofType.gps) %></p>
                  <p class="analytics-split-sub">Photo: <%= fmtNum(sb.byProofType.photo) %> · Manual: <%= fmtNum(sb.byProofType.manual) %></p>
                </div>
                <div class="analytics-split-card">
                  <p class="analytics-split-label">Auto-Approved</p>
                  <p class="analytics-split-value"><%= fmtNum(sb.autoApprovedCount) %></p>
                  <p class="analytics-split-sub"><%= fmtBar(sb.autoApprovedCount, sb.standardCount) %>% of standard</p>
                </div>
                <div class="analytics-split-card">
                  <p class="analytics-split-label">Suspicious Flagged</p>
                  <p class="analytics-split-value"><%= fmtNum(sb.suspiciousCount) %></p>
                  <p class="analytics-split-sub"><%= fmtBar(sb.suspiciousCount, sb.standardCount) %>% of standard</p>
                </div>
              </div>
            </section>
          <% } %>

          <!-- Section 11: Run Type Distribution -->
          <% if (mongo.runTypeDistribution && mongo.runTypeDistribution.length) { %>
            <% const rtTotal = mongo.runTypeDistribution.reduce(function(a,r){ return a + r.count; }, 0); %>
            <section class="dashboard-band" aria-labelledby="analytics-runtype-title">
              <h2 id="analytics-runtype-title" class="dashboard-section-title">Run Type Distribution (Approved)</h2>
              <div class="admin-analytics-table-wrap">
                <table class="admin-analytics-table">
                  <thead><tr><th>Run Type</th><th class="num">Count</th><th style="width:40%">Share</th></tr></thead>
                  <tbody>
                    <% mongo.runTypeDistribution.forEach(function(row) { %>
                      <% const pct = fmtBar(row.count, rtTotal); %>
                      <tr>
                        <td style="text-transform:capitalize"><%= String(row.runType || '').replace(/_/g,' ') %></td>
                        <td class="num"><%= fmtNum(row.count) %></td>
                        <td>
                          <div class="analytics-bar-row">
                            <div class="analytics-bar-track"><div class="analytics-bar-fill" style="--pct:<%= pct %>"></div></div>
                            <span style="font-size:0.75rem;color:#64748b;min-width:2.5rem"><%= pct %>%</span>
                          </div>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </section>
          <% } %>

        <% } %>

      <% } %>

    </section>
  </main>
  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
