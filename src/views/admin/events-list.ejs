<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title }) %>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <main class="admin-page admin-events-page">
    <section class="section admin-shell">
      <div class="admin-header-row">
        <div>
          <h2>Event Management</h2>
          <p>Review, publish, archive, and audit organizer events.</p>
        </div>
        <a href="/admin/dashboard" class="btn btn-secondary admin-event-action-btn">
          <i data-lucide="layout-dashboard"></i>
          <span>Admin Dashboard</span>
        </a>
      </div>

      <% if (message) { %>
        <div class="admin-alert admin-alert-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <div class="quick-link-grid">
        <a class="quick-link-card" href="/admin/events?needsReview=1">
          <span class="quick-link-title">Pending Review</span>
          <span class="quick-link-meta"><%= statusCounts.pendingReview %> event<%= statusCounts.pendingReview === 1 ? '' : 's' %></span>
        </a>
        <a class="quick-link-card" href="/admin/events?status=published">
          <span class="quick-link-title">Published</span>
          <span class="quick-link-meta"><%= statusCounts.published %> live</span>
        </a>
        <a class="quick-link-card" href="/admin/events?status=draft">
          <span class="quick-link-title">Drafts</span>
          <span class="quick-link-meta"><%= statusCounts.draft %> draft</span>
        </a>
        <a class="quick-link-card" href="/admin/events?status=archived">
          <span class="quick-link-title">Archived</span>
          <span class="quick-link-meta"><%= statusCounts.archived %> archived</span>
        </a>
        <a class="quick-link-card" href="/admin/events?deleted=1">
          <span class="quick-link-title">Deleted</span>
          <span class="quick-link-meta">Soft-deleted events</span>
        </a>
      </div>

      <form method="GET" action="/admin/events" class="admin-filters event-admin-filters">
        <div class="filter-field">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="" <%= !filters.status ? 'selected' : '' %>>All</option>
            <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
            <option value="pending_review" <%= filters.status === 'pending_review' ? 'selected' : '' %>>Pending Review</option>
            <option value="published" <%= filters.status === 'published' ? 'selected' : '' %>>Published</option>
            <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Closed</option>
            <option value="archived" <%= filters.status === 'archived' ? 'selected' : '' %>>Archived</option>
          </select>
        </div>
        <div class="filter-field">
          <label for="eventType">Type</label>
          <select id="eventType" name="eventType">
            <option value="" <%= !filters.eventType ? 'selected' : '' %>>All</option>
            <option value="virtual" <%= filters.eventType === 'virtual' ? 'selected' : '' %>>Virtual</option>
            <option value="onsite" <%= filters.eventType === 'onsite' ? 'selected' : '' %>>On-site</option>
            <option value="hybrid" <%= filters.eventType === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
          </select>
        </div>
        <div class="filter-field filter-grow">
          <label for="q">Search</label>
          <input id="q" name="q" type="search" value="<%= filters.q %>" placeholder="Title, slug, organizer, city, reference">
        </div>
        <label class="editor-mode-option">
          <input type="checkbox" name="needsReview" value="1" <%= filters.needsReview ? 'checked' : '' %>>
          Needs review
        </label>
        <label class="editor-mode-option">
          <input type="checkbox" name="deleted" value="1" <%= filters.deleted ? 'checked' : '' %>>
          Deleted
        </label>
        <div class="filter-actions">
          <button type="submit" class="btn admin-event-action-btn">
            <i data-lucide="filter"></i>
            <span>Filter</span>
          </button>
          <a href="/admin/events" class="btn btn-secondary admin-event-action-btn">
            <i data-lucide="rotate-ccw"></i>
            <span>Reset</span>
          </a>
        </div>
      </form>

      <p class="results-meta">
        Showing <%= events.length %> of <%= pagination.totalEvents %> matching events.
      </p>

      <% if (events.length) { %>
        <table class="admin-table">
          <thead>
            <tr>
              <th>Event</th>
              <th>Organizer</th>
              <th>Status</th>
              <th>Dates</th>
              <th>Activity</th>
              <th>Updated</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% events.forEach((event) => { %>
              <tr>
                <td>
                  <strong><%= event.title %></strong>
                  <div><small><%= event.referenceCode || event.slug %></small></div>
                </td>
                <td>
                  <strong><%= event.organizerName %></strong>
                  <div><small><%= event.organizerEmail %></small></div>
                </td>
                <td><span class="status-badge status-badge-<%= event.isDeleted ? 'archived' : event.status %>"><%= event.isDeleted ? 'Deleted' : event.statusLabel %></span></td>
                <td>
                  <div><small>Start: <%= event.eventStartAt ? new Date(event.eventStartAt).toLocaleDateString('en-US') : 'TBA' %></small></div>
                  <div><small>End: <%= event.eventEndAt ? new Date(event.eventEndAt).toLocaleDateString('en-US') : 'TBA' %></small></div>
                </td>
                <td>
                  <div><small><%= event.registrationsCount %> registrations</small></div>
                  <div><small><%= event.submissionsCount %> submissions</small></div>
                </td>
                <td><%= event.updatedAt ? new Date(event.updatedAt).toLocaleDateString('en-US') : 'N/A' %></td>
                <td class="policy-row-actions">
                  <a href="/admin/events/<%= event._id %>" class="btn btn-sm admin-event-action-btn">
                    <i data-lucide="external-link"></i>
                    <span>Open</span>
                  </a>
                  <% if (!event.isDeleted) { %>
                    <a href="/admin/events/<%= event._id %>/edit" class="btn btn-sm btn-secondary admin-event-action-btn">
                      <i data-lucide="pencil"></i>
                      <span>Edit</span>
                    </a>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <h3>No events found</h3>
          <p>Adjust the filters or reset to view all active events.</p>
          <a href="/admin/events" class="btn btn-secondary admin-event-action-btn">
            <i data-lucide="rotate-ccw"></i>
            <span>Reset Filters</span>
          </a>
        </div>
      <% } %>
    </section>
  </main>
  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
