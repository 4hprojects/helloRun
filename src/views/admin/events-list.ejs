<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title }) %>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <main class="admin-page admin-events-page">
    <section class="section admin-shell">
      <div class="admin-header-row">
        <div>
          <h2>Event Management</h2>
          <p>Review, publish, archive, and audit organizer events.</p>
        </div>
        <a href="/admin/dashboard" class="btn btn-secondary admin-event-action-btn">
          <i data-lucide="layout-dashboard"></i>
          <span>Admin Dashboard</span>
        </a>
      </div>

      <% if (message) { %>
        <div class="admin-alert admin-alert-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <div class="quick-link-grid">
        <a class="quick-link-card" href="/admin/events?needsReview=1">
          <span class="quick-link-title">Pending Review</span>
          <span class="quick-link-meta"><%= statusCounts.pendingReview %> event<%= statusCounts.pendingReview === 1 ? '' : 's' %></span>
        </a>
        <a class="quick-link-card" href="/admin/events?status=published">
          <span class="quick-link-title">Published</span>
          <span class="quick-link-meta"><%= statusCounts.published %> live</span>
        </a>
        <a class="quick-link-card" href="/admin/events?status=draft">
          <span class="quick-link-title">Drafts</span>
          <span class="quick-link-meta"><%= statusCounts.draft %> draft</span>
        </a>
        <a class="quick-link-card" href="/admin/events?status=archived">
          <span class="quick-link-title">Archived</span>
          <span class="quick-link-meta"><%= statusCounts.archived %> archived</span>
        </a>
        <a class="quick-link-card" href="/admin/events?deleted=1">
          <span class="quick-link-title">Deleted</span>
          <span class="quick-link-meta">Soft-deleted events</span>
        </a>
        <a class="quick-link-card" href="/admin/events?testData=1">
          <span class="quick-link-title">Test Data</span>
          <span class="quick-link-meta"><%= testDataCount %> flagged event<%= testDataCount === 1 ? '' : 's' %></span>
        </a>
      </div>

      <% if (filters.testData && testDataCascadeCounts) { %>
        <div class="admin-alert admin-alert-warning">
          <strong><%= testDataCascadeCounts.events %></strong> test-data event<%= testDataCascadeCounts.events === 1 ? '' : 's' %> flagged for cleanup, linked to
          <strong><%= testDataCascadeCounts.registrations %></strong> registration<%= testDataCascadeCounts.registrations === 1 ? '' : 's' %>,
          <strong><%= testDataCascadeCounts.submissions %></strong> submission<%= testDataCascadeCounts.submissions === 1 ? '' : 's' %>,
          <strong><%= testDataCascadeCounts.accumulatedSubmissions %></strong> accumulated-activity submission<%= testDataCascadeCounts.accumulatedSubmissions === 1 ? '' : 's' %>,
          <strong><%= testDataCascadeCounts.promotions %></strong> promotion campaign<%= testDataCascadeCounts.promotions === 1 ? '' : 's' %>, and
          <strong><%= testDataCascadeCounts.certificateTemplates %></strong> certificate template<%= testDataCascadeCounts.certificateTemplates === 1 ? '' : 's' %>.
          Purging also removes the matching Postgres/Supabase shadow records.
          <% if (viewerIsFullAdmin && testDataCascadeCounts.events > 0) { %>
            <div style="margin-top: 0.75rem;">
              <button type="button" class="btn btn-danger" id="adminEventsPurgeTestDataBtn">
                <i data-lucide="trash-2" aria-hidden="true"></i>
                Permanently Purge All Test Data
              </button>
            </div>
          <% } else if (!viewerIsFullAdmin) { %>
            <p class="metric-helper" style="margin-top: 0.5rem;">Only full-tier admins can permanently purge test data.</p>
          <% } %>
        </div>
      <% } %>

      <form method="GET" action="/admin/events" class="admin-filters event-admin-filters">
        <div class="filter-field filter-grow">
          <label for="q">Search</label>
          <input id="q" name="q" type="search" value="<%= filters.q %>" placeholder="Title, slug, organizer, city, reference">
        </div>
        <button type="button" class="event-filter-separator" id="eventSearchSubmitBtn" aria-label="Search events" title="Search events">
          <i data-lucide="search" aria-hidden="true"></i>
        </button>
        <div class="filter-field">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="" <%= !filters.status && !filters.deleted && !filters.needsReview ? 'selected' : '' %>>All</option>
            <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
            <option value="pending_review" <%= filters.status === 'pending_review' || filters.needsReview ? 'selected' : '' %>>Needs Review</option>
            <option value="published" <%= filters.status === 'published' ? 'selected' : '' %>>Published</option>
            <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Closed</option>
            <option value="archived" <%= filters.status === 'archived' ? 'selected' : '' %>>Archived</option>
            <option value="deleted" <%= filters.deleted ? 'selected' : '' %>>Deleted</option>
          </select>
        </div>
        <div class="filter-field">
          <label for="eventType">Type</label>
          <select id="eventType" name="eventType">
            <option value="" <%= !filters.eventType ? 'selected' : '' %>>All</option>
            <option value="virtual" <%= filters.eventType === 'virtual' ? 'selected' : '' %>>Virtual</option>
            <option value="onsite" <%= filters.eventType === 'onsite' ? 'selected' : '' %>>On-site</option>
            <option value="hybrid" <%= filters.eventType === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
          </select>
        </div>
        <div class="filter-field">
          <label for="perPage">Show</label>
          <select id="perPage" name="perPage">
            <option value="25" <%= String(filters.perPage || 25) === '25' ? 'selected' : '' %>>25</option>
            <option value="50" <%= String(filters.perPage || 25) === '50' ? 'selected' : '' %>>50</option>
            <option value="100" <%= String(filters.perPage || 25) === '100' ? 'selected' : '' %>>100</option>
            <option value="all" <%= String(filters.perPage || 25).toLowerCase() === 'all' ? 'selected' : '' %>>All</option>
          </select>
        </div>
      </form>

      <p class="results-meta">
        Showing <%= events.length %> of <%= pagination.totalEvents %> matching events.
      </p>

      <% if (events.length) { %>
        <div class="admin-users-toolbar">
          <div class="admin-users-bulk-actions">
            <button type="button" class="btn btn-danger" id="adminEventsBulkDeleteBtn" disabled>
              Delete Selected
            </button>
            <span class="metric-helper" id="adminEventsSelectedCount">0 selected</span>
          </div>
        </div>

        <div class="admin-users-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th style="width:2.5rem;">
                  <input type="checkbox" id="adminEventsSelectAll" aria-label="Select all events">
                </th>
                <th>Event</th>
                <th>Organizer</th>
                <th>Status</th>
                <th>Dates</th>
                <th>Activity</th>
                <th>Updated</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% events.forEach((event) => { %>
                <tr>
                  <td>
                    <input
                      type="checkbox"
                      name="eventIds"
                      value="<%= event._id %>"
                      class="admin-event-row-checkbox"
                      aria-label="Select <%= event.title %>"
                      <%= event.isDeleted ? 'disabled' : '' %>
                      data-event-checkbox
                    >
                  </td>
                  <td>
                    <strong><%= event.title %></strong>
                    <div><small><%= event.referenceCode || event.slug %></small></div>
                    <% if (event.homeFeatured) { %>
                      <div><small>Homepage featured<%= Number.isFinite(event.homeFeaturedRank) ? ` · rank ${event.homeFeaturedRank}` : '' %></small></div>
                    <% } %>
                  </td>
                  <td>
                    <strong><%= event.organizerName %></strong>
                    <div><small><%= event.organizerEmail %></small></div>
                  </td>
                  <td><span class="status-badge status-badge-<%= event.isDeleted ? 'archived' : event.status %>"><%= event.isDeleted ? 'Deleted' : event.statusLabel %></span></td>
                  <td>
                    <div><small>Start: <%= event.eventStartAt ? new Date(event.eventStartAt).toLocaleDateString('en-US') : 'TBA' %></small></div>
                    <div><small>End: <%= event.eventEndAt ? new Date(event.eventEndAt).toLocaleDateString('en-US') : 'TBA' %></small></div>
                  </td>
                  <td>
                    <div><small><%= event.registrationsCount %> registrations</small></div>
                    <div><small><%= event.submissionsCount %> submissions</small></div>
                  </td>
                  <td><%= event.updatedAt ? new Date(event.updatedAt).toLocaleDateString('en-US') : 'N/A' %></td>
                  <td class="policy-row-actions">
                    <a href="/admin/events/<%= event._id %>" class="btn btn-sm admin-event-action-btn">
                      <i data-lucide="external-link"></i>
                      <span>Open</span>
                    </a>
                    <% if (!event.isDeleted) { %>
                      <a href="/admin/events/<%= event._id %>/edit" class="btn btn-sm btn-secondary admin-event-action-btn">
                        <i data-lucide="pencil"></i>
                        <span>Edit</span>
                      </a>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h3>No events found</h3>
          <p>Adjust the filters or reset to view all active events.</p>
          <a href="/admin/events" class="btn btn-secondary admin-event-action-btn">
            <i data-lucide="rotate-ccw"></i>
            <span>Reset Filters</span>
          </a>
        </div>
      <% } %>
    </section>
  </main>

  <div class="admin-delete-confirm-backdrop" id="adminEventsBulkDeleteModal" hidden aria-hidden="true">
    <div class="admin-delete-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="adminEventsBulkDeleteTitle" tabindex="-1">
      <div class="admin-delete-confirm-icon-wrap">
        <i data-lucide="triangle-alert" aria-hidden="true"></i>
      </div>
      <h3 id="adminEventsBulkDeleteTitle">Confirm Bulk Delete</h3>
      <p id="adminEventsBulkDeleteDesc" class="admin-delete-confirm-desc"></p>
      <div class="admin-delete-confirm-pw-group">
        <label for="adminEventsBulkDeleteReason">Reason for deletion <span aria-hidden="true">(min 8 characters)</span></label>
        <textarea
          id="adminEventsBulkDeleteReason"
          rows="3"
          placeholder="Enter a reason..."
          class="admin-delete-confirm-pw-input"
          style="resize:vertical;"
        ></textarea>
        <p class="admin-delete-confirm-pw-error" id="adminEventsBulkDeleteReasonError" hidden></p>
      </div>
      <div class="admin-delete-confirm-pw-group">
        <label for="adminEventsBulkDeletePassword">Enter your password to confirm</label>
        <div class="admin-delete-confirm-pw-wrap">
          <input
            type="password"
            id="adminEventsBulkDeletePassword"
            autocomplete="current-password"
            placeholder="Your password"
            class="admin-delete-confirm-pw-input"
          >
          <button type="button" class="admin-delete-confirm-pw-toggle" id="adminEventsBulkDeletePwToggle" aria-label="Show password">
            <i data-lucide="eye" aria-hidden="true"></i>
          </button>
        </div>
        <p class="admin-delete-confirm-pw-error" id="adminEventsBulkDeletePwError" hidden></p>
      </div>
      <div class="admin-delete-confirm-progress" id="adminEventsBulkDeleteProgress" hidden aria-live="polite">
        <div class="admin-delete-confirm-progress-label-row">
          <span class="admin-delete-confirm-progress-label">Processing deletion</span>
          <span class="admin-delete-confirm-progress-status" id="adminEventsBulkDeleteProgressStatus">Working...</span>
        </div>
        <p class="admin-delete-confirm-progress-reason" id="adminEventsBulkDeleteProgressReason">
          Preparing your request.
        </p>
        <div class="admin-delete-confirm-progress-track" aria-hidden="true">
          <div class="admin-delete-confirm-progress-bar"></div>
        </div>
        <ol class="admin-delete-confirm-progress-steps" id="adminEventsBulkDeleteProgressSteps">
          <li data-progress-step="prepare">Preparing request</li>
          <li data-progress-step="verify">Verifying password and security token</li>
          <li data-progress-step="delete">Soft-deleting events and writing audit logs</li>
        </ol>
      </div>
      <div class="admin-delete-confirm-actions">
        <button type="button" class="btn btn-secondary" id="adminEventsBulkDeleteCancelBtn">Cancel</button>
        <button type="button" class="btn btn-danger" id="adminEventsBulkDeleteOkBtn">
          <i data-lucide="trash-2" aria-hidden="true"></i>
          Delete
        </button>
      </div>
    </div>
  </div>

  <div class="admin-delete-confirm-backdrop" id="adminEventsPurgeTestDataModal" hidden aria-hidden="true">
    <div class="admin-delete-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="adminEventsPurgeTestDataTitle" tabindex="-1">
      <div class="admin-delete-confirm-icon-wrap">
        <i data-lucide="triangle-alert" aria-hidden="true"></i>
      </div>
      <h3 id="adminEventsPurgeTestDataTitle">Permanently Purge Test Data</h3>
      <p id="adminEventsPurgeTestDataDesc" class="admin-delete-confirm-desc"></p>
      <div class="admin-delete-confirm-pw-group">
        <label for="adminEventsPurgeTestDataReason">Reason for purging <span aria-hidden="true">(min 8 characters)</span></label>
        <textarea
          id="adminEventsPurgeTestDataReason"
          rows="3"
          placeholder="Enter a reason..."
          class="admin-delete-confirm-pw-input"
          style="resize:vertical;"
        ></textarea>
        <p class="admin-delete-confirm-pw-error" id="adminEventsPurgeTestDataReasonError" hidden></p>
      </div>
      <div class="admin-delete-confirm-pw-group">
        <label for="adminEventsPurgeTestDataConfirmText">Type <strong>PURGE</strong> to confirm this is permanent and cannot be undone</label>
        <input
          type="text"
          id="adminEventsPurgeTestDataConfirmText"
          autocomplete="off"
          placeholder="PURGE"
          class="admin-delete-confirm-pw-input"
        >
        <p class="admin-delete-confirm-pw-error" id="adminEventsPurgeTestDataConfirmError" hidden></p>
      </div>
      <div class="admin-delete-confirm-pw-group">
        <label for="adminEventsPurgeTestDataPassword">Enter your password to confirm</label>
        <div class="admin-delete-confirm-pw-wrap">
          <input
            type="password"
            id="adminEventsPurgeTestDataPassword"
            autocomplete="current-password"
            placeholder="Your password"
            class="admin-delete-confirm-pw-input"
          >
          <button type="button" class="admin-delete-confirm-pw-toggle" id="adminEventsPurgeTestDataPwToggle" aria-label="Show password">
            <i data-lucide="eye" aria-hidden="true"></i>
          </button>
        </div>
        <p class="admin-delete-confirm-pw-error" id="adminEventsPurgeTestDataPwError" hidden></p>
      </div>
      <div class="admin-delete-confirm-progress" id="adminEventsPurgeTestDataProgress" hidden aria-live="polite">
        <div class="admin-delete-confirm-progress-label-row">
          <span class="admin-delete-confirm-progress-label">Processing purge</span>
          <span class="admin-delete-confirm-progress-status" id="adminEventsPurgeTestDataProgressStatus">Working...</span>
        </div>
        <p class="admin-delete-confirm-progress-reason" id="adminEventsPurgeTestDataProgressReason">
          Preparing your request.
        </p>
        <div class="admin-delete-confirm-progress-track" aria-hidden="true">
          <div class="admin-delete-confirm-progress-bar"></div>
        </div>
        <ol class="admin-delete-confirm-progress-steps" id="adminEventsPurgeTestDataProgressSteps">
          <li data-progress-step="prepare">Preparing request</li>
          <li data-progress-step="verify">Verifying password and security token</li>
          <li data-progress-step="delete">Deleting from MongoDB and Postgres, writing audit log</li>
        </ol>
      </div>
      <div class="admin-delete-confirm-actions">
        <button type="button" class="btn btn-secondary" id="adminEventsPurgeTestDataCancelBtn">Cancel</button>
        <button type="button" class="btn btn-danger" id="adminEventsPurgeTestDataOkBtn">
          <i data-lucide="trash-2" aria-hidden="true"></i>
          Purge Permanently
        </button>
      </div>
    </div>
  </div>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
  <script>
    window.helloRunAdminEventsList = {
      csrfToken: <%- JSON.stringify(locals.csrfToken || '') %>,
      testDataCascadeCounts: <%- JSON.stringify(testDataCascadeCounts || null) %>
    };
  </script>
  <script src="/js/admin-events-list.js"></script>
</body>
</html>
