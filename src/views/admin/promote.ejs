<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .promote-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; align-items: start; margin-top: 24px; }
    @media (max-width: 680px) { .promote-layout { grid-template-columns: 1fr; } }
    .promote-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 24px; }
    .promote-card h2 { font-size: 0.95rem; font-weight: 600; color: #1e293b; margin: 0 0 20px; padding-bottom: 12px; border-bottom: 1px solid #f1f5f9; }
    .form-group { margin-bottom: 18px; }
    .form-label { display: block; font-size: 0.82rem; font-weight: 600; color: #374151; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em; }
    .form-select { width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 0.9rem; color: #1e293b; background: #fff; }
    .form-select:focus { outline: none; border-color: #FA9A4B; box-shadow: 0 0 0 3px rgba(250,154,75,0.15); }
    .radio-group { display: flex; flex-direction: column; gap: 8px; }
    .radio-option { display: flex; align-items: flex-start; gap: 10px; padding: 10px 12px; border: 1px solid #e2e8f0; border-radius: 6px; cursor: pointer; }
    .radio-option:hover { border-color: #FA9A4B; }
    .radio-option input[type=radio] { margin-top: 2px; accent-color: #FA9A4B; }
    .radio-option-label { font-size: 0.88rem; font-weight: 500; color: #1e293b; }
    .radio-option-desc { font-size: 0.78rem; color: #64748b; margin-top: 2px; }
    .selected-email-panel { display: none; margin-top: 10px; }
    .selected-email-panel.is-visible { display: block; }
    .selected-email-panel textarea { width: 100%; min-height: 120px; resize: vertical; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font: inherit; font-size: 0.85rem; color: #1e293b; }
    .selected-email-panel textarea:focus { outline: none; border-color: #FA9A4B; box-shadow: 0 0 0 3px rgba(250,154,75,0.15); }
    .selected-email-help { font-size: 0.75rem; color: #64748b; margin: 6px 0 0; line-height: 1.4; }
    .platform-quota { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 14px 16px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }
    .platform-quota strong { font-size: 0.9rem; color: #166534; }
    .platform-quota span { font-size: 0.82rem; color: #15803d; }
    .recipient-preview { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; text-align: center; }
    .recipient-count { font-size: 2.2rem; font-weight: 700; color: #FA9A4B; line-height: 1; }
    .recipient-label { font-size: 0.82rem; color: #64748b; margin-top: 4px; }
    .submit-btn { width: 100%; padding: 12px; background: linear-gradient(135deg, #FA9A4B 0%, #E0A46A 100%); color: #fff; border: none; border-radius: 8px; font-size: 0.9rem; font-weight: 600; cursor: pointer; margin-top: 10px; }
    .submit-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .submit-btn:not(:disabled):hover { opacity: 0.9; }
    .campaigns-section { margin-top: 28px; }
    .campaigns-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .campaigns-table th { text-align: left; padding: 8px 10px; font-weight: 600; color: #64748b; border-bottom: 1px solid #e2e8f0; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .campaigns-table td { padding: 10px; color: #374151; border-bottom: 1px solid #f1f5f9; }
    .campaigns-table tr:last-child td { border-bottom: none; }
    .status-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.73rem; font-weight: 700; }
    .status-badge.completed { background: #dcfce7; color: #166534; }
    .status-badge.sending { background: #fef3c7; color: #92400e; }
    .status-badge.partial { background: #dbeafe; color: #1d4ed8; }
    .status-badge.failed { background: #fee2e2; color: #991b1b; }
    .admin-badge { background: #ede9fe; color: #5b21b6; border-radius: 3px; padding: 1px 5px; font-size: 0.7rem; font-weight: 600; margin-left: 4px; }
    .empty-state { text-align: center; padding: 28px; color: #94a3b8; font-size: 0.85rem; }
  </style>
</head>
<body>
  <%- include('../layouts/nav') %>
  <main class="admin-page">
    <section class="section admin-shell">

      <header class="admin-page-header">
        <div>
          <p class="admin-page-eyebrow">Admin</p>
          <h1>Promote Event</h1>
          <p class="admin-page-subtitle">Send event promotion emails to runner audiences.</p>
        </div>
        <a href="/admin" class="btn btn-outline btn-sm">← Dashboard</a>
      </header>

      <% if (message) { %>
        <div class="page-message page-message-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <%
        const eventList = Array.isArray(events) ? events : [];
      %>

      <div class="promote-layout">
        <!-- Left: Form -->
        <div class="promote-card">
          <h2>Send Promotion</h2>

          <div class="platform-quota">
            <strong>Platform email quota</strong>
            <span><%= platformSent %> / <%= platformLimit %> used today &bull; <%= platformRemaining %> remaining</span>
          </div>

          <form method="POST" action="/admin/promote" id="promote-form">
            <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">

            <div class="form-group">
              <label class="form-label" for="eventId">Event</label>
              <% if (!eventList.length) { %>
                <p style="font-size:0.85rem;color:#64748b;">No active events found.</p>
              <% } else { %>
                <select id="eventId" name="eventId" class="form-select" required>
                  <option value="">Select an event…</option>
                  <% eventList.forEach(function(ev) { %>
                    <option value="<%= ev._id %>"><%= ev.title %> (<%= ev.status %>)</option>
                  <% }); %>
                </select>
              <% } %>
            </div>

            <div class="form-group">
              <span class="form-label">Audience</span>
              <div class="radio-group">
                <label class="radio-option">
                  <input type="radio" name="audience" value="previous_participants" required>
                  <div>
                    <div class="radio-option-label">Previous Participants</div>
                    <div class="radio-option-desc">Runners who registered for this event's organiser events.</div>
                  </div>
                </label>
                <label class="radio-option">
                  <input type="radio" name="audience" value="non_participants">
                  <div>
                    <div class="radio-option-label">Non-Participants</div>
                    <div class="radio-option-desc">Runners not yet in the organiser's participant pool (up to 200).</div>
                  </div>
                </label>
                <label class="radio-option">
                  <input type="radio" name="audience" value="all_runners">
                  <div>
                    <div class="radio-option-label">All Runners</div>
                    <div class="radio-option-desc">All platform runners (up to 500). Admin only.</div>
                  </div>
                </label>
                <label class="radio-option">
                  <input type="radio" name="audience" value="selected_emails">
                  <div>
                    <div class="radio-option-label">Selected Emails</div>
                    <div class="radio-option-desc">Paste specific recipient emails, separated by commas, spaces, or new lines.</div>
                  </div>
                </label>
              </div>
              <div class="selected-email-panel" id="selected-email-panel">
                <label class="form-label" for="selectedEmails" style="margin-top:12px;">Email list</label>
                <textarea id="selectedEmails" name="selectedEmails" placeholder="runner@example.com&#10;another.runner@example.com"></textarea>
                <p class="selected-email-help">Existing HelloRun users who opted out of event promotions are excluded. Unknown emails can still receive this admin-selected promotion.</p>
              </div>
            </div>

            <button type="submit" class="submit-btn" id="promote-submit" disabled>
              Send Promotion
            </button>
          </form>
        </div>

        <!-- Right: Preview -->
        <div class="promote-card">
          <h2>Recipient Preview</h2>
          <div class="recipient-preview">
            <div class="recipient-count" id="recipient-count">—</div>
            <div class="recipient-label" id="recipient-label">Select an event and audience to preview</div>
            <div class="selected-email-help" id="recipient-extra" style="display:none;"></div>
          </div>
          <p style="font-size:0.78rem;color:#94a3b8;margin:12px 0 0;line-height:1.5;">
            Runners who opted out of event.promotion emails are excluded. All sends count against the platform daily quota.
          </p>
        </div>
      </div>

      <!-- Recent Campaigns -->
      <div class="promote-card campaigns-section">
        <h2>Recent Campaigns (All Organisers)</h2>
        <% if (!recentCampaigns || !recentCampaigns.length) { %>
          <div class="empty-state">No promotion campaigns sent yet.</div>
        <% } else { %>
          <table class="campaigns-table">
            <thead>
              <tr>
                <th>Event</th>
                <th>Organiser</th>
                <th>Audience</th>
                <th>Recipients</th>
                <th>Sent</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% recentCampaigns.forEach(function(c) { %>
                <tr>
                  <td><%= c.eventId && c.eventId.title ? c.eventId.title : '—' %></td>
                  <td><%= c.organizerId ? ((c.organizerId.firstName || '') + ' ' + (c.organizerId.lastName || '')).trim() || '—' : '—' %>
                    <% if (c.adminTriggered) { %><span class="admin-badge">ADMIN</span><% } %>
                  </td>
                  <td style="font-size:0.78rem;color:#64748b;">
                    <% if (c.audience === 'previous_participants') { %>Prev. Participants
                    <% } else if (c.audience === 'non_participants') { %>Non-Participants
                    <% } else if (c.audience === 'all_runners') { %>All Runners
                    <% } else if (c.audience === 'selected_emails') { %>Selected Emails
                    <% } else { %><%= c.audience %><% } %>
                  </td>
                  <td>
                    <% const sentDisplay = c.sentCount != null ? c.sentCount : (c.recipientCount || 0); %>
                    <strong><%= sentDisplay %></strong> sent
                    <div style="font-size:0.72rem;color:#94a3b8;">
                      <%= c.selectedCount || c.recipientCount || 0 %> selected
                      <% if ((c.queuedCount || 0) > 0) { %> &bull; <%= c.queuedCount %> queued<% } %>
                      <% if (((c.skippedCount || 0) + (c.suppressedCount || 0)) > 0) { %> &bull; <%= (c.skippedCount || 0) + (c.suppressedCount || 0) %> skipped<% } %>
                      <% if ((c.failedCount || 0) > 0) { %> &bull; <%= c.failedCount %> failed<% } %>
                    </div>
                  </td>
                  <td><%= c.sentAt ? new Date(c.sentAt).toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' }) : '—' %></td>
                  <td><span class="status-badge <%= c.status %>"><%= c.status %></span></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>

    </section>
  </main>

  <%- include('../layouts/footer') %>

  <script>
    (function () {
      const eventSelect = document.getElementById('eventId');
      const audienceRadios = document.querySelectorAll('input[name="audience"]');
      const countEl = document.getElementById('recipient-count');
      const labelEl = document.getElementById('recipient-label');
      const extraEl = document.getElementById('recipient-extra');
      const submitBtn = document.getElementById('promote-submit');
      const selectedEmailPanel = document.getElementById('selected-email-panel');
      const selectedEmails = document.getElementById('selectedEmails');

      function getAudience() {
        const checked = document.querySelector('input[name="audience"]:checked');
        return checked ? checked.value : '';
      }

      async function updatePreview() {
        const eventId = eventSelect ? eventSelect.value : '';
        const audience = getAudience();
        const selectedEmailValue = selectedEmails ? selectedEmails.value : '';
        if (selectedEmailPanel) {
          selectedEmailPanel.classList.toggle('is-visible', audience === 'selected_emails');
        }
        if (!eventId || !audience) {
          countEl.textContent = '—';
          labelEl.textContent = 'Select an event and audience to preview';
          extraEl.style.display = 'none';
          submitBtn.disabled = true;
          return;
        }
        if (audience === 'selected_emails' && !selectedEmailValue.trim()) {
          countEl.textContent = '—';
          labelEl.textContent = 'Enter one or more recipient emails';
          extraEl.style.display = 'none';
          submitBtn.disabled = true;
          return;
        }
        countEl.textContent = '…';
        labelEl.textContent = 'Loading…';
        extraEl.style.display = 'none';
        try {
          const params = new URLSearchParams({ eventId, audience });
          if (audience === 'selected_emails') params.set('selectedEmails', selectedEmailValue);
          const resp = await fetch(`/admin/promote/preview?${params.toString()}`);
          const data = await resp.json();
          const count = data.count || 0;
          countEl.textContent = count;
          labelEl.textContent = count === 1 ? 'eligible runner' : 'eligible runners';
          if (audience === 'selected_emails') {
            const details = [];
            if (data.invalidCount) details.push(`${data.invalidCount} invalid`);
            if (data.optedOutCount) details.push(`${data.optedOutCount} opted out`);
            if (data.capped) details.push(`capped at ${data.limit}`);
            extraEl.textContent = details.join(' • ');
            extraEl.style.display = details.length ? 'block' : 'none';
          }
          submitBtn.disabled = count === 0;
        } catch (_) {
          countEl.textContent = '?';
          labelEl.textContent = 'Preview unavailable';
          extraEl.style.display = 'none';
        }
      }

      if (eventSelect) eventSelect.addEventListener('change', updatePreview);
      if (selectedEmails) selectedEmails.addEventListener('input', updatePreview);
      audienceRadios.forEach(function (r) { r.addEventListener('change', updatePreview); });
    })();
  </script>
</body>
</html>
