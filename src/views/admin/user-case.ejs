<!DOCTYPE html><html lang="en"><head><%- include('../layouts/head', { title }) %><link rel="stylesheet" href="/css/admin.css"></head><body><%- include('../layouts/nav') %>
<main class="admin-page"><section class="section admin-shell">
  <div class="admin-header-row"><div><p class="dashboard-kicker">Cross-domain case</p><h2><%= [subject.firstName, subject.lastName].filter(Boolean).join(' ') || subject.email %></h2><p><%= subject.email %> · <%= subject.role %> · <%= subject.accountStatus || 'active' %></p></div><div class="header-actions"><a class="btn btn-secondary" href="/admin/search?q=<%= encodeURIComponent(subject.email) %>">Back to Search</a><a class="btn" href="/admin/users/<%= subject._id %>">Account Controls</a></div></div>
  <section class="workflow-incident-summary"><div><p class="workflow-eyebrow">Case status</p><h3>Open for review</h3><p>This read-only evidence workspace connects the subject's account, organizer activity, registrations, and decisions. Mutations remain on their governed source screens.</p></div><dl class="workflow-incident-facts"><div><dt>Subject ID</dt><dd><code><%= subject._id %></code></dd></div><div><dt>Organizer state</dt><dd><%= subject.organizerStatus || 'Not applicable' %></dd></div><div><dt>Last account update</dt><dd><%= subject.updatedAt ? new Date(subject.updatedAt).toLocaleString() : 'Unknown' %></dd></div></dl></section>
  <% const groups = [
    ['Organizer applications', applications, (x) => x.businessName || x.applicationId, (x) => `${x.status} · ${x.applicationId}`, (x) => `/admin/applications/${x._id}`],
    ['Owned events', events, (x) => x.title, (x) => x.status, (x) => `/admin/events/${x._id}`],
    ['Registrations', registrations, (x) => x.eventId?.title || x.confirmationCode, (x) => `${x.status} · payment ${x.paymentStatus} · ${x.confirmationCode}`, () => '/admin/reviews?type=payments'],
    ['Run submissions', submissions, (x) => x.eventId?.title || `Submission ${x._id}`, (x) => `${x.status}${x.rejectionReason ? ` · ${x.rejectionReason}` : ''}`, (x) => `/admin/submissions?search=${x._id}`]
  ]; %>
  <div class="admin-search-grid"><% groups.forEach(([label, items, primary, secondary, href]) => { %><section class="detail-card"><h3><%= label %> <span class="status-badge"><%= items.length %></span></h3><% if (items.length) { %><ul class="admin-search-results"><% items.forEach((item) => { %><li><div><strong><%= primary(item) %></strong><small><%= secondary(item) %></small></div><a class="btn btn-sm" href="<%= href(item) %>">Evidence</a></li><% }); %></ul><% } else { %><p class="text-muted">No records in this domain.</p><% } %></section><% }); %></div>
</section></main><%- include('../layouts/footer') %><script src="/js/main.js"></script><script>if (window.lucide) lucide.createIcons();</script></body></html>
