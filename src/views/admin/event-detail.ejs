<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title }) %>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <main class="admin-page admin-events-page">
    <section class="section admin-shell">
      <div class="admin-header-row">
        <div>
          <h2><%= event.title %></h2>
          <p>Admin event review, audit, and management.</p>
        </div>
        <div class="policy-list-actions">
          <a href="/admin/events" class="btn btn-secondary admin-event-action-btn">
            <i data-lucide="list"></i>
            <span>All Events</span>
          </a>
          <% if (!event.isDeleted) { %>
            <a href="/admin/events/<%= event._id %>/edit" class="btn admin-event-action-btn">
              <i data-lucide="pencil"></i>
              <span>Edit Event</span>
            </a>
          <% } %>
          <% if (event.status === 'published' && !event.isDeleted) { %>
            <a href="/events/<%= event.slug %>" class="btn btn-secondary admin-event-action-btn">
              <i data-lucide="globe"></i>
              <span>Public Page</span>
            </a>
          <% } %>
          <a href="/organizer/events/<%= event._id %>/registrants" class="btn btn-secondary admin-event-action-btn">
            <i data-lucide="users"></i>
            <span>Registrants</span>
          </a>
        </div>
      </div>

      <% if (message) { %>
        <div class="admin-alert admin-alert-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <div id="eventActionMessage" class="admin-alert" style="display:none;"></div>

      <div class="application-meta-grid">
        <article class="meta-card">
          <p class="meta-label">Status</p>
          <p class="meta-value"><span class="status-badge status-badge-<%= event.isDeleted ? 'archived' : event.status %>"><%= event.isDeleted ? 'Deleted' : statusLabel %></span></p>
        </article>
        <article class="meta-card">
          <p class="meta-label">Reference</p>
          <p class="meta-value mono"><%= event.referenceCode || event.slug %></p>
        </article>
        <article class="meta-card">
          <p class="meta-label">Registrations</p>
          <p class="meta-value"><%= counts.registrations %></p>
        </article>
        <article class="meta-card">
          <p class="meta-label">Submissions</p>
          <p class="meta-value"><%= counts.submissions %></p>
        </article>
      </div>

      <div class="details-grid">
        <article class="detail-card">
          <h3>Organizer</h3>
          <p><strong>Name:</strong> <%= [event.organizerId?.firstName, event.organizerId?.lastName].filter(Boolean).join(' ') || event.organiserName || 'N/A' %></p>
          <p><strong>Email:</strong> <%= event.organizerId?.email || 'N/A' %></p>
          <p><strong>Display:</strong> <%= event.organiserName || 'N/A' %></p>
        </article>
        <article class="detail-card">
          <h3>Schedule</h3>
          <p><strong>Registration:</strong> <%= event.registrationOpenAt ? new Date(event.registrationOpenAt).toLocaleString('en-US') : 'N/A' %> to <%= event.registrationCloseAt ? new Date(event.registrationCloseAt).toLocaleString('en-US') : 'N/A' %></p>
          <p><strong>Event:</strong> <%= event.eventStartAt ? new Date(event.eventStartAt).toLocaleString('en-US') : 'N/A' %> to <%= event.eventEndAt ? new Date(event.eventEndAt).toLocaleString('en-US') : 'N/A' %></p>
          <p><strong>Submitted:</strong> <%= event.submittedForReviewAt ? new Date(event.submittedForReviewAt).toLocaleString('en-US') : 'N/A' %></p>
          <p><strong>Approval:</strong> <%= event.approvalSource === 'auto' ? `Auto-approved (${event.autoApprovalRuleVersion || 'rule not recorded'})` : (event.approvalSource === 'admin' ? 'Admin approved' : 'Not approved') %></p>
        </article>
        <article class="detail-card">
          <h3>Event Rules</h3>
          <p><strong>Type:</strong> <%= event.eventType || 'N/A' %></p>
          <p><strong>Modes:</strong> <%= (event.eventTypesAllowed || []).join(', ') || 'N/A' %></p>
          <p><strong>Distances:</strong> <%= (event.raceDistances || []).join(', ') || 'N/A' %></p>
          <p><strong>Proofs:</strong> <%= (event.proofTypesAllowed || []).join(', ') || 'N/A' %></p>
        </article>
        <article class="detail-card">
          <h3>Fees & Payment</h3>
          <p><strong>Fee:</strong> <%= event.feeMode === 'paid' ? `${event.feeCurrency || 'PHP'} ${Number(event.feeAmount || 0).toFixed(2)}` : 'Free' %></p>
          <% if (event.feeMode === 'paid') { %>
            <p><strong>Account:</strong> <%= event.paymentAccountName || 'N/A' %></p>
            <p><strong>Instructions:</strong> <%= event.paymentInstructions || 'N/A' %></p>
            <p><strong>Payment QR:</strong> <%= event.paymentQrImageUrl ? 'Configured' : 'Missing' %></p>
          <% } %>
        </article>
        <article class="detail-card">
          <h3>Rewards</h3>
          <% const adminPhysicalRewardItems = [
            event.physicalRewardMedalEnabled ? 'Medal' : '',
            event.physicalRewardShirtEnabled ? 'Shirt' : '',
            event.physicalRewardPatchEnabled ? 'Patch' : '',
            event.physicalRewardFinisherKitEnabled ? 'Finisher Kit' : ''
          ].filter(Boolean); %>
          <p><strong>Digital Badge:</strong> <%= event.digitalBadgeEnabled ? 'Enabled' : 'Disabled' %></p>
          <p><strong>Digital Certificate:</strong> <%= event.digitalCertificateEnabled === false ? 'Disabled' : 'Enabled' %></p>
          <p><strong>Leaderboard Recognition:</strong> <%= event.leaderboardRecognitionEnabled === false ? 'Disabled' : 'Enabled' %></p>
          <p><strong>Physical Rewards:</strong> <%= event.physicalRewardsEnabled ? 'Enabled' : 'Disabled' %></p>
          <% if (event.physicalRewardsEnabled && adminPhysicalRewardItems.length) { %>
            <p><strong>Included Items:</strong> <%= adminPhysicalRewardItems.join(', ') %></p>
          <% } %>
          <% if (event.physicalRewardsEnabled && event.physicalRewardsDescription) { %>
            <p><%= event.physicalRewardsDescription %></p>
          <% } %>
        </article>
        <article class="detail-card">
          <h3>Location</h3>
          <p><strong>Venue:</strong> <%= event.venueName || 'N/A' %></p>
          <p><strong>City:</strong> <%= [event.city, event.province, event.country].filter(Boolean).join(', ') || 'N/A' %></p>
        </article>
        <article class="detail-card detail-card-full">
          <h3>Description</h3>
          <p><%= event.description || 'No description yet.' %></p>
        </article>
        <% if (eventDetailsHtml) { %>
          <article class="detail-card detail-card-full">
            <h3>Event Details</h3>
            <div class="event-rich-details"><%- eventDetailsHtml %></div>
          </article>
        <% } %>
        <article class="detail-card detail-card-full">
          <h3>Media</h3>
          <div class="admin-media-grid">
            <% [event.logoUrl, event.bannerImageUrl, event.posterImageUrl].filter(Boolean).forEach((url) => { %>
              <img src="<%= url %>" alt="" class="admin-event-thumb">
            <% }) %>
            <% (event.galleryImageUrls || []).slice(0, 6).forEach((url) => { %>
              <img src="<%= url %>" alt="" class="admin-event-thumb">
            <% }) %>
            <% if (!event.logoUrl && !event.bannerImageUrl && !event.posterImageUrl && !(event.galleryImageUrls || []).length) { %>
              <p>No media uploaded.</p>
            <% } %>
          </div>
        </article>
      </div>

      <% if (readinessErrors.length) { %>
        <div class="admin-alert admin-alert-warning">
          Cannot approve yet: <%= readinessErrors[0] %>
        </div>
      <% } %>

      <section class="review-actions">
        <h3>Admin Actions</h3>
        <p class="action-note">Archive and delete require a reason. Registrations and submissions are preserved.</p>
        <div class="policy-list-actions">
          <button type="button" class="btn btn-success event-action-btn admin-event-action-btn" data-action="approve" <%= event.status !== 'pending_review' || event.isDeleted || readinessErrors.length ? 'disabled' : '' %>>
            <i data-lucide="check-circle"></i>
            <span>Approve & Publish</span>
          </button>
          <button type="button" class="btn btn-secondary event-action-btn admin-event-action-btn" data-action="archive" <%= event.isDeleted || event.status === 'archived' ? 'disabled' : '' %>>
            <i data-lucide="archive"></i>
            <span>Archive</span>
          </button>
          <button type="button" class="btn btn-danger event-action-btn admin-event-action-btn" data-action="delete" <%= event.isDeleted ? 'disabled' : '' %>>
            <i data-lucide="trash-2"></i>
            <span>Soft Delete</span>
          </button>
        </div>
      </section>
    </section>
  </main>
  <div class="admin-delete-confirm-backdrop" id="adminEventDeleteConfirmModal" hidden aria-hidden="true">
    <div class="admin-delete-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="adminEventDeleteConfirmTitle" tabindex="-1">
      <div class="admin-delete-confirm-icon-wrap">
        <i data-lucide="triangle-alert" aria-hidden="true"></i>
      </div>
      <h3 id="adminEventDeleteConfirmTitle">Confirm Event Deletion</h3>
      <p id="adminEventDeleteConfirmDesc" class="admin-delete-confirm-desc"></p>
      <div class="admin-delete-confirm-pw-group">
        <label for="adminEventDeleteReason">Reason for deletion <span aria-hidden="true">(min 8 characters)</span></label>
        <textarea
          id="adminEventDeleteReason"
          rows="3"
          placeholder="Enter a reason..."
          class="admin-delete-confirm-pw-input"
          style="resize:vertical;"
        ></textarea>
        <p class="admin-delete-confirm-pw-error" id="adminEventDeleteReasonError" hidden></p>
      </div>
      <div class="admin-delete-confirm-pw-group">
        <label for="adminEventDeletePassword">Enter your password to confirm</label>
        <div class="admin-delete-confirm-pw-wrap">
          <input
            type="password"
            id="adminEventDeletePassword"
            autocomplete="current-password"
            placeholder="Your password"
            class="admin-delete-confirm-pw-input"
          >
          <button type="button" class="admin-delete-confirm-pw-toggle" id="adminEventDeletePwToggle" aria-label="Show password">
            <i data-lucide="eye" aria-hidden="true"></i>
          </button>
        </div>
        <p class="admin-delete-confirm-pw-error" id="adminEventDeletePwError" hidden></p>
      </div>
      <div class="admin-delete-confirm-actions">
        <button type="button" class="btn btn-secondary" id="adminEventDeleteCancelBtn">Cancel</button>
        <button type="button" class="btn btn-danger" id="adminEventDeleteOkBtn">
          <i data-lucide="trash-2" aria-hidden="true"></i>
          Delete
        </button>
      </div>
    </div>
  </div>
  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    (function() {
      const csrfToken = <%- JSON.stringify(locals.csrfToken || '') %>;
      const eventId = <%- JSON.stringify(String(event._id)) %>;
      const messageBox = document.getElementById('eventActionMessage');
      const deleteModal = document.getElementById('adminEventDeleteConfirmModal');
      const deleteModalDialog = deleteModal ? deleteModal.querySelector('.admin-delete-confirm-dialog') : null;
      const deleteConfirmDesc = document.getElementById('adminEventDeleteConfirmDesc');
      const deleteReasonInput = document.getElementById('adminEventDeleteReason');
      const deleteReasonError = document.getElementById('adminEventDeleteReasonError');
      const deletePwInput = document.getElementById('adminEventDeletePassword');
      const deletePwError = document.getElementById('adminEventDeletePwError');
      const deletePwToggle = document.getElementById('adminEventDeletePwToggle');
      const deleteCancelBtn = document.getElementById('adminEventDeleteCancelBtn');
      const deleteOkBtn = document.getElementById('adminEventDeleteOkBtn');
      let deleteModalResolve = null;
      let lastDeleteModalTrigger = null;

      function showMessage(type, text) {
        messageBox.className = `admin-alert admin-alert-${type}`;
        messageBox.textContent = text;
        messageBox.style.display = 'block';
      }

      function openDeleteConfirmModal(description, triggerEl) {
        if (!deleteModal) return Promise.resolve(null);
        lastDeleteModalTrigger = triggerEl || null;
        if (deleteConfirmDesc) deleteConfirmDesc.textContent = description;
        if (deleteReasonInput) deleteReasonInput.value = '';
        if (deleteReasonError) { deleteReasonError.hidden = true; deleteReasonError.textContent = ''; }
        if (deletePwInput) { deletePwInput.value = ''; deletePwInput.type = 'password'; }
        if (deletePwError) { deletePwError.hidden = true; deletePwError.textContent = ''; }
        if (deletePwToggle) {
          const icon = deletePwToggle.querySelector('i');
          if (icon) icon.setAttribute('data-lucide', 'eye');
          deletePwToggle.setAttribute('aria-label', 'Show password');
          if (window.lucide) lucide.createIcons({ nodes: [deletePwToggle] });
        }
        deleteModal.hidden = false;
        deleteModal.setAttribute('aria-hidden', 'false');
        if (deleteModalDialog) deleteModalDialog.focus();
        return new Promise((resolve) => { deleteModalResolve = resolve; });
      }

      function closeDeleteConfirmModal(result) {
        if (!deleteModal) return;
        deleteModal.hidden = true;
        deleteModal.setAttribute('aria-hidden', 'true');
        if (deleteReasonInput) deleteReasonInput.value = '';
        if (deletePwInput) deletePwInput.value = '';
        const resolve = deleteModalResolve;
        deleteModalResolve = null;
        if (resolve) resolve(result);
        if (lastDeleteModalTrigger) lastDeleteModalTrigger.focus();
        lastDeleteModalTrigger = null;
      }

      if (deletePwToggle && deletePwInput) {
        deletePwToggle.addEventListener('click', () => {
          const isPassword = deletePwInput.type === 'password';
          deletePwInput.type = isPassword ? 'text' : 'password';
          const icon = deletePwToggle.querySelector('i');
          if (icon) icon.setAttribute('data-lucide', isPassword ? 'eye-off' : 'eye');
          deletePwToggle.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
          if (window.lucide) lucide.createIcons({ nodes: [deletePwToggle] });
        });
      }

      if (deleteCancelBtn) {
        deleteCancelBtn.addEventListener('click', () => closeDeleteConfirmModal(null));
      }

      if (deleteOkBtn) {
        deleteOkBtn.addEventListener('click', () => {
          const reason = deleteReasonInput ? deleteReasonInput.value.trim() : '';
          const pw = deletePwInput ? deletePwInput.value.trim() : '';
          let valid = true;
          if (reason.length < 8) {
            if (deleteReasonError) {
              deleteReasonError.textContent = 'Reason must be at least 8 characters.';
              deleteReasonError.hidden = false;
            }
            if (deleteReasonInput) deleteReasonInput.focus();
            valid = false;
          } else if (deleteReasonError) {
            deleteReasonError.hidden = true;
          }
          if (!pw) {
            if (deletePwError) {
              deletePwError.textContent = 'Please enter your password.';
              deletePwError.hidden = false;
            }
            if (valid && deletePwInput) deletePwInput.focus();
            valid = false;
          } else if (deletePwError) {
            deletePwError.hidden = true;
          }
          if (!valid) return;
          closeDeleteConfirmModal({ reason, adminPassword: pw });
        });
      }

      if (deletePwInput) {
        deletePwInput.addEventListener('keydown', (event) => {
          if (event.key === 'Enter') {
            event.preventDefault();
            if (deleteOkBtn) deleteOkBtn.click();
          }
        });
      }

      if (deleteModal) {
        deleteModal.addEventListener('click', (event) => {
          if (event.target === deleteModal) closeDeleteConfirmModal(null);
        });
        deleteModal.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') closeDeleteConfirmModal(null);
        });
      }

      async function postAction(action, body = {}) {
        const response = await fetch(`/admin/events/${eventId}/${action}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken
          },
          body: JSON.stringify(body)
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) {
          throw new Error(data.message || 'Action failed.');
        }
        return data;
      }
      document.querySelectorAll('.event-action-btn').forEach((button) => {
        button.addEventListener('click', async () => {
          const action = button.dataset.action;
          let body = {};
          if (action === 'delete') {
            const desc = 'You are about to soft-delete this event. Enter a reason and your password to continue.';
            const result = await openDeleteConfirmModal(desc, button);
            if (!result) return;
            body = result;
          } else if (action === 'archive') {
            const reason = prompt(`Reason for ${action === 'archive' ? 'archiving' : 'soft-deleting'} this event:`);
            if (!reason) return;
            body.reason = reason;
          } else if (!confirm('Approve and publish this event?')) {
            return;
          }
          button.disabled = true;
          try {
            const data = await postAction(action, body);
            showMessage('success', data.message || 'Action completed.');
            window.setTimeout(() => window.location.reload(), 700);
          } catch (error) {
            showMessage('error', error.message);
            button.disabled = false;
          }
        });
      });
    })();
  </script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
