<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'Personal Information - HelloRun' }) %>
  <link rel="stylesheet" href="/css/runner-dashboard.css">
  <link rel="stylesheet" href="/css/runner-profile.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <% const _csrfToken = typeof csrfToken !== 'undefined' ? csrfToken : ''; %>

  <main class="runner-profile-page">
    <header class="runner-profile-header">
      <div>
        <h1>Personal Information</h1>
        <p>Keep your runner details accurate for registrations, certificates, leaderboards, and emergency contact records.</p>
      </div>
      <a href="/runner/dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </header>

    <% if (message) { %>
      <div
        class="page-message page-message-<%= message.type %>"
        role="<%= message.type === 'error' ? 'alert' : 'status' %>"
        aria-live="<%= message.type === 'error' ? 'assertive' : 'polite' %>"
      ><%= message.text %></div>
    <% } %>

    <div class="runner-profile-layout">
      <aside class="runner-profile-menu" aria-label="Profile quick menu">
        <h2>Quick Menu</h2>
        <nav>
<a href="#overview"><i data-lucide="user"></i>Overview</a>
<a href="#identity"><i data-lucide="fingerprint"></i>Identity</a>
<a href="#contact"><i data-lucide="mail"></i>Contact</a>
<a href="#emergency"><i data-lucide="phone-forwarded"></i>Emergency</a>
<a href="#badges"><i data-lucide="award"></i>Badges</a>
<a href="#integrations"><i data-lucide="plug"></i>Integrations</a>
<a href="#account"><i data-lucide="settings"></i>Account</a>
        </nav>
      </aside>

      <section class="runner-profile-content">
        <article class="runner-profile-card" id="overview">
          <h3>Overview</h3>
          <div class="profile-completeness">
            <div class="profile-completeness-header">
              <strong>Profile Completeness</strong>
              <span><%= profileCompleteness.percent %>%</span>
            </div>
            <div class="progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="<%= profileCompleteness.percent %>">
              <div class="progress-fill" style="width: <%= profileCompleteness.percent %>%"></div>
            </div>
            <small>Completed <%= profileCompleteness.completedCount %> of <%= profileCompleteness.requiredCount %> recommended fields.</small>
            <% if (profileCompleteness.missingFields.length) { %>
              <p class="missing-fields">Missing: <%= profileCompleteness.missingFields.join(', ') %></p>
            <% } %>
          </div>
        </article>

        <article class="runner-profile-card" id="identity">
          <div class="runner-profile-panel-header">
            <h3>Identity</h3>
            <button type="button" class="btn btn-secondary" data-panel-edit data-form-id="identityForm">
              <i data-lucide="edit-2"></i> Edit Identity
            </button>
          </div>
          <form id="identityForm" method="POST" action="/runner/profile/identity" class="runner-profile-form">
            <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
            <div class="profile-form-grid">
              <label class="profile-form-field">
                <span>First Name</span>
                <input type="text" name="firstName" maxlength="60" value="<%= profileData.firstName || '' %>" data-editable readonly>
              </label>
              <label class="profile-form-field">
                <span>Last Name</span>
                <input type="text" name="lastName" maxlength="60" value="<%= profileData.lastName || '' %>" data-editable readonly>
              </label>
              <label class="profile-form-field">
                <span class="profile-label-with-help">
                  Display Name
                  <button
                    type="button"
                    class="profile-help-trigger"
                    aria-describedby="displayNameTip"
                    title="Optional public-friendly name for areas like leaderboards."
                  >?</button>
                </span>
                <input type="text" name="displayName" maxlength="60" value="<%= profileData.displayName || '' %>" placeholder="Optional" data-editable readonly>
                <small id="displayNameTip" class="profile-field-help">Optional. If set, HelloRun can show this instead of your full name where event privacy settings allow it.</small>
              </label>
              <label class="profile-form-field">
                <span>Date of Birth</span>
                <input type="date" name="dateOfBirth" value="<%= profileData.dateOfBirth || '' %>" data-editable readonly>
              </label>
              <label class="profile-form-field">
                <span>Gender</span>
                <select name="gender" data-editable disabled>
                  <option value="" <%= !profileData.gender ? 'selected' : '' %>>Not set</option>
                  <option value="male" <%= profileData.gender === 'male' ? 'selected' : '' %>>Male</option>
                  <option value="female" <%= profileData.gender === 'female' ? 'selected' : '' %>>Female</option>
                  <option value="non_binary" <%= profileData.gender === 'non_binary' ? 'selected' : '' %>>Non-binary</option>
                  <option value="prefer_not_to_say" <%= profileData.gender === 'prefer_not_to_say' ? 'selected' : '' %>>Prefer not to say</option>
                </select>
              </label>
            </div>
            <div class="runner-profile-form-actions" hidden>
              <button type="submit" class="btn btn-primary" data-save-btn>Save Identity</button>
              <button type="button" class="btn btn-outline" data-cancel-edit>Cancel</button>
            </div>
          </form>
        </article>

        <article class="runner-profile-card" id="contact">
          <div class="runner-profile-panel-header">
            <h3>Contact</h3>
            <button type="button" class="btn btn-secondary" data-panel-edit data-form-id="contactForm">
              <i data-lucide="edit-2"></i> Edit Contact
            </button>
          </div>
          <form id="contactForm" method="POST" action="/runner/profile/contact" class="runner-profile-form">
            <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
            <div class="profile-form-grid">
              <label class="profile-form-field">
                <span>Email</span>
                <input type="email" value="<%= user.email || '' %>" readonly disabled>
              </label>
              <label class="profile-form-field">
                <span>Mobile</span>
                <input type="text" name="mobile" value="<%= profileData.mobile || '' %>" data-editable readonly>
              </label>
              <label class="profile-form-field">
                <span>Country</span>
                <select name="country" data-editable disabled>
                  <option value="" <%= !profileData.country ? 'selected' : '' %>>Not set</option>
                  <% (countries || []).forEach((country) => { %>
                    <option value="<%= country.code %>" <%= profileData.country === country.code ? 'selected' : '' %>><%= country.name %></option>
                  <% }) %>
                </select>
              </label>
              <label class="profile-form-field">
                <span>Running Group</span>
                <input type="text" value="<%= (profileData.runningGroups && profileData.runningGroups.length) ? profileData.runningGroups.join(', ') : (profileData.runningGroup || 'Not set') %>" readonly disabled>
              </label>
            </div>
            <div class="runner-profile-form-actions" hidden>
              <button type="submit" class="btn btn-primary" data-save-btn>Save Contact</button>
              <button type="button" class="btn btn-outline" data-cancel-edit>Cancel</button>
            </div>
          </form>
        </article>

        <article class="runner-profile-card" id="emergency">
          <div class="runner-profile-panel-header">
            <h3>Emergency Contact</h3>
            <button type="button" class="btn btn-secondary" data-panel-edit data-form-id="emergencyForm">Edit Emergency</button>
          </div>
          <form id="emergencyForm" method="POST" action="/runner/profile/emergency" class="runner-profile-form">
            <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
            <div class="profile-form-grid">
              <label class="profile-form-field">
                <span>Contact Name</span>
                <input type="text" name="emergencyContactName" maxlength="120" value="<%= profileData.emergencyContactName || '' %>" data-editable readonly>
              </label>
              <label class="profile-form-field">
                <span>Contact Number</span>
                <input type="text" name="emergencyContactNumber" value="<%= profileData.emergencyContactNumber || '' %>" data-editable readonly>
              </label>
            </div>
            <div class="runner-profile-form-actions" hidden>
              <button type="submit" class="btn btn-primary" data-save-btn>Save Emergency Contact</button>
              <button type="button" class="btn btn-outline" data-cancel-edit>Cancel</button>
            </div>
          </form>
        </article>

        <article class="runner-profile-card" id="badges">
          <div class="runner-profile-panel-header">
            <h3>Achievement Badges</h3>
            <span class="profile-readonly-note"><%= (badges || []).length %> earned</span>
          </div>
          <% const earnedBadges = badges || []; %>
          <% const progressBadges = badgeProgress || []; %>
          <% if (publicBadgeCollectionPath) { %>
            <div class="runner-profile-actions profile-badge-public-actions">
              <a href="<%= publicBadgeCollectionPath %>" class="btn btn-outline btn-sm" target="_blank" rel="noopener noreferrer">
                <i data-lucide="external-link"></i>
                Public Collection
              </a>
            </div>
          <% } %>
          <section class="profile-badge-progress-section" aria-label="Challenge badge progress">
            <h4>Challenge Progress</h4>
            <% if (progressBadges.length) { %>
              <div class="profile-badge-progress-grid">
                <% progressBadges.slice(0, 8).forEach((item) => { %>
                  <% const percent = Math.max(0, Math.min(100, Number(item.progressPercent || 0))); %>
                  <article class="profile-badge-progress-card">
                    <div class="profile-badge-progress-card-top">
                      <span class="profile-badge-icon"><i data-lucide="trending-up"></i></span>
                      <strong><%= percent.toFixed(percent % 1 === 0 ? 0 : 1) %>%</strong>
                    </div>
                    <h5><%= item.name %></h5>
                    <div class="profile-badge-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="<%= Math.round(percent) %>">
                      <span style="width: <%= percent %>%"></span>
                    </div>
                    <p><%= Number(item.currentValue || 0).toFixed(2) %> km / <%= Number(item.targetValue || 0).toFixed(2) %> km</p>
                  </article>
                <% }) %>
              </div>
            <% } else { %>
              <p class="profile-badge-progress-empty">No active challenge progress yet.</p>
            <% } %>
          </section>
          <% if (earnedBadges.length) { %>
            <% const featuredBadge = earnedBadges.find((badge) => badge.isFeatured); %>
            <% if (featuredBadge) { %>
              <div class="profile-featured-badge">
                <span class="profile-badge-icon"><i data-lucide="award"></i></span>
                <div>
                  <p>Featured Badge</p>
                  <strong><%= featuredBadge.name %></strong>
                  <small><%= featuredBadge.description || 'Verified HelloRun achievement.' %></small>
                </div>
              </div>
            <% } %>
            <div class="profile-badge-grid" aria-label="Earned achievement badges">
              <% earnedBadges.slice(0, 12).forEach((badge) => { %>
                <article class="profile-badge-card<%= badge.isFeatured ? ' is-featured' : '' %>">
                  <div class="profile-badge-card-top">
                    <span class="profile-badge-icon"><i data-lucide="award"></i></span>
                    <% if (badge.isFeatured) { %>
                      <span class="profile-badge-state">Featured</span>
                    <% } %>
                  </div>
                  <h4><%= badge.name %></h4>
                  <p><%= badge.description || 'Verified HelloRun achievement.' %></p>
                  <small><%= badge.badgeType ? badge.badgeType.replace(/_/g, ' ') : 'achievement' %></small>
                  <a href="/badges/<%= badge.userBadgeId %>" class="profile-badge-share-link" target="_blank" rel="noopener noreferrer">
                    <i data-lucide="external-link"></i>
                    <span>Share</span>
                  </a>
                  <% if (!badge.isFeatured) { %>
                    <form method="POST" action="/runner/profile/badges/featured" class="inline-form profile-badge-action">
                      <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
                      <input type="hidden" name="userBadgeId" value="<%= badge.userBadgeId %>">
                      <button type="submit" class="btn btn-outline btn-sm">Feature</button>
                    </form>
                  <% } %>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="profile-empty-state">
              <i data-lucide="award"></i>
              <strong>No badges yet</strong>
              <p>Verified event badges will appear here after eligible registrations or approved results.</p>
            </div>
          <% } %>
        </article>

        <article class="runner-profile-card" id="integrations">
          <div class="runner-profile-panel-header">
            <h3>Integrations</h3>
            <span class="profile-readonly-note">Connect your Strava account to import your own activities. HelloRun will only submit the activity you choose.</span>
          </div>
          <dl class="profile-readonly-grid">
            <div class="profile-readonly-item">
              <dt>Strava</dt>
              <dd><%= stravaConnection && stravaConnection.connected ? 'Connected' : 'Not connected' %></dd>
            </div>
            <% if (stravaConnection && stravaConnection.connected) { %>
              <div class="profile-readonly-item">
                <dt>Connected As</dt>
                <dd><%= stravaConnection.athleteName || ('Athlete #' + stravaConnection.stravaAthleteId) %></dd>
              </div>
            <% } %>
          </dl>
          <div class="runner-profile-actions">
            <% if (stravaConnection && stravaConnection.connected) { %>
              <form method="POST" action="/integrations/strava/disconnect" class="inline-form">
                <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
                <input type="hidden" name="returnTo" value="/runner/profile#integrations">
                <button type="submit" class="btn btn-outline-danger">
                  <i data-lucide="unlink"></i> Disconnect Strava
                </button>
              </form>
            <% } else { %>
              <a href="/integrations/strava/connect?returnTo=/runner/profile%23integrations" class="btn btn-primary">
                <i data-lucide="plug"></i> Connect Strava
              </a>
            <% } %>
          </div>
        </article>

        <article class="runner-profile-card" id="account">
          <h3>Account</h3>
          <dl class="profile-readonly-grid">
            <div class="profile-readonly-item"><dt>Auth Provider</dt><dd><%= user.authProvider === 'google' ? 'Google' : 'Email and password' %></dd></div>
            <div class="profile-readonly-item"><dt>Google Link</dt><dd><%= user.googleId ? 'Linked' : 'Not linked' %></dd></div>
            <div class="profile-readonly-item"><dt>Local Password</dt><dd><%= user.passwordHash ? 'Set' : 'Not set' %></dd></div>
          </dl>
          <div class="runner-profile-actions">
            <a href="/runner/security/password" class="btn btn-primary"><%= user.passwordHash ? 'Change Password' : 'Set Password' %></a>
            <% if (user.googleId) { %>
              <form method="POST" action="/runner/auth/google/unlink" class="inline-form">
                <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
                <input type="hidden" name="returnTo" value="/runner/profile">
                <button type="button"
                        class="btn btn-outline-danger<%= !user.passwordHash ? ' disabled' : '' %>"
                        data-open-unlink-modal
                        aria-label="Unlink Google"
                        <%= !user.passwordHash ? 'disabled aria-disabled="true"' : '' %>>
                  <i data-lucide="unlink"></i> Unlink Google
                </button>
              </form>
            <% } %>
          </div>
          <% if (user.googleId && !user.passwordHash) { %>
            <p class="profile-readonly-note">Set a password first to avoid being locked out when you unlink Google.</p>
          <% } %>
        </article>
      </section>
    </div>
  </main>

  <% if (user.googleId) { %>
    <div class="modal-backdrop" id="unlinkGoogleModal" hidden>
      <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="unlinkGoogleModalTitle" aria-describedby="unlinkGoogleModalDesc" tabindex="-1">
        <h3 id="unlinkGoogleModalTitle">Unlink Google sign-in?</h3>
        <p id="unlinkGoogleModalDesc">
          You can still sign in with your local password.<% if (!user.passwordHash) { %> Set a password before unlinking to avoid lockout.<% } %>
        </p>
        <div class="modal-actions">
          <button type="button" class="btn btn-outline" data-cancel-unlink>Cancel</button>
          <button type="button" class="btn btn-danger" data-confirm-unlink>Yes, unlink</button>
        </div>
      </div>
    </div>
  <% } %>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/runner-profile.js"></script>
  <script>
    if (window.lucide) lucide.createIcons();
  </script>
</body>
</html>
