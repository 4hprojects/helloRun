<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'Submission Detail - HelloRun' }) %>
  <link rel="stylesheet" href="/css/runner-dashboard.css">
  <link rel="stylesheet" href="/css/runner-submissions.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <% const view = submission.presentation; %>
  <% const correction = view.correction; %>
  <% const ms = Number(submission.elapsedMs || 0); const totalSec = Math.floor(ms / 1000); const elapsedPrefill = `${String(Math.floor(totalSec / 3600)).padStart(2, '0')}:${String(Math.floor((totalSec % 3600) / 60)).padStart(2, '0')}:${String(totalSec % 60).padStart(2, '0')}`; %>

  <main class="dashboard-container sub-page sub-detail-page" id="main-content">
    <nav class="sub-breadcrumb" aria-label="Breadcrumb"><a href="/runner/submissions" class="sub-breadcrumb-link"><i data-lucide="arrow-left" aria-hidden="true"></i>Submission History</a><span class="sub-breadcrumb-sep" aria-hidden="true">/</span><span class="sub-breadcrumb-current" aria-current="page"><%= submission.eventTitle %></span></nav>

    <header class="sub-detail-header sub-detail-compact-header">
      <div class="sub-detail-heading">
        <span class="section-kicker"><i data-lucide="<%= submission.isPersonalRecord ? 'star' : (submission.isAccumulatedActivity ? 'layers-3' : 'flag') %>" aria-hidden="true"></i><%= submission.typeLabel %></span>
        <h1><%= submission.eventTitle %></h1>
        <p><%= submission.runDateLabel !== '–' ? 'Activity on ' + submission.runDateLabel : 'Submitted activity' %> · Submitted <%= submission.submittedAtRelativeLabel || submission.submittedAtLabel %></p>
      </div>
      <div class="sub-detail-primary-action">
        <span class="sub-review-state sub-review-state-<%= submission.status %>"><%= submission.statusLabel %></span>
        <% if (view.primaryAction.type === 'resubmit') { %><button type="button" class="btn btn-warning" data-open-run-proof-modal data-registration-id="<%= view.primaryAction.registrationId %>"><i data-lucide="upload" aria-hidden="true"></i><%= view.primaryAction.label %></button>
        <% } else { %><a href="<%= view.primaryAction.href %>" class="btn <%= view.primaryAction.type === 'certificate' ? 'btn-primary' : 'btn-outline' %>"<% if (view.primaryAction.type === 'certificate') { %> target="_blank" rel="noopener noreferrer"<% } %>><%= view.primaryAction.label %></a><% } %>
      </div>
    </header>

    <section class="sub-outcome sub-outcome-<%= submission.status %>" aria-labelledby="submissionOutcomeTitle">
      <span class="sub-outcome-icon"><i data-lucide="<%= submission.status === 'approved' ? 'circle-check-big' : (submission.status === 'rejected' ? 'triangle-alert' : 'clock-3') %>" aria-hidden="true"></i></span>
      <div><h2 id="submissionOutcomeTitle"><%= view.outcomeTitle %></h2><p><%= view.outcomeText %></p><% if (submission.reviewedAtLabel !== '–') { %><small>Decision recorded <%= submission.reviewedAtLabel %></small><% } %></div>
    </section>

    <% if (submission.status === 'rejected') { %>
      <section class="sub-correction-panel" aria-labelledby="correctionTitle">
        <div class="sub-correction-heading"><span><i data-lucide="wrench" aria-hidden="true"></i></span><div><h2 id="correctionTitle">What to fix</h2><p><%= correction.guidance %></p></div></div>
        <% if (submission.rejectionReason) { %><div class="sub-organizer-feedback"><strong>Organizer feedback</strong><p><%= submission.rejectionReason %></p><% if (submission.reviewNotes) { %><blockquote><%= submission.reviewNotes %></blockquote><% } %></div><% } %>

        <% if (correction.strategy === 'strava') { %><div class="sub-strava-locked-note"><i data-lucide="lock" aria-hidden="true"></i><p>Activity details are locked to Strava. Sync the corrected activity, then upload it through the submission flow.</p></div><% } %>

        <% if (correction.canEditMetadata) { %>
          <details class="sub-correction-disclosure"<%= correction.strategy === 'metadata' ? ' open' : '' %>>
            <summary><span><i data-lucide="pencil" aria-hidden="true"></i><strong>Correct activity details</strong><small>Your existing proof stays on file.</small></span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
            <form method="POST" action="/runner/submissions/<%= submission.submissionId %>/edit-metadata" class="sub-metadata-edit-form" data-submission-edit-form>
              <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
              <label><span>Distance (km)</span><input type="number" name="distanceKm" step="0.01" min="0.1" max="500" value="<%= submission.distanceKm || '' %>" required class="form-input"></label>
              <label><span>Elapsed time (hh:mm:ss)</span><input type="text" name="elapsedTime" pattern="^\d{1,2}:\d{2}:\d{2}$" value="<%= elapsedPrefill %>" required class="form-input"></label>
              <label><span>Activity date</span><input type="date" name="runDate" value="<%= submission.runDate ? new Date(submission.runDate).toISOString().slice(0, 10) : '' %>" required class="form-input"></label>
              <label><span>Activity type</span><select name="runType" class="form-input"><% ['run','walk','hike','trail_run'].forEach((type) => { %><option value="<%= type %>"<%= submission.runType === type ? ' selected' : '' %>><%= type.replace('_', ' ') %></option><% }) %></select></label>
              <label class="sub-metadata-edit-wide"><span>Location</span><input type="text" name="runLocation" maxlength="200" value="<%= submission.runLocation || '' %>" class="form-input"></label>
              <button type="submit" class="btn btn-primary" data-submit-label="Update and Resubmit">Update and Resubmit</button><p class="sub-form-status" aria-live="polite"></p>
            </form>
          </details>
        <% } %>
        <% if (correction.canUploadProof) { %><button type="button" class="btn btn-warning sub-upload-proof-action" data-open-run-proof-modal data-registration-id="<%= submission.registrationObjectId %>"><i data-lucide="upload" aria-hidden="true"></i>Upload new proof</button><% } %>
      </section>
    <% } %>

    <div class="sub-detail-layout sub-review-detail-layout">
      <div class="sub-detail-main">
        <section class="sub-result-summary" aria-labelledby="resultSummaryTitle">
          <header><span><i data-lucide="gauge" aria-hidden="true"></i></span><div><h2 id="resultSummaryTitle">Activity result</h2><p>The activity information attached to this review record.</p></div></header>
          <dl><% view.metrics.forEach((metric) => { %><div><dt><%= metric.label %></dt><dd><%= metric.value %></dd></div><% }) %></dl>
        </section>

        <details class="sub-record-disclosure">
          <summary><span><i data-lucide="file-text" aria-hidden="true"></i><strong>Submission record</strong><small>Event, registration, proof, and review details</small></span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
          <dl class="sub-record-grid">
            <div><dt>Event</dt><dd><% if (submission.eventSlug && !submission.isPersonalRecord) { %><a href="/events/<%= submission.eventSlug %>"><%= submission.eventTitle %></a><% } else { %><%= submission.eventTitle %><% } %></dd></div>
            <% if (submission.organiserName) { %><div><dt>Organizer</dt><dd><%= submission.organiserName %></dd></div><% } %>
            <% if (submission.eventReferenceCode) { %><div><dt>Event code</dt><dd><code><%= submission.eventReferenceCode %></code></dd></div><% } %>
            <% if (submission.confirmationCode) { %><div><dt>Confirmation</dt><dd><code><%= submission.confirmationCode %></code></dd></div><% } %>
            <div><dt>Participation</dt><dd><%= submission.participationMode || 'Not listed' %></dd></div><div><dt>Proof type</dt><dd><%= submission.proofType.toUpperCase() %></dd></div><div><dt>Submitted</dt><dd><%= submission.submittedAtLabel %></dd></div>
            <% if (submission.reviewedAtLabel !== '–') { %><div><dt>Reviewed</dt><dd><%= submission.reviewedAtLabel %></dd></div><% } %>
          </dl>
        </details>

        <% if (view.showProofReadingDetails) { %>
          <details class="sub-record-disclosure">
            <summary><span><i data-lucide="scan-text" aria-hidden="true"></i><strong>Proof reading details</strong><small>Visible extracted metrics that may explain a mismatch</small></span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
            <dl class="sub-record-grid"><% if (submission.ocrData.detectedSource) { %><div><dt>Detected app</dt><dd><%= submission.ocrData.detectedSource %></dd></div><% } %><% if (submission.ocrData.extractedDistanceKm != null) { %><div><dt>Distance read from proof</dt><dd><%= submission.ocrData.extractedDistanceKm %> km<% if (submission.ocrData.distanceMismatch) { %> · Does not match<% } %></dd></div><% } %><% if (submission.ocrData.extractedTimeMs != null) { %><div><dt>Duration read from proof</dt><dd><%= submission.ocrData.extractedTimeMsLabel %><% if (submission.ocrData.timeMismatch) { %> · Does not match<% } %></dd></div><% } %></dl>
          </details>
        <% } %>
      </div>

      <aside class="sub-detail-sidebar" aria-label="Submission actions">
        <% if (submission.hasCertificate) { %><section class="sub-side-card sub-certificate-card"><span class="sub-side-icon"><i data-lucide="badge-check" aria-hidden="true"></i></span><h2>Certificate ready</h2><% if (submission.certificateVerifiedDistanceKm !== null) { %><p>Completed the <strong><%= Number(submission.certificateGoalDistanceKm || 0).toFixed(2) %> km</strong> goal with <strong><%= Number(submission.certificateVerifiedDistanceKm).toFixed(2) %> km</strong> finally verified.</p><% } else { %><p>Your approved event recognition is ready to download and verify.</p><% } %><a href="/my-submissions/<%= submission.submissionId %>/certificate" target="_blank" rel="noopener noreferrer" class="btn btn-primary"><i data-lucide="download" aria-hidden="true"></i>Download certificate</a><% if (submission.certVerificationUrl) { %><a href="<%= submission.certVerificationUrl %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Verify certificate</a><div class="sub-share-controls" aria-label="Share certificate"><button type="button" class="btn btn-outline" data-copy-url="<%= submission.certVerificationUrl %>"><i data-lucide="copy" aria-hidden="true"></i><span>Copy verification link</span></button><p class="sub-copy-status" aria-live="polite"></p></div><% } %></section><% } %>
        <section class="sub-side-card"><h2>Supporting actions</h2><% if (submission.hasProof) { %><a href="/runner/submissions/<%= submission.submissionId %>/proof" target="_blank" rel="noopener noreferrer" class="btn btn-outline"><i data-lucide="image" aria-hidden="true"></i>View submitted proof</a><% } %><% if (view.showLeaderboard) { %><a href="/events/<%= submission.eventSlug %>/leaderboard" class="btn btn-outline"><i data-lucide="trophy" aria-hidden="true"></i>View standings</a><% } %><a href="/runner/submissions" class="btn btn-outline"><i data-lucide="arrow-left" aria-hidden="true"></i>All submissions</a></section>
      </aside>
    </div>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/runner-submissions.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
