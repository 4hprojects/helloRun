<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: 'Dashboard - helloRun' }) %>
  <link rel="stylesheet" href="/css/runner-dashboard.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="runner-dashboard-page">
    <div class="dashboard-container">
      <% const _csrfToken = typeof csrfToken !== 'undefined' ? csrfToken : ''; %>
      <% const selectedResultStatus = dashboardFilters?.resultStatus || ''; %>
      <% const preservedGroupQuery = String(runningGroupFeature?.query || '').trim(); %>
      <% const currentGroups = runningGroupFeature?.currentGroups || []; %>

      <section class="dashboard-hero">
        <div class="dashboard-header">
          <div class="header-content">
            <span class="dashboard-eyebrow">Runner Dashboard</span>
            <h1>Welcome back, <%= userName %>!</h1>
            <p class="header-subtitle">Track upcoming races, results, certificates, and community progress in one place.</p>
          </div>
          <div class="header-actions">
            <div class="header-buttons">
              <button
                type="button"
                class="btn btn-primary"
                data-open-run-proof-modal
                data-tooltip="Submit your latest run result"
                data-run-proof-surface="runner-dashboard"
                data-run-proof-title="Submit your latest run result"
                data-run-proof-description="Choose the eligible event you want to update, then upload your run proof for organizer review."
                data-run-proof-submit-label="Submit Run Proof"
                data-run-proof-empty-message="You do not have any paid, confirmed events that are currently accepting run submissions."
                data-run-proof-empty-link-href="/my-registrations"
                data-run-proof-empty-link-label="Review my registrations"
                aria-label="Submit your latest run result">
                <i data-lucide="upload" class="btn-icon"></i><span class="btn-label">Submit Run Proof</span>
              </button>
              <a
                href="/my-registrations"
                class="btn btn-outline-light"
                data-tooltip="View your registrations and payment status"
                aria-label="View your registrations and payment status">
                <i data-lucide="clipboard-list" class="btn-icon"></i><span class="btn-label">My Registrations</span>
              </a>
            </div>
            <div class="hero-highlights" aria-label="Quick dashboard highlights">
              <div class="hero-highlight" title="Completed Events">
                <i data-lucide="award" class="highlight-icon"></i>
                <span class="highlight-label">Completed Events</span>
                <strong><%= performanceStats?.completedEvents || 0 %></strong>
              </div>
              <div class="hero-highlight" title="Pending Review">
                <i data-lucide="clock" class="highlight-icon"></i>
                <span class="highlight-label">Pending Review</span>
                <strong><%= submissionStats?.submitted || 0 %></strong>
              </div>
              <div class="hero-highlight" title="Running Groups">
                <i data-lucide="users" class="highlight-icon"></i>
                <span class="highlight-label">Running Groups</span>
                <strong><%= currentGroups.length %></strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <% if (message) { %>
        <div class="alert alert-<%= message.type === 'error' ? 'danger' : message.type %>"
             role="<%= message.type === 'error' ? 'alert' : 'status' %>"
             aria-live="<%= message.type === 'error' ? 'assertive' : 'polite' %>">
          <%= message.text %>
        </div>
      <% } %>
      <% if (errors && Object.keys(errors).length) { %>
        <div class="alert alert-danger" role="alert" aria-live="assertive">
          <%= Object.values(errors).join(' ') %>
        </div>
      <% } %>

      <section class="kpi-section" aria-label="Runner dashboard summary">
        <div class="section-heading">
          <div>
            <span class="section-kicker">At a glance</span>
            <h2>Current running snapshot</h2>
          </div>
        </div>
        <div class="kpi-grid">
          <div class="kpi-card kpi-card-upcoming">
            <div class="kpi-icon"><i data-lucide="calendar"></i></div>
            <div class="kpi-content">
              <span class="kpi-label">Upcoming Events</span>
              <span class="kpi-value"><%= stats?.upcoming || 0 %></span>
            </div>
          </div>
          <div class="kpi-card kpi-card-results">
            <div class="kpi-icon"><i data-lucide="clock"></i></div>
            <div class="kpi-content">
              <span class="kpi-label">Pending Results</span>
              <span class="kpi-value"><%= submissionStats?.submitted || 0 %></span>
            </div>
          </div>
          <div class="kpi-card kpi-card-certificates">
            <div class="kpi-icon"><i data-lucide="award"></i></div>
            <div class="kpi-content">
              <span class="kpi-label">Certificates</span>
              <span class="kpi-value"><%= submissionStats?.certificates || 0 %></span>
            </div>
          </div>
          <div class="kpi-card kpi-card-distance">
            <div class="kpi-icon"><i data-lucide="map-pin"></i></div>
            <div class="kpi-content">
              <span class="kpi-label">Total Distance</span>
              <span class="kpi-value"><%= Number(performanceStats?.totalDistanceKm || 0).toFixed(2) %> km</span>
            </div>
          </div>
        </div>
      </section>

      <div class="dashboard-grid">
        <section class="card card-featured">
          <div class="card-header">
            <h2><i data-lucide="calendar"></i> Upcoming Events</h2>
          </div>
          <div class="card-content">
            <% if (cards.upcoming && cards.upcoming.length) { %>
              <ul class="item-list">
                <% cards.upcoming.forEach((item) => { %>
                  <li class="item-row">
                    <div class="item-main">
                      <div class="item-title">
                        <% if (item.slug) { %>
                          <a href="/events/<%= item.slug %>"><%= item.title %></a>
                        <% } else { %>
                          <%= item.title %>
                        <% } %>
                      </div>
                      <div class="item-meta">
                        <span><%= item.startAtLabel %></span> &middot; <span><%= item.distance %></span> &middot; <span class="badge badge-<%= item.mode %>"><%= item.mode %></span>
                      </div>
                      <div class="item-meta">Confirmation: <code><%= item.confirmationCode %></code></div>
                    </div>
                    <% if (item.isUnpaid) { %>
                      <a href="/my-registrations" class="btn btn-sm btn-warning">Pay</a>
                    <% } %>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <div class="empty-state">
                <p class="empty-message">No upcoming events.</p>
                <a href="/events" class="btn btn-primary btn-sm">Browse events</a>
              </div>
            <% } %>
          </div>
        </section>

        <section class="card profile-card">
          <div class="card-header profile-card-header">
            <h2><i data-lucide="user"></i> Account</h2>
            <a href="/runner/profile" class="btn btn-icon-only btn-outline" data-tooltip="View Profile" aria-label="View Profile">
              <i data-lucide="arrow-right"></i>
            </a>
          </div>
          <div class="card-content">
            <div class="profile-identity">
              <div class="profile-avatar">
                <i data-lucide="user"></i>
              </div>
              <div class="profile-info">
                <strong class="profile-name"><%= userName %></strong>
                <span class="profile-email"><%= user.email %></span>
              </div>
            </div>

            <div class="account-status-list">
              <div class="account-status-row">
                <span class="account-status-icon account-status-icon--<%= user.authProvider === 'google' ? 'google' : 'email' %>">
                  <i data-lucide="<%= user.authProvider === 'google' ? 'chrome' : 'mail' %>"></i>
                </span>
                <span class="account-status-label">Sign-in method</span>
                <span class="account-status-value"><%= user.authProvider === 'google' ? 'Google' : 'Email' %><% if (user.googleId && user.authProvider !== 'google') { %> &amp; Google linked<% } %></span>
              </div>
              <% if (user.passwordHash) { %>
              <div class="account-status-row">
                <span class="account-status-icon account-status-icon--ok">
                  <i data-lucide="lock"></i>
                </span>
                <span class="account-status-label">Password</span>
                <span class="account-status-value">Set</span>
              </div>
              <% } else { %>
              <div class="account-status-row">
                <span class="account-status-icon account-status-icon--warn">
                  <i data-lucide="lock-open"></i>
                </span>
                <span class="account-status-label">Password</span>
                <span class="account-status-value account-status-value--warn">Not set</span>
              </div>
              <% } %>
            </div>

          </div>
        </section>

        <%- include('partials/result-submissions-card', {
          selectedResultStatus,
          preservedGroupQuery,
          resultCards: cards.results
        }) %>

        <section class="card">
          <div class="card-header">
            <h2><i data-lucide="history"></i> Past Events</h2>
          </div>
          <div class="card-content">
            <% if (cards.past && cards.past.length) { %>
              <ul class="item-list">
                <% cards.past.forEach((item) => { %>
                  <li class="item-row">
                    <div class="item-main">
                      <div class="item-title">
                        <% if (item.slug) { %>
                          <a href="/events/<%= item.slug %>"><%= item.title %></a>
                        <% } else { %>
                          <%= item.title %>
                        <% } %>
                      </div>
                      <div class="item-meta">
                        <span><%= item.startAtLabel %></span> &middot; <span><%= item.distance %></span> &middot; <span class="badge badge-<%= item.mode %>"><%= item.mode %></span>
                      </div>
                      <div class="item-meta">Status: <span class="badge badge-<%= item.status %>"><%= item.status %></span></div>
                    </div>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <div class="empty-state">
                <p class="empty-message">No past events yet.</p>
              </div>
            <% } %>
          </div>
        </section>

        <section class="card collapsible">
          <div class="card-header">
            <h2><i data-lucide="activity"></i> Activity Log</h2>
            <button type="button" class="btn-toggle"
                    data-toggle-target="activityPanel"
                    data-toggle-show-label="Show"
                    data-toggle-hide-label="Hide"
                    aria-controls="activityPanel"
                    aria-expanded="false">
              Show
            </button>
          </div>
          <div class="card-content" id="activityPanel" hidden>
            <% if (cards.activity && cards.activity.length) { %>
              <ul class="item-list">
                <% cards.activity.forEach((item) => { %>
                  <li class="item-row">
                    <div class="item-main">
                      <% if (item.type === 'group_activity') { %>
                        <div><span class="badge badge-group activity-pill activity-group">Group</span> <strong><%= item.groupName %></strong></div>
                        <div class="item-meta"><%= item.message %></div>
                      <% } else if (item.type === 'result_submitted' || item.type === 'result_approved' || item.type === 'result_rejected' || item.type === 'certificate_issued') { %>
                        <div><span class="badge badge-result">Result</span> <strong><%= item.eventTitle %></strong></div>
                        <div class="item-meta"><%= item.message %></div>
                      <% } else { %>
                        <div><span class="badge badge-registration">Registration</span> <strong><%= item.eventTitle %></strong></div>
                        <div class="item-meta">Code: <code><%= item.confirmationCode %></code></div>
                      <% } %>
                      <div class="item-meta"><%= item.atLabel %> <% if (item.atRelativeLabel) { %><span class="text-muted">(<%= item.atRelativeLabel %>)</span><% } %></div>
                    </div>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <div class="empty-state">
                <p class="empty-message">No activity yet.</p>
              </div>
            <% } %>
          </div>
        </section>

        <section class="card collapsible">
          <div class="card-header">
            <h2><i data-lucide="award"></i> Certificates Earned</h2>
            <button type="button" class="btn-toggle"
                    data-toggle-target="certificatesPanel"
                    data-toggle-show-label="Show"
                    data-toggle-hide-label="Hide"
                    aria-controls="certificatesPanel"
                    aria-expanded="false">
              Show
            </button>
          </div>
          <div class="card-content" id="certificatesPanel" hidden>
            <div class="stats-mini">
              <div><strong>Total distance:</strong> <%= Number(performanceStats?.totalDistanceKm || 0).toFixed(2) %> km</div>
              <div><strong>Completed events:</strong> <%= performanceStats?.completedEvents || 0 %></div>
              <% if (personalBest) { %>
                <div><strong>Personal best:</strong> <%= personalBest.elapsedLabel %> (<%= personalBest.raceDistance %>) <span class="text-muted"><%= personalBest.eventTitle %></span></div>
              <% } %>
              <div><strong>Total certificates:</strong> <%= submissionStats?.certificates || 0 %></div>
            </div>
            <% if (cards.certificates && cards.certificates.length) { %>
              <ul class="item-list compact">
                <% cards.certificates.forEach((item) => { %>
                  <li class="item-row">
                    <div class="item-main">
                      <div><strong><%= item.eventTitle %></strong></div>
                      <div class="item-meta">Issued: <%= item.issuedAtLabel %></div>
                      <% if (item.confirmationCode) { %><div class="item-meta">Code: <code><%= item.confirmationCode %></code></div><% } %>
                    </div>
                    <a href="/my-submissions/<%= item.submissionId %>/certificate" class="btn btn-sm btn-outline">Download</a>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <div class="empty-state">
                <p class="empty-message">No certificates yet.</p>
              </div>
            <% } %>
          </div>
        </section>

        <section class="card collapsible">
          <div class="card-header">
            <h2><i data-lucide="bar-chart-3"></i> Progress Statistics</h2>
            <button type="button" class="btn-toggle"
                    data-toggle-target="progressPanel"
                    data-toggle-show-label="Show stats"
                    data-toggle-hide-label="Hide stats"
                    aria-controls="progressPanel"
                    aria-expanded="false">
              <span data-toggle-label>Show stats</span>
              <i data-lucide="chevron-down" class="toggle-chevron" aria-hidden="true"></i>
            </button>
          </div>
          <div class="card-content progress-panel" id="progressPanel" hidden>
            <ul class="stats-list">
              <li><span>Total registrations</span> <strong><%= stats.total %></strong></li>
              <li><span>Upcoming</span> <strong><%= stats.upcoming %></strong></li>
              <li><span>Past</span> <strong><%= stats.past %></strong></li>
              <li><span>Unpaid</span> <strong><%= stats.unpaid %></strong></li>
              <li><span>Paid</span> <strong><%= stats.paid %></strong></li>
              <li><span>Total results</span> <strong><%= submissionStats?.total || 0 %></strong></li>
              <li><span>Pending review</span> <strong><%= submissionStats?.submitted || 0 %></strong></li>
              <li><span>Approved</span> <strong><%= submissionStats?.approved || 0 %></strong></li>
              <li><span>Rejected</span> <strong><%= submissionStats?.rejected || 0 %></strong></li>
              <li><span>Certificates</span> <strong><%= submissionStats?.certificates || 0 %></strong></li>
            </ul>
            <div class="progress-panel-actions">
              <a href="/my-registrations" class="btn btn-primary btn-sm progress-panel-action">View all registrations</a>
            </div>
          </div>
        </section>

        <section class="card running-groups-card">
          <div class="card-header running-groups-header">
            <h2><i data-lucide="users"></i> Running Groups</h2>
            <a href="/runner/groups" class="btn btn-sm btn-outline running-groups-action">Manage Groups</a>
          </div>
          <div class="card-content running-groups-content">
            <% if (currentGroups.length) { %>
              <ul class="item-list compact running-groups-list">
                <% currentGroups.slice(0, 3).forEach((group) => { %>
                  <li class="item-row running-group-row">
                    <div class="item-main running-group-main">
                      <div class="item-title running-group-title"><a href="/runner/groups/<%= group.slug %>"><%= group.name %></a></div>
                      <div class="item-meta running-group-meta"><%= group.memberCount || 0 %> members</div>
                    </div>
                  </li>
                <% }) %>
              </ul>
              <p class="text-muted running-groups-summary">You are currently a member of <strong><%= currentGroups.length %></strong> running group<%= currentGroups.length > 1 ? 's' : '' %>.</p>
            <% } else { %>
              <div class="empty-state running-groups-empty">
                <p class="empty-message">You are not currently in a running group.</p>
              </div>
            <% } %>
            <p class="text-muted running-groups-help">Use the Manage Groups page to search groups, join a community, or create your own.</p>
          </div>
        </section>
      </div>
    </div>
  </main>

  <%- include('../layouts/footer') %>

  <div class="modal-backdrop" id="logoutModal" hidden>
    <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="logoutModalTitle" aria-describedby="logoutModalDesc" tabindex="-1">
      <h3 id="logoutModalTitle">Log out?</h3>
      <p id="logoutModalDesc">Are you sure you want to log out of your account?</p>
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" data-cancel-logout>Cancel</button>
        <button type="button" class="btn btn-danger" data-confirm-logout>Yes, log out</button>
      </div>
    </div>
  </div>



  <script src="/js/main.js"></script>
  <script src="/js/runner-dashboard.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>
