<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: 'Dashboard - HelloRun' }) %>
  <link rel="stylesheet" href="/css/runner-dashboard.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <main class="runner-dashboard-page">
    <div class="dashboard-container">
      <section class="dashboard-hero" aria-labelledby="runner-dashboard-title">
        <div class="dashboard-header">
          <div class="header-content">
            <% const dashboardIdentity = runnerDashboardPresentation.identity; %>
            <div class="dashboard-welcome-identity">
              <span class="dashboard-profile-avatar" aria-hidden="true">
                <span class="dashboard-profile-initials"><%= dashboardIdentity.initials %></span>
                <% if (dashboardIdentity.avatarUrl) { %><img src="<%= dashboardIdentity.avatarUrl %>" alt="" width="60" height="60" onerror="this.hidden=true;"><% } %>
              </span>
              <div class="dashboard-welcome-copy">
                <span class="dashboard-eyebrow">Runner Dashboard</span>
                <h1 id="runner-dashboard-title"><%= isFirstLogin ? 'Let’s get moving,' : 'Welcome back,' %> <a class="dashboard-profile-name" href="<%= dashboardIdentity.profileUrl %>" aria-label="View <%= dashboardIdentity.displayName %>’s profile"><%= dashboardIdentity.displayName %></a>!</h1>
              </div>
            </div>
            <p class="header-subtitle"><%= runnerDashboardPresentation.subtitle %></p>
          </div>
          <div class="header-actions">
            <div class="header-buttons">
              <% const heroJourney = runnerDashboardPresentation.primaryJourney; %>
              <% const heroAction = heroJourney?.nextAction; %>
              <% if (heroAction && (heroAction.type === 'submit' || heroAction.type === 'resubmit')) { %>
                <button type="button" class="btn btn-primary" data-open-run-proof-modal data-run-proof-surface="runner-dashboard-header" data-run-proof-mode="<%= heroAction.type %>" data-run-proof-registration-id="<%= heroJourney.registrationId || '' %>" aria-label="<%= heroAction.label %>" title="<%= heroAction.label %>">
                  <i data-lucide="upload" class="btn-icon" aria-hidden="true"></i><span class="btn-label"><%= heroAction.label %></span>
                </button>
              <% } else { %>
                <a href="<%= heroAction?.href || '/events' %>" class="btn btn-primary" aria-label="<%= heroAction?.label || 'Browse Events' %>" title="<%= heroAction?.label || 'Browse Events' %>"><i data-lucide="arrow-right" class="btn-icon" aria-hidden="true"></i><span class="btn-label"><%= heroAction?.label || 'Browse Events' %></span></a>
              <% } %>
              <a href="/my-registrations" class="btn btn-outline-light" aria-label="My Registrations" title="My Registrations"><i data-lucide="clipboard-list" class="btn-icon" aria-hidden="true"></i><span class="btn-label">My Registrations</span></a>
            </div>
          </div>
        </div>
      </section>

      <% if (message) { %><div class="alert alert-<%= message.type === 'error' ? 'danger' : message.type %>" role="<%= message.type === 'error' ? 'alert' : 'status' %>" aria-live="<%= message.type === 'error' ? 'assertive' : 'polite' %>"><%= message.text %></div><% } %>
      <% if (errors && Object.keys(errors).length) { %><div class="alert alert-danger" role="alert" aria-live="assertive"><%= Object.values(errors).join(' ') %></div><% } %>
      <% if (runnerDashboardPresentation.accountAlert) { %><aside class="dashboard-account-alert alert alert-warning" role="alert"><span><i data-lucide="shield-alert" aria-hidden="true"></i><%= runnerDashboardPresentation.accountAlert.text %></span><a href="<%= runnerDashboardPresentation.accountAlert.href %>"><%= runnerDashboardPresentation.accountAlert.label %></a></aside><% } %>

      <%- include('partials/dashboard-active-journey') %>
      <%- include('partials/dashboard-summary') %>

      <section class="dashboard-support-grid" aria-label="Recent runner updates">
        <%- include('partials/dashboard-recent-activity') %>
        <%- include('partials/dashboard-latest-achievement') %>
      </section>

      <section class="runner-dashboard-zone dashboard-tools" aria-labelledby="runner-tools-title">
        <div class="runner-dashboard-zone-heading"><div><span class="section-kicker">Your account</span><h2 id="runner-tools-title">Runner tools</h2></div></div>
        <nav class="dashboard-secondary-links" aria-label="Runner tools">
          <a href="/runner/submissions"><i data-lucide="file-check" aria-hidden="true"></i><span><strong>Submission History</strong><small><%= runnerDashboardPresentation.toolCounts.submissions %> recorded</small></span></a>
          <a href="/runner/profile#badges"><i data-lucide="award" aria-hidden="true"></i><span><strong>Achievements</strong><small><%= runnerDashboardPresentation.toolCounts.achievements %> earned</small></span></a>
          <a href="/runner/groups"><i data-lucide="users" aria-hidden="true"></i><span><strong>Running Groups</strong><small><%= runnerDashboardPresentation.toolCounts.groups %> joined</small></span></a>
          <a href="/events"><i data-lucide="heart" aria-hidden="true"></i><span><strong>Saved &amp; New Events</strong><small><%= runnerDashboardPresentation.toolCounts.savedEvents %> saved</small></span></a>
          <a href="/my-registrations"><i data-lucide="archive" aria-hidden="true"></i><span><strong>Registration History</strong><small><%= runnerDashboardPresentation.toolCounts.history %> historical</small></span></a>
        </nav>
      </section>
    </div>
  </main>
  <%- include('../layouts/footer') %>
  <div class="modal-backdrop" id="logoutModal" hidden><div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="logoutModalTitle" aria-describedby="logoutModalDesc" tabindex="-1"><h3 id="logoutModalTitle">Log out?</h3><p id="logoutModalDesc">Are you sure you want to log out of your account?</p><div class="modal-actions"><button type="button" class="btn btn-outline" data-cancel-logout>Cancel</button><button type="button" class="btn btn-danger" data-confirm-logout>Yes, log out</button></div></div></div>
  <script src="/js/main.js"></script><script src="/js/event-save.js"></script><script src="/js/runner-dashboard.js"></script><script>lucide.createIcons();</script>
</body>
</html>
