<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'Create Running Group - HelloRun' }) %>
  <link rel="stylesheet" href="/css/runner-dashboard.css">
  <link rel="stylesheet" href="/css/runner-groups.css">
</head>
<body class="runner-groups-shell">
  <%- include('../layouts/nav') %>
  <% const _csrfToken = typeof csrfToken !== 'undefined' ? csrfToken : ''; %>

  <main class="dashboard-container runner-groups-page runner-group-create-page">
    <div class="dashboard-header runner-groups-header">
      <div class="header-content">
        <h1>Create Running Group</h1>
        <p class="header-subtitle">Set up your group on a dedicated page.</p>
      </div>
      <a href="/runner/groups" class="btn btn-outline">Back to Groups</a>
    </div>

    <% if (message) { %>
      <div
        class="page-message page-message-<%= message.type %>"
        role="<%= message.type === 'error' ? 'alert' : 'status' %>"
        aria-live="<%= message.type === 'error' ? 'assertive' : 'polite' %>"
      ><%= message.text %></div>
    <% } %>

    <% if (currentGroups && currentGroups.length) { %>
      <section class="dashboard-card profile-card runner-group-current-card">
        <div class="card-header">
          <h2><i data-lucide="users"></i> Your Groups</h2>
        </div>
        <div class="card-content card-content-list">
          <p>You currently belong to <strong><%= currentGroups.length %> running group<%= currentGroups.length === 1 ? '' : 's' %></strong>.</p>
          <p class="text-muted">Creating a group adds another membership to your profile and joins you as its first member.</p>
          <a href="/runner/groups" class="runner-group-membership-link">Review your groups</a>
        </div>
      </section>
    <% } %>

    <section class="dashboard-card profile-card">
      <div class="card-header">
        <h2><i data-lucide="plus-circle"></i> New Group Details</h2>
      </div>
      <div class="card-content card-content-list">
        <form method="POST" action="/runner/groups/create" class="group-create runner-group-create-form">
          <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
          <input type="hidden" name="returnTo" value="/runner/groups/create">
          <label for="groupName">Group name</label>
          <input id="groupName" type="text" name="name" maxlength="120" required placeholder="e.g. Manila Sunrise Runners">
          <label for="groupDescription">Description (optional)</label>
          <textarea id="groupDescription" name="description" maxlength="400" rows="4" placeholder="Who your group is for, training style, and goals."></textarea>
          <div class="runner-group-create-actions">
            <a href="/runner/groups" class="btn btn-outline">Cancel</a>
            <button type="submit" class="btn btn-primary">Create Group</button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    if (window.lucide) lucide.createIcons();
  </script>
</body>
</html>
