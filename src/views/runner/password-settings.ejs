<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: 'Password Settings - helloRun' }) %>
  <link rel="stylesheet" href="/css/runner-dashboard.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <% const _csrfToken = typeof csrfToken !== 'undefined' ? csrfToken : ''; %>

  <main
    class="dashboard-container"
    data-password-update-success="<%= message?.type === 'success' ? 'true' : 'false' %>"
    data-password-update-message="<%= message?.type === 'success' ? message.text : '' %>"
    data-password-update-redirect="/runner/dashboard"
  >
    <div class="dashboard-header password-settings-header">
      <div class="header-content">
        <h1>Password Settings</h1>
        <p class="header-subtitle">Manage your local sign-in password.</p>
      </div>
      <a
        href="/runner/dashboard"
        class="btn btn-outline btn-icon-only password-settings-header-action"
        data-tooltip="Back to Dashboard"
        aria-label="Back to Dashboard"
      >
        <i data-lucide="arrow-left"></i>
      </a>
    </div>

    <% if (message && message.type !== 'success') { %>
      <div
        class="page-message page-message-<%= message.type %>"
        role="<%= message.type === 'error' ? 'alert' : 'status' %>"
        aria-live="<%= message.type === 'error' ? 'assertive' : 'polite' %>"
      ><%= message.text %></div>
    <% } %>

    <% if (errors && Object.keys(errors).length) { %>
      <div class="page-message page-message-error" role="alert" aria-live="assertive">
        <%= Object.values(errors).join(' ') %>
      </div>
    <% } %>

    <section class="dashboard-card profile-card">
      <div class="card-header">
        <h2>
          <i data-lucide="lock"></i>
          <%= hasLocalPassword ? 'Change Password' : 'Set Password' %>
        </h2>
      </div>
      <div class="card-content card-content-list">
        <form method="POST" action="/runner/security/password" class="password-settings-form">
          <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
          <% if (hasLocalPassword) { %>
            <div class="form-field">
              <span>Current Password</span>
              <input type="password" name="currentPassword" autocomplete="current-password" required>
            </div>
          <% } %>

          <div class="form-field">
            <span>New Password</span>
            <input
              type="password"
              name="newPassword"
              id="newPassword"
              autocomplete="new-password"
              aria-describedby="passwordHint passwordStrengthText passwordRequirementList"
              required
            >
            <div class="password-strength" data-password-strength>
              <div class="password-strength-bars" aria-hidden="true">
                <span class="password-strength-bar"></span>
                <span class="password-strength-bar"></span>
                <span class="password-strength-bar"></span>
              </div>
              <p class="password-strength-text" id="passwordStrengthText" aria-live="polite">Enter a new password.</p>
              <ul class="password-requirement-list" id="passwordRequirementList">
                <li data-password-rule="length">At least 8 characters</li>
                <li data-password-rule="uppercase">One uppercase letter</li>
                <li data-password-rule="lowercase">One lowercase letter</li>
                <li data-password-rule="number">One number</li>
              </ul>
            </div>
            <small id="passwordHint">At least 8 characters with uppercase, lowercase, and number.</small>
          </div>

          <div class="form-field">
            <span>Confirm New Password</span>
            <input
              type="password"
              name="confirmPassword"
              id="confirmPassword"
              autocomplete="new-password"
              aria-describedby="confirmPasswordStatus"
              required
            >
            <p class="confirm-password-status" id="confirmPasswordStatus" aria-live="polite"></p>
          </div>

          <div class="password-settings-actions">
            <a href="/runner/dashboard" class="btn btn-outline password-settings-back">Back to Dashboard</a>
            <button type="submit" class="btn btn-primary password-settings-submit">Save Password</button>
          </div>
        </form>
      </div>
    </section>

    <div class="modal-backdrop" id="passwordConfirmModal" hidden>
      <div
        class="modal-dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="passwordConfirmModalTitle"
        aria-describedby="passwordConfirmModalDesc"
        tabindex="-1"
      >
        <h3 id="passwordConfirmModalTitle">Confirm password change</h3>
        <p id="passwordConfirmModalDesc">Your account password will be updated. Continue with this change?</p>
        <div class="modal-actions">
          <button type="button" class="btn btn-outline" data-cancel-password-change>Cancel</button>
          <button type="button" class="btn btn-primary" data-confirm-password-change>Yes, update password</button>
        </div>
      </div>
    </div>

    <div class="modal-backdrop" id="passwordSuccessModal" hidden>
      <div
        class="modal-dialog password-success-dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="passwordSuccessModalTitle"
        aria-describedby="passwordSuccessModalDesc passwordSuccessModalCountdown"
        tabindex="-1"
      >
        <h3 id="passwordSuccessModalTitle">Password updated</h3>
        <p id="passwordSuccessModalDesc"><%= message?.type === 'success' ? message.text : 'Your password has been updated successfully.' %></p>
        <p class="password-success-countdown" id="passwordSuccessModalCountdown">
          Returning to your dashboard in <strong data-password-success-countdown>5</strong> seconds.
        </p>
        <div class="modal-actions">
          <a href="/runner/dashboard" class="btn btn-primary" data-password-success-redirect>Go to Dashboard Now</a>
        </div>
      </div>
    </div>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/password-settings.js"></script>
  <script>
    lucide.createIcons();
  </script>
</body>
</html>
