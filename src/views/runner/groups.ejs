<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'Running Groups - HelloRun' }) %>
  <link rel="stylesheet" href="/css/runner-dashboard.css">
  <link rel="stylesheet" href="/css/runner-groups.css">
</head>
<body class="runner-groups-shell">
  <%- include('../layouts/nav') %>
  <% const _csrfToken = typeof csrfToken !== 'undefined' ? csrfToken : ''; %>

  <main class="dashboard-container runner-groups-page">
    <header class="dashboard-header runner-groups-header">
      <div class="header-content">
        <span class="runner-groups-kicker">Runner community</span>
        <h1>Running Groups</h1>
        <p class="header-subtitle"><%= groupsPresentation.joinedCount %> joined · Find a group or create your own.</p>
      </div>
      <div class="runner-groups-header-actions">
        <a href="/runner/dashboard" class="btn btn-outline"><span class="runner-groups-label-desktop">Back to Dashboard</span><span class="runner-groups-label-mobile">Dashboard</span></a>
        <a href="/runner/groups/create" class="btn btn-primary"><i data-lucide="plus" aria-hidden="true"></i>Create Group</a>
      </div>
    </header>

    <% if (message) { %>
      <div class="page-message page-message-<%= message.type %>" role="<%= message.type === 'error' ? 'alert' : 'status' %>" aria-live="<%= message.type === 'error' ? 'assertive' : 'polite' %>"><%= message.text %></div>
    <% } %>

    <section class="runner-groups-section" aria-labelledby="your-groups-title">
      <div class="runner-groups-section-heading">
        <div>
          <h2 id="your-groups-title">Your groups</h2>
          <p>Groups currently connected to your runner profile.</p>
        </div>
        <span class="runner-groups-count"><%= groupsPresentation.joinedCount %> joined</span>
      </div>

      <% if (groupsPresentation.currentGroups.length) { %>
        <div class="runner-groups-grid runner-groups-current-grid">
          <% groupsPresentation.currentGroups.forEach((group) => { %>
            <article class="runner-group-card is-member">
              <div class="runner-group-card-heading">
                <span class="runner-group-icon"><i data-lucide="users" aria-hidden="true"></i></span>
                <span class="runner-group-state"><i data-lucide="check" aria-hidden="true"></i>Joined</span>
              </div>
              <div class="runner-group-card-copy">
                <h3><a href="/runner/groups/<%= group.slug %>"><%= group.name %></a></h3>
                <p class="runner-group-members"><%= group.memberCount %> member<%= group.memberCount === 1 ? '' : 's' %></p>
                <p class="runner-group-description"><%= group.description || 'No group description yet.' %></p>
              </div>
              <div class="runner-group-card-actions is-single-action"><a href="/runner/groups/<%= group.slug %>" class="btn btn-outline">View Group</a></div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="runner-groups-empty">
          <i data-lucide="users" aria-hidden="true"></i>
          <div><strong>You have not joined a group yet.</strong><p>Browse popular groups below or create a community for runners you know.</p></div>
        </div>
      <% } %>
    </section>

    <section class="runner-groups-section" aria-labelledby="discover-groups-title">
      <div class="runner-groups-section-heading runner-groups-discovery-heading">
        <div>
          <h2 id="discover-groups-title">Discover groups</h2>
          <p>Search by group name or browse active communities.</p>
        </div>
      </div>

      <form method="GET" action="/runner/groups" class="runner-groups-search" role="search">
        <label class="sr-only" for="runnerGroupSearch">Search running groups</label>
        <input id="runnerGroupSearch" type="search" name="q" value="<%= groupsPresentation.query %>" maxlength="80" placeholder="Search group names…">
        <button type="submit" class="btn btn-primary" aria-label="Search running groups"><i data-lucide="search" aria-hidden="true"></i><span>Search</span></button>
        <% if (groupsPresentation.query) { %><a href="/runner/groups" class="btn btn-outline">Clear</a><% } %>
      </form>

      <div class="runner-groups-results-heading">
        <h3><%= groupsPresentation.discovery.title %></h3>
        <% if (groupsPresentation.discovery.isSearch) { %>
          <span><%= groupsPresentation.discovery.resultCount %> result<%= groupsPresentation.discovery.resultCount === 1 ? '' : 's' %></span>
        <% } %>
      </div>

      <% if (groupsPresentation.discovery.groups.length) { %>
        <div class="runner-groups-grid">
          <% groupsPresentation.discovery.groups.forEach((group) => { %>
            <article class="runner-group-card<%= group.isMember ? ' is-member' : '' %>">
              <div class="runner-group-card-heading">
                <span class="runner-group-icon"><i data-lucide="users" aria-hidden="true"></i></span>
                <% if (group.isMember) { %><span class="runner-group-state"><i data-lucide="check" aria-hidden="true"></i>Joined</span><% } %>
              </div>
              <div class="runner-group-card-copy">
                <h3><a href="/runner/groups/<%= group.slug %>"><%= group.name %></a></h3>
                <p class="runner-group-members"><%= group.memberCount %> member<%= group.memberCount === 1 ? '' : 's' %></p>
                <p class="runner-group-description"><%= group.description || 'No group description yet.' %></p>
              </div>
              <div class="runner-group-card-actions<%= group.isMember ? ' has-joined-state' : '' %>">
                <a href="/runner/groups/<%= group.slug %>" class="btn btn-outline">View</a>
                <% if (group.isMember) { %>
                  <span class="runner-group-joined-action" aria-label="Already joined">Joined</span>
                <% } else { %>
                  <form method="POST" action="/runner/groups/join" data-group-action-form data-group-action="join" data-group-name="<%= group.name %>">
                    <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
                    <input type="hidden" name="groupId" value="<%= group.id %>">
                    <input type="hidden" name="returnTo" value="/runner/groups">
                    <button type="submit" class="btn btn-primary"><%= group.actionLabel %></button>
                  </form>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="runner-groups-empty">
          <i data-lucide="search-x" aria-hidden="true"></i>
          <div>
            <strong><%= groupsPresentation.discovery.isSearch ? 'No groups match this search.' : 'No running groups are available yet.' %></strong>
            <p><%= groupsPresentation.discovery.isSearch ? 'Try another group name or clear the search.' : 'Create the first group and invite your running community.' %></p>
          </div>
          <a href="<%= groupsPresentation.discovery.isSearch ? '/runner/groups' : '/runner/groups/create' %>" class="btn btn-outline"><%= groupsPresentation.discovery.isSearch ? 'Clear search' : 'Create group' %></a>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('partials/group-membership-confirmation') %>
  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/runner-groups.js"></script>
</body>
</html>
