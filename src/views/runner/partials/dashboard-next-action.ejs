<section class="runner-next-action" aria-labelledby="next-action-title" data-dashboard-fragment="nextAction">
  <div class="runner-dashboard-zone-heading"><div><span class="section-kicker">Most important</span><h2 id="next-action-title">Your Next Action</h2></div></div>
  <% const item = runnerJourney.nextActionCard; %>
  <% const nextActionProgressPercent = Math.max(0, Math.min(100, Number(item?.progress?.percent || 0))); %>
  <% const nextActionProgressPercentLabel = Math.round(nextActionProgressPercent); %>
  <% if (item) { %>
    <div class="card runner-next-action-card runner-next-action-card--<%= item.stateTone %>">
      <div class="runner-next-action-heading"><div><div class="runner-next-action-status-row"><span class="badge badge-<%= item.stateTone %>"><%= item.stateLabel %></span><span class="deadline-chip deadline-chip--<%= item.deadlineTone %>"><i data-lucide="clock" aria-hidden="true"></i><%= item.deadlineLabel %></span></div><div class="runner-next-action-event"><span class="runner-next-action-event-icon"><img src="<%= item.eventImageUrl || '/images/helloRun-icon.webp' %>" alt="<%= item.eventTitle %> logo" loading="lazy"></span><div><h3 class="dashboard-event-progress-title"><% if (item.eventSlug) { %><a href="/events/<%= item.eventSlug %>"><%= item.eventTitle %></a><% } else { %><%= item.eventTitle %><% } %></h3><p class="item-meta"><%= item.raceDistance || 'Distance TBA' %> · <%= item.eventType %> · <%= item.participationMode || 'Mode TBA' %></p></div></div></div></div>
      <% if (item.progress) { %><div class="next-action-progress"><div class="next-action-progress-label"><strong><%= Number(item.progress.approvedDistanceKm || 0).toFixed(2) %> km approved</strong><span><%= Number(item.progress.targetDistanceKm || 0).toFixed(2) %> km target</span></div><div class="dashboard-event-progress-track" role="progressbar" aria-label="Official approved progress for <%= item.eventTitle %>: <%= nextActionProgressPercentLabel %>% complete" aria-valuemin="0" aria-valuemax="100" aria-valuenow="<%= nextActionProgressPercentLabel %>"><span style="width:<%= nextActionProgressPercent %>%"></span><strong class="dashboard-event-progress-percent" aria-hidden="true"><%= nextActionProgressPercentLabel %>%</strong></div><dl class="next-action-progress-list"><div><dt>Awaiting review</dt><dd><%= Number(item.progress.pendingDistanceKm || 0).toFixed(2) %> km</dd></div><div><dt>Remaining</dt><dd><%= Number(item.progress.remainingDistanceKm || 0).toFixed(2) %> km</dd></div><% if (item.progress.suggestedDailyDistanceKm) { %><div><dt>Suggested per day</dt><dd><%= Number(item.progress.suggestedDailyDistanceKm).toFixed(2) %> km/day</dd></div><% } %></dl></div><% } %>
      <% if (item.payment?.required) { %><div class="next-action-payment"><span><small>Amount due</small><strong><%= item.payment.currency %> <%= Number(item.payment.amount || 0).toFixed(2) %></strong></span><% if (item.payment.packageName) { %><span><small>Package</small><strong><%= item.payment.packageName %></strong></span><% } %><% if (item.payment.categoryName) { %><span><small>Category</small><strong><%= item.payment.categoryName %></strong></span><% } %></div><% } %>
      <p class="runner-next-action-help"><%= item.helperText %></p>
      <div class="runner-next-action-footer"><div class="next-action-dates"><span>Starts <%= item.eventStartAtLabel %></span><span>Ends <%= item.eventEndAtLabel %></span><span>Submit by <%= item.submissionDeadlineLabel %></span></div><% if (item.nextAction) { %><% if (item.nextAction.type === 'submit' || item.nextAction.type === 'resubmit') { %><button type="button" class="btn btn-primary" data-open-run-proof-modal data-run-proof-mode="<%= item.nextAction.type %>" data-run-proof-registration-id="<%= item.registrationId %>"><%= item.nextAction.label %></button><% } else { %><a href="<%= item.nextAction.href %>"<% if (item.nextAction.type === 'download_certificate') { %> target="_blank" rel="noopener noreferrer"<% } %> class="btn btn-primary"><%= item.nextAction.label %></a><% } %><% } %></div>
    </div>
  <% } else { %>
    <div class="card runner-next-action-card runner-next-action-empty"><div><h3>Find your next challenge</h3><p>You have not joined an event yet. Choose a distance, register, and start tracking your progress.</p></div><a href="/events" class="btn btn-primary">Browse Active Events</a></div>
  <% } %>
</section>
