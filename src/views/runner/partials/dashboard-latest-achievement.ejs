<section class="runner-dashboard-zone dashboard-achievement" aria-labelledby="latest-achievement-title" data-dashboard-fragment="latestAchievement">
  <div class="runner-dashboard-zone-heading"><div><span class="section-kicker">Latest reward</span><h2 id="latest-achievement-title">Latest Achievement</h2></div><a href="/runner/profile#badges" class="btn btn-sm btn-outline">View All Achievements</a></div>
  <% if (latestAchievement) { %><div class="card latest-achievement-card"><div class="latest-achievement-icon"><% if (latestAchievement.imageUrl) { %><img src="<%= latestAchievement.imageUrl %>" alt="<%= latestAchievement.title %> badge"><% } else { %><i data-lucide="<%= latestAchievement.type === 'certificate' ? 'badge-check' : latestAchievement.type === 'badge' ? 'medal' : 'target' %>" aria-hidden="true"></i><% } %></div><div class="latest-achievement-main"><span class="badge badge-approved"><%= latestAchievement.label %></span><h3><%= latestAchievement.title %></h3><p><%= latestAchievement.description %></p></div><div class="latest-achievement-actions"><a href="<%= latestAchievement.href %>"<% if (latestAchievement.type === 'certificate') { %> target="_blank" rel="noopener noreferrer"<% } %> class="btn btn-primary btn-sm latest-achievement-action" aria-label="<%= latestAchievement.type === 'certificate' ? 'View Certificate' : 'View Achievement' %>" title="<%= latestAchievement.type === 'certificate' ? 'View Certificate' : 'View Achievement' %>"><i data-lucide="<%= latestAchievement.type === 'certificate' ? 'file-down' : 'eye' %>" aria-hidden="true"></i><span><%= latestAchievement.type === 'certificate' ? 'View Certificate' : 'View Achievement' %></span></a><% if (latestAchievement.type === 'certificate' && latestAchievement.verifyUrl) { %><a href="<%= latestAchievement.verifyUrl %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm latest-achievement-action" aria-label="Verify Certificate" title="Verify Certificate"><i data-lucide="shield-check" aria-hidden="true"></i><span>Verify</span></a><button type="button" class="btn btn-outline btn-sm latest-achievement-action" aria-label="Copy Certificate Link" title="Copy Certificate Link" data-copy-cert-url="<%= latestAchievement.verifyUrl %>"><i data-lucide="copy" aria-hidden="true"></i><span>Copy Link</span></button><button type="button" class="btn btn-outline btn-sm latest-achievement-action" aria-label="Share Certificate" title="Share Certificate" data-share-cert-url="<%= latestAchievement.verifyUrl %>" data-share-cert-title="<%= latestAchievement.title %>"><i data-lucide="share-2" aria-hidden="true"></i><span>Share</span></button><% } %></div></div><% } else { %><div class="card"><div class="card-content empty-state"><p class="empty-message">Complete an event or reach a milestone to see your latest achievement here.</p><a href="/events" class="btn btn-primary btn-sm">Find an Event</a></div></div><% } %>
</section>
