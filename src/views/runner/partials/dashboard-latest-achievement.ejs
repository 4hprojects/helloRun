<section class="runner-dashboard-zone dashboard-achievement" aria-labelledby="latest-achievement-title" data-dashboard-fragment="latestAchievement">
  <div class="runner-dashboard-zone-heading">
    <div><span class="section-kicker">Latest reward</span><h2 id="latest-achievement-title">Latest Achievement</h2></div>
    <a href="/runner/profile#badges" class="btn btn-sm btn-outline">View All Achievements</a>
  </div>
  <% if (latestAchievement) { %>
    <article class="card latest-achievement-card">
      <div class="latest-achievement-icon">
        <i data-lucide="<%= latestAchievement.type === 'certificate' ? 'badge-check' : latestAchievement.type === 'badge' ? 'medal' : 'target' %>" aria-hidden="true"></i>
        <% if (latestAchievement.imageUrl) { %><img src="<%= latestAchievement.imageUrl %>" alt="<%= latestAchievement.title %> badge" loading="lazy" onerror="this.hidden=true;"><% } %>
      </div>
      <div class="latest-achievement-main">
        <span class="badge badge-approved"><%= latestAchievement.label %></span>
        <h3><%= latestAchievement.title %></h3>
        <p><%= latestAchievement.description %></p>
      </div>
      <div class="latest-achievement-actions<%= latestAchievement.type === 'certificate' && latestAchievement.verifyUrl ? ' latest-achievement-actions--certificate' : '' %>">
        <a href="<%= latestAchievement.href %>"<% if (latestAchievement.type === 'certificate') { %> target="_blank" rel="noopener noreferrer"<% } %> class="btn btn-primary btn-sm latest-achievement-action latest-achievement-action--primary" aria-label="<%= latestAchievement.type === 'certificate' ? 'View Certificate' : 'View Achievement' %>" title="<%= latestAchievement.type === 'certificate' ? 'View Certificate' : 'View Achievement' %>"><i data-lucide="<%= latestAchievement.type === 'certificate' ? 'file-down' : 'eye' %>" aria-hidden="true"></i><span><%= latestAchievement.type === 'certificate' ? 'View Certificate' : 'View Achievement' %></span></a>
        <% if (latestAchievement.type === 'certificate' && latestAchievement.verifyUrl) { %>
          <a href="<%= latestAchievement.verifyUrl %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm latest-achievement-action latest-achievement-action--secondary" aria-label="Verify Certificate" title="Verify Certificate"><i data-lucide="shield-check" aria-hidden="true"></i><span>Verify</span></a>
          <div class="latest-achievement-share" data-certificate-share>
            <button type="button" class="btn btn-outline btn-sm latest-achievement-action latest-achievement-action--secondary" aria-label="Share Certificate" title="Share Certificate" aria-haspopup="menu" aria-expanded="false" aria-controls="latest-achievement-share-menu" data-certificate-share-toggle><i data-lucide="share-2" aria-hidden="true"></i><span>Share</span></button>
            <div id="latest-achievement-share-menu" class="latest-achievement-share-menu" role="menu" aria-label="Share certificate" data-certificate-share-menu hidden>
              <a href="<%= latestAchievement.shareUrls?.facebook %>" target="_blank" rel="noopener noreferrer" role="menuitem" data-certificate-social-link><i data-lucide="facebook" aria-hidden="true"></i><span>Facebook</span></a>
              <a href="<%= latestAchievement.shareUrls?.x %>" target="_blank" rel="noopener noreferrer" role="menuitem" data-certificate-social-link><i data-lucide="twitter" aria-hidden="true"></i><span>X</span></a>
              <a href="<%= latestAchievement.shareUrls?.linkedin %>" target="_blank" rel="noopener noreferrer" role="menuitem" data-certificate-social-link><i data-lucide="linkedin" aria-hidden="true"></i><span>LinkedIn</span></a>
              <button type="button" role="menuitem" data-native-cert-share-url="<%= latestAchievement.verifyUrl %>" data-share-cert-title="<%= latestAchievement.title %>" data-share-cert-text="<%= latestAchievement.shareUrls?.text %>"><i data-lucide="send" aria-hidden="true"></i><span>More</span></button>
              <button type="button" role="menuitem" data-copy-cert-url="<%= latestAchievement.verifyUrl %>"><i data-lucide="copy" aria-hidden="true"></i><span>Copy Link</span></button>
            </div>
          </div>
        <% } %>
      </div>
    </article>
  <% } else { %>
    <div class="card latest-achievement-empty"><span class="latest-achievement-empty-icon"><i data-lucide="award" aria-hidden="true"></i></span><div><h3>Your next achievement starts here</h3><p>Complete an event or reach a milestone to add recognition to your runner profile.</p></div><a href="/events" class="btn btn-primary btn-sm">Find an Event</a></div>
  <% } %>
</section>
