<div class="runner-groups-modal" data-group-confirm-modal hidden aria-hidden="true">
  <div class="runner-groups-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="groupConfirmTitle" aria-describedby="groupConfirmDescription" tabindex="-1">
    <span class="runner-groups-modal-icon"><i data-lucide="users" aria-hidden="true"></i></span>
    <h2 id="groupConfirmTitle" data-group-confirm-title>Confirm leaving group</h2>
    <p id="groupConfirmDescription" data-group-confirm-description></p>
    <div class="runner-groups-modal-actions">
      <button type="button" class="btn btn-outline" data-cancel-group-action>Cancel</button>
      <button type="button" class="btn btn-primary" data-confirm-group-action>Confirm</button>
    </div>
  </div>
</div>
