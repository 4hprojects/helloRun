<section class="card card-featured" data-dashboard-fragment="upcoming">
  <div class="card-header"><h3><i data-lucide="calendar" aria-hidden="true"></i> Upcoming Event</h3></div>
  <div class="card-content"><% const item = cards.upcoming?.[0]; %><% if (item) { %><div class="dashboard-upcoming-event"><span class="badge badge-<%= item.mode %>"><%= item.mode %></span><h4><% if (item.slug) { %><a href="/events/<%= item.slug %>"><%= item.title %></a><% } else { %><%= item.title %><% } %></h4><dl><div><dt>Distance</dt><dd><%= item.distance %></dd></div><div><dt>Starts</dt><dd><%= item.startAtLabel %></dd></div><div><dt>Payment</dt><dd><%= item.paymentStatus === 'paid' ? 'Paid' : item.paymentStatus === 'proof_submitted' ? 'Under review' : 'Payment needed' %></dd></div></dl><a href="<%= item.slug ? '/events/' + item.slug : '/my-registrations' %>" class="btn btn-outline btn-sm">View Event</a></div><% } else { %><div class="empty-state"><p class="empty-message">No upcoming registered event. Join an event to keep its start date and payment status close at hand.</p><a href="/events" class="btn btn-primary btn-sm">Browse Events</a></div><% } %></div>
</section>
