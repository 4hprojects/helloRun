<section class="card runner-event-progress-card" data-dashboard-fragment="eventProgress">
  <div class="card-header runner-event-progress-header"><h2><i data-lucide="flag"></i> Event Progress</h2><a href="/my-registrations" class="btn btn-sm btn-outline runner-event-progress-action">View registrations</a></div>
  <div class="card-content runner-event-progress-content">
    <% const eventProgressCards = cards.eventProgress || []; %>
    <% if (eventProgressCards.length) { %>
      <ul class="dashboard-event-progress-list" aria-label="Registered event progress and run proof status">
        <% eventProgressCards.forEach((item) => { %>
          <%- include('event-progress-row', { item }) %>
        <% }) %>
      </ul>
    <% } else { %><div class="empty-state"><p class="empty-message">No registered event progress yet.</p><a href="/events" class="btn btn-primary btn-sm">Browse events</a></div><% } %>
  </div>
</section>
