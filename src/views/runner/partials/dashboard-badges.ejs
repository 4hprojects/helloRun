<%
  const BADGE_ICONS_DB = {
    participant: 'user-check', finisher: 'trophy',
    distance_finisher: 'medal', mode_finisher: 'zap',
    challenge_progress: 'trending-up', challenge_finisher: 'award',
    category_winner: 'crown', top_rank: 'star',
    distance_winner: 'flag', mode_winner: 'shield-check'
  };
  const getBadgeIconDB = (type, isFeatured) => isFeatured ? 'star' : (BADGE_ICONS_DB[type] || 'award');
%>
<section class="card runner-badges-card" data-dashboard-fragment="badges">
  <div class="card-header runner-badges-header"><h2><i data-lucide="award"></i> Recent Badges</h2><a href="/runner/profile#badges" class="btn btn-sm btn-outline runner-badges-action">View all</a></div>
  <div class="card-content runner-badges-content">
    <% const recentBadges = cards.badges || []; %>
    <% if (recentBadges.length) { %>
      <ul class="dashboard-badge-list" aria-label="Recently earned badges">
        <% recentBadges.forEach((badge) => { %>
          <li class="dashboard-badge-row">
            <span class="dashboard-badge-icon badge-placeholder" data-badge-type="<%= badge.badgeType %>">
              <% if (badge.imageUrl) { %><img src="<%= badge.imageUrl %>" alt="" loading="lazy"><% } else { %><i data-lucide="<%= getBadgeIconDB(badge.badgeType, badge.isFeatured) %>"></i><% } %>
            </span>
            <span class="dashboard-badge-main">
              <strong class="dashboard-badge-title"><%= badge.name %></strong>
              <% if (badge.description) { %><span class="dashboard-badge-meta"><%= badge.description %></span><% } %>
            </span>
            <% if (badge.points > 0) { %><span class="dashboard-badge-points"><%= badge.points %> pts</span><% } %>
            <% if (badge.isFeatured) { %><span class="dashboard-badge-state">Featured</span><% } %>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <div class="empty-state runner-badges-empty"><p class="empty-message">No badges yet.</p><a href="/events" class="btn btn-primary btn-sm">Browse events</a></div>
    <% } %>
  </div>
</section>
