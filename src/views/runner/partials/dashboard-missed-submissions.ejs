<section class="card runner-missed-submissions-card" data-dashboard-fragment="missedSubmissions">
  <div class="card-header runner-event-progress-header"><h2><i data-lucide="calendar-x"></i> Missed Submissions</h2></div>
  <div class="card-content runner-event-progress-content">
    <% const missedCards = cards.missedSubmissions || []; %>
    <% if (missedCards.length) { %>
      <ul class="dashboard-event-progress-list" aria-label="Events whose submission window has closed without a proof submission">
        <% missedCards.forEach((item) => { %>
          <%- include('event-progress-row', { item }) %>
        <% }) %>
      </ul>
    <% } else { %><div class="empty-state"><p class="empty-message">No missed submissions. Nice work staying on top of your run proofs.</p></div><% } %>
  </div>
</section>
