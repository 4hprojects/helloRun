<div data-dashboard-fragment="activity">
  <% if (cards.activity?.length) { %><ul class="dashboard-activity-list" aria-label="Three most recent activities"><% cards.activity.forEach((item) => { %><li><span class="dashboard-activity-icon"><i data-lucide="<%= item.type === 'result_rejected' ? 'triangle-alert' : item.type === 'certificate_issued' ? 'badge-check' : item.type === 'registration' ? 'clipboard-check' : 'activity' %>" aria-hidden="true"></i></span><div><strong><%= item.eventTitle || item.groupName || 'Runner activity' %></strong><p><%= item.message || (item.type === 'registration' ? 'Event registration received.' : 'Activity updated.') %></p><small><%= item.atRelativeLabel || item.atLabel %></small></div><% if (item.type?.startsWith('result_') || item.type === 'certificate_issued') { %><a href="/runner/submissions" aria-label="View details for <%= item.eventTitle %>"><i data-lucide="arrow-right" aria-hidden="true"></i></a><% } %></li><% }) %></ul><% } else { %><div class="empty-state"><p class="empty-message">You have not submitted an activity yet. Once your event starts, upload an activity screenshot or sync Strava.</p><a href="/my-registrations" class="btn btn-primary btn-sm">View My Events</a></div><% } %>
</div>
