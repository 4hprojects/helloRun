<div class="card-content" id="activityPanel" hidden data-dashboard-fragment="activity">
  <% if (cards.activity && cards.activity.length) { %><ul class="item-list"><% cards.activity.forEach((item) => { %><li class="item-row"><div class="item-main"><% if (item.type === 'group_activity') { %><div><span class="badge badge-group activity-pill activity-group">Group</span> <strong><%= item.groupName %></strong></div><div class="item-meta"><%= item.message %></div><% } else if (item.type === 'result_submitted' || item.type === 'result_approved' || item.type === 'result_rejected' || item.type === 'certificate_issued') { %><div><span class="badge badge-result">Result</span> <strong><%= item.eventTitle %></strong></div><div class="item-meta"><%= item.message %></div><% } else { %><div><span class="badge badge-registration">Registration</span> <strong><%= item.eventTitle %></strong></div><div class="item-meta">Code: <code><%= item.confirmationCode %></code></div><% } %><div class="item-meta"><%= item.atLabel %> <% if (item.atRelativeLabel) { %><span class="text-muted">(<%= item.atRelativeLabel %>)</span><% } %></div></div></li><% }) %></ul>
  <% } else { %><div class="empty-state"><p class="empty-message">No activity yet.</p></div><% } %>
</div>
