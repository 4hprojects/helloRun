<section
  class="card card-featured result-submissions-card"
  id="resultSubmissionsCard"
  data-result-submissions-root
  data-result-submissions-endpoint="/runner/dashboard/result-submissions"
>
  <div class="card-header result-submissions-header">
    <h2><i data-lucide="timer"></i> Result Submissions</h2>
    <a href="/runner/submissions" class="btn btn-sm btn-outline result-submissions-view-all">View All &rarr;</a>
    <nav class="result-status-tabs" aria-label="Filter result submissions by status">
      <a href="/runner/dashboard<%= preservedGroupQuery ? ('?groupQ=' + encodeURIComponent(preservedGroupQuery)) : '' %>"
         class="result-status-tab <%= !selectedResultStatus ? 'is-active' : '' %>"
         <%= !selectedResultStatus ? 'aria-current="page"' : '' %>>
        All
      </a>
      <a href="/runner/dashboard?resultStatus=submitted<%= preservedGroupQuery ? ('&groupQ=' + encodeURIComponent(preservedGroupQuery)) : '' %>"
         class="result-status-tab <%= selectedResultStatus === 'submitted' ? 'is-active' : '' %>"
         <%= selectedResultStatus === 'submitted' ? 'aria-current="page"' : '' %>>
        Submitted
      </a>
      <a href="/runner/dashboard?resultStatus=approved<%= preservedGroupQuery ? ('&groupQ=' + encodeURIComponent(preservedGroupQuery)) : '' %>"
         class="result-status-tab <%= selectedResultStatus === 'approved' ? 'is-active' : '' %>"
         <%= selectedResultStatus === 'approved' ? 'aria-current="page"' : '' %>>
        Approved
      </a>
      <a href="/runner/dashboard?resultStatus=rejected<%= preservedGroupQuery ? ('&groupQ=' + encodeURIComponent(preservedGroupQuery)) : '' %>"
         class="result-status-tab <%= selectedResultStatus === 'rejected' ? 'is-active' : '' %>"
         <%= selectedResultStatus === 'rejected' ? 'aria-current="page"' : '' %>>
        Rejected
      </a>
    </nav>
  </div>
  <div class="card-content result-submissions-panel">
    <% if (resultCards && resultCards.length) { %>
      <p class="result-submissions-count"><small>Latest <%= resultCards.length %> event<%= resultCards.length !== 1 ? 's' : '' %> by recent activity</small></p>
      <ul class="runner-compact-activity-list" aria-label="Recent result submission activity">
        <% resultCards.forEach((item) => { %>
          <li class="runner-compact-activity-row runner-compact-activity-row--<%= item.stateTone || item.state %>">
            <div class="runner-compact-activity-main">
              <strong><% if (item.eventSlug) { %><a href="/events/<%= item.eventSlug %>"><%= item.eventTitle %></a><% } else { %><%= item.eventTitle %><% } %></strong>
              <span><%= item.raceDistance || 'Distance TBA' %> · <%= item.isAccumulated ? 'Accumulated challenge' : 'Run result' %><% if (item.confirmationCode) { %> · Code <code><%= item.confirmationCode %></code><% } %></span>
            </div>
            <div class="runner-compact-activity-time">
              <% if (item.submittedAtLabel && item.submittedAtLabel !== 'TBA') { %><span>Submitted <%= item.submittedAtLabel %></span><% } %>
              <% if (item.reviewedAtLabel && item.reviewedAtLabel !== 'TBA') { %><span>Reviewed <%= item.reviewedAtLabel %></span><% } %>
            </div>
            <span class="badge badge-<%= item.stateTone || item.state %>"><%= item.stateLabel %></span>
            <% if (item.nextAction) { %>
              <div class="runner-compact-activity-action">
                <% if (item.nextAction.type === 'submit' || item.nextAction.type === 'resubmit') { %><button type="button" class="btn btn-sm <%= item.nextAction.type === 'resubmit' ? 'btn-outline' : 'btn-primary' %>" data-open-run-proof-modal data-run-proof-mode="<%= item.nextAction.type === 'resubmit' ? 'resubmit' : 'submit' %>" data-run-proof-registration-id="<%= item.registrationId %>"><%= item.nextAction.label %></button><% } else { %><a href="<%= item.nextAction.href %>"<% if (item.nextAction.type === 'download_certificate') { %> target="_blank" rel="noopener noreferrer"<% } %> class="btn btn-sm btn-outline"><%= item.nextAction.label %></a><% } %>
              </div>
            <% } %>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <div class="empty-state">
        <p class="empty-message">No result activity yet. After registering for an event, submit your run result here to earn a certificate and badges.</p>
      </div>
    <% } %>
  </div>
</section>
