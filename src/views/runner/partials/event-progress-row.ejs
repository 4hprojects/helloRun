<% const progressPercent = Math.max(0, Math.min(100, Number(item.progress?.percent || 0))); %>
<% const progressPercentLabel = Math.round(progressPercent); %>
<li class="dashboard-event-progress-row dashboard-event-progress-row--<%= item.stateTone || item.state %>">
  <div class="dashboard-event-progress-main">
    <div class="dashboard-event-progress-event"><span class="dashboard-event-progress-event-icon"><img src="<%= item.eventImageUrl || '/images/helloRun-icon.webp' %>" alt="<%= item.eventTitle %> logo" loading="lazy"></span><div><div class="dashboard-event-progress-title"><% if (item.eventSlug) { %><a href="/events/<%= item.eventSlug %>"><%= item.eventTitle %></a><% } else { %><%= item.eventTitle %><% } %></div><div class="item-meta"><span><%= item.raceDistance || 'Distance TBA' %></span> · <span><%= item.eventType %></span> · <span><%= item.participationMode || 'Mode TBA' %></span></div></div></div>
    <div class="event-card-status-line"><span class="badge badge-<%= item.stateTone || item.state %>"><%= item.stateLabel %></span><span class="deadline-chip deadline-chip--<%= item.deadlineTone %>"><i data-lucide="clock" aria-hidden="true"></i><%= item.deadlineLabel %></span></div>
    <% if (item.progress) { %><div class="dashboard-event-progress-track" role="progressbar" aria-label="Official approved progress for <%= item.eventTitle %>: <%= progressPercentLabel %>% complete" aria-valuemin="0" aria-valuemax="100" aria-valuenow="<%= progressPercentLabel %>"><span style="width:<%= progressPercent %>%"></span><strong class="dashboard-event-progress-percent" aria-hidden="true"><%= progressPercentLabel %>%</strong></div><dl class="event-progress-detail-list"><div><dt>Approved</dt><dd><%= Number(item.progress.approvedDistanceKm || 0).toFixed(2) %> km</dd></div><div><dt>Remaining</dt><dd><%= Number(item.progress.remainingDistanceKm || 0).toFixed(2) %> km</dd></div><div><dt>Awaiting review</dt><dd><%= Number(item.progress.pendingDistanceKm || 0).toFixed(2) %> km</dd></div><div><dt>Target</dt><dd><%= Number(item.progress.targetDistanceKm || 0).toFixed(2) %> km</dd></div></dl><% if (item.progress.rejectedActivityCount) { %><p class="event-progress-rejected"><%= item.progress.rejectedActivityCount %> rejected activit<%= item.progress.rejectedActivityCount === 1 ? 'y' : 'ies' %> · <%= Number(item.progress.rejectedDistanceKm || 0).toFixed(2) %> km</p><% } %><% } %>
    <% if (item.payment?.required) { %><div class="event-payment-summary"><strong><%= item.payment.currency %> <%= Number(item.payment.amount || 0).toFixed(2) %> due</strong><% if (item.payment.packageName) { %><span><%= item.payment.packageName %></span><% } %><% if (item.payment.categoryName) { %><span><%= item.payment.categoryName %></span><% } %></div><% } %>
    <p class="dashboard-event-progress-help"><%= item.helperText %></p>
    <div class="event-card-dates"><span>Starts <%= item.eventStartAtLabel %></span><span>Ends <%= item.eventEndAtLabel %></span><span>Submit by <%= item.submissionDeadlineLabel %></span><% if (item.nextAction?.type === 'submit') { %><button type="button" class="btn btn-primary event-card-add-activity" aria-label="<%= item.nextAction.label %> for <%= item.eventTitle %>" title="<%= item.nextAction.label %>" data-open-run-proof-modal data-run-proof-mode="<%= item.nextAction.type %>" data-run-proof-registration-id="<%= item.registrationId %>"><i data-lucide="plus" aria-hidden="true"></i></button><% } %></div>
  </div>
  <div class="dashboard-event-progress-side"><a href="/my-registrations" class="event-card-secondary-link">Registration details</a><% if (item.nextAction && item.nextAction.type !== 'submit') { %><% if (item.nextAction.type === 'resubmit') { %><button type="button" class="btn btn-sm btn-outline" data-open-run-proof-modal data-run-proof-mode="<%= item.nextAction.type %>" data-run-proof-registration-id="<%= item.registrationId %>"><%= item.nextAction.label %></button><% } else { %><a href="<%= item.nextAction.href %>"<% if (item.nextAction.type === 'download_certificate') { %> target="_blank" rel="noopener noreferrer"<% } %> class="btn btn-sm btn-outline"><%= item.nextAction.label %></a><% } %><% } %></div>
</li>
