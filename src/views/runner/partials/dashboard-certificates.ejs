<div class="card-content" id="certificatesPanel" hidden data-dashboard-fragment="certificates">
  <div class="stats-mini">
    <div><strong>Total distance:</strong> <%= Number(performanceStats?.totalDistanceKm || 0).toFixed(2) %> km</div>
    <div><strong>Completed events:</strong> <%= performanceStats?.completedEvents || 0 %></div>
    <% if (personalBest) { %><div><strong>Personal best:</strong> <%= personalBest.elapsedLabel %> (<%= personalBest.raceDistance %>) <span class="text-muted"><%= personalBest.eventTitle %></span></div><% } %>
    <div><strong>Total certificates:</strong> <%= submissionStats?.certificates || 0 %></div>
  </div>
  <% if (cards.certificates && cards.certificates.length) { %><ul class="item-list compact certificate-list"><% cards.certificates.forEach((item) => { %><li class="item-row certificate-row"><span class="certificate-row-icon"><i data-lucide="badge-check" aria-hidden="true"></i></span><div class="item-main"><div><strong><%= item.eventTitle %></strong></div><div class="item-meta">Issued: <%= item.issuedAtLabel %><% if (item.raceDistance) { %> &middot; <%= item.raceDistance %><% } %><% if (item.elapsedLabel && item.elapsedLabel !== '00:00:00') { %> &middot; <%= item.elapsedLabel %><% } %></div><% if (item.confirmationCode) { %><div class="item-meta">Code: <code><%= item.confirmationCode %></code></div><% } %></div><a href="/my-submissions/<%= item.submissionId %>/certificate" class="btn btn-sm btn-primary"><i data-lucide="download" aria-hidden="true"></i> Download</a></li><% }) %></ul>
  <% } else { %><div class="empty-state"><p class="empty-message">No certificates yet.</p></div><% } %>
</div>
