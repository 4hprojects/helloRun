<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'Submission History - HelloRun' }) %>
  <link rel="stylesheet" href="/css/runner-dashboard.css">
  <link rel="stylesheet" href="/css/runner-submissions.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="dashboard-container sub-page sub-history-page" id="main-content">
    <header class="sub-page-header sub-history-header">
      <div class="sub-page-heading">
        <span class="section-kicker"><i data-lucide="file-check-2" aria-hidden="true"></i>Your activity records</span>
        <h1>Submission History</h1>
        <p>Follow organizer decisions, correct entries that need attention, and collect approved results and certificates.</p>
      </div>
      <nav class="sub-page-actions" aria-label="Submission tools">
        <a href="/runner/dashboard" class="btn btn-outline sub-dashboard-action"><i data-lucide="arrow-left" aria-hidden="true"></i>Back to Dashboard</a>
        <a href="/my-registrations" class="btn btn-outline"><i data-lucide="clipboard-list" aria-hidden="true"></i><span class="sub-action-label-desktop">My Registrations</span><span class="sub-action-label-mobile">My Events</span></a>
        <button type="button" class="btn btn-primary" data-open-run-proof-modal aria-label="Submit activity"><i data-lucide="upload-cloud" aria-hidden="true"></i><span class="sub-action-label-desktop">Submit Activity</span><span class="sub-action-label-mobile">Submit</span></button>
      </nav>
    </header>

    <% if (message) { %>
      <div class="page-message page-message-<%= message.type %>" role="<%= message.type === 'error' ? 'alert' : 'status' %>" aria-live="<%= message.type === 'error' ? 'assertive' : 'polite' %>"><%= message.text %></div>
    <% } %>

    <nav class="sub-summary-strip" aria-label="Submission summary">
      <a href="<%= presentation.summaryUrls.rejected %>" class="sub-summary-item sub-summary-rejected"><span class="sub-summary-label-desktop">Needs correction</span><span class="sub-summary-label-mobile">Corrections</span><strong><%= counts.rejected %></strong></a>
      <a href="<%= presentation.summaryUrls.submitted %>" class="sub-summary-item sub-summary-submitted"><span class="sub-summary-label-desktop">Awaiting review</span><span class="sub-summary-label-mobile">Pending</span><strong><%= counts.submitted %></strong></a>
      <a href="<%= presentation.summaryUrls.approved %>" class="sub-summary-item sub-summary-approved"><span>Approved</span><strong><%= counts.approved %></strong></a>
      <a href="<%= presentation.summaryUrls.approved %>" class="sub-summary-item sub-summary-certificate" title="Show approved entries, including certificates"><span>Certificates</span><strong><%= counts.certificatesIssued %></strong></a>
    </nav>

    <section class="sub-discovery" aria-labelledby="submissionSearchTitle">
      <h2 id="submissionSearchTitle" class="sr-only">Find a submission</h2>
      <form method="GET" action="/runner/submissions" class="sub-filter-form">
        <label class="sub-search-wrap" for="submissionSearch">
          <span class="sr-only">Search submissions</span>
          <i data-lucide="search" class="sub-search-icon" aria-hidden="true"></i>
          <input id="submissionSearch" type="search" name="q" value="<%= filters.q %>" placeholder="Search events, organizers, or confirmation codes" maxlength="100" class="sub-search-input">
        </label>
        <button type="submit" class="btn btn-primary sub-search-button" aria-label="Search submissions"><i data-lucide="search" aria-hidden="true"></i><span>Search</span></button>

        <details class="sub-filter-details"<%= presentation.filtersOpen ? ' open' : '' %>>
          <summary><span><i data-lucide="sliders-horizontal" aria-hidden="true"></i>Filters &amp; sort<% if (presentation.chips.length) { %> <strong><%= presentation.chips.length %></strong><% } %></span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
          <div class="sub-filter-fields">
            <label><span>Status</span><select name="status" class="sub-select"><% presentation.statusOptions.forEach((option) => { %><option value="<%= option.value %>"<%= option.value === filters.status ? ' selected' : '' %>><%= option.label %></option><% }) %></select></label>
            <label><span>Activity type</span><select name="activityType" class="sub-select"><% presentation.activityOptions.forEach((option) => { %><option value="<%= option.value %>"<%= option.value === filters.activityType ? ' selected' : '' %>><%= option.label %></option><% }) %></select></label>
            <label class="sub-filter-sort-field"><span>Sort by</span><select name="sort" class="sub-select"><% presentation.sortOptions.forEach((option) => { %><option value="<%= option.value %>"<%= option.value === filters.sort ? ' selected' : '' %>><%= option.label %></option><% }) %></select></label>
            <button type="submit" class="btn btn-primary">Apply filters</button>
            <% if (presentation.hasActiveFilters) { %><a href="<%= presentation.clearFiltersUrl %>" class="btn btn-outline">Clear filters</a><% } %>
          </div>
        </details>
      </form>
    </section>

    <% if (presentation.chips.length) { %>
      <nav class="sub-active-filters" aria-label="Active filters">
        <span>Active filters</span>
        <% presentation.chips.forEach((chip) => { %><a href="<%= chip.href %>"><%= chip.label %><i data-lucide="x" aria-hidden="true"></i><span class="sr-only">Remove <%= chip.label %></span></a><% }) %>
      </nav>
    <% } %>

    <% if (presentation.showAttention) { %>
      <aside class="sub-attention-callout" aria-label="Submissions needing correction">
        <span class="sub-attention-icon"><i data-lucide="triangle-alert" aria-hidden="true"></i></span>
        <div><strong><%= counts.rejected %> <%= counts.rejected === 1 ? 'entry needs' : 'entries need' %> correction</strong><p>Review the organizer feedback and fix these before their submission windows close.</p></div>
        <a href="<%= presentation.attentionUrl %>" class="btn btn-warning"><span class="sub-action-label-desktop">Review corrections</span><span class="sub-action-label-mobile">Review</span></a>
      </aside>
    <% } %>

    <div class="sub-results-toolbar">
      <div><span class="section-kicker">Activity records</span><h2><%= presentation.resultLabel %></h2></div>
      <form method="GET" action="/runner/submissions" class="sub-sort-form">
        <% if (filters.q) { %><input type="hidden" name="q" value="<%= filters.q %>"><% } %>
        <% if (filters.status) { %><input type="hidden" name="status" value="<%= filters.status %>"><% } %>
        <% if (filters.activityType) { %><input type="hidden" name="activityType" value="<%= filters.activityType %>"><% } %>
        <label for="submissionSort">Sort by</label>
        <select id="submissionSort" name="sort" class="sub-select"><% presentation.sortOptions.forEach((option) => { %><option value="<%= option.value %>"<%= option.value === filters.sort ? ' selected' : '' %>><%= option.label %></option><% }) %></select>
        <button type="submit" class="btn btn-outline">Apply</button>
      </form>
    </div>

    <% if (!submissions.length) { %>
      <div class="empty-state sub-empty-state" role="status">
        <i data-lucide="<%= presentation.hasActiveFilters ? 'search-x' : 'file-plus-2' %>" class="empty-state-icon" aria-hidden="true"></i>
        <h2><%= presentation.hasActiveFilters ? 'No submissions match' : 'No activity submitted yet' %></h2>
        <p class="empty-message"><%= presentation.hasActiveFilters ? 'Remove the current filters to return to your full submission history.' : 'When you submit an activity for an event or personal record, its review status will appear here.' %></p>
        <% if (presentation.hasActiveFilters) { %><a href="<%= presentation.clearFiltersUrl %>" class="btn btn-primary">View all submissions</a><% } else { %><button type="button" class="btn btn-primary" data-open-run-proof-modal>Submit Activity</button><% } %>
      </div>
    <% } else { %>
      <div class="sub-history-table-wrap">
        <table class="sub-history-table">
          <caption>Your submitted activities and organizer review status</caption>
          <thead><tr><th scope="col">Entry</th><th scope="col">Review status</th><th scope="col">Result</th><th scope="col">Activity date</th><th scope="col">Timeline</th><th scope="col"><span class="sr-only">Action</span></th></tr></thead>
          <tbody>
            <% submissions.forEach((sub) => { %>
              <tr class="sub-history-row sub-history-row-<%= sub.status %><%= sub.isAccumulatedActivity ? ' sub-history-row--accumulated' : '' %>">
                <td data-label="Entry" class="sub-entry-cell"><span class="sub-entry-type"><i data-lucide="<%= sub.isPersonalRecord ? 'star' : (sub.isAccumulatedActivity ? 'layers-3' : 'flag') %>" aria-hidden="true"></i><%= sub.typeLabel %></span><a href="<%= sub.detailUrl %>"><%= sub.eventTitle %></a><% if (sub.raceDistance) { %><small><%= sub.raceDistance %><% if (sub.activityType) { %> · <%= sub.activityType.replace(/_/g, ' ') %><% } %></small><% } %></td>
                <td data-label="Review status" class="sub-review-cell"><span class="sub-review-state sub-review-state-<%= sub.status %>"><%= sub.statusLabel %></span><small class="sub-status-helper<%= sub.isAccumulatedActivity && sub.status === 'approved' ? ' sub-status-helper--approved-challenge' : '' %>"><%= sub.statusHelper %></small></td>
                <td data-label="<%= sub.isAccumulatedActivity ? 'Distance' : 'Result' %>" class="sub-result-cell"><strong><%= sub.distanceKm > 0 ? sub.distanceKm.toFixed(2) + ' km' : 'Distance unavailable' %></strong><% if (!sub.isAccumulatedActivity && sub.elapsedLabel !== '–') { %><small><%= sub.elapsedLabel %><% if (sub.paceLabel !== '–') { %> · <%= sub.paceLabel %><% } %></small><% } else if (sub.isAccumulatedActivity) { %><small class="sub-accumulated-result-label">Accumulated activity</small><% } %></td>
                <td data-label="Activity date" class="sub-activity-date-cell"><%= sub.runDateLabel %></td>
                <td data-label="Timeline" class="sub-timeline-cell"><span>Submitted <%= sub.submittedAtRelativeLabel || sub.submittedAtLabel %></span><% if (sub.reviewedAtRelativeLabel) { %><small>Reviewed <%= sub.reviewedAtRelativeLabel %></small><% } %></td>
                <td class="sub-row-actions">
                  <a href="<%= sub.primaryAction.href %>" class="btn btn-sm <%= sub.primaryAction.type === 'certificate' ? 'btn-primary' : (sub.status === 'rejected' ? 'btn-warning' : 'btn-outline') %>"<% if (sub.primaryAction.type === 'certificate') { %> target="_blank" rel="noopener noreferrer"<% } %>><%= sub.primaryAction.label %></a>
                  <% if (sub.primaryAction.type === 'certificate') { %><a href="<%= sub.detailUrl %>" class="sub-row-secondary">View entry</a><% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (presentation.pagination.totalPages > 1) { %>
      <nav class="sub-pagination" aria-label="Submission history pages">
        <div class="sub-pagination-desktop">
          <% if (presentation.pagination.previousUrl) { %><a href="<%= presentation.pagination.previousUrl %>" class="btn btn-outline" aria-label="Previous page"><i data-lucide="chevron-left" aria-hidden="true"></i>Previous</a><% } %>
          <% presentation.pagination.links.forEach((link) => { %><% if (link.type === 'ellipsis') { %><span class="sub-pagination-ellipsis" aria-hidden="true">…</span><% } else { %><a href="<%= link.href %>" class="btn <%= link.current ? 'btn-primary' : 'btn-outline' %>"<% if (link.current) { %> aria-current="page"<% } %>><%= link.page %></a><% } %><% }) %>
          <% if (presentation.pagination.nextUrl) { %><a href="<%= presentation.pagination.nextUrl %>" class="btn btn-outline" aria-label="Next page">Next<i data-lucide="chevron-right" aria-hidden="true"></i></a><% } %>
        </div>
        <div class="sub-pagination-mobile">
          <% if (presentation.pagination.previousUrl) { %><a href="<%= presentation.pagination.previousUrl %>" class="btn btn-outline" aria-label="Previous page"><i data-lucide="chevron-left" aria-hidden="true"></i><span>Previous</span></a><% } else { %><span class="btn btn-outline sub-pagination-disabled" aria-disabled="true"><i data-lucide="chevron-left" aria-hidden="true"></i><span>Previous</span></span><% } %>
          <span class="sub-pagination-status" aria-current="page">Page <strong><%= presentation.pagination.page %></strong> of <strong><%= presentation.pagination.totalPages %></strong></span>
          <% if (presentation.pagination.nextUrl) { %><a href="<%= presentation.pagination.nextUrl %>" class="btn btn-outline" aria-label="Next page"><span>Next</span><i data-lucide="chevron-right" aria-hidden="true"></i></a><% } else { %><span class="btn btn-outline sub-pagination-disabled" aria-disabled="true"><span>Next</span><i data-lucide="chevron-right" aria-hidden="true"></i></span><% } %>
        </div>
      </nav>
    <% } %>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/runner-submissions.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
