<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/static-pages.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <button type="button" class="back-to-top privacy-back-to-top" id="backToTopBtn" aria-label="Back to top">&uarr;</button>

  <main class="static-page privacy-page">
    <div class="static-wrap privacy-wrap">
      <header class="static-hero privacy-hero">
        <span class="privacy-kicker">Legal</span>
        <h1>Terms and Conditions</h1>
        <p>Rules and responsibilities for using helloRun.</p>
        <% if (policyMeta && (policyMeta.versionNumber || policyMeta.effectiveDate || policyMeta.updatedAt)) { %>
          <div class="privacy-meta-pills">
            <% if (policyMeta.versionNumber) { %>
              <span class="privacy-meta-pill">Version <%= policyMeta.versionNumber %></span>
            <% } %>
            <% if (policyMeta.effectiveDate) { %>
              <span class="privacy-meta-pill">Effective <%= new Date(policyMeta.effectiveDate).toLocaleDateString('en-US') %></span>
            <% } %>
            <% if (policyMeta.updatedAt) { %>
              <span class="privacy-meta-pill">Updated <%= new Date(policyMeta.updatedAt).toLocaleDateString('en-US') %></span>
            <% } %>
          </div>
        <% } %>
      </header>

      <div class="privacy-layout">
        <section class="static-card privacy-content-card">
          <% if (policyLoadedFromFile && policyHtml) { %>
            <article class="legal-markdown"><%- policyHtml %></article>
          <% } else { %>
            <article class="privacy-fallback">
              <h2>Account Responsibilities</h2>
              <p>You are responsible for maintaining accurate account information and safeguarding your login credentials.</p>

              <h2>Event and Submission Integrity</h2>
              <ul>
                <li>Provide truthful registration and profile data.</li>
                <li>Submit genuine payment and result proofs.</li>
                <li>Do not manipulate rankings, records, or review workflows.</li>
              </ul>

              <h2>Platform Conduct</h2>
              <p>Abusive, fraudulent, or disruptive behavior may lead to account restrictions or removal.</p>

              <h2>Service Changes</h2>
              <p>helloRun may update features, workflows, and terms to maintain platform reliability and compliance.</p>
            </article>
          <% } %>
        </section>

        <aside class="privacy-side-stack">
          <section class="static-card privacy-side-card">
            <h2>At a Glance</h2>
            <div class="privacy-side-body">
              <ul>
                <li>Using helloRun means accepting account, event, and submission responsibilities.</li>
                <li>False or manipulated submissions can result in rejection or account restrictions.</li>
                <li>Terms can be updated to keep services secure, fair, and compliant.</li>
              </ul>
              <p class="privacy-side-note">Questions about these terms:</p>
              <a class="privacy-contact-link" href="mailto:hellorunonline@gmail.com">hellorunonline@gmail.com</a>
            </div>
          </section>

          <section class="static-card privacy-toc-card" id="termsTocCard" hidden>
            <h2>Quick Contents</h2>
            <ul class="privacy-toc-list" id="termsTocList"></ul>
          </section>
        </aside>
      </div>
    </div>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    (function initTermsPage() {
      const backToTopBtn = document.getElementById('backToTopBtn');
      if (backToTopBtn) {
        const toggleBackToTop = () => {
          if (window.scrollY > 300) {
            backToTopBtn.classList.add('visible');
          } else {
            backToTopBtn.classList.remove('visible');
          }
        };
        window.addEventListener('scroll', toggleBackToTop, { passive: true });
        backToTopBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        toggleBackToTop();
      }

      const tocCard = document.getElementById('termsTocCard');
      const tocList = document.getElementById('termsTocList');
      const contentRoot = document.querySelector('.privacy-content-card .legal-markdown, .privacy-content-card .privacy-fallback');

      if (tocCard && tocList && contentRoot) {
        const headingNodes = Array.from(contentRoot.querySelectorAll('h1, h2, h3'));
        const usedIds = new Set();

        const toSlug = (value) => String(value || '')
          .toLowerCase()
          .replace(/[^a-z0-9\s-]/g, '')
          .trim()
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-');

        let tocIndex = 0;

        headingNodes.forEach((headingNode, index) => {
          const headingText = headingNode.textContent.trim();
          if (!headingText) return;

          if (headingNode.tagName.toLowerCase() === 'h1' && /terms( and conditions| of service)?/i.test(headingText) && !/^\d+[\.)]/.test(headingText)) {
            return;
          }

          const baseId = toSlug(headingText) || `section-${index + 1}`;
          let nextId = baseId;
          let collisionCount = 2;
          while (usedIds.has(nextId) || document.getElementById(nextId)) {
            nextId = `${baseId}-${collisionCount}`;
            collisionCount += 1;
          }

          usedIds.add(nextId);
          headingNode.id = nextId;
          headingNode.classList.add('privacy-anchor-target');

          const listItem = document.createElement('li');
          const link = document.createElement('a');
          link.href = `#${nextId}`;
          link.textContent = headingText;
          const tagName = headingNode.tagName.toLowerCase();
          const levelClass = tagName === 'h1'
            ? 'level-1'
            : tagName === 'h3'
              ? 'level-3'
              : 'level-2';
          link.className = `privacy-toc-link ${levelClass}`;
          listItem.appendChild(link);
          tocList.appendChild(listItem);
          tocIndex += 1;
        });

        if (tocIndex === 0) {
          const boldNodes = Array.from(contentRoot.querySelectorAll('p > strong:first-child, li > strong:first-child'));
          boldNodes.forEach((strongNode, index) => {
            const hostNode = strongNode.parentElement;
            if (!hostNode) return;

            const hostText = hostNode.textContent.trim();
            const strongText = strongNode.textContent.trim();
            if (!strongText || strongText.length > 120) return;
            if (!hostText.startsWith(strongText)) return;
            if (hostText.length > strongText.length + 120) return;

            const headingText = strongText.replace(/:+$/, '').trim();
            if (!headingText) return;

            const baseId = toSlug(headingText) || `section-bold-${index + 1}`;
            let nextId = baseId;
            let collisionCount = 2;
            while (usedIds.has(nextId) || document.getElementById(nextId)) {
              nextId = `${baseId}-${collisionCount}`;
              collisionCount += 1;
            }

            usedIds.add(nextId);
            hostNode.id = nextId;
            hostNode.classList.add('privacy-anchor-target');

            const listItem = document.createElement('li');
            const link = document.createElement('a');
            link.href = `#${nextId}`;
            link.textContent = headingText;
            link.className = 'privacy-toc-link level-2';
            listItem.appendChild(link);
            tocList.appendChild(listItem);
            tocIndex += 1;
          });
        }

        if (tocIndex > 0) {
          tocCard.hidden = false;
        }
      }

      if (window.lucide) lucide.createIcons();
    })();
  </script>
</body>
</html>
