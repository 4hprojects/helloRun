<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/static-pages.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <button type="button" class="back-to-top static-back-to-top" id="backToTopBtn" aria-label="Back to top">&uarr;</button>

  <main class="static-page">
    <div class="static-wrap">
      <header class="static-hero">
        <h1>Cookie Policy</h1>
        <p>How helloRun uses cookies and similar technologies.</p>
        <% if (policyMeta && (policyMeta.versionNumber || policyMeta.effectiveDate || policyMeta.updatedAt)) { %>
          <p class="static-note">
            <% if (policyMeta.versionNumber) { %>Version <%= policyMeta.versionNumber %><% } %>
            <% if (policyMeta.effectiveDate) { %> | Effective <%= new Date(policyMeta.effectiveDate).toLocaleDateString('en-US') %><% } %>
            <% if (policyMeta.updatedAt) { %> | Updated <%= new Date(policyMeta.updatedAt).toLocaleDateString('en-US') %><% } %>
          </p>
        <% } %>
      </header>

      <% if (policyLoadedFromFile && policyHtml) { %>
        <section class="static-card">
          <article class="legal-markdown"><%- policyHtml %></article>
        </section>
      <% } else { %>
        <section class="static-card">
          <h2>Essential Cookies</h2>
          <p>These cookies support core account, login, and session functionality needed to run helloRun securely.</p>
        </section>

        <section class="static-card">
          <h2>Performance and Analytics</h2>
          <p>We may use analytics cookies to understand usage patterns and improve platform reliability and user experience.</p>
        </section>

        <section class="static-card">
          <h2>Managing Cookies</h2>
          <p>You can control cookies through browser settings. Disabling some cookies may affect key site features.</p>
        </section>
      <% } %>
    </div>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    (function initCookiePolicyPage() {
      const backToTopBtn = document.getElementById('backToTopBtn');
      if (backToTopBtn) {
        const toggleBackToTop = () => {
          if (window.scrollY > 300) {
            backToTopBtn.classList.add('visible');
          } else {
            backToTopBtn.classList.remove('visible');
          }
        };
        window.addEventListener('scroll', toggleBackToTop, { passive: true });
        backToTopBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        toggleBackToTop();
      }

      if (window.lucide) lucide.createIcons();
    })();
  </script>
</body>
</html>
