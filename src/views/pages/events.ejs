<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title, seo: typeof seo !== 'undefined' ? seo : null }) %>
  <link rel="stylesheet" href="/css/events.css">
</head>
<body class="<%= locals.isAuthenticated && !locals.isAdmin && !locals.isApprovedOrganizer && !locals.isOrganizer ? 'has-runner-mobile-nav' : '' %>">
  <%- include('../layouts/nav') %>

  <% if (loginSuccess && userName) { %>
    <div class="toast toast-success" role="status">
      <i data-lucide="check-circle" aria-hidden="true"></i>
      <span>Welcome back, <strong><%= userName %></strong>.</span>
    </div>
  <% } %>

  <main class="events-page">
    <% const defaultEventImageUrl = '/images/helloRun-icon.webp'; %>

    <section class="events-discovery-header" aria-labelledby="eventsPageTitle">
      <div class="container">
        <div class="events-intro-row">
          <div class="events-intro-copy">
            <p class="section-kicker">Find your next finish line</p>
            <h1 id="eventsPageTitle"><%= pageContent?.heroTitle || 'Discover Running Events' %></h1>
            <p><%= pageContent?.heroDescription || 'Compare virtual, on-site, and hybrid events to find your next challenge.' %></p>
          </div>
          <% if (locals.isAuthenticated) { %>
            <a href="/my-registrations" class="btn btn-outline events-registrations-link">
              <i data-lucide="clipboard-list" aria-hidden="true"></i>
              My Registrations
            </a>
          <% } %>
        </div>

        <form method="GET" action="/events#event-results" class="events-discovery-form">
          <div class="events-search-row">
            <div class="search-field">
              <label for="eventsSearch" class="sr-only">Search events, organizers, or locations</label>
              <i data-lucide="search" aria-hidden="true"></i>
              <input
                id="eventsSearch"
                type="search"
                name="q"
                value="<%= filters?.q || '' %>"
                placeholder="Search events, organizer, or location..."
              >
            </div>
            <button type="submit" class="btn btn-primary events-search-submit">
              <span>Search events</span>
              <i data-lucide="arrow-right" aria-hidden="true"></i>
            </button>
          </div>

          <div class="events-control-row">
            <details class="events-filter-panel" <%= filterMeta?.hasActiveFilters || filterMeta?.validationError ? 'open' : '' %>>
              <summary>
                <span class="filter-summary-label">
                  <i data-lucide="sliders-horizontal" aria-hidden="true"></i>
                  Filters
                  <% if (filterMeta?.activeFilterCount) { %>
                    <span class="filter-count" aria-label="<%= filterMeta.activeFilterCount %> active <%= filterMeta.activeFilterCount === 1 ? 'filter' : 'filters' %>"><%= filterMeta.activeFilterCount %></span>
                  <% } %>
                </span>
                <span class="filter-summary-hint">Mode, distance, availability, and date</span>
              </summary>

              <div class="events-filter-content">
                <div class="events-filter-grid" aria-label="Event filters">
                  <div class="filter-group">
                    <label for="eventsMode">Mode</label>
                    <select id="eventsMode" name="eventType">
                      <option value="">All modes</option>
                      <option value="virtual" <%= filters?.eventType === 'virtual' ? 'selected' : '' %>>Virtual</option>
                      <option value="onsite" <%= filters?.eventType === 'onsite' ? 'selected' : '' %>>On-site</option>
                      <option value="hybrid" <%= filters?.eventType === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
                    </select>
                  </div>

                  <div class="filter-group">
                    <label for="eventsDistance">Distance</label>
                    <select id="eventsDistance" name="distance">
                      <option value="">All distances</option>
                      <% (filterMeta?.distanceOptions || []).forEach((distanceItem) => { %>
                        <option value="<%= distanceItem %>" <%= filters?.distance === distanceItem ? 'selected' : '' %>><%= distanceItem %></option>
                      <% }) %>
                    </select>
                  </div>

                  <div class="filter-group">
                    <label for="eventsStatus">Registration availability</label>
                    <select id="eventsStatus" name="status">
                      <option value="all" <%= (filters?.status || 'all') === 'all' ? 'selected' : '' %>>All availability</option>
                      <option value="open" <%= filters?.status === 'open' ? 'selected' : '' %>>Open now</option>
                      <option value="upcoming" <%= filters?.status === 'upcoming' ? 'selected' : '' %>>Opens later</option>
                      <option value="closed" <%= filters?.status === 'closed' ? 'selected' : '' %>>Closed</option>
                    </select>
                  </div>

                  <div class="filter-group">
                    <label for="eventsDateFrom">Starts from</label>
                    <input type="date" id="eventsDateFrom" name="dateFrom" value="<%= filters?.dateFrom ? filters.dateFrom.toISOString().slice(0,10) : '' %>" <%= filterMeta?.validationError ? 'aria-invalid="true" aria-describedby="eventsDateError"' : '' %>>
                  </div>

                  <div class="filter-group">
                    <label for="eventsDateTo">Starts by</label>
                    <input type="date" id="eventsDateTo" name="dateTo" value="<%= filters?.dateTo ? filters.dateTo.toISOString().slice(0,10) : '' %>" <%= filterMeta?.validationError ? 'aria-invalid="true" aria-describedby="eventsDateError"' : '' %>>
                  </div>
                </div>

                <% if (filterMeta?.validationError) { %>
                  <p class="filter-validation-error" id="eventsDateError" role="alert"><%= filterMeta.validationError %></p>
                <% } %>

                <div class="events-filter-actions">
                  <% if (filterMeta?.hasActiveFilters) { %>
                    <a href="<%= filterMeta.clearFiltersUrl %>#event-results" class="btn btn-outline">Clear filters</a>
                  <% } %>
                  <button type="submit" class="btn btn-primary">Apply filters</button>
                </div>
              </div>
            </details>

            <div class="events-sort-control">
              <label for="eventsSort">Sort by</label>
              <select id="eventsSort" name="sort">
                <option value="recommended" <%= (filters?.sort || 'recommended') === 'recommended' ? 'selected' : '' %>>Recommended</option>
                <option value="closing-soon" <%= filters?.sort === 'closing-soon' ? 'selected' : '' %>>Registration closing soon</option>
                <option value="start-date" <%= filters?.sort === 'start-date' ? 'selected' : '' %>>Event start date</option>
                <option value="newest" <%= filters?.sort === 'newest' ? 'selected' : '' %>>Newest listed</option>
              </select>
              <button type="submit" class="btn btn-outline">Apply sort</button>
            </div>
          </div>
        </form>
      </div>
    </section>

    <section class="events-results-section" aria-labelledby="event-results">
      <div class="container">
        <div class="events-results-header">
          <div>
            <p class="section-kicker">Events for you</p>
            <h2 id="event-results" tabindex="-1"><%= (filterMeta?.resultsCount || 0).toLocaleString('en-US') %> <%= filterMeta?.resultsCount === 1 ? 'event' : 'events' %></h2>
          </div>
          <p class="results-range">
            <% if ((filterMeta?.resultsCount || 0) > 0) { %>
              Showing <strong><%= pagination.resultStart %>–<%= pagination.resultEnd %></strong> of <strong><%= filterMeta.resultsCount %></strong>
            <% } else { %>
              No matches yet
            <% } %>
          </p>
        </div>

        <% if (filterMeta?.activeFilters?.length) { %>
          <div class="active-filters" aria-label="Active filters">
            <% filterMeta.activeFilters.forEach((activeFilter) => { %>
              <a href="<%= activeFilter.clearUrl %>#event-results" class="filter-chip" aria-label="Remove <%= activeFilter.label %> filter: <%= activeFilter.value %>">
                <span><strong><%= activeFilter.label %>:</strong> <%= activeFilter.value %></span>
                <span aria-hidden="true">×</span>
              </a>
            <% }) %>
            <a href="<%= filterMeta.clearFiltersUrl %>#event-results" class="filter-chip filter-chip-clear">Clear filters</a>
          </div>
        <% } %>

        <% if (events && events.length) { %>
          <div class="events-card-grid">
            <% let eventsFeedAdCount = 0; %>
            <% events.forEach((event, eventIndex) => { %>
              <% const eventBannerImageUrl = event.bannerImageUrl || defaultEventImageUrl; %>
              <article class="event-card" data-event-slug="<%= event.slug %>">
                <a href="/events/<%= event.slug %>" class="event-card-image-link" tabindex="-1" aria-hidden="true">
                  <img
                    class="event-card-image"
                    src="<%= eventBannerImageUrl %>"
                    alt=""
                    loading="lazy"
                    onerror="this.onerror=null;this.src='<%= defaultEventImageUrl %>';"
                  >
                </a>

                <div class="event-card-body">
                  <div class="event-card-topline">
                    <div class="event-card-tags">
                      <span class="tag tag-status tag-status-<%= event.availability?.tone || 'closed' %>"><%= event.availability?.label || 'Closed' %></span>
                      <span class="tag"><%= event.eventTypeLabel || 'Event' %></span>
                    </div>
                    <% if (locals.isAuthenticated) { %>
                      <% const _isSaved = savedEventIds && savedEventIds.has(String(event._id)); %>
                      <button type="button"
                        class="btn btn-save-event js-save-event<%= _isSaved ? ' is-saved' : '' %>"
                        data-event-slug="<%= event.slug %>"
                        data-saved="<%= _isSaved ? '1' : '0' %>"
                        aria-label="<%= _isSaved ? 'Remove from saved' : 'Save event' %>"
                        title="<%= _isSaved ? 'Remove from saved' : 'Save event' %>">
                        <i data-lucide="heart" aria-hidden="true"></i>
                      </button>
                    <% } %>
                  </div>

                  <h3 class="event-card-title"><a href="/events/<%= event.slug %>"><%= event.title %></a></h3>
                  <p class="event-card-helper"><%= event.availability?.helper || 'Review the event schedule and registration details.' %></p>

                  <dl class="event-card-facts">
                    <div>
                      <dt><i data-lucide="calendar" aria-hidden="true"></i><span>Date</span></dt>
                      <dd><%= event.startDateLabel || 'Not listed' %></dd>
                    </div>
                    <div>
                      <dt><i data-lucide="map-pin" aria-hidden="true"></i><span>Location</span></dt>
                      <dd><%= event.locationLabel || 'Not listed' %></dd>
                    </div>
                    <div>
                      <dt><i data-lucide="flag" aria-hidden="true"></i><span>Distance</span></dt>
                      <dd>
                        <span aria-hidden="true"><%= event.distanceLabel || 'Not listed' %></span>
                        <span class="sr-only"><%= event.distanceFullLabel || event.distanceLabel || 'Not listed' %></span>
                      </dd>
                    </div>
                    <div>
                      <dt><i data-lucide="wallet-cards" aria-hidden="true"></i><span>Price</span></dt>
                      <dd><%= event.priceLabel || 'Not listed' %></dd>
                    </div>
                  </dl>

                  <p class="event-card-organizer">Hosted by <strong><%= event.organizerName || 'HelloRun' %></strong></p>

                  <a href="/events/<%= event.slug %>" class="btn btn-primary event-card-cta">
                    <%= event.cardCtaLabel || 'View event' %>
                    <i data-lucide="arrow-right" aria-hidden="true"></i>
                  </a>
                </div>
              </article>

              <% if ((eventIndex + 1) % 6 === 0 && eventsFeedAdCount < 2) { eventsFeedAdCount += 1; %>
                <%- include('../partials/ad-unit', { group: 'events', placement: 'in_feed', className: 'ad-unit-feed' }) %>
              <% } %>
            <% }); %>
          </div>

          <%- include('../partials/ad-unit', { group: 'events', placement: 'after_results_meta' }) %>

          <% if (pagination && pagination.totalPages > 1) { %>
            <nav class="pagination" aria-label="Events pagination">
              <a
                href="<%= pagination.getPageUrl(Math.max(1, pagination.currentPage - 1)) %>"
                class="pagination-link pagination-prev <%= pagination.currentPage === 1 ? 'disabled' : '' %>"
                aria-label="Go to previous events page"
                <%= pagination.currentPage === 1 ? 'aria-disabled="true" tabindex="-1"' : '' %>
              ><i data-lucide="chevron-left" aria-hidden="true"></i><span>Previous</span></a>

              <div class="pagination-numbers">
                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                  <% if (i === 1 || i === pagination.totalPages || (i >= pagination.currentPage - 1 && i <= pagination.currentPage + 1)) { %>
                    <a
                      href="<%= pagination.getPageUrl(i) %>"
                      class="pagination-link events-page-number<%= i === pagination.currentPage ? ' active' : '' %>"
                      aria-label="<%= i === pagination.currentPage ? `Current page, page ${i}` : `Go to page ${i}` %>"
                      <%= i === pagination.currentPage ? 'aria-current="page"' : '' %>
                    ><%= i %></a>
                  <% } else if (i === pagination.currentPage - 2 || i === pagination.currentPage + 2) { %>
                    <span class="pagination-ellipsis" aria-hidden="true">…</span>
                  <% } %>
                <% } %>
              </div>

              <a
                href="<%= pagination.getPageUrl(Math.min(pagination.totalPages, pagination.currentPage + 1)) %>"
                class="pagination-link pagination-next <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>"
                aria-label="Go to next events page"
                <%= pagination.currentPage === pagination.totalPages ? 'aria-disabled="true" tabindex="-1"' : '' %>
              ><span>Next</span><i data-lucide="chevron-right" aria-hidden="true"></i></a>
            </nav>
          <% } %>
        <% } else { %>
          <div class="events-empty-state">
            <span class="empty-state-icon"><i data-lucide="calendar-search" aria-hidden="true"></i></span>
            <h3><%= filterMeta?.hasActiveFilters ? 'No events match your search yet' : 'New events are on the way' %></h3>
            <% if (filterMeta?.hasActiveFilters) { %>
              <p>Try clearing a filter to see more races and challenges.</p>
              <a href="<%= filterMeta.clearFiltersUrl %>#event-results" class="btn btn-primary">See all events</a>
            <% } else { %>
              <p>Check back soon for newly published races and virtual challenges.</p>
              <a href="/how-it-works" class="btn btn-outline">See how HelloRun works</a>
            <% } %>
          </div>
        <% } %>

        <details class="events-guide">
          <summary>Not sure which event fits you?</summary>
          <div>
            <p>A 5K works well for beginners and walkers. A 10K offers a stronger weekly goal, while 21K and accumulated-distance challenges need more planning.</p>
            <p>Open an event to compare its activity window, accepted proof, payment instructions, rewards, and leaderboard rules. You can also read <a href="/how-it-works">How It Works</a> or the <a href="/faq">FAQ</a>.</p>
          </div>
        </details>
      </div>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <div class="events-action-status" data-events-action-status role="status" aria-live="polite" aria-atomic="true"></div>
  <script src="/js/main.js"></script>
  <% if (locals.isAuthenticated) { %><script src="/js/event-save.js"></script><% } %>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
