<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/events.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <% if (loginSuccess && userName) { %>
    <section class="login-success-banner">
      <div class="container">
        <p>Welcome back, <strong><%= userName %></strong>.</p>
      </div>
    </section>
  <% } %>

  <main>
    <section class="events-hero">
      <h1>Published Events</h1>
      <p>Explore active helloRun races and pick your next challenge.</p>
      <% if (locals.isAuthenticated) { %>
        <div class="hero-actions">
          <a href="/my-registrations" class="btn btn-secondary">My Registrations</a>
        </div>
      <% } %>
    </section>

    <section class="events-list">
      <div class="container">
        <h2>Browse Events</h2>
        <form method="GET" action="/events" class="events-filter-form">
          <div class="events-filter-group events-filter-group-search">
            <label for="eventsSearch">Search</label>
            <input
              id="eventsSearch"
              type="search"
              name="q"
              value="<%= filters?.q || '' %>"
              placeholder="Search title, location, or description"
            >
          </div>

          <div class="events-filter-group">
            <label for="eventsMode">Mode</label>
            <select id="eventsMode" name="eventType">
              <option value="">All Modes</option>
              <option value="virtual" <%= filters?.eventType === 'virtual' ? 'selected' : '' %>>Virtual</option>
              <option value="onsite" <%= filters?.eventType === 'onsite' ? 'selected' : '' %>>On-site</option>
              <option value="hybrid" <%= filters?.eventType === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
            </select>
          </div>

          <div class="events-filter-group">
            <label for="eventsDistance">Distance</label>
            <select id="eventsDistance" name="distance">
              <option value="">All Distances</option>
              <% (filterMeta?.distanceOptions || []).forEach((distanceItem) => { %>
                <option value="<%= distanceItem %>" <%= filters?.distance === distanceItem ? 'selected' : '' %>><%= distanceItem %></option>
              <% }) %>
            </select>
          </div>

          <div class="events-filter-group">
            <label for="eventsStatus">Status</label>
            <select id="eventsStatus" name="status">
              <option value="all" <%= (filters?.status || 'all') === 'all' ? 'selected' : '' %>>All</option>
              <option value="upcoming" <%= filters?.status === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
              <option value="open" <%= filters?.status === 'open' ? 'selected' : '' %>>Open Registration</option>
              <option value="closed" <%= filters?.status === 'closed' ? 'selected' : '' %>>Closed</option>
            </select>
          </div>

          <div class="events-filter-actions">
            <button type="submit" class="btn">Apply</button>
            <% if (filterMeta?.hasActiveFilters) { %>
              <a href="/events" class="btn btn-secondary">Clear filters</a>
            <% } %>
          </div>
        </form>

        <p class="events-results-meta">
          Showing <strong><%= filterMeta?.resultsCount || 0 %></strong> published event<%= (filterMeta?.resultsCount || 0) === 1 ? '' : 's' %><%= filterMeta?.hasActiveFilters ? ` with ${filterMeta.activeFilterCount} active filter${filterMeta.activeFilterCount === 1 ? '' : 's'}` : '' %>.
        </p>

        <% if (events && events.length) { %>
          <div class="events-grid">
            <% events.forEach((event) => { %>
              <article class="event-card">
                <% if (event.bannerImageUrl) { %>
                  <a href="/events/<%= event.slug %>" class="event-banner-link" aria-label="View <%= event.title %>">
                    <img class="event-banner" src="<%= event.bannerImageUrl %>" alt="<%= event.title %> banner">
                  </a>
                <% } %>

                <div class="event-card-content">
                  <div class="event-chip-row">
                    <span class="event-chip"><%= event.eventType || 'event' %></span>
                    <span class="event-chip event-chip-muted"><%= (event.eventTypesAllowed || []).join(' / ') || 'N/A' %></span>
                  </div>

                  <h3><a href="/events/<%= event.slug %>"><%= event.title %></a></h3>

                  <p class="event-meta">
                    <i data-lucide="calendar"></i>
                    <span><%= event.eventStartAt ? new Date(event.eventStartAt).toLocaleString('en-US') : 'Start date TBA' %></span>
                  </p>

                  <p class="event-meta">
                    <i data-lucide="map-pin"></i>
                    <span><%= [event.venueName, event.city, event.countryLabel].filter(Boolean).join(', ') || 'Location TBA' %></span>
                  </p>

                  <p class="event-meta">
                    <i data-lucide="flag"></i>
                    <span><%= (event.raceDistances || []).join(', ') || 'Distances TBA' %></span>
                  </p>

                  <p class="event-description"><%= event.description || 'No event description available.' %></p>

                  <div class="event-actions">
                    <a href="/events/<%= event.slug %>" class="btn">View Event</a>
                  </div>
                </div>
              </article>
            <% }); %>
          </div>

          <% if (pagination && pagination.totalPages > 1) { %>
            <% const params = new URLSearchParams({
              q: filters?.q || '',
              eventType: filters?.eventType || '',
              distance: filters?.distance || '',
              status: filters?.status || 'all'
            }); %>
            <% const basePageUrl = `/events?${params.toString()}`; %>
            <nav class="events-pagination" aria-label="Events pagination">
              <% const prevPage = Math.max(1, pagination.currentPage - 1); %>
              <% const nextPage = Math.min(pagination.totalPages, pagination.currentPage + 1); %>
              <a
                href="<%= basePageUrl %>&page=<%= prevPage %>"
                class="events-page-btn <%= pagination.currentPage === 1 ? 'disabled' : '' %>"
                <%= pagination.currentPage === 1 ? 'aria-disabled=\"true\" tabindex=\"-1\"' : '' %>
              >
                Previous
              </a>
              <div class="events-page-numbers">
                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                  <% if (i === 1 || i === pagination.totalPages || (i >= pagination.currentPage - 1 && i <= pagination.currentPage + 1)) { %>
                    <a
                      href="<%= basePageUrl %>&page=<%= i %>"
                      class="events-page-number <%= i === pagination.currentPage ? 'active' : '' %>"
                      <%= i === pagination.currentPage ? 'aria-current=\"page\"' : '' %>
                    >
                      <%= i %>
                    </a>
                  <% } else if (i === pagination.currentPage - 2 || i === pagination.currentPage + 2) { %>
                    <span class="events-page-ellipsis">...</span>
                  <% } %>
                <% } %>
              </div>
              <span class="events-page-info">Page <%= pagination.currentPage %> of <%= pagination.totalPages %></span>
              <a
                href="<%= basePageUrl %>&page=<%= nextPage %>"
                class="events-page-btn <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>"
                <%= pagination.currentPage === pagination.totalPages ? 'aria-disabled=\"true\" tabindex=\"-1\"' : '' %>
              >
                Next
              </a>
            </nav>
          <% } %>
        <% } else { %>
          <div class="no-events-message">
            <i data-lucide="calendar-x"></i>
            <h3>No published events yet</h3>
            <% if (filterMeta?.hasActiveFilters) { %>
              <p>No events matched your current filters.</p>
              <a href="/events" class="btn btn-secondary">Clear filters</a>
            <% } else { %>
              <p>Check back soon for newly published races.</p>
            <% } %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
