<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/events.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <% if (loginSuccess && userName) { %>
    <div class="toast toast-success">
      <i data-lucide="check-circle"></i>
      <span>Welcome back, <strong><%= userName %></strong>.</span>
    </div>
  <% } %>

  <main class="main-content">
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <h1>Published Events</h1>
        <p>Explore active helloRun races and pick your next challenge.</p>
        <% if (locals.isAuthenticated) { %>
          <a href="/my-registrations" class="btn btn-outline">My Registrations</a>
        <% } %>
      </div>
    </section>

    <!-- Events Section -->
    <section class="events-section">
      <div class="container">
        <!-- Filter Bar -->
        <form method="GET" action="/events" class="filter-bar">
          <div class="filter-group">
            <label for="eventsSearch" class="sr-only">Search</label>
            <div class="search-wrapper">
              <i data-lucide="search"></i>
              <input
                id="eventsSearch"
                type="search"
                name="q"
                value="<%= filters?.q || '' %>"
                placeholder="Search events..."
              >
            </div>
          </div>

          <div class="filter-group">
            <label for="eventsMode">Mode</label>
            <select id="eventsMode" name="eventType">
              <option value="">All Modes</option>
              <option value="virtual" <%= filters?.eventType === 'virtual' ? 'selected' : '' %>>Virtual</option>
              <option value="onsite" <%= filters?.eventType === 'onsite' ? 'selected' : '' %>>On-site</option>
              <option value="hybrid" <%= filters?.eventType === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
            </select>
          </div>

          <div class="filter-group">
            <label for="eventsDistance">Distance</label>
            <select id="eventsDistance" name="distance">
              <option value="">All Distances</option>
              <% (filterMeta?.distanceOptions || []).forEach((distanceItem) => { %>
                <option value="<%= distanceItem %>" <%= filters?.distance === distanceItem ? 'selected' : '' %>><%= distanceItem %></option>
              <% }) %>
            </select>
          </div>

          <div class="filter-group">
            <label for="eventsStatus">Status</label>
            <select id="eventsStatus" name="status">
              <option value="all" <%= (filters?.status || 'all') === 'all' ? 'selected' : '' %>>All</option>
              <option value="upcoming" <%= filters?.status === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
              <option value="open" <%= filters?.status === 'open' ? 'selected' : '' %>>Open</option>
              <option value="closed" <%= filters?.status === 'closed' ? 'selected' : '' %>>Closed</option>
            </select>
          </div>

          <div class="filter-actions">
            <button type="submit" class="btn btn-primary">Apply</button>
            <% if (filterMeta?.hasActiveFilters) { %>
              <a href="/events" class="btn btn-outline">Clear</a>
            <% } %>
          </div>
        </form>

        <!-- Results Meta -->
        <p class="results-meta">
          Showing <strong><%= filterMeta?.resultsCount || 0 %></strong> event<%= (filterMeta?.resultsCount || 0) === 1 ? '' : 's' %><%= filterMeta?.hasActiveFilters ? ` with ${filterMeta.activeFilterCount} active filter${filterMeta.activeFilterCount === 1 ? '' : 's'}` : '' %>.
        </p>

        <!-- Event Cards -->
        <% if (events && events.length) { %>
          <div class="card-grid">
            <% events.forEach((event) => { %>
              <article class="card">
                <% if (event.bannerImageUrl) { %>
                  <a href="/events/<%= event.slug %>" class="card-image-link">
                    <img class="card-image" src="<%= event.bannerImageUrl %>" alt="<%= event.title %> banner">
                  </a>
                <% } %>

                <div class="card-content">
                  <div class="card-tags">
                    <span class="tag"><%= event.eventType || 'event' %></span>
                    <span class="tag tag-muted"><%= (event.eventTypesAllowed || []).join(' / ') || 'N/A' %></span>
                  </div>

                  <h3 class="card-title">
                    <a href="/events/<%= event.slug %>"><%= event.title %></a>
                  </h3>

                  <div class="card-meta">
                    <i data-lucide="calendar"></i>
                    <span><%= event.eventStartAt ? new Date(event.eventStartAt).toLocaleString('en-US') : 'Start date TBA' %></span>
                  </div>

                  <div class="card-meta">
                    <i data-lucide="map-pin"></i>
                    <span><%= [event.venueName, event.city, event.countryLabel].filter(Boolean).join(', ') || 'Location TBA' %></span>
                  </div>

                  <div class="card-meta">
                    <i data-lucide="flag"></i>
                    <span><%= (event.raceDistances || []).join(', ') || 'Distances TBA' %></span>
                  </div>

                  <p class="card-description"><%= event.description || 'No event description available.' %></p>

                  <div class="card-actions">
                    <a href="/events/<%= event.slug %>" class="btn btn-primary btn-sm">View Event</a>
                  </div>
                </div>
              </article>
            <% }); %>
          </div>

          <!-- Pagination -->
          <% if (pagination && pagination.totalPages > 1) { %>
            <% const params = new URLSearchParams({
              q: filters?.q || '',
              eventType: filters?.eventType || '',
              distance: filters?.distance || '',
              status: filters?.status || 'all'
            }); %>
            <% const basePageUrl = `/events?${params.toString()}`; %>
            <p class="results-meta">Page <%= pagination.currentPage %> of <%= pagination.totalPages %></p>
            <nav class="pagination" aria-label="Events pagination">
              <a
                href="<%= basePageUrl %>&page=<%= Math.max(1, pagination.currentPage - 1) %>"
                class="pagination-prev <%= pagination.currentPage === 1 ? 'disabled' : '' %>"
                <%= pagination.currentPage === 1 ? 'aria-disabled="true" tabindex="-1"' : '' %>
              >
                <i data-lucide="chevron-left"></i> Previous
              </a>

              <div class="pagination-numbers">
                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                  <% if (i === 1 || i === pagination.totalPages || (i >= pagination.currentPage - 1 && i <= pagination.currentPage + 1)) { %>
                    <a
                      href="<%= basePageUrl %>&page=<%= i %>"
                      class="events-page-number<%= i === pagination.currentPage ? ' active' : '' %>"
                      <%= i === pagination.currentPage ? 'aria-current="page"' : '' %>
                    >
                      <%= i %>
                    </a>
                  <% } else if (i === pagination.currentPage - 2 || i === pagination.currentPage + 2) { %>
                    <span class="pagination-ellipsis">…</span>
                  <% } %>
                <% } %>
              </div>

              <a
                href="<%= basePageUrl %>&page=<%= Math.min(pagination.totalPages, pagination.currentPage + 1) %>"
                class="pagination-next <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>"
                <%= pagination.currentPage === pagination.totalPages ? 'aria-disabled="true" tabindex="-1"' : '' %>
              >
                Next <i data-lucide="chevron-right"></i>
              </a>
            </nav>
          <% } %>

        <% } else { %>
          <div class="empty-state">
            <i data-lucide="calendar-x"></i>
            <h3>No published events yet</h3>
            <% if (filterMeta?.hasActiveFilters) { %>
              <p>No events matched your current filters.</p>
              <a href="/events" class="btn btn-outline">Clear filters</a>
            <% } else { %>
              <p>Check back soon for newly published races.</p>
            <% } %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
