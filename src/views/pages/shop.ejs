<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title, seo: typeof seo !== 'undefined' ? seo : null }) %>
  <link rel="stylesheet" href="/css/shop.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="shop-page">
    <section class="shop-header">
      <div>
        <p class="shop-eyebrow">Shop</p>
        <h1>HelloRun Shop</h1>
      </div>
    </section>

    <section class="shop-content" aria-label="Shop catalog">
      <% if (message) { %>
        <div class="page-message page-message-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <form method="GET" action="/shop" class="shop-filter-bar">
        <div class="shop-filter-search">
          <label for="shopSearchInput">Search products</label>
          <div class="shop-search-wrapper">
            <input
              id="shopSearchInput"
              type="search"
              name="q"
              value="<%= filters.q || '' %>"
              placeholder="Search by product or category..."
            >
            <i data-lucide="search"></i>
          </div>
        </div>
        <% if (filters.event) { %><input type="hidden" name="event" value="<%= filters.event %>"><% } %>
        <button type="submit" class="btn btn-outline">
          <i data-lucide="search" aria-hidden="true"></i>
          <span>Search</span>
        </button>
      </form>

      <% if (filteredEvent) { %>
        <p>
          <span class="shop-active-filter-chip">
            <i data-lucide="calendar" aria-hidden="true"></i>
            <span>Browsing: <%= filteredEvent.title %></span>
            <a href="/shop<%= filters.q ? `?q=${encodeURIComponent(filters.q)}` : '' %>" aria-label="Clear event filter"><i data-lucide="x"></i></a>
          </span>
        </p>
      <% } %>

      <% if (products.length) { %>
        <p class="shop-results-meta"><%= totalCount %> <%= totalCount === 1 ? 'product' : 'products' %> found<% if (filters.q) { %> for "<%= filters.q %>"<% } %></p>

        <%- include('../partials/ad-unit', { group: 'shopDiscovery', placement: 'after_results_meta' }) %>

        <div class="shop-product-grid">
          <% products.forEach((product) => { %>
            <article class="shop-product-card">
              <a href="<%= product.detailUrl %>" class="shop-product-media" aria-label="View <%= product.name %>">
                <i data-lucide="package"></i>
              </a>
              <div class="shop-product-body">
                <div>
                  <% if (product.eventTitle) { %>
                    <a href="/events/<%= product.eventSlug %>/shop" class="shop-event-badge"><i data-lucide="calendar" aria-hidden="true"></i><span><%= product.eventTitle %></span></a>
                  <% } %>
                  <h2><a href="<%= product.detailUrl %>"><%= product.name %></a></h2>
                  <% if (product.category) { %><p><%= product.category %></p><% } %>
                </div>
                <div class="shop-product-footer">
                  <strong><%= product.priceLabel %></strong>
                  <a class="btn btn-outline" href="<%= product.detailUrl %>"><i data-lucide="eye"></i><span>View</span></a>
                </div>
              </div>
            </article>
          <% }) %>
        </div>

        <% if (pagination.totalPages > 1) { %>
          <nav class="shop-pagination" aria-label="Shop pagination">
            <a
              href="<%= pagination.getPageUrl(Math.max(1, pagination.currentPage - 1)) %>"
              class="shop-pagination-prev <%= pagination.currentPage === 1 ? 'disabled' : '' %>"
              <%= pagination.currentPage === 1 ? 'aria-disabled="true" tabindex="-1"' : '' %>
            >
              <i data-lucide="chevron-left"></i> Previous
            </a>

            <div class="shop-pagination-numbers">
              <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                <% if (i === 1 || i === pagination.totalPages || (i >= pagination.currentPage - 1 && i <= pagination.currentPage + 1)) { %>
                  <a
                    href="<%= pagination.getPageUrl(i) %>"
                    class="shop-pagination-number<%= i === pagination.currentPage ? ' active' : '' %>"
                    <%= i === pagination.currentPage ? 'aria-current="page"' : '' %>
                  ><%= i %></a>
                <% } else if (i === pagination.currentPage - 2 || i === pagination.currentPage + 2) { %>
                  <span class="shop-pagination-ellipsis">&hellip;</span>
                <% } %>
              <% } %>
            </div>

            <a
              href="<%= pagination.getPageUrl(Math.min(pagination.totalPages, pagination.currentPage + 1)) %>"
              class="shop-pagination-next <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>"
              <%= pagination.currentPage === pagination.totalPages ? 'aria-disabled="true" tabindex="-1"' : '' %>
            >
              Next <i data-lucide="chevron-right"></i>
            </a>
          </nav>
        <% } %>
      <% } else { %>
        <section class="shop-empty-state">
          <i data-lucide="shopping-bag"></i>
          <% if (filters.q || filters.event) { %>
            <h2>No matching products</h2>
            <p>Try a different search term<% if (filteredEvent) { %> or clear the event filter<% } %>.</p>
            <a href="/shop" class="btn btn-outline"><i data-lucide="x"></i><span>Clear filters</span></a>
          <% } else { %>
            <h2>No shop items yet</h2>
            <p>Event organisers haven't published any shop products yet. Check back soon.</p>
            <a href="/events" class="btn btn-outline"><i data-lucide="arrow-left"></i><span>Browse Events</span></a>
          <% } %>
        </section>
      <% } %>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
