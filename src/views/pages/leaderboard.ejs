<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title }) %>
  <link rel="stylesheet" href="/css/leaderboard.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="leaderboard-page">
    <section class="leaderboard-shell">
      <header class="leaderboard-header">
        <h1>Leaderboard</h1>
        <p>Rankings from approved submissions across helloRun events.</p>
      </header>

      <form method="GET" action="/leaderboard" class="leaderboard-filters">
        <div class="leaderboard-filter-field">
          <label for="event">
            <i data-lucide="calendar-days" aria-hidden="true"></i>
            <span>Event</span>
          </label>
          <select id="event" name="event">
            <option value="" <%= !leaderboard.filters.eventId ? 'selected' : '' %>>All</option>
            <% (leaderboard.options.events || []).forEach((event) => { %>
              <option value="<%= event.id %>" <%= leaderboard.filters.eventId === event.id ? 'selected' : '' %>>
                <%= event.title %> (<%= event.approvedCount %>)
              </option>
            <% }) %>
          </select>
        </div>

        <div class="leaderboard-filter-field">
          <label for="distance">
            <i data-lucide="ruler" aria-hidden="true"></i>
            <span>Distance</span>
          </label>
          <select id="distance" name="distance">
            <option value="" <%= !leaderboard.filters.distance ? 'selected' : '' %>>All</option>
            <% (leaderboard.options.distances || []).forEach((distance) => { %>
              <option value="<%= distance %>" <%= leaderboard.filters.distance === distance ? 'selected' : '' %>><%= distance %></option>
            <% }) %>
          </select>
        </div>

        <div class="leaderboard-filter-field">
          <label for="mode">
            <i data-lucide="monitor-smartphone" aria-hidden="true"></i>
            <span>Mode</span>
          </label>
          <select id="mode" name="mode">
            <option value="" <%= !leaderboard.filters.mode ? 'selected' : '' %>>All</option>
            <% (leaderboard.options.modes || []).forEach((mode) => { %>
              <option value="<%= mode %>" <%= leaderboard.filters.mode === mode ? 'selected' : '' %>><%= mode %></option>
            <% }) %>
          </select>
        </div>

        <div class="leaderboard-filter-field">
          <label for="period">
            <i data-lucide="clock-3" aria-hidden="true"></i>
            <span>Period</span>
          </label>
          <select id="period" name="period">
            <option value="all" <%= leaderboard.filters.period === 'all' ? 'selected' : '' %>>All time</option>
            <option value="7d" <%= leaderboard.filters.period === '7d' ? 'selected' : '' %>>Last 7 days</option>
            <option value="30d" <%= leaderboard.filters.period === '30d' ? 'selected' : '' %>>Last 30 days</option>
            <option value="90d" <%= leaderboard.filters.period === '90d' ? 'selected' : '' %>>Last 90 days</option>
          </select>
        </div>

        <% if (filterMeta?.hasActiveFilters) { %>
          <div class="leaderboard-filter-actions">
            <a href="/leaderboard" class="btn btn-secondary leaderboard-action-btn">
              <i data-lucide="rotate-ccw" aria-hidden="true"></i>
              <span>Clear filters</span>
            </a>
          </div>
        <% } %>
      </form>

      <p class="leaderboard-results-meta">
        Showing <strong><%= leaderboard.stats.totalShown %></strong> ranked result<%= leaderboard.stats.totalShown === 1 ? '' : 's' %>
        from <strong><%= leaderboard.stats.totalApproved %></strong> approved submission<%= leaderboard.stats.totalApproved === 1 ? '' : 's' %><%= filterMeta?.hasActiveFilters ? ` with ${filterMeta.activeFilterCount} active filter${filterMeta.activeFilterCount === 1 ? '' : 's'}` : '' %>.
      </p>

      <% if (leaderboard.entries && leaderboard.entries.length) { %>
        <div class="leaderboard-table-wrap">
          <table class="leaderboard-table">
            <thead>
              <tr>
                <th>Rank</th>
                <th>Runner</th>
                <th>Event</th>
                <th>Distance</th>
                <th>Mode</th>
                <th>Time</th>
                <th>Submitted</th>
              </tr>
            </thead>
            <tbody>
              <% leaderboard.entries.forEach((entry) => { %>
                <tr>
                  <td class="leaderboard-rank-cell" data-label="Rank">
                    <span class="leaderboard-rank-badge">#<%= entry.rank %></span>
                  </td>
                  <td class="leaderboard-runner-cell" data-label="Runner"><%= entry.runnerName %></td>
                  <td class="leaderboard-event-cell" data-label="Event">
                    <% if (entry.eventSlug) { %>
                      <a href="/events/<%= entry.eventSlug %>"><%= entry.eventTitle %></a>
                    <% } else { %>
                      <%= entry.eventTitle %>
                    <% } %>
                  </td>
                  <td data-label="Distance"><%= entry.raceDistance %></td>
                  <td data-label="Mode"><%= entry.participationMode %></td>
                  <td class="leaderboard-time-cell" data-label="Time"><strong><%= entry.elapsedLabel %></strong></td>
                  <td data-label="Submitted"><%= entry.submittedAt ? new Date(entry.submittedAt).toLocaleString('en-US') : 'N/A' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h2>No leaderboard entries yet</h2>
          <p><%= filterMeta?.hasActiveFilters ? 'No entries matched your selected filters.' : 'Approved result submissions will appear here.' %></p>
          <% if (filterMeta?.hasActiveFilters) { %>
            <a href="/leaderboard" class="btn btn-secondary leaderboard-action-btn">
              <i data-lucide="rotate-ccw" aria-hidden="true"></i>
              <span>Clear filters</span>
            </a>
          <% } %>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    if (window.lucide) lucide.createIcons();

    const leaderboardFilters = document.querySelector('.leaderboard-filters');
    if (leaderboardFilters) {
      leaderboardFilters.querySelectorAll('select').forEach((select) => {
        select.addEventListener('change', () => {
          if (typeof leaderboardFilters.requestSubmit === 'function') {
            leaderboardFilters.requestSubmit();
            return;
          }
          leaderboardFilters.submit();
        });
      });
    }
  </script>
</body>
</html>
