<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title }) %>
  <link rel="stylesheet" href="/css/leaderboard.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="leaderboard-page">
    <section class="leaderboard-shell leaderboard-discovery-shell">
      <header class="leaderboard-header leaderboard-discovery-header">
        <div>
          <p class="leaderboard-card-kicker">Event Results</p>
          <h1>Find Event Leaderboards</h1>
          <p>Choose an event to view official rankings, your standing, nearby runners, search, and verification status.</p>
        </div>
        <div class="leaderboard-discovery-summary" aria-label="Leaderboard summary">
          <strong><%= leaderboard.stats.totalShown %></strong>
          <span>leaderboard event<%= leaderboard.stats.totalShown === 1 ? '' : 's' %> shown</span>
        </div>
      </header>

      <form method="GET" action="/leaderboard" class="leaderboard-filters leaderboard-discovery-filters">
        <div class="leaderboard-filter-field leaderboard-search-field">
          <label for="q">
            <i data-lucide="search" aria-hidden="true"></i>
            <span>Search event or organiser</span>
          </label>
          <input id="q" name="q" type="search" value="<%= leaderboard.filters.q || '' %>" placeholder="Event or organiser name">
        </div>

        <div class="leaderboard-filter-field">
          <label for="type">
            <i data-lucide="trophy" aria-hidden="true"></i>
            <span>Leaderboard type</span>
          </label>
          <select id="type" name="type">
            <option value="" <%= !leaderboard.filters.type ? 'selected' : '' %>>All types</option>
            <% (leaderboard.options.types || []).forEach((typeOption) => { %>
              <option value="<%= typeOption.value %>" <%= leaderboard.filters.type === typeOption.value ? 'selected' : '' %>><%= typeOption.label %></option>
            <% }) %>
          </select>
        </div>

        <div class="leaderboard-filter-field">
          <label for="distance">
            <i data-lucide="ruler" aria-hidden="true"></i>
            <span>Distance</span>
          </label>
          <select id="distance" name="distance">
            <option value="" <%= !leaderboard.filters.distance ? 'selected' : '' %>>All distances</option>
            <% (leaderboard.options.distances || []).forEach((distance) => { %>
              <option value="<%= distance %>" <%= leaderboard.filters.distance === distance ? 'selected' : '' %>><%= distance %></option>
            <% }) %>
          </select>
        </div>

        <div class="leaderboard-filter-field">
          <label for="mode">
            <i data-lucide="monitor-smartphone" aria-hidden="true"></i>
            <span>Mode</span>
          </label>
          <select id="mode" name="mode">
            <option value="" <%= !leaderboard.filters.mode ? 'selected' : '' %>>All modes</option>
            <option value="virtual" <%= leaderboard.filters.mode === 'virtual' ? 'selected' : '' %>>Virtual</option>
            <option value="onsite" <%= leaderboard.filters.mode === 'onsite' ? 'selected' : '' %>>Onsite</option>
          </select>
        </div>

        <div class="leaderboard-filter-actions">
          <button type="submit" class="btn btn-primary leaderboard-action-btn">
            <i data-lucide="filter" aria-hidden="true"></i>
            <span>Apply</span>
          </button>
          <% if (filterMeta?.hasActiveFilters) { %>
            <a href="/leaderboard" class="btn btn-secondary leaderboard-action-btn">
              <i data-lucide="rotate-ccw" aria-hidden="true"></i>
              <span>Clear filters</span>
            </a>
          <% } %>
        </div>
      </form>

      <p class="leaderboard-results-meta">
        Official ranks are event-specific. <strong><%= leaderboard.stats.totalVerifiedResults %></strong> verified result<%= leaderboard.stats.totalVerifiedResults === 1 ? '' : 's' %>
        currently count toward these public leaderboards<%= filterMeta?.hasActiveFilters ? ` with ${filterMeta.activeFilterCount} active filter${filterMeta.activeFilterCount === 1 ? '' : 's'}` : '' %>.
      </p>

      <% if (leaderboard.cards && leaderboard.cards.length) { %>
        <%- include('../partials/ad-unit', { group: 'leaderboard', placement: 'after_results_meta' }) %>
      <% } %>

      <% if (leaderboard.cards && leaderboard.cards.length) { %>
        <section class="leaderboard-discovery-grid" aria-label="Event leaderboards">
          <% let leaderboardFeedAdCount = 0; %>
          <% leaderboard.cards.forEach((card, cardIndex) => { %>
            <article class="leaderboard-discovery-card">
              <a class="leaderboard-discovery-image-link" href="<%= card.href %>" aria-label="View rankings for <%= card.title %>">
                <img src="<%= card.imageUrl %>" alt="" loading="lazy">
              </a>
              <div class="leaderboard-discovery-card-body">
                <div class="leaderboard-discovery-card-top">
                  <span class="leaderboard-status-badge leaderboard-status-verified"><%= card.leaderboardTypeLabel %></span>
                  <span><%= card.modeLabel %></span>
                </div>
                <h2><a href="<%= card.href %>"><%= card.title %></a></h2>
                <p class="leaderboard-discovery-organiser"><%= card.organiserName || 'HelloRun organiser' %></p>
                <p class="leaderboard-discovery-rule"><%= card.rankingExplanation %> Official rankings include verified submissions only.</p>
                <dl class="leaderboard-discovery-stats">
                  <div><dt>Verified</dt><dd><%= card.verifiedCount %></dd></div>
                  <div><dt>Pending</dt><dd><%= card.pendingCount %></dd></div>
                  <div><dt>Distances</dt><dd><%= card.distanceLabel %></dd></div>
                  <div><dt>Dates</dt><dd><%= card.dateLabel %></dd></div>
                </dl>
                <p class="leaderboard-discovery-updated">Last updated: <%= card.lastUpdatedLabel %></p>
                <div class="leaderboard-discovery-actions">
                  <a href="<%= card.href %>" class="btn btn-primary leaderboard-action-btn">View rankings</a>
                  <a href="<%= card.eventHref %>" class="btn btn-secondary leaderboard-action-btn">View event details</a>
                </div>
              </div>
            </article>
            <% if ((cardIndex + 1) % 6 === 0 && leaderboardFeedAdCount < 2) { leaderboardFeedAdCount += 1; %>
              <%- include('../partials/ad-unit', { group: 'leaderboard', placement: 'in_feed', className: 'ad-unit-feed' }) %>
            <% } %>
          <% }) %>
        </section>
      <% } else { %>
        <div class="empty-state leaderboard-discovery-empty">
          <h2>No event leaderboards found</h2>
          <p><%= filterMeta?.hasActiveFilters ? 'No leaderboard-enabled events matched your filters.' : 'Leaderboard-enabled public events will appear here once organisers publish them.' %></p>
          <% if (filterMeta?.hasActiveFilters) { %>
            <a href="/leaderboard" class="btn btn-secondary leaderboard-action-btn">
              <i data-lucide="rotate-ccw" aria-hidden="true"></i>
              <span>Clear filters</span>
            </a>
          <% } %>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    if (window.lucide) lucide.createIcons();
  </script>
</body>
</html>
