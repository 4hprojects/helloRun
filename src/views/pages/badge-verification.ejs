<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title, seo }) %>
  <% if (typeof openBadgeUrl !== 'undefined' && openBadgeUrl) { %>
    <link rel="alternate" type="application/json" title="Open Badges metadata" href="<%= openBadgeUrl %>">
  <% } %>
  <% if (typeof openBadgeMetadata !== 'undefined' && openBadgeMetadata) { %>
    <script type="application/ld+json"><%- JSON.stringify(openBadgeMetadata) %></script>
  <% } %>
  <link rel="stylesheet" href="/css/badge-verification.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="badge-verification-page">
    <section class="badge-verify-hero" aria-labelledby="badge-title">
      <div class="badge-verify-wrap">
        <div class="badge-verify-card">
          <div class="badge-verify-mark" aria-hidden="true">
            <% if (badge.imageUrl) { %>
              <img src="<%= badge.imageUrl %>" alt="">
            <% } else { %>
              <i data-lucide="award"></i>
            <% } %>
          </div>
          <div class="badge-verify-copy">
            <span class="badge-verify-status"><i data-lucide="badge-check"></i> Verified Badge</span>
            <h1 id="badge-title"><%= badge.name %></h1>
            <p><%= badge.description || 'Verified HelloRun achievement.' %></p>
          </div>
        </div>

        <aside class="badge-verify-panel" aria-label="Verification details">
          <div>
            <span>Earned by</span>
            <strong><%= badge.runnerName %></strong>
          </div>
          <% if (badge.eventTitle) { %>
            <div>
              <span>Event</span>
              <% if (badge.eventSlug) { %>
                <strong><a href="/events/<%= badge.eventSlug %>"><%= badge.eventTitle %></a></strong>
              <% } else { %>
                <strong><%= badge.eventTitle %></strong>
              <% } %>
            </div>
          <% } else { %>
            <div>
              <span>Scope</span>
              <strong>Global HelloRun achievement</strong>
            </div>
          <% } %>
          <% if (badge.points > 0) { %>
            <div>
              <span>Points</span>
              <strong><%= badge.points %></strong>
            </div>
          <% } %>
          <div>
            <span>Evidence</span>
            <strong><%= badge.evidenceLabel %></strong>
          </div>
          <div>
            <span>Awarded</span>
            <strong><%= formatDateOnly(badge.earnedAt) %></strong>
          </div>
          <div>
            <span>Verification ID</span>
            <strong><%= badge.verificationCode %></strong>
          </div>
        </aside>
      </div>
    </section>

    <section class="badge-share-section" aria-label="Share badge">
      <div class="badge-share-wrap">
        <div>
          <h2>Share This Badge</h2>
          <p>This public page confirms that the badge is currently verified in HelloRun.</p>
        </div>
        <div class="badge-share-actions">
          <a href="<%= facebookShareUrl %>" target="_blank" rel="noopener noreferrer" class="badge-share-btn" aria-label="Share on Facebook" title="Share on Facebook"><i data-lucide="share-2"></i></a>
          <a href="<%= xShareUrl %>" target="_blank" rel="noopener noreferrer" class="badge-share-btn" aria-label="Share on X" title="Share on X"><i data-lucide="at-sign"></i></a>
          <a href="<%= linkedInShareUrl %>" target="_blank" rel="noopener noreferrer" class="badge-share-btn" aria-label="Share on LinkedIn" title="Share on LinkedIn"><i data-lucide="link"></i></a>
          <a href="<%= mailShareUrl %>" class="badge-share-btn" aria-label="Share by email" title="Share by email"><i data-lucide="mail"></i></a>
          <% if (typeof openBadgeUrl !== 'undefined' && openBadgeUrl) { %>
            <a href="<%= openBadgeUrl %>" class="badge-share-btn" aria-label="Open badge metadata" title="Open badge metadata"><i data-lucide="braces"></i></a>
          <% } %>
          <a href="<%= badgeUrl %>" class="badge-share-link"><%= badgeUrl %></a>
        </div>
      </div>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>
