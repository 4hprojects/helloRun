<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title, seo: typeof seo !== 'undefined' ? seo : null }) %>
  <link rel="stylesheet" href="/css/events.css">
  <link rel="stylesheet" href="/css/event-details.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="event-details-page">
    <%
      const details = publicEvent || {};
      const registrationToneClass = details.registrationState ? `event-status-${details.registrationState.tone}` : 'event-status-neutral';
      const defaultEventImageUrl = '/images/helloRun-icon.webp';
      const heroImageUrl = details.heroImageUrl || defaultEventImageUrl;
      const isPreviewMode = Boolean(typeof previewMode !== 'undefined' && previewMode);
      const previewReturnHref = typeof previewBackHref !== 'undefined' && previewBackHref ? previewBackHref : '/organizer/create-event';
      const previewErrorsRaw = typeof previewErrors !== 'undefined' ? previewErrors : [];
      const previewErrorMessages = Array.isArray(previewErrorsRaw)
        ? previewErrorsRaw
        : Object.values(previewErrorsRaw || {});
      const registrationOptionItems = Array.isArray(details.raceDistances)
        ? details.raceDistances.map((item) => String(item || '').trim()).filter(Boolean)
        : [];
      const showRegistrationOptionBullets = Boolean(
        details.isAccumulatedChallenge &&
        registrationOptionItems.length > 1
      );
    %>

    <% if (isPreviewMode) { %>
      <section class="event-preview-notice" role="status" aria-label="Event preview status">
        <div>
          <strong>Preview mode</strong>
          <span>This is the same public event page participants will see. File selections only appear here after they have been uploaded.</span>
        </div>
        <a href="<%= previewReturnHref %>" class="btn btn-outline"><i data-lucide="arrow-left"></i><span>Back to Editor</span></a>
      </section>
      <% if (previewErrorMessages.length) { %>
        <section class="event-preview-errors" aria-label="Preview validation issues">
          <strong>Some required details still need attention before this event can be submitted.</strong>
          <ul>
            <% previewErrorMessages.forEach((message) => { %>
              <li><%= message %></li>
            <% }) %>
          </ul>
        </section>
      <% } %>
    <% } %>

    <section class="event-landing-hero" style="--event-hero-image: url('<%= heroImageUrl %>');">
      <div class="event-landing-hero-overlay"></div>
      <div class="event-landing-hero-inner">
        <div class="event-hero-copy">
          <div class="event-hero-meta-row">
            <div class="event-chip-row">
              <span class="event-chip event-chip-solid"><%= details.eventTypeLabel || 'Event' %></span>
              <% if (details.isAccumulatedChallenge) { %>
                <span class="event-chip event-chip-solid">Accumulated Challenge</span>
              <% } %>
              <span class="event-chip event-chip-status <%= registrationToneClass %>"><%= details.registrationState?.label || 'Event Listing' %></span>
            </div>

          </div>

          <p class="event-organizer">Hosted by <%= details.organizerName || 'HelloRun' %></p>
          <h1><%= details.title %></h1>
          <p class="event-lead"><%= details.description || 'View event details, registration timing, and completion rules.' %></p>

          <div class="event-hero-actions">
            <% if (details.primaryCta && !details.primaryCta.disabled) { %>
              <a href="<%= details.primaryCta.href %>" class="btn btn-primary"><i data-lucide="ticket"></i><span><%= details.primaryCta.label %></span></a>
            <% } else { %>
              <button type="button" class="btn btn-outline btn-hero-disabled" disabled><%= details.primaryCta?.label || 'Registration Unavailable' %></button>
            <% } %>
            <% if (isPreviewMode) { %>
              <a href="<%= previewReturnHref %>" class="btn btn-outline btn-hero-secondary"><i data-lucide="arrow-left"></i><span>Back to Editor</span></a>
            <% } else { %>
              <a href="/events" class="btn btn-outline btn-hero-secondary"><i data-lucide="search"></i><span>Browse Events</span></a>
            <% } %>
          </div>
        </div>

        <aside class="event-hero-panel">
          <p class="event-panel-label"><%= details.pricing?.label || 'Pricing' %></p>
          <strong><%= details.pricing?.amountLabel || 'TBA' %></strong>
          <span><%= details.pricing?.helper || details.registrationState?.helper || '' %></span>
          <% if (details.registrationState?.helper) { %>
            <div class="event-panel-divider"></div>
            <p class="event-panel-label">Registration</p>
            <span><%= details.registrationState.helper %></span>
          <% } %>
        </aside>
      </div>
    </section>

    <section class="event-details-shell">
      <div class="event-nav-row">
        <% if (isPreviewMode) { %>
          <a href="<%= previewReturnHref %>" class="btn btn-outline"><i data-lucide="arrow-left"></i><span>Back to Editor</span></a>
        <% } else { %>
          <a href="/events" class="btn btn-outline"><i data-lucide="arrow-left"></i><span>Back to Events</span></a>
        <% } %>
        <% if (!isPreviewMode && eventShop && eventShop.count > 0) { %>
          <a href="<%= eventShop.href %>" class="btn btn-outline"><i data-lucide="shopping-bag"></i><span>Event Shop</span></a>
        <% } %>
        <% if (locals.isAuthenticated) { %>
          <a href="/my-registrations" class="btn btn-outline"><i data-lucide="badge-check"></i><span>My Registrations</span></a>
        <% } %>
      </div>

      <section class="event-stats-strip" aria-label="Event highlights">
        <% (details.stats || []).forEach((stat) => { %>
          <% const useRegistrationOptionBullets = showRegistrationOptionBullets && stat.label === 'Registration Options'; %>
          <article class="event-stat">
            <span><%= stat.label %></span>
            <% if (useRegistrationOptionBullets) { %>
              <ul class="event-registration-option-bullets event-registration-option-bullets-stat">
                <% registrationOptionItems.forEach((option) => { %>
                  <li><%= option %></li>
                <% }) %>
              </ul>
            <% } else { %>
              <strong><%= stat.value %></strong>
            <% } %>
            <small><%= stat.helper %></small>
          </article>
        <% }) %>
      </section>

      <div class="event-main-layout">
        <div class="event-main-content">
          <section class="event-section">
            <div class="event-section-heading">
              <span class="event-section-icon"><i data-lucide="route"></i></span>
              <div>
                <h2>How This Event Works</h2>
                <p><%= details.isAccumulatedChallenge ? 'Build your distance over time. Approved submissions count toward your official progress.' : 'Register, complete the event, then submit your result for review.' %></p>
              </div>
            </div>

            <div class="event-mechanics-grid">
              <article>
                <span>1</span>
                <h3>Register</h3>
                <p>Choose your participation mode and confirm your runner profile.</p>
              </article>
              <article>
                <span>2</span>
                <h3>Complete Activities</h3>
                <p><%= details.virtualRules?.acceptedActivities?.length ? `Accepted activities: ${details.virtualRules.acceptedActivities.join(', ')}.` : 'Complete the configured event distance during the event window.' %></p>
              </article>
              <article>
                <span>3</span>
                <h3>Submit Proof</h3>
                <p><%= details.virtualRules?.proofTypes?.length ? `Proof accepted: ${details.virtualRules.proofTypes.join(', ')}.` : 'Submit your result through HelloRun for organizer review.' %></p>
              </article>
              <article>
                <span>4</span>
                <h3>Earn Recognition</h3>
                <p><%= details.virtualRules?.recognitionMode || 'Finishers receive the recognition configured for this event.' %></p>
              </article>
            </div>
          </section>

          <% if (details.isAccumulatedChallenge || details.virtualRules?.targetDistanceKm) { %>
            <section class="event-section event-goal-section">
              <div>
                <p class="event-section-kicker">Accumulated Completion Goal</p>
                <h2>Complete <%= details.targetDistanceLabel %></h2>
                <p>Only approved submissions count toward the official total. Keep submitting valid activities until your progress reaches the completion goal.</p>
                <% if (details.isAccumulatedChallenge && details.distanceSummaryLabel && details.distanceSummaryLabel !== details.targetDistanceLabel) { %>
                  <div class="event-goal-options">
                    <strong>Registration options:</strong>
                    <% if (showRegistrationOptionBullets) { %>
                      <ul class="event-registration-option-bullets">
                        <% registrationOptionItems.forEach((option) => { %>
                          <li><%= option %></li>
                        <% }) %>
                      </ul>
                      <p>These are runner-facing distance labels; completion is measured against the goal above.</p>
                    <% } else { %>
                      <p><%= details.distanceSummaryLabel %>. These are runner-facing distance labels; completion is measured against the goal above.</p>
                    <% } %>
                  </div>
                <% } %>
              </div>
              <div class="event-goal-panel">
                <strong><%= details.targetDistanceLabel %></strong>
                <span>Completion goal</span>
                <% if (details.isAccumulatedChallenge && details.distanceSummaryLabel && details.distanceSummaryLabel !== details.targetDistanceLabel) { %>
                  <% if (showRegistrationOptionBullets) { %>
                    <small>Options:</small>
                    <ul class="event-registration-option-bullets event-registration-option-bullets-compact">
                      <% registrationOptionItems.forEach((option) => { %>
                        <li><%= option %></li>
                      <% }) %>
                    </ul>
                  <% } else { %>
                    <small>Options: <%= details.distanceSummaryLabel %></small>
                  <% } %>
                <% } else { %>
                  <small><%= details.virtualRules?.completionMode || 'Completion goal' %></small>
                <% } %>
                <% if (details.virtualRules?.minimumDistance) { %><small><%= details.virtualRules.minimumDistance %></small><% } %>
              </div>
            </section>
          <% } %>

          <% if ((details.raceCategories || []).length) { %>
            <section class="event-section">
              <div class="event-section-heading">
                <span class="event-section-icon"><i data-lucide="list-checks"></i></span>
                <div>
                  <h2>Race Categories</h2>
                  <p>Choose the category that matches your distance, eligibility, and event goal.</p>
                </div>
              </div>

              <div class="event-package-grid">
                <% details.raceCategories.forEach((category) => { %>
                  <article>
                    <h3><%= category.name %></h3>
                    <strong><%= category.typeLabel %></strong>
                    <% if (category.summary) { %><p><%= category.summary %></p><% } %>
                    <% if (category.rewardsDescription) { %><small><%= category.rewardsDescription %></small><% } %>
                  </article>
                <% }) %>
              </div>
            </section>
          <% } %>

          <section class="event-section">
            <div class="event-section-heading">
              <span class="event-section-icon"><i data-lucide="gift"></i></span>
              <div>
                <h2>Rewards & Recognition</h2>
                <p>What runners can expect after valid completion.</p>
              </div>
            </div>

            <% if ((details.rewardItems || []).length) { %>
              <div class="event-reward-grid">
                <% details.rewardItems.forEach((reward) => { %>
                  <article>
                    <i data-lucide="<%= reward.type === 'physical' ? 'package' : 'award' %>"></i>
                    <span><%= reward.label %></span>
                  </article>
                <% }) %>
              </div>
            <% } else { %>
              <p class="event-muted">Rewards have not been listed by the organizer yet.</p>
            <% } %>

            <% if (event.physicalRewardsDescription) { %>
              <p class="event-supporting-copy"><%= event.physicalRewardsDescription %></p>
            <% } %>

            <% const eventBadges = badges || []; %>
            <% if (eventBadges.length) { %>
              <div class="event-badge-grid" aria-label="Available achievement badges">
                <% eventBadges.forEach((badge) => { %>
                  <article class="event-badge-card">
                    <span class="event-badge-icon"><i data-lucide="award"></i></span>
                    <div>
                      <h3><%= badge.name %></h3>
                      <p><%= badge.description || 'Awarded after verified event activity.' %></p>
                      <small><%= badge.badgeType ? badge.badgeType.replace(/_/g, ' ') : 'achievement' %></small>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% } else if (event.digitalBadgeEnabled) { %>
              <div class="event-badge-empty">
                <i data-lucide="award"></i>
                <div>
                  <strong>Badges pending</strong>
                  <p>Achievement badges are enabled for this event but have not been generated yet.</p>
                </div>
              </div>
            <% } else { %>
              <div class="event-badge-empty">
                <i data-lucide="award"></i>
                <div>
                  <strong>Badges not enabled</strong>
                  <p>This event is not currently issuing digital achievement badges.</p>
                </div>
              </div>
            <% } %>
          </section>

          <% if ((details.pricingOptions || []).length || (details.packageOptions || []).length || details.pricing?.hasOptionalCosts) { %>
            <section class="event-section">
              <div class="event-section-heading">
                <span class="event-section-icon"><i data-lucide="shopping-bag"></i></span>
                <div>
                  <h2>Pricing & Registration Options</h2>
                  <p><%= details.pricing?.helper || 'Review registration and package details before joining.' %></p>
                </div>
              </div>

              <div class="event-pricing-summary">
                <strong><%= details.pricing?.amountLabel || 'TBA' %></strong>
                <span><%= details.pricing?.label || 'Pricing' %></span>
              </div>

              <% if ((details.pricingOptions || []).length) { %>
                <div class="event-package-grid">
                  <% details.pricingOptions.forEach((pricingOption) => { %>
                    <article>
                      <% if (pricingOption.pricingPeriodBadge) { %>
                        <small class="event-pricing-period-badge"><%= pricingOption.pricingPeriodBadge %></small>
                      <% } %>
                      <h3><%= pricingOption.label %></h3>
                      <strong><%= pricingOption.amountLabel %></strong>
                      <p><%= pricingOption.helper %></p>
                    </article>
                  <% }) %>
                </div>
              <% } %>

              <% if ((details.packageOptions || []).length) { %>
                <div class="event-package-grid">
                  <% details.packageOptions.forEach((packageOption) => { %>
                    <article>
                      <h3><%= packageOption.name %></h3>
                      <strong><%= packageOption.amountLabel %></strong>
                      <% if (packageOption.includedItems.length) { %>
                        <p><%= packageOption.includedItems.join(', ') %></p>
                      <% } %>
                      <% if (packageOption.notes) { %><small><%= packageOption.notes %></small><% } %>
                    </article>
                  <% }) %>
                </div>
              <% } %>

              <% if (details.pricing?.deliveryAmount !== null && details.pricing?.deliveryAmount !== undefined) { %>
                <p class="event-supporting-copy">Delivery or claiming fee: <strong><%= details.pricing.currency || 'PHP' %> <%= Number(details.pricing.deliveryAmount || 0).toLocaleString('en-US') %></strong>.</p>
              <% } %>
            </section>
          <% } %>

          <section class="event-section">
            <div class="event-section-heading">
              <span class="event-section-icon"><i data-lucide="upload-cloud"></i></span>
              <div>
                <h2>Submission Rules</h2>
                <p>Use clear proof so the organizer can review your progress accurately.</p>
              </div>
            </div>

            <div class="event-rule-list">
              <p><strong>Event window</strong><span><%= details.virtualRules?.virtualWindowLabel || 'TBA' %></span></p>
              <p><strong>Accepted activities</strong><span><%= details.virtualRules?.acceptedActivities?.join(', ') || 'See event details' %></span></p>
              <p><strong>Proof types</strong><span><%= details.virtualRules?.proofTypes?.join(', ') || 'See event details' %></span></p>
              <p><strong>Final deadline</strong><span><%= details.virtualRules?.finalSubmissionDeadline || 'TBA' %></span></p>
              <p><strong>Leaderboard</strong><span><%= details.virtualRules?.leaderboardMode || 'N/A' %></span></p>
            </div>
          </section>

          <% if (eventDetailsHtml) { %>
            <section class="event-section event-details-description">
              <div class="event-section-heading">
                <span class="event-section-icon"><i data-lucide="file-text"></i></span>
                <div>
                  <h2>Full Event Details</h2>
                  <p>Organizer-published details, reminders, and event-specific rules.</p>
                </div>
              </div>
              <div class="event-rich-details"><%- eventDetailsHtml %></div>
            </section>
          <% } %>

          <% if ((details.galleryImageUrls || []).length) { %>
            <section class="event-section">
              <div class="event-section-heading">
                <span class="event-section-icon"><i data-lucide="images"></i></span>
                <div>
                  <h2>Gallery</h2>
                  <p>Visuals shared by the organizer for this event.</p>
                </div>
              </div>
              <div class="event-gallery-grid">
                <% details.galleryImageUrls.forEach((galleryUrl, galleryIndex) => { %>
                  <button
                    type="button"
                    class="event-gallery-thumb-btn"
                    data-gallery-index="<%= galleryIndex %>"
                    data-gallery-src="<%- galleryUrl %>"
                    aria-label="Open gallery image <%= galleryIndex + 1 %>"
                  >
                    <img class="event-gallery-image" src="<%= galleryUrl %>" alt="<%= details.title %> gallery image <%= galleryIndex + 1 %>">
                  </button>
                <% }) %>
              </div>
            </section>
          <% } %>
        </div>

        <aside class="event-side-panel">
          <section class="event-side-card event-register-card">
            <p class="event-side-eyebrow"><%= details.registrationState?.label || 'Registration' %></p>
            <h2><%= details.pricing?.amountLabel || 'TBA' %></h2>
            <p><%= details.registrationState?.helper || details.pricing?.helper || '' %></p>
            <% if (details.primaryCta && !details.primaryCta.disabled) { %>
              <a href="<%= details.primaryCta.href %>" class="btn btn-primary btn-block">Register Now</a>
            <% } else { %>
              <button type="button" class="btn btn-outline btn-block" disabled><%= details.primaryCta?.label || 'Registration Unavailable' %></button>
            <% } %>
          </section>

          <section class="event-side-card">
            <h3>Event Timeline</h3>
            <div class="event-timeline-list">
              <% (details.timeline || []).forEach((item) => { %>
                <p>
                  <i data-lucide="<%= item.icon %>"></i>
                  <span><strong><%= item.label %></strong><small><%= item.value %></small></span>
                </p>
              <% }) %>
            </div>
          </section>

          <section class="event-side-card event-detail-card">
            <h3>Event Details</h3>
            <div class="event-side-list">
              <% const registrationOptionsLabel = details.isAccumulatedChallenge ? ((details.raceDistances || []).length > 1 ? 'Registration Options' : 'Registration Option') : ((details.raceDistances || []).length > 1 ? 'Distances' : 'Distance'); %>
              <% if (showRegistrationOptionBullets) { %>
                <div class="event-side-list-row">
                  <strong><%= registrationOptionsLabel %></strong>
                  <div class="event-side-value">
                    <ul class="event-registration-option-bullets event-registration-option-bullets-side">
                      <% registrationOptionItems.forEach((option) => { %>
                        <li><%= option %></li>
                      <% }) %>
                    </ul>
                  </div>
                </div>
              <% } else { %>
                <p><strong><%= registrationOptionsLabel %></strong><span><%= details.distanceSummaryLabel || (details.raceDistances || []).join(', ') || details.targetDistanceLabel || 'TBA' %></span></p>
              <% } %>
              <% if ((details.raceCategories || []).length) { %>
                <% if (details.raceCategories.length > 2) { %>
                  <div class="event-side-list-row">
                    <strong>Categories</strong>
                    <div class="event-side-value">
                      <ul class="event-side-value-list">
                        <% details.raceCategories.forEach((category) => { %>
                          <li><%= category.name %></li>
                        <% }) %>
                      </ul>
                    </div>
                  </div>
                <% } else { %>
                  <p><strong>Categories</strong><span><%= details.raceCategories.map((category) => category.name).join(', ') %></span></p>
                <% } %>
              <% } %>
              <% if (details.isAccumulatedChallenge) { %>
                <p><strong>Completion Goal</strong><span><%= details.targetDistanceLabel || 'TBA' %></span></p>
              <% } %>
              <p><strong>Mode</strong><span><%= (details.allowedModes || []).join(' / ') || details.eventTypeLabel || 'TBA' %></span></p>
              <% if (details.showLocation) { %>
                <p><strong>Location</strong><span><%= details.location.summary %></span></p>
              <% } else { %>
                <p><strong>Location</strong><span>Anywhere</span></p>
              <% } %>
            </div>
          </section>

          <% if (details.posterImageUrl) { %>
            <section class="event-side-card">
              <h3>Event Poster</h3>
              <button
                type="button"
                class="event-poster-thumb-btn"
                data-poster-src="<%- details.posterImageUrl %>"
                aria-label="Open promotional poster"
              >
                <img class="event-details-poster-inline" src="<%= details.posterImageUrl %>" alt="<%= details.title %> promotional poster">
              </button>
            </section>
          <% } %>

          <% if (!isPreviewMode && eventShop && eventShop.count > 0) { %>
            <section class="event-side-card">
              <h3>Event Shop</h3>
              <p class="event-side-card-copy"><%= eventShop.count %> item<%= eventShop.count === 1 ? '' : 's' %> available for this event.</p>
              <a href="<%= eventShop.href %>" class="btn btn-outline btn-block"><i data-lucide="shopping-bag"></i><span>Browse Shop</span></a>
            </section>
          <% } %>
        </aside>
      </div>

      <section class="event-cta-row">
        <% if (details.primaryCta && !details.primaryCta.disabled) { %>
          <a href="<%= details.primaryCta.href %>" class="btn btn-primary">Register for This Event</a>
        <% } else { %>
          <button type="button" class="btn btn-outline" disabled><%= details.primaryCta?.label || 'Registration Unavailable' %></button>
        <% } %>
        <% if (isPreviewMode) { %>
          <a href="<%= previewReturnHref %>" class="btn btn-outline">Back to Editor</a>
        <% } else { %>
          <a href="/events" class="btn btn-outline">Browse Other Events</a>
        <% } %>
      </section>

      <div class="event-mobile-sticky-cta">
        <% if (details.primaryCta && !details.primaryCta.disabled) { %>
          <a href="<%= details.primaryCta.href %>" class="btn btn-primary btn-block">Register Now</a>
        <% } else { %>
          <button type="button" class="btn btn-outline btn-block" disabled><%= details.primaryCta?.label || 'Registration Unavailable' %></button>
        <% } %>
      </div>

      <% if ((details.galleryImageUrls || []).length) { %>
        <div id="galleryLightbox" class="gallery-lightbox hidden" aria-hidden="true">
          <div class="gallery-lightbox-backdrop" data-close-lightbox="1"></div>
          <div class="gallery-lightbox-dialog" role="dialog" aria-modal="true" aria-label="Gallery viewer">
            <button type="button" class="gallery-lightbox-close" id="galleryCloseBtn" aria-label="Close gallery">&times;</button>
            <button type="button" class="gallery-lightbox-nav gallery-lightbox-prev" id="galleryPrevBtn" aria-label="Previous image">&#10094;</button>
            <img id="galleryLightboxImage" class="gallery-lightbox-image" src="" alt="">
            <button type="button" class="gallery-lightbox-nav gallery-lightbox-next" id="galleryNextBtn" aria-label="Next image">&#10095;</button>
            <p id="galleryLightboxCounter" class="gallery-lightbox-counter"></p>
          </div>
        </div>
      <% } %>

      <% if (details.posterImageUrl) { %>
        <div id="posterLightbox" class="gallery-lightbox hidden" aria-hidden="true">
          <div class="gallery-lightbox-backdrop" data-close-poster-lightbox="1"></div>
          <div class="gallery-lightbox-dialog" role="dialog" aria-modal="true" aria-label="Promotional poster viewer">
            <button type="button" class="gallery-lightbox-close" id="posterCloseBtn" aria-label="Close poster">&times;</button>
            <div class="poster-zoom-controls">
              <button type="button" class="poster-zoom-btn" id="posterZoomOutBtn" aria-label="Zoom out">-</button>
              <button type="button" class="poster-zoom-btn" id="posterZoomInBtn" aria-label="Zoom in">+</button>
              <button type="button" class="poster-zoom-btn" id="posterResetBtn" aria-label="Reset zoom">Reset</button>
            </div>
            <img id="posterLightboxImage" class="gallery-lightbox-image" src="" alt="">
          </div>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    if (window.lucide) lucide.createIcons();

    (function initGalleryLightbox() {
      const lightbox = document.getElementById('galleryLightbox');
      if (!lightbox) return;

      const body = document.body;
      const thumbButtons = Array.from(document.querySelectorAll('.event-gallery-thumb-btn'));
      const imageEl = document.getElementById('galleryLightboxImage');
      const counterEl = document.getElementById('galleryLightboxCounter');
      const closeBtn = document.getElementById('galleryCloseBtn');
      const prevBtn = document.getElementById('galleryPrevBtn');
      const nextBtn = document.getElementById('galleryNextBtn');
      const closeBackdrop = lightbox.querySelector('[data-close-lightbox="1"]');
      const gallerySources = thumbButtons.map((btn) => ({
        src: btn.getAttribute('data-gallery-src') || '',
        alt: btn.querySelector('img')?.alt || 'Gallery image'
      }));
      let currentIndex = 0;

      function updateLightboxImage() {
        const item = gallerySources[currentIndex];
        if (!item) return;
        imageEl.src = item.src;
        imageEl.alt = item.alt;
        counterEl.textContent = `${currentIndex + 1} / ${gallerySources.length}`;
      }

      function openLightbox(index) {
        currentIndex = Math.max(0, Math.min(index, gallerySources.length - 1));
        updateLightboxImage();
        lightbox.classList.remove('hidden');
        lightbox.setAttribute('aria-hidden', 'false');
        body.classList.add('no-scroll');
        closeBtn.focus();
      }

      function closeLightbox() {
        lightbox.classList.add('hidden');
        lightbox.setAttribute('aria-hidden', 'true');
        body.classList.remove('no-scroll');
      }

      function showPrev() {
        currentIndex = (currentIndex - 1 + gallerySources.length) % gallerySources.length;
        updateLightboxImage();
      }

      function showNext() {
        currentIndex = (currentIndex + 1) % gallerySources.length;
        updateLightboxImage();
      }

      thumbButtons.forEach((btn, index) => {
        btn.addEventListener('click', () => openLightbox(index));
      });
      closeBtn.addEventListener('click', closeLightbox);
      prevBtn.addEventListener('click', showPrev);
      nextBtn.addEventListener('click', showNext);
      if (closeBackdrop) closeBackdrop.addEventListener('click', closeLightbox);

      document.addEventListener('keydown', (event) => {
        if (lightbox.classList.contains('hidden')) return;
        if (event.key === 'Escape') closeLightbox();
        if (event.key === 'ArrowLeft') showPrev();
        if (event.key === 'ArrowRight') showNext();
      });
    })();

    (function initPosterLightbox() {
      const posterBtn = document.querySelector('.event-poster-thumb-btn');
      const lightbox = document.getElementById('posterLightbox');
      if (!posterBtn || !lightbox) return;

      const body = document.body;
      const imageEl = document.getElementById('posterLightboxImage');
      const closeBtn = document.getElementById('posterCloseBtn');
      const zoomInBtn = document.getElementById('posterZoomInBtn');
      const zoomOutBtn = document.getElementById('posterZoomOutBtn');
      const resetBtn = document.getElementById('posterResetBtn');
      const closeBackdrop = lightbox.querySelector('[data-close-poster-lightbox="1"]');
      const posterSrc = posterBtn.getAttribute('data-poster-src') || '';
      const posterAlt = posterBtn.querySelector('img')?.alt || 'Promotional poster';
      let zoomLevel = 1;
      let translateX = 0;
      let translateY = 0;
      let isDragging = false;
      let dragStartX = 0;
      let dragStartY = 0;

      function updatePosterTransform() {
        imageEl.style.transform = `translate(${translateX}px, ${translateY}px) scale(${zoomLevel})`;
        imageEl.classList.toggle('is-zoomed', zoomLevel > 1);
        imageEl.style.cursor = zoomLevel > 1 ? (isDragging ? 'grabbing' : 'grab') : 'zoom-in';
        if (zoomInBtn) zoomInBtn.disabled = zoomLevel >= 3;
        if (zoomOutBtn) zoomOutBtn.disabled = zoomLevel <= 1;
      }

      function setZoom(nextZoomLevel) {
        const clamped = Math.max(1, Math.min(3, Number(nextZoomLevel.toFixed(2))));
        zoomLevel = clamped;
        if (zoomLevel === 1) {
          translateX = 0;
          translateY = 0;
        }
        updatePosterTransform();
      }

      function resetZoom() {
        isDragging = false;
        setZoom(1);
      }

      function openLightbox() {
        imageEl.src = posterSrc;
        imageEl.alt = posterAlt;
        resetZoom();
        lightbox.classList.remove('hidden');
        lightbox.setAttribute('aria-hidden', 'false');
        body.classList.add('no-scroll');
        closeBtn.focus();
      }

      function closeLightbox() {
        lightbox.classList.add('hidden');
        lightbox.setAttribute('aria-hidden', 'true');
        body.classList.remove('no-scroll');
        resetZoom();
      }

      posterBtn.addEventListener('click', openLightbox);
      closeBtn.addEventListener('click', closeLightbox);
      if (zoomInBtn) zoomInBtn.addEventListener('click', () => setZoom(zoomLevel + 0.25));
      if (zoomOutBtn) zoomOutBtn.addEventListener('click', () => setZoom(zoomLevel - 0.25));
      if (resetBtn) resetBtn.addEventListener('click', resetZoom);
      if (closeBackdrop) closeBackdrop.addEventListener('click', closeLightbox);

      imageEl.addEventListener('pointerdown', (event) => {
        if (zoomLevel <= 1) return;
        isDragging = true;
        dragStartX = event.clientX - translateX;
        dragStartY = event.clientY - translateY;
        imageEl.setPointerCapture(event.pointerId);
        updatePosterTransform();
      });

      imageEl.addEventListener('pointermove', (event) => {
        if (!isDragging || zoomLevel <= 1) return;
        translateX = event.clientX - dragStartX;
        translateY = event.clientY - dragStartY;
        updatePosterTransform();
      });

      function stopDragging() {
        if (!isDragging) return;
        isDragging = false;
        updatePosterTransform();
      }

      imageEl.addEventListener('pointerup', stopDragging);
      imageEl.addEventListener('pointercancel', stopDragging);
      imageEl.addEventListener('pointerleave', stopDragging);

      document.addEventListener('keydown', (event) => {
        if (lightbox.classList.contains('hidden')) return;
        if (event.key === 'Escape') closeLightbox();
      });
    })();
  </script>
</body>
</html>
