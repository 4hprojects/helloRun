<%
  const details = publicEvent || {};
  const isPreviewMode = Boolean(typeof previewMode !== 'undefined' && previewMode);
  const runnerState = typeof runnerEventState !== 'undefined' ? runnerEventState : null;
  const pagePrimaryAction = runnerState
    ? runnerState.primaryAction
    : (details.primaryCta && !details.primaryCta.disabled ? { ...details.primaryCta, type: 'link' } : null);
  const showMobileStickyCta = Boolean(!isPreviewMode && pagePrimaryAction);
  const hasEventShopSidebar = Boolean(!isPreviewMode && typeof eventShop !== 'undefined' && eventShop && eventShop.count > 0);
  const hasEventSidebarAd = Boolean(
    !isPreviewMode
    && locals.ads
    && locals.ads.canRender('eventDetails', 'sidebar')
    && locals.ads.getSlot('eventDetails', 'sidebar')
  );
  const showEventSidebar = Boolean(
    !details.isAccumulatedChallenge
    || hasEventShopSidebar
    || (!isPreviewMode && locals.user)
    || hasEventSidebarAd
  );
-%>
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title, seo: typeof seo !== 'undefined' ? seo : null }) %>
  <link rel="stylesheet" href="/css/events.css">
  <link rel="stylesheet" href="/css/event-details.css">
</head>
<body class="event-details-body<%= details.isAccumulatedChallenge ? ' is-accumulated-challenge' : '' %><%= locals.isAuthenticated ? ' is-authenticated' : '' %><%= locals.isAuthenticated && !locals.isAdmin && !locals.isApprovedOrganizer && !locals.isOrganizer ? ' has-runner-mobile-nav' : '' %><%= showMobileStickyCta ? ' has-event-mobile-sticky-cta' : '' %>">
  <%- include('../layouts/nav') %>

  <main class="event-details-page">
    <%
      const registrationToneClass = details.registrationState ? `event-status-${details.registrationState.tone}` : 'event-status-neutral';
      const defaultEventImageUrl = '/images/helloRun-icon.webp';
      const heroImageUrl = details.heroImageUrl || defaultEventImageUrl;
      const previewReturnHref = typeof previewBackHref !== 'undefined' && previewBackHref ? previewBackHref : '/organizer/create-event';
      const previewErrorsRaw = typeof previewErrors !== 'undefined' ? previewErrors : [];
      const previewErrorMessages = Array.isArray(previewErrorsRaw)
        ? previewErrorsRaw
        : Object.values(previewErrorsRaw || {});
      const registrationOptionItems = Array.isArray(details.raceDistances)
        ? details.raceDistances.map((item) => String(item || '').trim()).filter(Boolean)
        : [];
      const showRegistrationOptionBullets = Boolean(
        details.isAccumulatedChallenge &&
        registrationOptionItems.length > 1
      );
      const hasDetailedRaceCategories = (details.raceCategories || []).some((category) => Boolean(
        (category.type && category.type !== 'distance') ||
        category.slotsLabel ||
        category.cutoffTime ||
        category.ageGroup ||
        category.rewardsDescription
      ));
      const showRaceCategoriesSection = Boolean(
        (details.raceCategories || []).length &&
        (!details.hasCategorySpecificGoals || hasDetailedRaceCategories)
      );
    %>

    <% if (isPreviewMode) { %>
      <section class="event-preview-notice" role="status" aria-label="Event preview status">
        <div>
          <strong>Preview mode</strong>
          <span>This is the same public event page participants will see. File selections only appear here after they have been uploaded.</span>
        </div>
        <a href="<%= previewReturnHref %>" class="btn btn-outline"><i data-lucide="arrow-left"></i><span>Back to Editor</span></a>
      </section>
      <% if (previewErrorMessages.length) { %>
        <section class="event-preview-errors" aria-label="Preview validation issues">
          <strong>Some required details still need attention before this event can be submitted.</strong>
          <ul>
            <% previewErrorMessages.forEach((message) => { %>
              <li><%= message %></li>
            <% }) %>
          </ul>
        </section>
      <% } %>
    <% } %>

    <section class="event-landing-hero" style="--event-hero-image: url('<%= heroImageUrl %>');">
      <div class="event-landing-hero-overlay"></div>
      <div class="event-landing-hero-inner">
        <div class="event-hero-copy">
          <div class="event-hero-meta-row">
            <div class="event-chip-row">
              <span class="event-chip event-chip-solid"><%= details.eventTypeLabel || 'Event' %></span>
              <% if (details.isAccumulatedChallenge) { %>
                <span class="event-chip event-chip-solid">Accumulated Challenge</span>
              <% } %>
              <span class="event-chip event-chip-status <%= registrationToneClass %>"><%= details.registrationState?.label || 'Event Listing' %></span>
            </div>

          </div>

          <p class="event-organizer">Hosted by <%= details.organizerName || 'HelloRun' %></p>
          <h1><%= details.title %></h1>
          <div class="event-lead">
            <span class="event-lead-label">About this event</span>
            <p><%= details.challengeSummary || details.descriptionText || details.description || 'Review the event schedule, registration details, and completion requirements.' %></p>
          </div>

          <div class="event-hero-actions">
            <% if (!runnerState && details.primaryCta && !details.primaryCta.disabled) { %>
              <a href="<%= details.primaryCta.href %>" class="btn btn-primary"><i data-lucide="ticket"></i><span><%= details.primaryCta.label %></span></a>
            <% } else if (!runnerState) { %>
              <button type="button" class="btn btn-outline btn-hero-disabled" disabled><%= details.primaryCta?.label || 'Registration Unavailable' %></button>
            <% } %>
            <% if (isPreviewMode) { %>
              <a href="<%= previewReturnHref %>" class="btn btn-outline btn-hero-secondary"><i data-lucide="arrow-left"></i><span>Back to Editor</span></a>
            <% } else { %>
              <a href="/events" class="btn btn-outline btn-hero-secondary"><i data-lucide="search"></i><span>Browse Events</span></a>
              <% if (details.secondaryCtas?.[0]) { %>
                <a href="<%= details.secondaryCtas[0].href %>" class="btn btn-outline btn-hero-secondary"><i data-lucide="trophy"></i><span><%= details.secondaryCtas[0].label %></span></a>
              <% } %>
              <% if (locals.isAuthenticated) { %>
                <button type="button"
                  class="btn btn-outline btn-hero-secondary btn-save-event js-save-event<%= isSaved ? ' is-saved' : '' %>"
                  data-event-slug="<%= event.slug %>"
                  data-saved="<%= isSaved ? '1' : '0' %>"
                  aria-label="<%= isSaved ? 'Remove from saved' : 'Save event' %>"
                  title="<%= isSaved ? 'Saved' : 'Save event' %>">
                  <i data-lucide="heart" aria-hidden="true"></i>
                  <span class="save-label"><%= isSaved ? 'Saved' : 'Save' %></span>
                </button>
              <% } %>
            <% } %>
          </div>
        </div>

        <aside class="event-hero-panel" aria-label="Event registration summary">
          <% if (runnerState) { %>
            <div class="event-hero-panel-group event-hero-panel-price">
              <p class="event-panel-label">Your challenge</p>
              <strong><%= runnerState.selectedQuest %></strong>
              <span><%= runnerState.stateLabel %></span>
            </div>
            <div class="event-panel-divider"></div>
            <div class="event-hero-panel-group event-hero-panel-registration">
              <p class="event-panel-label">Verified progress</p>
              <strong class="event-panel-status"><%= runnerState.approvedDistanceLabel %> / <%= runnerState.targetDistanceLabel %></strong>
              <span><%= runnerState.progressLabel %></span>
            </div>
          <% } else { %>
            <div class="event-hero-panel-group event-hero-panel-price">
              <p class="event-panel-label"><%= details.pricing?.label || 'Pricing' %></p>
              <strong><%= details.pricing?.amountLabel || 'Pricing not listed' %></strong>
              <span><%= details.pricing?.helper || 'Review the available registration options.' %></span>
            </div>
            <% if (details.registrationState?.helper) { %>
              <div class="event-panel-divider"></div>
              <div class="event-hero-panel-group event-hero-panel-registration">
                <p class="event-panel-label">Registration</p>
                <strong class="event-panel-status"><%= details.registrationState.label || 'Event listing' %></strong>
                <span><%= details.registrationState.helper %></span>
              </div>
            <% } %>
          <% } %>
        </aside>
      </div>
    </section>

    <section class="event-details-shell<%= showEventSidebar ? '' : ' event-details-shell-wide' %>">
      <div class="event-nav-row">
        <% if (isPreviewMode) { %>
          <a href="<%= previewReturnHref %>" class="btn btn-outline event-nav-back"><i data-lucide="arrow-left"></i><span>Back to Editor</span></a>
        <% } else { %>
          <a href="/events" class="btn btn-outline event-nav-back"><i data-lucide="arrow-left"></i><span>Back to Events</span></a>
        <% } %>
        <% if (!isPreviewMode && eventShop && eventShop.count > 0) { %>
          <a href="<%= eventShop.href %>" class="btn btn-outline event-nav-shop"><i data-lucide="shopping-bag"></i><span>Event Shop</span></a>
        <% } %>
        <% if (locals.isAuthenticated) { %>
          <a href="/my-registrations" class="btn btn-outline event-nav-registrations"><i data-lucide="badge-check"></i><span>My Registrations</span></a>
        <% } %>
      </div>

      <% if (details.isAccumulatedChallenge) { %>
        <section class="event-challenge-decision<%= runnerState ? ' event-runner-progress-card' : '' %>" id="event-goals" aria-labelledby="eventGoalsTitle">
          <% if (runnerState) { %>
            <div class="event-runner-progress-heading">
              <div>
                <p class="event-section-kicker">Your July quest</p>
                <h2 id="eventGoalsTitle"><%= runnerState.selectedQuest %></h2>
                <p><%= runnerState.helperText %></p>
              </div>
              <span class="event-runner-state event-runner-state-<%= runnerState.state %>"><%= runnerState.stateLabel %></span>
            </div>

            <div class="event-runner-progress-summary">
              <div class="event-runner-progress-total">
                <span>Verified distance</span>
                <strong><%= runnerState.approvedDistanceLabel %></strong>
                <small>of <%= runnerState.targetDistanceLabel %></small>
              </div>
              <div class="event-runner-progress-track-wrap">
                <div
                  class="event-runner-progress-track"
                  role="progressbar"
                  aria-label="Verified progress toward <%= runnerState.selectedQuest %>"
                  aria-valuemin="0"
                  aria-valuemax="100"
                  aria-valuenow="<%= runnerState.progressBarPercentage %>"
                  aria-valuetext="<%= runnerState.progressLabel %>; <%= runnerState.approvedDistanceLabel %> of <%= runnerState.targetDistanceLabel %>"
                >
                  <span style="width: <%= runnerState.progressBarPercentage %>%"></span>
                </div>
                <strong><%= runnerState.progressLabel %></strong>
              </div>
              <dl class="event-runner-progress-facts">
                <div><dt>Remaining</dt><dd><%= runnerState.completed ? 'Goal completed' : runnerState.remainingDistanceLabel %></dd></div>
                <div><dt>Verified activities</dt><dd><%= runnerState.approvedActivityCount %></dd></div>
                <div><dt>Pending</dt><dd><%= runnerState.pendingDistanceLabel %> · <%= runnerState.pendingActivityCount %> activit<%= runnerState.pendingActivityCount === 1 ? 'y' : 'ies' %></dd></div>
                <div><dt>Submit by</dt><dd><%= runnerState.submissionTiming?.label || 'Deadline not listed' %></dd></div>
              </dl>
            </div>

            <% if (runnerState.primaryAction || runnerState.secondaryAction) { %>
              <div class="event-runner-actions">
                <% [runnerState.primaryAction, runnerState.secondaryAction].filter(Boolean).forEach((action, actionIndex) => { %>
                  <% if (action.type === 'submit' || action.type === 'resubmit') { %>
                    <button
                      type="button"
                      class="btn <%= actionIndex === 0 ? 'btn-primary' : 'btn-outline' %>"
                      data-open-run-proof-modal
                      data-run-proof-surface="event-detail"
                      data-run-proof-mode="<%= action.type %>"
                      data-run-proof-registration-id="<%= action.registrationId %>"
                    ><%= action.label %></button>
                  <% } else { %>
                    <a href="<%= action.href %>" class="btn <%= actionIndex === 0 ? 'btn-primary' : 'btn-outline' %>"><%= action.label %></a>
                  <% } %>
                <% }) %>
              </div>
            <% } %>
          <% } else { %>
            <div class="event-challenge-decision-heading">
              <div>
                <p class="event-section-kicker">Choose your challenge goal</p>
                <h2 id="eventGoalsTitle">Pick a goal that fits your month</h2>
                <p>Compare the targets below. Every approved activity moves you closer to your selected goal.</p>
              </div>
              <% if (details.primaryCta && !details.primaryCta.disabled) { %>
                <div class="event-challenge-decision-action">
                  <a href="<%= details.primaryCta.href %>" class="btn btn-primary">Choose a goal &amp; register</a>
                  <small>You’ll select your category during registration.</small>
                </div>
              <% } %>
            </div>
            <div class="event-challenge-goal-grid" aria-label="Available accumulated distance goals">
              <% (details.categoryGoalOptions || []).forEach((option) => { %>
                <article aria-label="<%= option.name %>, <%= option.distanceKmLabel %>">
                  <span><%= option.compactName || option.name %></span>
                  <strong><%= option.distanceKmLabel %></strong>
                </article>
              <% }) %>
            </div>
          <% } %>
        </section>
      <% } %>

      <section class="event-stats-strip" aria-label="Event highlights">
        <% if (details.isAccumulatedChallenge) { %>
          <% (details.challengeDates || []).forEach((item) => { %>
            <article class="event-stat event-stat-<%= item.key %>">
              <span><%= item.label %></span>
              <strong><%= item.value %></strong>
              <small><%= item.helper %></small>
            </article>
          <% }) %>
        <% } else { %>
          <% (details.stats || []).filter((stat) => stat.label !== 'Registration Options').forEach((stat) => { %>
            <% const statClass = stat.label === 'Signups' ? 'event-stat-signups' : (stat.label === 'Duration' ? 'event-stat-duration' : 'event-stat-detail'); %>
            <article class="event-stat <%= statClass %>">
              <span><%= stat.label %></span>
              <strong><%= stat.value %></strong>
              <small><%= stat.helper %></small>
            </article>
          <% }) %>
        <% } %>
      </section>

      <details class="event-section-jump">
        <summary>Jump to section</summary>
        <nav class="event-section-nav" aria-label="Event page sections">
          <a href="#event-how-it-works">Steps</a>
          <% if ((details.pricingOptions || []).length || (details.packageOptions || []).length || details.pricing?.hasOptionalCosts) { %>
            <a href="#event-registration-options">Registration</a>
          <% } %>
          <a href="#event-submission-rules">Rules</a>
          <a href="#event-rewards">Rewards</a>
          <% if (eventDetailsHtml) { %><a href="#event-full-details">Full details</a><% } %>
        </nav>
      </details>

      <% if (!details.isAccumulatedChallenge) { %><section class="event-mobile-key-facts" id="event-summary" aria-labelledby="eventMobileFactsTitle">
        <div class="event-mobile-key-facts-heading">
          <p>At a glance</p>
          <h2 id="eventMobileFactsTitle">Key event facts</h2>
        </div>
        <div class="event-mobile-facts-grid">
          <% (details.timeline || []).forEach((item) => { %>
            <p><span><%= item.label %></span><strong><%= item.value %></strong></p>
          <% }) %>
          <p><span>Mode</span><strong><%= (details.allowedModes || []).join(' / ') || details.eventTypeLabel || 'Not listed' %></strong></p>
          <p><span><%= details.isAccumulatedChallenge ? 'Registration options' : 'Distance' %></span><strong><%= details.distanceSummaryLabel || details.targetDistanceLabel || 'Not listed' %></strong></p>
          <p><span>Location</span><strong><%= details.location?.publicLabel || details.location?.summary || 'Not listed' %></strong></p>
        </div>
      </section><% } %>

      <div class="event-main-layout">
        <div class="event-main-content">
          <section class="event-section" id="event-how-it-works">
            <div class="event-section-heading">
              <span class="event-section-icon"><i data-lucide="route"></i></span>
              <div>
                <h2>How This Event Works</h2>
                <p><%= details.isAccumulatedChallenge ? 'Build your distance over time. Approved submissions count toward your official progress.' : 'Register, complete the event, then submit your result for review.' %></p>
              </div>
            </div>

            <div class="event-mechanics-grid">
              <article>
                <span>1</span>
                <h3>Register</h3>
                <p>Choose your participation mode and confirm your runner profile.</p>
              </article>
              <article>
                <span>2</span>
                <h3>Complete Activities</h3>
                <p><%= details.virtualRules?.acceptedActivities?.length ? `Accepted activities: ${details.virtualRules.acceptedActivities.join(', ')}.` : 'Complete the configured event distance during the event window.' %></p>
              </article>
              <article>
                <span>3</span>
                <h3>Submit Proof</h3>
                <p><%= details.virtualRules?.proofTypes?.length ? `Proof accepted: ${details.virtualRules.proofTypes.join(', ')}.` : 'Submit your result through HelloRun for organizer review.' %></p>
              </article>
              <article>
                <span>4</span>
                <h3>Earn Recognition</h3>
                <p><%= details.virtualRules?.recognitionMode || 'Finishers receive the recognition configured for this event.' %></p>
              </article>
            </div>
          </section>

          <% if (!isPreviewMode) { %>
            <%- include('../partials/ad-unit', { group: 'eventDetails', placement: 'after_how_it_works' }) %>
          <% } %>

          <section class="event-section" id="event-submission-rules">
            <div class="event-section-heading">
              <span class="event-section-icon"><i data-lucide="upload-cloud"></i></span>
              <div>
                <h2>Activities & Submission Rules</h2>
                <p>Use eligible activities and clear proof so verified distance counts toward your goal.</p>
              </div>
            </div>

            <dl class="event-rule-list">
              <div><dt>Event window</dt><dd><%= details.virtualRules?.virtualWindowLabel || 'Not listed' %></dd></div>
              <div><dt>Accepted activities</dt><dd><%= details.virtualRules?.acceptedActivities?.join(', ') || 'Not specified' %></dd></div>
              <div><dt>Proof types</dt><dd><%= details.virtualRules?.proofTypes?.join(', ') || 'Not specified' %></dd></div>
              <div><dt>Final deadline</dt><dd><%= details.virtualRules?.finalSubmissionDeadline || 'Not listed' %></dd></div>
              <div><dt>Leaderboard</dt><dd><%= details.virtualRules?.leaderboardMode || 'Not available' %></dd></div>
            </dl>
          </section>

          <% if ((details.isAccumulatedChallenge || details.virtualRules?.targetDistanceKm) && !details.hasCategorySpecificGoals) { %>
            <section class="event-section event-goal-section<%= details.hasCategorySpecificGoals ? ' event-goal-section-categories' : '' %>">
              <% if (details.hasCategorySpecificGoals) { %>
                <div class="event-category-goal-content">
                  <p class="event-section-kicker">Category Completion Goals</p>
                  <h2>Your category sets your finish target</h2>
                  <p>Select a category during registration. Its distance becomes the approved total you need to complete.</p>
                  <div class="event-category-goal-grid" aria-label="Category completion distances">
                    <% details.categoryGoalOptions.forEach((option) => { %>
                      <article>
                        <span><%= option.name %></span>
                        <strong><%= option.distanceKmLabel %></strong>
                      </article>
                    <% }) %>
                  </div>
                  <p class="event-category-goal-note">Only approved submissions count toward your finish target.</p>
                </div>
              <% } else { %>
                <div>
                  <p class="event-section-kicker">Accumulated Completion Goal</p>
                  <h2>Complete <%= details.targetDistanceLabel %></h2>
                  <p>Only approved submissions count toward the official total. Keep submitting valid activities until your progress reaches the completion goal.</p>
                <% if (details.isAccumulatedChallenge && details.distanceSummaryLabel && details.distanceSummaryLabel !== details.targetDistanceLabel) { %>
                  <div class="event-goal-options">
                    <strong>Registration options:</strong>
                    <% if (showRegistrationOptionBullets) { %>
                      <ul class="event-registration-option-bullets">
                        <% registrationOptionItems.forEach((option) => { %>
                          <li><%= option %></li>
                        <% }) %>
                      </ul>
                      <p>These are runner-facing distance labels for the listed completion goal.</p>
                    <% } else { %>
                      <p><%= details.distanceSummaryLabel %>. These are runner-facing distance labels for the listed completion goal.</p>
                    <% } %>
                  </div>
                <% } %>
                </div>
                <div class="event-goal-panel">
                  <strong><%= details.completionGoalLabel || details.targetDistanceLabel %></strong>
                  <span>Completion goal</span>
                <% if (details.isAccumulatedChallenge && details.distanceSummaryLabel && details.distanceSummaryLabel !== details.targetDistanceLabel) { %>
                  <% if (showRegistrationOptionBullets) { %>
                    <small>Options:</small>
                    <ul class="event-registration-option-bullets event-registration-option-bullets-compact">
                      <% registrationOptionItems.forEach((option) => { %>
                        <li><%= option %></li>
                      <% }) %>
                    </ul>
                  <% } else { %>
                    <small>Options: <%= details.distanceSummaryLabel %></small>
                  <% } %>
                <% } else { %>
                  <small><%= details.virtualRules?.completionMode || 'Completion goal' %></small>
                <% } %>
                <% if (details.virtualRules?.minimumDistance) { %><small><%= details.virtualRules.minimumDistance %></small><% } %>
                </div>
              <% } %>
            </section>
          <% } %>

          <% if (showRaceCategoriesSection) { %>
            <section class="event-section">
              <div class="event-section-heading">
                <span class="event-section-icon"><i data-lucide="list-checks"></i></span>
                <div>
                  <h2><%= details.hasCategorySpecificGoals ? 'Category Details' : 'Race Categories' %></h2>
                  <p><%= details.hasCategorySpecificGoals ? 'Review eligibility, availability, timing, and category-specific rewards.' : 'Choose the category that matches your distance, eligibility, and event goal.' %></p>
                </div>
              </div>

              <div class="event-package-grid">
                <% details.raceCategories.forEach((category) => { %>
                  <article>
                    <h3><%= category.name %></h3>
                    <strong><%= category.typeLabel %></strong>
                    <% if (category.summary) { %><p><%= category.summary %></p><% } %>
                    <% if (category.rewardsDescription) { %><small><%= category.rewardsDescription %></small><% } %>
                  </article>
                <% }) %>
              </div>
            </section>
          <% } %>

          <section class="event-section" id="event-rewards">
            <div class="event-section-heading">
              <span class="event-section-icon"><i data-lucide="gift"></i></span>
              <div>
                <h2>Rewards & Recognition</h2>
                <p>What runners can expect after valid completion.</p>
              </div>
            </div>

            <% if ((details.rewardItems || []).length) { %>
              <div class="event-reward-grid">
                <% details.rewardItems.forEach((reward) => { %>
                  <article>
                    <i data-lucide="<%= reward.type === 'physical' ? 'package' : 'award' %>"></i>
                    <span><%= reward.label %></span>
                  </article>
                <% }) %>
              </div>
            <% } else { %>
              <p class="event-muted">Rewards have not been listed by the organizer yet.</p>
            <% } %>

            <% if (event.physicalRewardsDescription) { %>
              <p class="event-supporting-copy"><%= event.physicalRewardsDescription %></p>
            <% } %>

            <% const eventBadges = badges || []; %>
            <% if (eventBadges.length) { %>
              <div class="event-badge-grid" aria-label="Event badges">
                <% eventBadges.forEach((badge) => { %>
                  <article class="event-badge-card">
                    <span class="event-badge-icon">
                      <% if (badge.imageUrl) { %>
                        <img src="<%= badge.imageUrl %>" alt="" loading="lazy">
                      <% } else { %>
                        <i data-lucide="award"></i>
                      <% } %>
                    </span>
                    <div>
                      <h3><%= badge.name %></h3>
                      <p><%= badge.description || 'Awarded after verified event activity.' %></p>
                      <small><%= badge.badgeType ? badge.badgeType.replace(/_/g, ' ') : 'achievement' %></small>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% } else { %>
              <div class="event-badge-empty">
                <i data-lucide="award"></i>
                <div>
                  <strong>No event badges listed</strong>
                  <p>This event is not currently listing digital badges.</p>
                </div>
              </div>
            <% } %>
          </section>

          <% if (details.recap) { %>
            <section class="event-section event-recap-section">
              <div class="event-section-heading">
                <span class="event-section-icon"><i data-lucide="notebook-text"></i></span>
                <div>
                  <h2>Event Recap</h2>
                  <p>This past event remains available as a useful public record for runners and visitors.</p>
                </div>
              </div>
              <p class="event-recap-body"><%= details.recap.body %></p>
              <ul class="event-recap-list">
                <% details.recap.details.forEach((item) => { %>
                  <li><%= item %></li>
                <% }) %>
              </ul>
            </section>
          <% } %>

          <% if ((details.pricingOptions || []).length || (details.packageOptions || []).length || details.pricing?.hasOptionalCosts) { %>
            <section class="event-section" id="event-registration-options">
              <div class="event-section-heading">
                <span class="event-section-icon"><i data-lucide="shopping-bag"></i></span>
                <div>
                  <h2>Pricing & Registration Options</h2>
                  <p><%= details.pricing?.helper || 'Review registration and package details before joining.' %></p>
                </div>
              </div>

              <div class="event-pricing-summary">
                <strong><%= details.pricing?.amountLabel || 'Pricing not listed' %></strong>
                <span><%= details.pricing?.label || 'Pricing' %></span>
              </div>

              <% if ((details.pricingOptions || []).length) { %>
                <div class="event-package-grid">
                  <% details.pricingOptions.forEach((pricingOption) => { %>
                    <article>
                      <% if (pricingOption.pricingPeriodBadge) { %>
                        <small class="event-pricing-period-badge"><%= pricingOption.pricingPeriodBadge %></small>
                      <% } %>
                      <h3><%= pricingOption.label %></h3>
                      <strong><%= pricingOption.amountLabel %></strong>
                      <p><%= pricingOption.helper %></p>
                    </article>
                  <% }) %>
                </div>
              <% } %>

              <% if ((details.packageOptions || []).length) { %>
                <div class="event-package-grid">
                  <% details.packageOptions.forEach((packageOption) => { %>
                    <article>
                      <h3><%= packageOption.name %></h3>
                      <strong><%= packageOption.amountLabel %></strong>
                      <% if (packageOption.includedItems.length) { %>
                        <p><%= packageOption.includedItems.join(', ') %></p>
                      <% } %>
                      <% if (packageOption.notes) { %><small><%= packageOption.notes %></small><% } %>
                    </article>
                  <% }) %>
                </div>
              <% } %>

              <% if (details.pricing?.deliveryAmount !== null && details.pricing?.deliveryAmount !== undefined) { %>
                <p class="event-supporting-copy">Delivery or claiming fee: <strong><%= details.pricing.currency || 'PHP' %> <%= Number(details.pricing.deliveryAmount || 0).toLocaleString('en-US') %></strong>.</p>
              <% } %>
            </section>
          <% } %>

          <% if (eventDetailsHtml) { %>
            <details class="event-section event-details-description" id="event-full-details">
              <summary class="event-organizer-details-summary">
                <span class="event-section-icon"><i data-lucide="file-text"></i></span>
                <span>
                  <strong>Additional organizer details</strong>
                  <small>Read the full event information, extended instructions, and community notes.</small>
                </span>
              </summary>
              <div class="event-authoritative-note" role="note">
                <i data-lucide="shield-check" aria-hidden="true"></i>
                <span>Dates, pricing, categories, and submission rules shown in the structured sections above are the current event settings.</span>
              </div>
              <div class="event-rich-details-shell">
                <div class="event-rich-details"><%- eventDetailsHtml %></div>
              </div>
            </details>
          <% } %>

          <% if (details.isAccumulatedChallenge && details.posterImageUrl) { %>
            <section class="event-section event-challenge-poster-section">
              <div class="event-section-heading">
                <span class="event-section-icon"><i data-lucide="image"></i></span>
                <div>
                  <h2>Event Poster</h2>
                  <p>Open the organizer’s promotional artwork. If artwork dates differ, the current structured dates above apply.</p>
                </div>
              </div>
              <button
                type="button"
                class="event-poster-thumb-btn"
                data-poster-src="<%= details.posterImageUrl %>"
                aria-label="Open promotional poster"
              >
                <img class="event-details-poster-inline" src="<%= details.posterImageUrl %>" alt="<%= details.title %> promotional poster" loading="lazy">
              </button>
            </section>
          <% } %>

          <% if ((details.galleryImageUrls || []).length) { %>
            <section class="event-section" id="event-gallery">
              <div class="event-section-heading">
                <span class="event-section-icon"><i data-lucide="images"></i></span>
                <div>
                  <h2>Gallery</h2>
                  <p>Visuals shared by the organizer for this event.</p>
                </div>
              </div>
              <div class="event-gallery-grid">
                <% details.galleryImageUrls.forEach((galleryUrl, galleryIndex) => { %>
                  <button
                    type="button"
                    class="event-gallery-thumb-btn"
                    data-gallery-index="<%= galleryIndex %>"
                    data-gallery-src="<%= galleryUrl %>"
                    aria-label="Open gallery image <%= galleryIndex + 1 %>"
                  >
                    <img class="event-gallery-image" src="<%= galleryUrl %>" alt="<%= details.title %> gallery image <%= galleryIndex + 1 %>">
                  </button>
                <% }) %>
              </div>
            </section>
          <% } %>

          <% if (details.isAccumulatedChallenge && !runnerState && !isPreviewMode && details.primaryCta && !details.primaryCta.disabled) { %>
            <section class="event-challenge-closing-cta" aria-labelledby="eventChallengeClosingTitle">
              <div>
                <p class="event-section-kicker">Ready to take on the challenge?</p>
                <h2 id="eventChallengeClosingTitle">Choose your goal and start building distance</h2>
                <p>Register now, select the target that fits your month, and submit approved activities as you go.</p>
              </div>
              <a href="<%= details.primaryCta.href %>" class="btn btn-primary">Register for this challenge</a>
            </section>
          <% } %>
        </div>

        <% if (showEventSidebar) { %><aside class="event-side-panel">
          <% if (!details.isAccumulatedChallenge) { %>
          <section class="event-side-card event-register-card">
            <p class="event-side-eyebrow"><%= details.registrationState?.label || 'Registration' %></p>
            <h2><%= details.pricing?.amountLabel || 'Pricing not listed' %></h2>
            <p><%= details.registrationState?.helper || details.pricing?.helper || '' %></p>
            <% if (details.primaryCta && !details.primaryCta.disabled) { %>
              <a href="<%= details.primaryCta.href %>" class="btn btn-primary btn-block">Register Now</a>
            <% } else { %>
              <button type="button" class="btn btn-outline btn-block" disabled><%= details.primaryCta?.label || 'Registration Unavailable' %></button>
            <% } %>
          </section>

          <section class="event-side-card event-timeline-card">
            <h3>Event Timeline</h3>
            <div class="event-timeline-list">
              <% (details.timeline || []).forEach((item) => { %>
                <p>
                  <i data-lucide="<%= item.icon %>"></i>
                  <span><strong><%= item.label %></strong><small><%= item.value %></small></span>
                </p>
              <% }) %>
            </div>
          </section>

          <section class="event-side-card event-detail-card">
            <h3>Event Details</h3>
            <div class="event-side-list">
              <% const registrationOptionsLabel = details.isAccumulatedChallenge ? ((details.raceDistances || []).length > 1 ? 'Registration Options' : 'Registration Option') : ((details.raceDistances || []).length > 1 ? 'Distances' : 'Distance'); %>
              <% if (showRegistrationOptionBullets) { %>
                <div class="event-side-list-row">
                  <strong><%= registrationOptionsLabel %></strong>
                  <div class="event-side-value">
                    <ul class="event-registration-option-bullets event-registration-option-bullets-side">
                      <% registrationOptionItems.forEach((option) => { %>
                        <li><%= option %></li>
                      <% }) %>
                    </ul>
                  </div>
                </div>
              <% } else { %>
                <p><strong><%= registrationOptionsLabel %></strong><span><%= details.distanceSummaryLabel || (details.raceDistances || []).join(', ') || details.targetDistanceLabel || 'Distances not listed' %></span></p>
              <% } %>
              <% if ((details.raceCategories || []).length) { %>
                <% if (details.raceCategories.length > 2) { %>
                  <div class="event-side-list-row">
                    <strong>Categories</strong>
                    <div class="event-side-value">
                      <ul class="event-side-value-list">
                        <% details.raceCategories.forEach((category) => { %>
                          <li><%= category.name %></li>
                        <% }) %>
                      </ul>
                    </div>
                  </div>
                <% } else { %>
                  <p><strong>Categories</strong><span><%= details.raceCategories.map((category) => category.name).join(', ') %></span></p>
                <% } %>
              <% } %>
              <% if (details.isAccumulatedChallenge) { %>
                <p><strong>Completion Goal</strong><span><%= details.completionGoalLabel || details.targetDistanceLabel || 'Goal not listed' %></span></p>
              <% } %>
              <p><strong>Mode</strong><span><%= (details.allowedModes || []).join(' / ') || details.eventTypeLabel || 'Event mode not listed' %></span></p>
              <% if (details.showLocation) { %>
                <p><strong>Location</strong><span><%= details.location.publicLabel || details.location.summary %></span></p>
              <% } else { %>
                <p><strong>Location</strong><span><%= details.location?.publicLabel || 'Location details not listed' %></span></p>
              <% } %>
            </div>
          </section>
          <% } %>

          <% if (details.posterImageUrl && !details.isAccumulatedChallenge) { %>
            <section class="event-side-card">
              <h3>Event Poster</h3>
              <button
                type="button"
                class="event-poster-thumb-btn"
                data-poster-src="<%= details.posterImageUrl %>"
                aria-label="Open promotional poster"
              >
                <img class="event-details-poster-inline" src="<%= details.posterImageUrl %>" alt="<%= details.title %> promotional poster">
              </button>
            </section>
          <% } %>

          <% if (!isPreviewMode && eventShop && eventShop.count > 0) { %>
            <section class="event-side-card">
              <h3>Event Shop</h3>
              <p class="event-side-card-copy"><%= eventShop.count %> item<%= eventShop.count === 1 ? '' : 's' %> available for this event.</p>
              <a href="<%= eventShop.href %>" class="btn btn-outline btn-block"><i data-lucide="shopping-bag"></i><span>Browse Shop</span></a>
            </section>
          <% } %>

          <% if (locals.user && !isPreviewMode) { %>
            <section class="event-side-card event-contact-card" id="contact-organiser">
              <div class="event-contact-heading">
                <span class="event-contact-icon"><i data-lucide="message-circle" aria-hidden="true"></i></span>
                <div>
                  <h3>Contact Organiser</h3>
                  <p>Ask a question about this event.</p>
                </div>
              </div>
              <% if (locals.message?.type && req?.query?.msg && req?.query?.msg.toString().includes('organiser')) { %>
                <div class="page-message page-message-<%= locals.message.type %>"><%= locals.message?.text || '' %></div>
              <% } %>
              <form method="POST" action="/events/<%= event.slug %>/contact-organiser" class="contact-organiser-form">
                <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
                <div class="contact-organiser-field">
                  <label class="contact-organiser-label" for="contactSubject">Subject <span>Optional</span></label>
                  <input type="text" id="contactSubject" name="subject" class="contact-organiser-input" maxlength="200" placeholder="e.g. Question about proof format">
                </div>
                <div class="contact-organiser-field">
                  <label class="contact-organiser-label" for="contactMessage">Message</label>
                  <textarea id="contactMessage" name="message" class="contact-organiser-input" rows="4" minlength="10" maxlength="1000" required aria-describedby="contactMessageHelp" placeholder="Write your event question..."></textarea>
                  <div class="contact-organiser-help" id="contactMessageHelp"><span>Minimum 10 characters</span><span data-contact-message-count>0 / 1000</span></div>
                </div>
                <button type="submit" class="btn btn-outline btn-block btn-sm"><i data-lucide="send" aria-hidden="true"></i><span>Send message</span></button>
                <p class="contact-organiser-note"><i data-lucide="shield-check" aria-hidden="true"></i><span>Your email is shared only so the organiser can reply directly.</span></p>
              </form>
            </section>
          <% } %>

          <% if (!isPreviewMode) { %>
            <%- include('../partials/ad-unit', { group: 'eventDetails', placement: 'sidebar', className: 'ad-unit-sidebar' }) %>
          <% } %>
        </aside><% } %>
      </div>

      <% if (!details.isAccumulatedChallenge) { %><section class="event-cta-row event-final-cta-row">
        <% if (details.primaryCta && !details.primaryCta.disabled) { %>
          <a href="<%= details.primaryCta.href %>" class="btn btn-primary">Register for This Event</a>
        <% } else { %>
          <button type="button" class="btn btn-outline" disabled><%= details.primaryCta?.label || 'Registration Unavailable' %></button>
        <% } %>
        <% if (isPreviewMode) { %>
          <a href="<%= previewReturnHref %>" class="btn btn-outline">Back to Editor</a>
        <% } else { %>
          <a href="/events" class="btn btn-outline">Browse Other Events</a>
        <% } %>
      </section><% } %>

      <% if (showMobileStickyCta) { %>
        <div class="event-mobile-sticky-cta" aria-label="Event registration">
          <div class="event-mobile-sticky-copy">
            <span><%= runnerState?.stateLabel || details.registrationState?.label || 'Registration open' %></span>
            <strong><%= runnerState?.selectedQuest || details.pricing?.amountLabel || 'View pricing' %></strong>
            <small><%= runnerState?.progressLabel || details.registrationState?.helper || '' %></small>
          </div>
          <% if (pagePrimaryAction.type === 'submit' || pagePrimaryAction.type === 'resubmit') { %>
            <button
              type="button"
              class="btn btn-primary"
              data-open-run-proof-modal
              data-run-proof-surface="event-detail-mobile"
              data-run-proof-mode="<%= pagePrimaryAction.type %>"
              data-run-proof-registration-id="<%= pagePrimaryAction.registrationId %>"
            ><%= pagePrimaryAction.label %></button>
          <% } else { %>
            <a href="<%= pagePrimaryAction.href %>" class="btn btn-primary"><%= pagePrimaryAction.label %></a>
          <% } %>
        </div>
      <% } %>

      <% if ((details.galleryImageUrls || []).length) { %>
        <div id="galleryLightbox" class="gallery-lightbox hidden" aria-hidden="true">
          <div class="gallery-lightbox-backdrop" data-close-lightbox="1"></div>
          <div class="gallery-lightbox-dialog" role="dialog" aria-modal="true" aria-label="Gallery viewer">
            <button type="button" class="gallery-lightbox-close" id="galleryCloseBtn" aria-label="Close gallery">&times;</button>
            <button type="button" class="gallery-lightbox-nav gallery-lightbox-prev" id="galleryPrevBtn" aria-label="Previous image">&#10094;</button>
            <img id="galleryLightboxImage" class="gallery-lightbox-image" src="" alt="">
            <button type="button" class="gallery-lightbox-nav gallery-lightbox-next" id="galleryNextBtn" aria-label="Next image">&#10095;</button>
            <p id="galleryLightboxCounter" class="gallery-lightbox-counter"></p>
          </div>
        </div>
      <% } %>

      <% if (details.posterImageUrl) { %>
        <div id="posterLightbox" class="gallery-lightbox hidden" aria-hidden="true">
          <div class="gallery-lightbox-backdrop" data-close-poster-lightbox="1"></div>
          <div class="gallery-lightbox-dialog" role="dialog" aria-modal="true" aria-label="Promotional poster viewer">
            <button type="button" class="gallery-lightbox-close" id="posterCloseBtn" aria-label="Close poster">&times;</button>
            <div class="poster-zoom-controls">
              <button type="button" class="poster-zoom-btn" id="posterZoomOutBtn" aria-label="Zoom out">-</button>
              <button type="button" class="poster-zoom-btn" id="posterZoomInBtn" aria-label="Zoom in">+</button>
              <button type="button" class="poster-zoom-btn" id="posterResetBtn" aria-label="Reset zoom">Reset</button>
            </div>
            <img id="posterLightboxImage" class="gallery-lightbox-image" src="" alt="">
          </div>
        </div>
      <% } %>
    </section>
  </main>

  <% if (!isPreviewMode && relatedEvents && relatedEvents.length) { %>
    <section class="event-related-section" aria-labelledby="relatedEventsTitle">
      <div class="event-related-wrap">
        <h2 id="relatedEventsTitle">Similar Events</h2>
        <div class="event-related-grid">
          <% relatedEvents.forEach((relEvent) => { %>
            <article class="event-related-card">
              <a href="/events/<%= relEvent.slug %>" class="event-related-img-link" tabindex="-1" aria-hidden="true">
                <% if (relEvent.bannerImageUrl) { %>
                  <img src="<%= relEvent.bannerImageUrl %>" alt="" loading="lazy" class="event-related-img">
                <% } else { %>
                  <div class="event-related-img-placeholder"></div>
                <% } %>
              </a>
              <div class="event-related-body">
                <div class="event-related-tags">
                  <span class="tag tag-status tag-status-<%= relEvent.displayState?.tone || 'neutral' %>"><%= relEvent.displayState?.label || 'Event' %></span>
                  <% if (relEvent.raceDistances && relEvent.raceDistances.length) { %>
                    <span class="tag"><%= relEvent.raceDistances.slice(0, 2).join(' · ') %></span>
                  <% } %>
                </div>
                <h3 class="event-related-title"><a href="/events/<%= relEvent.slug %>"><%= relEvent.title %></a></h3>
                <p class="event-related-organiser"><%= relEvent.organiserName %></p>
              </div>
            </article>
          <% }) %>
        </div>
        <a href="/events" class="event-related-browse">Browse all events →</a>
      </div>
    </section>
  <% } %>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <% if (locals.isAuthenticated) { %><script src="/js/event-save.js"></script><% } %>
  <script>
    if (window.lucide) lucide.createIcons();

    (function initEventSectionJump() {
      const jump = document.querySelector('.event-section-jump');
      if (!jump) return;
      jump.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', () => {
          jump.open = false;
        });
      });
    })();

    (function initContactMessageCount() {
      const message = document.getElementById('contactMessage');
      const count = document.querySelector('[data-contact-message-count]');
      if (!message || !count) return;
      const updateCount = () => {
        count.textContent = `${message.value.length} / 1000`;
      };
      message.addEventListener('input', updateCount);
      updateCount();
    })();

    (function initGalleryLightbox() {
      const lightbox = document.getElementById('galleryLightbox');
      if (!lightbox) return;

      const body = document.body;
      const thumbButtons = Array.from(document.querySelectorAll('.event-gallery-thumb-btn'));
      const imageEl = document.getElementById('galleryLightboxImage');
      const counterEl = document.getElementById('galleryLightboxCounter');
      const closeBtn = document.getElementById('galleryCloseBtn');
      const prevBtn = document.getElementById('galleryPrevBtn');
      const nextBtn = document.getElementById('galleryNextBtn');
      const closeBackdrop = lightbox.querySelector('[data-close-lightbox="1"]');
      const gallerySources = thumbButtons.map((btn) => ({
        src: btn.getAttribute('data-gallery-src') || '',
        alt: btn.querySelector('img')?.alt || 'Gallery image'
      }));
      let currentIndex = 0;
      let lastFocusedElement = null;

      function keepFocusInside(event) {
        if (event.key !== 'Tab') return;
        const focusable = Array.from(lightbox.querySelectorAll('button:not([disabled]), [href], [tabindex]:not([tabindex="-1"])'));
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }

      function updateLightboxImage() {
        const item = gallerySources[currentIndex];
        if (!item) return;
        imageEl.src = item.src;
        imageEl.alt = item.alt;
        counterEl.textContent = `${currentIndex + 1} / ${gallerySources.length}`;
      }

      function openLightbox(index) {
        lastFocusedElement = document.activeElement;
        currentIndex = Math.max(0, Math.min(index, gallerySources.length - 1));
        updateLightboxImage();
        lightbox.classList.remove('hidden');
        lightbox.setAttribute('aria-hidden', 'false');
        body.classList.add('no-scroll');
        closeBtn.focus();
      }

      function closeLightbox() {
        lightbox.classList.add('hidden');
        lightbox.setAttribute('aria-hidden', 'true');
        body.classList.remove('no-scroll');
        if (lastFocusedElement && typeof lastFocusedElement.focus === 'function') lastFocusedElement.focus();
      }

      function showPrev() {
        currentIndex = (currentIndex - 1 + gallerySources.length) % gallerySources.length;
        updateLightboxImage();
      }

      function showNext() {
        currentIndex = (currentIndex + 1) % gallerySources.length;
        updateLightboxImage();
      }

      thumbButtons.forEach((btn, index) => {
        btn.addEventListener('click', () => openLightbox(index));
      });
      closeBtn.addEventListener('click', closeLightbox);
      prevBtn.addEventListener('click', showPrev);
      nextBtn.addEventListener('click', showNext);
      if (closeBackdrop) closeBackdrop.addEventListener('click', closeLightbox);

      document.addEventListener('keydown', (event) => {
        if (lightbox.classList.contains('hidden')) return;
        keepFocusInside(event);
        if (event.key === 'Escape') closeLightbox();
        if (event.key === 'ArrowLeft') showPrev();
        if (event.key === 'ArrowRight') showNext();
      });
    })();

    (function initPosterLightbox() {
      const posterBtn = document.querySelector('.event-poster-thumb-btn');
      const lightbox = document.getElementById('posterLightbox');
      if (!posterBtn || !lightbox) return;

      const body = document.body;
      const imageEl = document.getElementById('posterLightboxImage');
      const closeBtn = document.getElementById('posterCloseBtn');
      const zoomInBtn = document.getElementById('posterZoomInBtn');
      const zoomOutBtn = document.getElementById('posterZoomOutBtn');
      const resetBtn = document.getElementById('posterResetBtn');
      const closeBackdrop = lightbox.querySelector('[data-close-poster-lightbox="1"]');
      const posterSrc = posterBtn.getAttribute('data-poster-src') || '';
      const posterAlt = posterBtn.querySelector('img')?.alt || 'Promotional poster';
      let zoomLevel = 1;
      let translateX = 0;
      let translateY = 0;
      let isDragging = false;
      let dragStartX = 0;
      let dragStartY = 0;
      let lastFocusedElement = null;

      function keepFocusInside(event) {
        if (event.key !== 'Tab') return;
        const focusable = Array.from(lightbox.querySelectorAll('button:not([disabled]), [href], [tabindex]:not([tabindex="-1"])'));
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }

      function updatePosterTransform() {
        imageEl.style.transform = `translate(${translateX}px, ${translateY}px) scale(${zoomLevel})`;
        imageEl.classList.toggle('is-zoomed', zoomLevel > 1);
        imageEl.style.cursor = zoomLevel > 1 ? (isDragging ? 'grabbing' : 'grab') : 'zoom-in';
        if (zoomInBtn) zoomInBtn.disabled = zoomLevel >= 3;
        if (zoomOutBtn) zoomOutBtn.disabled = zoomLevel <= 1;
      }

      function setZoom(nextZoomLevel) {
        const clamped = Math.max(1, Math.min(3, Number(nextZoomLevel.toFixed(2))));
        zoomLevel = clamped;
        if (zoomLevel === 1) {
          translateX = 0;
          translateY = 0;
        }
        updatePosterTransform();
      }

      function resetZoom() {
        isDragging = false;
        setZoom(1);
      }

      function openLightbox() {
        lastFocusedElement = document.activeElement;
        imageEl.src = posterSrc;
        imageEl.alt = posterAlt;
        resetZoom();
        lightbox.classList.remove('hidden');
        lightbox.setAttribute('aria-hidden', 'false');
        body.classList.add('no-scroll');
        closeBtn.focus();
      }

      function closeLightbox() {
        lightbox.classList.add('hidden');
        lightbox.setAttribute('aria-hidden', 'true');
        body.classList.remove('no-scroll');
        resetZoom();
        if (lastFocusedElement && typeof lastFocusedElement.focus === 'function') lastFocusedElement.focus();
      }

      posterBtn.addEventListener('click', openLightbox);
      closeBtn.addEventListener('click', closeLightbox);
      if (zoomInBtn) zoomInBtn.addEventListener('click', () => setZoom(zoomLevel + 0.25));
      if (zoomOutBtn) zoomOutBtn.addEventListener('click', () => setZoom(zoomLevel - 0.25));
      if (resetBtn) resetBtn.addEventListener('click', resetZoom);
      if (closeBackdrop) closeBackdrop.addEventListener('click', closeLightbox);

      imageEl.addEventListener('pointerdown', (event) => {
        if (zoomLevel <= 1) return;
        isDragging = true;
        dragStartX = event.clientX - translateX;
        dragStartY = event.clientY - translateY;
        imageEl.setPointerCapture(event.pointerId);
        updatePosterTransform();
      });

      imageEl.addEventListener('pointermove', (event) => {
        if (!isDragging || zoomLevel <= 1) return;
        translateX = event.clientX - dragStartX;
        translateY = event.clientY - dragStartY;
        updatePosterTransform();
      });

      function stopDragging() {
        if (!isDragging) return;
        isDragging = false;
        updatePosterTransform();
      }

      imageEl.addEventListener('pointerup', stopDragging);
      imageEl.addEventListener('pointercancel', stopDragging);
      imageEl.addEventListener('pointerleave', stopDragging);

      document.addEventListener('keydown', (event) => {
        if (lightbox.classList.contains('hidden')) return;
        keepFocusInside(event);
        if (event.key === 'Escape') closeLightbox();
      });
    })();
  </script>
</body>
</html>
