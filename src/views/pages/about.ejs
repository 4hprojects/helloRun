<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title, seo: seo }) %>
  <link rel="stylesheet" href="/css/about.css">
</head>
<body class="about-body<%= locals.isAuthenticated && !locals.isAdmin && !locals.isApprovedOrganizer && !locals.isOrganizer ? ' has-runner-mobile-nav' : '' %>">
  <%- include('../layouts/nav') %>

  <main class="about-page">
    <section class="about-hero" aria-labelledby="aboutHeroTitle">
      <div class="about-container about-hero-grid">
        <div class="about-hero-copy">
          <p class="about-kicker">About HelloRun</p>
          <h1 id="aboutHeroTitle">A clearer way to join, prove, and celebrate every run.</h1>
          <p class="about-hero-lead">HelloRun brings event discovery, registration, activity proof, review status, results, and recognition into one runner-friendly journey.</p>
          <div class="about-actions" aria-label="About HelloRun actions">
            <a href="<%= aboutActions.primary.href %>" class="btn btn-primary">
              <i data-lucide="<%= aboutActions.primary.icon %>" aria-hidden="true"></i>
              <span><%= aboutActions.primary.label %></span>
            </a>
            <a href="<%= aboutActions.account.href %>" class="btn btn-outline">
              <i data-lucide="<%= aboutActions.account.icon %>" aria-hidden="true"></i>
              <span><%= aboutActions.account.label %></span>
            </a>
          </div>
          <a href="<%= aboutActions.organizer.href %>" class="about-organizer-link">
            <%= aboutActions.organizer.label %>
            <i data-lucide="arrow-right" aria-hidden="true"></i>
          </a>
        </div>

        <aside class="about-journey-preview" aria-label="HelloRun runner journey">
          <p class="about-preview-label">One connected journey</p>
          <ol>
            <li><span>1</span><div><strong>Find your event</strong><small>Compare the goal, dates, rules, and organizer.</small></div></li>
            <li><span>2</span><div><strong>Complete your activity</strong><small>Follow the event’s accepted activity and proof rules.</small></div></li>
            <li><span>3</span><div><strong>Track the review</strong><small>See whether your submission is pending or approved.</small></div></li>
            <li><span>4</span><div><strong>Keep the result</strong><small>View eligible standings, badges, or certificates.</small></div></li>
          </ol>
        </aside>
      </div>
    </section>

    <section class="about-trust-strip" aria-label="Why runners use HelloRun">
      <div class="about-container">
        <article><i data-lucide="map" aria-hidden="true"></i><div><strong>Flexible formats</strong><span>Virtual, on-site, and hybrid events</span></div></article>
        <article><i data-lucide="file-check-2" aria-hidden="true"></i><div><strong>Reviewed submissions</strong><span>Evidence checked where required</span></div></article>
        <article><i data-lucide="scan-search" aria-hidden="true"></i><div><strong>Visible status</strong><span>Pending and approved states stay clear</span></div></article>
        <article><i data-lucide="award" aria-hidden="true"></i><div><strong>Event recognition</strong><span>Results, badges, and certificates when enabled</span></div></article>
      </div>
    </section>

    <div class="about-container about-content">
      <section class="about-section about-runner-journey" aria-labelledby="aboutJourneyTitle">
        <div class="about-section-heading">
          <span class="about-section-icon"><i data-lucide="route" aria-hidden="true"></i></span>
          <div>
            <p class="about-eyebrow">From signup to recognition</p>
            <h2 id="aboutJourneyTitle">How HelloRun works for runners</h2>
            <p>Choose the event that fits your goal, follow its rules, and keep every next step visible.</p>
          </div>
        </div>

        <ol class="about-steps">
          <li><span>1</span><div><h3>Discover and register</h3><p>Review the format, distance, dates, price, and organizer before joining.</p></div></li>
          <li><span>2</span><div><h3>Complete the activity</h3><p>Run or complete an accepted activity during the event window.</p></div></li>
          <li><span>3</span><div><h3>Submit accepted proof</h3><p>Use the proof method published by the organizer and track its status.</p></div></li>
          <li><span>4</span><div><h3>Receive reviewed recognition</h3><p>Approved entries may appear in standings and unlock event recognition.</p></div></li>
        </ol>

        <div class="about-format-row" aria-label="Event formats supported by HelloRun">
          <span>Virtual runs</span>
          <span>On-site races</span>
          <span>Hybrid events</span>
          <span>Accumulated-distance challenges</span>
          <span>Community events</span>
        </div>
      </section>

      <section class="about-section about-accountability" aria-labelledby="aboutTrustTitle">
        <div class="about-section-heading">
          <span class="about-section-icon"><i data-lucide="shield-check" aria-hidden="true"></i></span>
          <div>
            <p class="about-eyebrow">Trust and accountability</p>
            <h2 id="aboutTrustTitle">Know what is reviewed, private, and official</h2>
            <p>Every event keeps its own published rules. HelloRun makes the responsible organizer, review state, and recognition boundaries easier to understand.</p>
          </div>
        </div>

        <div class="about-accountability-grid">
          <article>
            <span class="about-card-icon"><i data-lucide="clipboard-check" aria-hidden="true"></i></span>
            <h3>Why submissions and leaderboards are reviewed</h3>
            <p>Where review is configured, an uploaded screenshot does not become an official result automatically. Authorized organizers or administrators check eligibility before approval and publication.</p>
          </article>
          <article>
            <span class="about-card-icon"><i data-lucide="lock-keyhole" aria-hidden="true"></i></span>
            <h3>Data privacy and proof handling</h3>
            <p>Activity proof and payment records are available only to authorized reviewers unless an event explicitly identifies information that will be public.</p>
            <a href="/privacy" class="about-inline-link">Read the Privacy Policy <i data-lucide="arrow-up-right" aria-hidden="true"></i></a>
          </article>
          <article>
            <span class="about-card-icon"><i data-lucide="users" aria-hidden="true"></i></span>
            <h3>Know who manages the event</h3>
            <div class="about-owner-labels">
              <span class="about-label about-label-official">Official HelloRun Event</span>
              <span class="about-label about-label-managed">Organiser-Managed Event</span>
            </div>
            <p>Event pages identify whether HelloRun or an independent organizer controls the rules, reviews, participant support, and event-specific decisions.</p>
          </article>
          <article>
            <span class="about-card-icon"><i data-lucide="badge-check" aria-hidden="true"></i></span>
            <h3>Recognition has a clear boundary</h3>
            <p>HelloRun certificates and badges are event-based recognition. They do not replace official timing, government records, accreditation, or third-party certification unless explicitly stated.</p>
          </article>
        </div>
      </section>

      <section class="about-organizer-path" aria-labelledby="aboutOrganizerTitle">
        <div>
          <p class="about-eyebrow">For event organizers</p>
          <h2 id="aboutOrganizerTitle">Replace scattered forms and spreadsheets with one event workflow</h2>
          <p>Create event pages, manage registrations, review payment and activity proof, publish approved results, and issue configured recognition from one platform.</p>
        </div>
        <ul>
          <li><i data-lucide="check" aria-hidden="true"></i>Participant and registration records</li>
          <li><i data-lucide="check" aria-hidden="true"></i>Submission review and status tracking</li>
          <li><i data-lucide="check" aria-hidden="true"></i>Leaderboards and certificates</li>
        </ul>
        <a href="<%= aboutActions.organizer.href %>" class="btn btn-outline"><%= aboutActions.organizer.label %></a>
      </section>

      <section class="about-section about-operator" aria-labelledby="aboutOperatorTitle">
        <div class="about-section-heading">
          <span class="about-section-icon"><i data-lucide="map-pinned" aria-hidden="true"></i></span>
          <div>
            <p class="about-eyebrow">Local roots, accountable operation</p>
            <h2 id="aboutOperatorTitle">Built from real community event work</h2>
          </div>
        </div>
        <div class="about-operator-grid">
          <div class="about-operator-story">
            <p>HelloRun began with a practical problem: runners and organizers were managing registrations, receipts, screenshots, results, and certificates across disconnected tools.</p>
            <p>The platform brings those tasks into one clearer workflow without replacing the experience of running or the authority of each event organizer.</p>
          </div>
          <aside class="about-operator-card" aria-label="HelloRun operator information">
            <img src="/images/helloRun-icon.webp" alt="" aria-hidden="true">
            <div>
              <span>Developed and operated by</span>
              <strong>Henson M. Sagorsor</strong>
              <p>A product of <strong>4HProjects</strong>, based in Benguet, Philippines.</p>
              <a href="/contact" class="about-inline-link">Contact HelloRun <i data-lucide="arrow-right" aria-hidden="true"></i></a>
            </div>
          </aside>
        </div>
      </section>

      <section class="about-section about-current-events" aria-labelledby="currentEventsTitle">
        <div class="about-section-heading about-section-heading-action">
          <span class="about-section-icon"><i data-lucide="calendar-search" aria-hidden="true"></i></span>
          <div>
            <p class="about-eyebrow">Put it into action</p>
            <h2 id="currentEventsTitle">Find your next event</h2>
            <p>These published events are available to explore now. Check each event page for its organizer, rules, dates, and registration state.</p>
          </div>
          <a href="/events" class="btn btn-outline">Browse All Events</a>
        </div>

        <% if (currentEvents && currentEvents.length) { %>
          <div class="about-event-grid">
            <% currentEvents.forEach((event) => { %>
              <article class="about-event-card">
                <a href="<%= event.href %>" class="about-event-image-link" tabindex="-1" aria-hidden="true">
                  <img src="<%= event.imageUrl %>" alt="" loading="lazy" onerror="this.onerror=null;this.src='<%= event.fallbackImageUrl %>';">
                </a>
                <div class="about-event-body">
                  <div class="about-event-tags">
                    <span class="about-label about-label-managed">Organiser-Managed Event</span>
                    <span class="about-event-status about-event-status-<%= event.displayState?.tone || 'neutral' %>"><%= event.displayState?.label || 'Event Listing' %></span>
                  </div>
                  <h3><a href="<%= event.href %>"><%= event.title %></a></h3>
                  <div class="about-event-meta">
                    <span><i data-lucide="calendar" aria-hidden="true"></i><%= event.dateLabel %></span>
                    <span><i data-lucide="flag" aria-hidden="true"></i><span class="about-event-distance"><%= event.distanceLabel %></span></span>
                    <span><i data-lucide="map-pin" aria-hidden="true"></i><%= event.locationLabel %></span>
                  </div>
                  <% if (event.organiserName) { %><p class="about-event-organizer">Hosted by <strong><%= event.organiserName %></strong></p><% } %>
                  <a href="<%= event.href %>" class="about-inline-link">View event <i data-lucide="arrow-right" aria-hidden="true"></i></a>
                </div>
              </article>
            <% }); %>
          </div>
        <% } else { %>
          <div class="about-empty-state">
            <span class="about-card-icon"><i data-lucide="calendar-search" aria-hidden="true"></i></span>
            <div><h3>No published events are available right now</h3><p>Check back soon or browse the full event directory.</p></div>
            <a href="/events" class="btn btn-outline">Browse Events</a>
          </div>
        <% } %>
      </section>
    </div>

    <section class="about-final-cta" aria-labelledby="aboutCtaTitle">
      <div class="about-container">
        <div>
          <p class="about-kicker">Your next goal starts here</p>
          <h2 id="aboutCtaTitle">Find an event that fits the way you run.</h2>
          <p>Compare the goal, organizer, dates, and proof rules before you join.</p>
        </div>
        <div class="about-final-actions">
          <a href="<%= aboutActions.primary.href %>" class="btn btn-primary"><%= aboutActions.primary.label %></a>
          <a href="<%= aboutActions.organizer.href %>" class="about-organizer-link"><%= aboutActions.organizer.label %> <i data-lucide="arrow-right" aria-hidden="true"></i></a>
        </div>
      </div>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
