<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || `${post?.title || 'Blog Post'} - HelloRun`, seo: seo }) %>
  <link rel="stylesheet" href="/css/blog-pages.css">
  <%
    function safeJson(obj) {
      return JSON.stringify(obj).replace(/<\/script>/gi, '<\\/script>');
    }
    const _postCanonical = (seo && seo.canonicalUrl) || '';
    const _postImage = (seo && seo.ogImage) ? seo.ogImage : (post.coverImageUrl || '');
    const _postDesc = (seo && seo.description) || post.excerpt || '';
    const _postPublished = post.publishedAt ? new Date(post.publishedAt).toISOString() : new Date(post.createdAt).toISOString();
    const _postModified = post.updatedAt ? new Date(post.updatedAt).toISOString() : _postPublished;
  %>
  <script type="application/ld+json"><%- safeJson({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.title,
    "description": _postDesc,
    "image": _postImage,
    "url": _postCanonical,
    "datePublished": _postPublished,
    "dateModified": _postModified,
    "author": { "@type": authorDisplay.schemaType || "Person", "name": authorDisplay.name },
    "publisher": {
      "@type": "Organization",
      "name": "HelloRun",
      "logo": { "@type": "ImageObject", "url": "https://hellorun.online/images/helloRun-icon.webp" }
    },
    "keywords": (post.tags || []).join(', '),
    "articleSection": post.category
  }) %></script>
  <script type="application/ld+json"><%- safeJson({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Blog", "item": "https://hellorun.online/blog" },
      { "@type": "ListItem", "position": 2, "name": post.title, "item": _postCanonical }
    ]
  }) %></script>
</head>
<body>
  <%- include('../layouts/nav') %>
  <div class="blog-read-progress" id="blogReadProgress" aria-hidden="true"></div>
  
    <main class="blog-post-shell">
    <div class="blog-post-topbar">
      <nav class="blog-post-breadcrumb" aria-label="Breadcrumb">
        <a href="/blog">Blog</a>
        <i data-lucide="chevron-right" class="breadcrumb-sep" aria-hidden="true"></i>
        <span class="breadcrumb-current" aria-current="page"><%= post.title %></span>
      </nav>
      <a href="/blog" class="blog-back-btn"><i data-lucide="arrow-left"></i>Back to Blog</a>
    </div>

    <article class="blog-post-article">
      <header class="blog-post-hero">
        <div class="blog-post-topic-row">
          <span class="blog-category-chip"><%= articlePresentation?.categoryLabel || post.category %></span>
          <span class="blog-post-audience">For <strong><%= articlePresentation?.audience || 'the running community' %></strong></span>
        </div>
        <div class="blog-post-title-row">
          <h1><%= post.title %></h1>
        </div>
        <div class="post-audience-chips">
          <% (articlePresentation?.tags || []).forEach(function(tag) { %>
            <span class="post-audience-chip post-audience-chip-tag">#<%= tag %></span>
          <% }) %>
        </div>
        <% if (post.excerpt) { %>
          <p class="blog-post-excerpt"><%= post.excerpt %></p>
        <% } %>
        <div class="blog-post-byline">
          <span class="blog-post-author-avatar" aria-hidden="true">
            <% if (post.authorId?.avatarUrl) { %>
              <img src="<%= post.authorId.avatarUrl %>" alt="">
            <% } else { %>
              <%= (authorDisplay?.name || 'H').charAt(0) %>
            <% } %>
          </span>
          <div class="blog-post-author-copy">
            <a href="<%= post.authorId?._id ? `/blog?author=${post.authorId._id}` : '/blog' %>" class="blog-post-author-name">
              <%= authorDisplay?.name || `${post.authorId?.firstName || 'HelloRun'} ${post.authorId?.lastName || ''}` %>
              <% if (post.authorId?.verifiedAuthor) { %>
                <i data-lucide="badge-check" class="verified-author-icon" aria-label="Verified writer"></i>
              <% } %>
            </a>
            <p class="blog-post-submeta">
              <%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '' %>
              <span aria-hidden="true">·</span> <%= post.readingTime || 1 %> min read
            </p>
          </div>
          <div class="blog-post-community-stats" aria-label="Article engagement">
            <span><i data-lucide="eye" aria-hidden="true"></i><strong><%= Number(post.views || 0).toLocaleString('en-US') %></strong> views</span>
            <span><i data-lucide="heart" aria-hidden="true"></i><strong><%= Number(post.likesCount || 0).toLocaleString('en-US') %></strong> likes</span>
            <a href="#blogComments"><i data-lucide="message-circle" aria-hidden="true"></i><strong id="blogCommentCount"><%= Number(post.commentsCount || 0).toLocaleString('en-US') %></strong> comments</a>
          </div>
        </div>
        <div class="toast hidden" id="copyToast" role="status" aria-live="polite">Link copied!</div>
      </header>

      <% if (post.coverImageUrl) { %>
        <img src="<%= post.coverImageUrl %>" alt="<%= post.coverImageAlt || `${post.title} cover` %>" loading="lazy" class="blog-cover-image" data-blog-cover-image>
      <% } %>

      <%- include('../partials/ad-unit', { group: 'blogPost', placement: 'after_intro' }) %>

      <div class="blog-post-layout">
        <!-- Mobile Toggle for TOC -->
        <details class="blog-post-toc-mobile">
          <summary>On this page</summary>
          <aside class="blog-post-toc-card" id="blogPostTocWrap">
            <ul id="blogPostTocList"></ul>
          </aside>
        </details>

        <aside class="blog-engagement-rail" aria-label="Article actions">
          <div class="blog-engagement-rail-inner">
            <button type="button" class="blog-like-btn<%= interactionState?.likedByCurrentUser ? ' is-liked' : '' %>" id="blogLikeBtn" data-liked="<%= interactionState?.likedByCurrentUser ? '1' : '0' %>" <%= interactionState?.isAuthenticated ? '' : 'data-login-required="1"' %> aria-pressed="<%= interactionState?.likedByCurrentUser ? 'true' : 'false' %>">
              <i data-lucide="heart" aria-hidden="true"></i>
              <span id="blogLikeLabel"><%= interactionState?.likedByCurrentUser ? 'Unlike' : 'Like' %></span>
              <span class="blog-like-count" id="blogLikeCount"><%= Number(post.likesCount || 0).toLocaleString('en-US') %></span>
            </button>
            <%- include('../partials/blog-share-menu', {
              instanceId: 'blog',
              canonicalUrl: seo?.canonicalUrl || '',
              articleTitle: post.title || '',
              triggerLabel: 'Share',
              containerClass: 'blog-share-rail-menu',
              triggerClass: 'btn btn-icon share-mobile-toggle'
            }) %>
            <a href="#blogComments" class="blog-comment-jump"><i data-lucide="message-circle" aria-hidden="true"></i><span>Discuss</span></a>
          </div>
        </aside>

        <!-- Desktop TOC -->
        <aside class="blog-post-toc-card desktop-only" id="blogPostTocWrapDesktop">
          <h4>On this page</h4>
          <ul id="blogPostTocListDesktop"></ul>
        </aside>

        <div class="blog-post-body">
          <div class="run-action-panel">
            <span class="run-action-panel-label">Put this into action</span>
            <div class="run-action-panel-links">
              <% (articlePresentation?.actions || []).forEach(function(link) { %>
                <a href="<%= link.href %>" class="run-action-panel-link">
                  <i data-lucide="<%= link.icon %>" aria-hidden="true"></i>
                  <%= link.label %>
                </a>
              <% }) %>
            </div>
          </div>
          <section class="blog-content" id="blogPostContent">
            <%- (blogContentParts && blogContentParts.beforeAd) || post.contentHtml %>
            <% if (blogContentParts && blogContentParts.afterAd) { %>
              <%- include('../partials/ad-unit', { group: 'blogPost', placement: 'in_article' }) %>
              <%- blogContentParts.afterAd %>
            <% } %>
          </section>

          <% if (post.galleryImageUrls && post.galleryImageUrls.length) { %>
            <section class="blog-gallery">
              <h3>Story gallery</h3>
              <div class="blog-gallery-grid">
                <% post.galleryImageUrls.forEach((imageUrl, imageIndex) => { %>
                  <button type="button" class="blog-gallery-item" data-gallery-index="<%= imageIndex %>" data-gallery-url="<%= imageUrl %>" data-gallery-caption="<%= post.galleryCaptions?.[imageIndex] || '' %>" aria-label="Open gallery image <%= imageIndex + 1 %>">
                    <img src="<%= imageUrl %>" alt="<%= post.title %> gallery image <%= imageIndex + 1 %>" loading="lazy">
                  </button>
                <% }) %>
              </div>
            </section>
          <% } %>

          <section class="blog-end-share-card" aria-labelledby="blogEndShareTitle">
            <div class="blog-end-share-copy">
              <span class="blog-end-share-kicker">Pass it on</span>
              <h2 id="blogEndShareTitle">Found this helpful?</h2>
              <p>Share this guide with a runner who could use it.</p>
            </div>
            <%- include('../partials/blog-share-menu', {
              instanceId: 'endBlog',
              canonicalUrl: seo?.canonicalUrl || '',
              articleTitle: post.title || '',
              triggerLabel: 'Share this guide',
              containerClass: 'blog-share-end-menu',
              triggerClass: 'btn btn-secondary blog-end-share-trigger'
            }) %>
          </section>

          <% if (post.tags && post.tags.length) { %>
            <div class="blog-tag-list">
              <% post.tags.forEach((tag) => { %>
                <span class="blog-tag">#<%= tag %></span>
              <% }) %>
            </div>
          <% } %>

          <div class="post-next-step">
            <span class="post-next-step-text">Ready to take the next step?</span>
            <a href="<%= articlePresentation?.nextStep?.href || '/events' %>" class="post-next-step-cta">
              <%= articlePresentation?.nextStep?.label || 'Browse community events' %> <i data-lucide="arrow-right" aria-hidden="true"></i>
            </a>
          </div>

          <section class="blog-interactions">
            <div class="blog-interactions-bar">
              <% if (interactionState?.isAuthenticated) { %>
                <details class="blog-report-details">
                  <summary>Report post</summary>
                  <form id="blogReportForm" class="blog-report-form">
                    <select name="reason" required>
                      <option value="">Select reason</option>
                      <% (interactionState?.reportReasons || []).forEach((reason) => { %>
                        <option value="<%= reason %>"><%= reason.replace(/_/g, ' ') %></option>
                      <% }) %>
                    </select>
                    <textarea name="note" rows="3" maxlength="500" placeholder="Optional note"></textarea>
                    <button type="submit" class="btn-icon" aria-label="Send Report">
                      <i data-lucide="send"></i>
                      <span class="btn-tooltip">Send Report</span>
                    </button>
                  </form>
                </details>
              <% } else { %>
                <a href="/login?redirect=/blog/<%= post.slug %>" class="btn btn-secondary">Sign in to like or comment</a>
              <% } %>
            </div>

            <div class="blog-comments-section" id="blogComments"
              data-blog-comments
              data-post-slug="<%= post.slug %>"
              data-csrf-token="<%= locals.csrfToken || '' %>"
              data-current-user-id="<%= interactionState?.currentUserId || '' %>">
              <span class="sr-only" aria-hidden="true"><strong id="blogContributionCount"><%= Number(post.commentsCount || 0).toLocaleString('en-US') %></strong></span>
              <p data-comments-bootstrap-status role="status" aria-live="polite"></p>
              <threaded-comments></threaded-comments>
            </div>
          </section>

          <section class="blog-author-box">
            <div class="author-avatar">
              <% if (post.authorId?.avatarUrl) { %>
                <img src="<%= post.authorId.avatarUrl %>" alt="<%= authorDisplay?.name || 'Author' %>" loading="lazy">
              <% } else { %>
                <div class="author-avatar-placeholder"><%= (authorDisplay?.name || 'U')[0] %></div>
              <% } %>
            </div>
            <div class="author-details">
              <h4>
                <%= authorDisplay?.name || `${post.authorId?.firstName || 'HelloRun'} ${post.authorId?.lastName || ''}` %>
                <% if (post.authorId?.verifiedAuthor) { %>
                  <span class="verified-author-badge" title="Verified Author" style="color:#2196f3;vertical-align:middle;">
                    <i data-lucide="badge-check" aria-hidden="true"></i> Verified
                  </span>
                <% } %>
              </h4>
              <p class="author-bio"><%= authorDisplay?.bio || 'HelloRun publishes practical guides for runners and event organizers.' %></p>
              <% if (typeof post.authorId?.trustScore === 'number') { %>
                <div class="author-trust-score" style="font-size:0.95em;color:#4caf50;">
                  Trust Score: <strong><%= post.authorId.trustScore %></strong>/100
                </div>
              <% } %>
              <% if (post.authorId?._id) { %>
                <a href="/blog?author=<%= post.authorId._id %>" class="author-more-posts">More posts by this author →</a>
              <% } %>
            </div>
          </section>

        </div>
      </div>
    </article>

    <% if (relatedPosts && relatedPosts.length) { %>
      <%- include('../partials/ad-unit', { group: 'blogPost', placement: 'before_related' }) %>

      <section class="blog-related">
        <h3>Continue reading</h3>
        <div class="blog-related-grid">
          <% relatedPosts.forEach((item) => { %>
            <a href="/blog/<%= item.slug %>" class="blog-related-card">
              <% if (item.coverImageUrl) { %>
                <img src="<%= item.coverImageUrl %>" alt="<%= item.title %> cover" loading="lazy" data-blog-cover-image>
              <% } %>
              <div class="blog-related-card-body">
                <strong><%= item.title %></strong>
                <p class="related-meta">
                  <%= item.category === 'Other' && item.customCategory ? item.customCategory : item.category %> |
                  <%= item.publishedAt ? new Date(item.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %>
                </p>
                <% if (item.excerpt) { %>
                  <p class="related-excerpt"><%= item.excerpt %></p>
                <% } %>
              </div>
            </a>
          <% }) %>
        </div>
      </section>
    <% } %>
  </main>

  <% if (interactionState?.isAuthenticated) { %>
    <dialog class="blog-confirm-dialog" id="blogCommentConfirmDialog" aria-labelledby="blogCommentConfirmTitle" aria-describedby="blogCommentConfirmDescription">
      <div class="blog-confirm-dialog-content">
        <div class="blog-confirm-dialog-icon" aria-hidden="true"><i data-lucide="message-circle"></i></div>
        <div class="blog-confirm-dialog-copy">
          <span class="blog-confirm-dialog-kicker">Community comment</span>
          <h2 id="blogCommentConfirmTitle">Post this comment?</h2>
          <p id="blogCommentConfirmDescription">Review your message before it becomes visible in the discussion.</p>
        </div>
        <blockquote class="blog-confirm-preview" id="blogCommentConfirmPreview"></blockquote>
        <p class="blog-confirm-status" id="blogCommentConfirmStatus" role="status" aria-live="polite"></p>
        <div class="blog-confirm-actions">
          <button type="button" class="btn btn-secondary" id="blogCommentConfirmCancel">Go back</button>
          <button type="button" class="btn btn-primary" id="blogCommentConfirmSubmit"><i data-lucide="send" aria-hidden="true"></i><span>Post comment</span></button>
        </div>
      </div>
    </dialog>
    <dialog class="blog-confirm-dialog blog-confirm-dialog-danger" id="blogCommentDeleteDialog" aria-labelledby="blogCommentDeleteTitle" aria-describedby="blogCommentDeleteDescription">
      <div class="blog-confirm-dialog-content">
        <div class="blog-confirm-dialog-icon" aria-hidden="true"><i data-lucide="trash-2"></i></div>
        <div class="blog-confirm-dialog-copy">
          <span class="blog-confirm-dialog-kicker">Permanent action</span>
          <h2 id="blogCommentDeleteTitle">Delete this comment?</h2>
          <p id="blogCommentDeleteDescription">This removes your comment from the discussion and cannot be undone.</p>
        </div>
        <blockquote class="blog-confirm-preview" id="blogCommentDeletePreview"></blockquote>
        <p class="blog-confirm-status" id="blogCommentDeleteStatus" role="status" aria-live="polite"></p>
        <div class="blog-confirm-actions">
          <button type="button" class="btn btn-secondary" id="blogCommentDeleteCancel">Cancel</button>
          <button type="button" class="btn btn-danger" id="blogCommentDeleteConfirm"><i data-lucide="trash-2" aria-hidden="true"></i><span>Delete comment</span></button>
        </div>
      </div>
    </dialog>
    <dialog class="blog-confirm-dialog blog-comment-report-dialog" id="blogCommentReportDialog" aria-labelledby="blogCommentReportTitle" aria-describedby="blogCommentReportDescription">
      <form class="blog-confirm-dialog-content" id="blogCommentReportForm">
        <div class="blog-confirm-dialog-icon" aria-hidden="true"><i data-lucide="flag"></i></div>
        <div class="blog-confirm-dialog-copy">
          <span class="blog-confirm-dialog-kicker">Community safety</span>
          <h2 id="blogCommentReportTitle">Report this comment?</h2>
          <p id="blogCommentReportDescription">Tell the moderation team why this comment needs review. Your report is private.</p>
        </div>
        <div class="blog-comment-report-context">
          <strong id="blogCommentReportAuthor"></strong>
          <blockquote class="blog-confirm-preview" id="blogCommentReportPreview"></blockquote>
        </div>
        <label class="blog-comment-report-field" for="blogCommentReportReason">
          <span>What is wrong with this comment?</span>
          <select id="blogCommentReportReason" name="reason" required>
            <option value="">Select why this comment should be reviewed</option>
            <option value="spam">Spam or repeated messages</option>
            <option value="plagiarism">Copied or impersonated comment</option>
            <option value="promotion">Advertising or unwanted promotion</option>
            <option value="unsafe_medical">Dangerous health or medical advice</option>
            <option value="abuse">Harassment, hate, or abusive language</option>
            <option value="other">Another concern about this comment</option>
          </select>
        </label>
        <label class="blog-comment-report-field" for="blogCommentReportNote">
          <span>Additional context <small>Optional</small></span>
          <textarea id="blogCommentReportNote" name="note" rows="3" maxlength="500" placeholder="Add context that will help moderators review this comment."></textarea>
        </label>
        <p class="blog-confirm-status" id="blogCommentReportStatus" role="status" aria-live="polite"></p>
        <div class="blog-confirm-actions">
          <button type="button" class="btn btn-secondary" id="blogCommentReportCancel">Cancel</button>
          <button type="submit" class="btn btn-primary" id="blogCommentReportSubmit"><i data-lucide="flag" aria-hidden="true"></i><span>Submit report</span></button>
        </div>
      </form>
    </dialog>
    <dialog class="blog-confirm-dialog blog-confirm-dialog-danger" id="blogRevisionRedactDialog" aria-labelledby="blogRevisionRedactTitle" aria-describedby="blogRevisionRedactDescription">
      <div class="blog-confirm-dialog-content">
        <div class="blog-confirm-dialog-icon" aria-hidden="true"><i data-lucide="eye-off"></i></div>
        <div class="blog-confirm-dialog-copy">
          <span class="blog-confirm-dialog-kicker">Revision privacy</span>
          <h2 id="blogRevisionRedactTitle">Remove this revision’s text?</h2>
          <p id="blogRevisionRedactDescription">The wording will be permanently replaced by a redaction marker. Its timestamp and any private report snapshot remain.</p>
        </div>
        <blockquote class="blog-confirm-preview" id="blogRevisionRedactPreview"></blockquote>
        <p class="blog-confirm-status" id="blogRevisionRedactStatus" role="status" aria-live="polite"></p>
        <div class="blog-confirm-actions">
          <button type="button" class="btn btn-secondary" id="blogRevisionRedactCancel">Cancel</button>
          <button type="button" class="btn btn-danger" id="blogRevisionRedactConfirm"><i data-lucide="eye-off" aria-hidden="true"></i><span>Remove revision text</span></button>
        </div>
      </div>
    </dialog>
  <% } %>

  <dialog class="blog-confirm-dialog blog-comment-history-dialog" id="blogCommentHistoryDialog" aria-labelledby="blogCommentHistoryTitle" aria-describedby="blogCommentHistoryDescription">
    <div class="blog-confirm-dialog-content">
      <div class="blog-confirm-dialog-icon" aria-hidden="true"><i data-lucide="history"></i></div>
      <div class="blog-confirm-dialog-copy">
        <span class="blog-confirm-dialog-kicker">Public edit history</span>
        <h2 id="blogCommentHistoryTitle">Comment revisions</h2>
        <p id="blogCommentHistoryDescription">Previous public versions are shown in chronological order.</p>
      </div>
      <div class="blog-comment-history-list" id="blogCommentHistoryList"></div>
      <p class="blog-confirm-status" id="blogCommentHistoryStatus" role="status" aria-live="polite"></p>
      <div class="blog-confirm-actions">
        <button type="button" class="btn btn-secondary" id="blogCommentHistoryClose">Close</button>
      </div>
    </div>
  </dialog>

  <!-- Gallery Modal -->
  <div class="blog-gallery-modal hidden" id="blogGalleryModal" aria-hidden="true">
    <div class="blog-gallery-backdrop" data-gallery-close="1"></div>
    <div class="blog-gallery-dialog" role="dialog" aria-modal="true" aria-label="Gallery viewer">
      <button type="button" class="blog-gallery-close" data-gallery-close="1" aria-label="Close gallery">&times;</button>
      <button type="button" class="blog-gallery-nav prev" id="blogGalleryPrev" aria-label="Previous image">‹</button>
      <div class="gallery-image-container">
        <img id="blogGalleryImage" src="" alt="Blog gallery image">
        <div class="gallery-spinner hidden" id="gallerySpinner"></div>
      </div>
      <button type="button" class="blog-gallery-nav next" id="blogGalleryNext" aria-label="Next image">›</button>
      <p class="blog-gallery-counter" id="blogGalleryCounter"></p>
      <p class="blog-gallery-caption" id="blogGalleryCaption"></p>
    </div>
  </div>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    (function initBlogPostEnhancements() {
      // ---- DOM elements ----
      const content = document.getElementById('blogPostContent');
      const tocWrapDesktop = document.getElementById('blogPostTocWrapDesktop');
      const tocListDesktop = document.getElementById('blogPostTocListDesktop');
      const tocWrapMobile = document.getElementById('blogPostTocWrap'); // from details
      const tocListMobile = document.getElementById('blogPostTocList');
      const copyToast = document.getElementById('copyToast');
      const progressBar = document.getElementById('blogReadProgress');
      const galleryModal = document.getElementById('blogGalleryModal');
      const galleryImageEl = document.getElementById('blogGalleryImage');
      const galleryCounterEl = document.getElementById('blogGalleryCounter');
      const galleryCaptionEl = document.getElementById('blogGalleryCaption');
      const galleryPrevBtn = document.getElementById('blogGalleryPrev');
      const galleryNextBtn = document.getElementById('blogGalleryNext');
      const gallerySpinner = document.getElementById('gallerySpinner');
      const shareWidgets = Array.from(document.querySelectorAll('[data-blog-share]'));
      const likeBtn = document.getElementById('blogLikeBtn');
      const likeLabel = document.getElementById('blogLikeLabel');
      const likeCountEl = document.getElementById('blogLikeCount');
      const reportForm = document.getElementById('blogReportForm');
      
      // ---- Data from EJS ----
      const canonicalUrl = <%- safeJson(seo?.canonicalUrl || '') %>;
      const postSlug = <%- safeJson(post.slug || '') %>;
      const csrfToken = <%- safeJson(locals.csrfToken || '') %>;
      const galleryButtons = Array.from(document.querySelectorAll('[data-gallery-index][data-gallery-url]'));
      let activeGalleryIndex = 0;
      let galleryUrls = [];
      let galleryCaptions = [];

      // ---- Helper functions ----
      function showToast(message, duration = 2000) {
        if (!copyToast) return;
        copyToast.textContent = message;
        copyToast.classList.remove('hidden');
        setTimeout(() => copyToast.classList.add('hidden'), duration);
      }

      async function jsonRequest(url, options = {}) {
        const headers = Object.assign({
          'Content-Type': 'application/json',
          'x-csrf-token': csrfToken
        }, options.headers || {});
        const response = await fetch(url, Object.assign({}, options, { headers }));
        const contentType = response.headers.get('content-type') || '';
        const body = contentType.includes('application/json')
          ? await response.json()
          : { success: response.ok, message: await response.text() };
        if (!response.ok) {
          throw new Error(body.message || 'Request failed.');
        }
        return body;
      }

      // ---- Cover image fallback ----
      const fallbackCover = '/images/helloRun-icon.webp';
      const applyCoverFallback = (image) => {
        if (image.dataset.fallbackApplied === '1') return;
        image.dataset.fallbackApplied = '1';
        image.src = fallbackCover;
        image.alt = 'HelloRun logo';
        image.classList.add('is-fallback');
        image.closest('.blog-related-card')?.classList.add('is-fallback');
      };
      document.querySelectorAll('[data-blog-cover-image]').forEach((image) => {
        image.addEventListener('error', () => applyCoverFallback(image));
        if (image.complete && image.naturalWidth === 0) applyCoverFallback(image);
      });

      // ---- 1. Scroll progress ----
      if (content && progressBar) {
        const updateProgress = () => {
          const rect = content.getBoundingClientRect();
          const pageTop = window.scrollY + rect.top;
          const total = Math.max(content.scrollHeight - window.innerHeight, 1);
          const done = Math.min(Math.max(window.scrollY - pageTop, 0), total);
          const pct = Math.round((done / total) * 100);
          progressBar.style.width = `${pct}%`;
        };
        window.addEventListener('scroll', updateProgress, { passive: true });
        window.addEventListener('resize', updateProgress);
        updateProgress();
      }

      // ---- 2. Table of Contents with scroll spy ----
      const buildToc = (container, listElement) => {
        if (!content || !container || !listElement) return;
        const headings = Array.from(content.querySelectorAll('h2, h3'));
        if (!headings.length) {
          container.style.display = 'none';
          return;
        }
        headings.forEach((heading, index) => {
          const id = heading.id || `section-${index + 1}`;
          heading.id = id;
          const li = document.createElement('li');
          li.className = heading.tagName.toLowerCase() === 'h3' ? 'toc-sub' : '';
          const a = document.createElement('a');
          a.href = `#${id}`;
          a.textContent = heading.textContent || `Section ${index + 1}`;
          li.appendChild(a);
          listElement.appendChild(li);
        });

        // Scroll spy
        const tocLinks = listElement.querySelectorAll('a');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              tocLinks.forEach(link => {
                link.removeAttribute('aria-current');
                if (link.getAttribute('href') === `#${id}`) {
                  link.setAttribute('aria-current', 'location');
                }
              });
            }
          });
        }, { rootMargin: '-80px 0px -80% 0px', threshold: 0 });

        headings.forEach(h => observer.observe(h));

        // Smooth scroll with offset
        listElement.addEventListener('click', (e) => {
          const link = e.target.closest('a');
          if (!link) return;
          e.preventDefault();
          const targetId = link.getAttribute('href').substring(1);
          const targetEl = document.getElementById(targetId);
          if (targetEl) {
            const offset = 80; // height of fixed nav
            window.scrollTo({
              top: targetEl.offsetTop - offset,
              behavior: 'smooth'
            });
          }
        });
      };

      buildToc(tocWrapDesktop, tocListDesktop);
      buildToc(tocWrapMobile, tocListMobile);

      // ---- 3. Reusable share disclosures ----
      const closeShareMenu = (widget, restoreFocus = false) => {
        if (!widget?.open) return;
        widget.open = false;
        if (restoreFocus) widget.querySelector('summary')?.focus();
      };
      const closeOtherShareMenus = (currentWidget) => {
        shareWidgets.forEach((widget) => {
          if (widget !== currentWidget) closeShareMenu(widget);
        });
      };
      shareWidgets.forEach((widget) => {
        const summary = widget.querySelector('summary');
        const shareItems = Array.from(widget.querySelectorAll('[role="menuitem"]'));
        widget.addEventListener('toggle', () => {
          if (!widget.open) return;
          closeOtherShareMenus(widget);
          shareItems[0]?.focus();
        });
        shareItems.forEach((item) => item.addEventListener('click', () => closeShareMenu(widget)));
        widget.querySelectorAll('[data-copy-blog-link]').forEach((copyButton) => {
          copyButton.addEventListener('click', async () => {
            const url = widget.dataset.shareUrl || canonicalUrl || window.location.href;
            try {
              if (!navigator.clipboard?.writeText) throw new Error('Clipboard unavailable');
              await navigator.clipboard.writeText(url);
              showToast('Link copied!');
            } catch {
              showToast('Copy failed');
            }
          });
        });
        summary?.addEventListener('click', () => {
          if (!widget.open) closeOtherShareMenus(widget);
        });
      });
      document.addEventListener('click', (event) => {
        shareWidgets.forEach((widget) => {
          if (!widget.contains(event.target)) closeShareMenu(widget);
        });
      });
      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        const openWidget = shareWidgets.find((widget) => widget.open);
        if (!openWidget) return;
        event.preventDefault();
        closeShareMenu(openWidget, true);
      });

      // ---- 4. Gallery with touch, spinner, captions ----
      if (galleryModal && galleryImageEl && galleryButtons.length) {
        galleryUrls = galleryButtons.map(btn => btn.getAttribute('data-gallery-url')).filter(Boolean);
        galleryCaptions = galleryButtons.map(btn => btn.getAttribute('data-gallery-caption') || '');

        const renderGallery = () => {
          if (!galleryUrls.length) return;
          const index = Math.min(Math.max(activeGalleryIndex, 0), galleryUrls.length - 1);
          activeGalleryIndex = index;
          // Show spinner while loading
          gallerySpinner.classList.remove('hidden');
          galleryImageEl.classList.add('loading');
          galleryImageEl.src = galleryUrls[index];
          galleryCounterEl.textContent = `${index + 1} / ${galleryUrls.length}`;
          galleryCaptionEl.textContent = galleryCaptions[index];
        };

        galleryImageEl.addEventListener('load', () => {
          gallerySpinner.classList.add('hidden');
          galleryImageEl.classList.remove('loading');
        });
        galleryImageEl.addEventListener('error', () => {
          gallerySpinner.classList.add('hidden');
          galleryImageEl.classList.remove('loading');
          galleryImageEl.alt = 'Image failed to load';
        });

        const openGallery = (index) => {
          activeGalleryIndex = index;
          renderGallery();
          galleryModal.classList.remove('hidden');
          galleryModal.setAttribute('aria-hidden', 'false');
          document.body.classList.add('no-scroll');
          // Focus trap inside modal
          modalFocusTrap(galleryModal);
        };

        const closeGallery = () => {
          galleryModal.classList.add('hidden');
          galleryModal.setAttribute('aria-hidden', 'true');
          document.body.classList.remove('no-scroll');
        };

        // Focus trap function
        const modalFocusTrap = (modal) => {
          const focusableElements = modal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
          const first = focusableElements[0];
          const last = focusableElements[focusableElements.length - 1];
          modal.addEventListener('keydown', (e) => {
            if (e.key === 'Tab') {
              if (e.shiftKey && document.activeElement === first) {
                e.preventDefault();
                last.focus();
              } else if (!e.shiftKey && document.activeElement === last) {
                e.preventDefault();
                first.focus();
              }
            }
            if (e.key === 'Escape') closeGallery();
          });
          first.focus();
        };

        galleryButtons.forEach((btn) => {
          btn.addEventListener('click', () => {
            const index = Number(btn.getAttribute('data-gallery-index') || '0');
            openGallery(index);
          });
        });

        galleryModal.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          if (target.getAttribute('data-gallery-close') === '1') {
            closeGallery();
          }
        });

        galleryPrevBtn?.addEventListener('click', () => {
          activeGalleryIndex = (activeGalleryIndex - 1 + galleryUrls.length) % galleryUrls.length;
          renderGallery();
        });

        galleryNextBtn?.addEventListener('click', () => {
          activeGalleryIndex = (activeGalleryIndex + 1) % galleryUrls.length;
          renderGallery();
        });

        // Touch swipe support
        let touchStartX = 0;
        galleryModal.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });
        galleryModal.addEventListener('touchend', (e) => {
          if (!touchStartX) return;
          const diff = e.changedTouches[0].screenX - touchStartX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              // swipe right -> previous
              activeGalleryIndex = (activeGalleryIndex - 1 + galleryUrls.length) % galleryUrls.length;
            } else {
              // swipe left -> next
              activeGalleryIndex = (activeGalleryIndex + 1) % galleryUrls.length;
            }
            renderGallery();
          }
          touchStartX = 0;
        });

        window.addEventListener('keydown', (event) => {
          if (galleryModal.classList.contains('hidden')) return;
          if (event.key === 'Escape') closeGallery();
          if (event.key === 'ArrowLeft') {
            activeGalleryIndex = (activeGalleryIndex - 1 + galleryUrls.length) % galleryUrls.length;
            renderGallery();
          }
          if (event.key === 'ArrowRight') {
            activeGalleryIndex = (activeGalleryIndex + 1) % galleryUrls.length;
            renderGallery();
          }
        });
      }

      // ---- Re-run Lucide for any new icons ----
      if (window.lucide) lucide.createIcons();

      let likePending = false;
      likeBtn?.addEventListener('click', async () => {
        if (likeBtn.dataset.loginRequired === '1') {
          window.location.href = `/login?redirect=/blog/${postSlug}`;
          return;
        }
        if (likePending) return;
        likePending = true;
        likeBtn.setAttribute('aria-busy', 'true');
        likeBtn.disabled = true;

        // Optimistic update
        const wasLiked = likeBtn.dataset.liked === '1';
        const prevCount = parseInt(likeCountEl?.textContent?.replace(/,/g, '') || '0', 10);
        const optimisticLiked = !wasLiked;
        const optimisticCount = optimisticLiked ? prevCount + 1 : Math.max(0, prevCount - 1);
        likeBtn.dataset.liked = optimisticLiked ? '1' : '0';
        likeBtn.setAttribute('aria-pressed', optimisticLiked ? 'true' : 'false');
        likeBtn.classList.toggle('is-liked', optimisticLiked);
        if (likeLabel) likeLabel.textContent = optimisticLiked ? 'Unlike' : 'Like';
        if (likeCountEl) likeCountEl.textContent = optimisticCount.toLocaleString('en-US');

        try {
          const body = await jsonRequest(`/blog/${postSlug}/like`, { method: 'POST', body: '{}' });
          // Reconcile with server truth
          likeBtn.dataset.liked = body.liked ? '1' : '0';
          likeBtn.setAttribute('aria-pressed', body.liked ? 'true' : 'false');
          likeBtn.classList.toggle('is-liked', !!body.liked);
          if (likeLabel) likeLabel.textContent = body.liked ? 'Unlike' : 'Like';
          if (likeCountEl) likeCountEl.textContent = Number(body.likesCount || 0).toLocaleString('en-US');
        } catch (error) {
          // Revert on failure
          likeBtn.dataset.liked = wasLiked ? '1' : '0';
          likeBtn.setAttribute('aria-pressed', wasLiked ? 'true' : 'false');
          likeBtn.classList.toggle('is-liked', wasLiked);
          if (likeLabel) likeLabel.textContent = wasLiked ? 'Unlike' : 'Like';
          if (likeCountEl) likeCountEl.textContent = prevCount.toLocaleString('en-US');
          showToast(error.message || 'Failed to update like');
        } finally {
          likePending = false;
          likeBtn.removeAttribute('aria-busy');
          likeBtn.disabled = false;
        }
      });

      reportForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(reportForm);
        const submitButton = reportForm.querySelector('button[type="submit"]');
        if (submitButton) {
          submitButton.disabled = true;
          submitButton.setAttribute('aria-busy', 'true');
        }
        try {
          await jsonRequest(`/blog/${postSlug}/report`, {
            method: 'POST',
            body: JSON.stringify({
              reason: String(formData.get('reason') || ''),
              note: String(formData.get('note') || '')
            })
          });
          reportForm.reset();
          showToast('Post reported.');
        } catch (error) {
          showToast(error.message || 'Failed to submit report');
        } finally {
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.removeAttribute('aria-busy');
          }
        }
      });

    })();
  </script>
  <script src="/js/blog-comments.js" defer></script>
</body>
</html>
