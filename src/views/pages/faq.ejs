<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title, seo: typeof seo !== 'undefined' ? seo : null }) %>
  <link rel="stylesheet" href="/css/faq-page.css">
  <script type="application/ld+json"><%- faqPresentation.structuredDataJson %></script>
</head>
<body class="faq-body<%= locals.isAuthenticated && !locals.isAdmin && !locals.isApprovedOrganizer && !locals.isOrganizer ? ' has-runner-mobile-nav' : '' %>">
  <%- include('../layouts/nav') %>

  <main class="faq-page" id="main-content">
    <div class="faq-wrap">
      <header class="faq-hero" aria-labelledby="faq-title">
        <div class="faq-hero-copy">
          <span class="faq-kicker"><i data-lucide="circle-help" aria-hidden="true"></i>HelloRun support library</span>
          <h1 id="faq-title">How can we help?</h1>
          <p>Find clear answers about joining events, submitting activities, following reviews, earning recognition, managing an account, and organizing with HelloRun.</p>

          <div class="faq-search" role="search" aria-labelledby="faq-search-label">
            <label id="faq-search-label" for="faq-search-input">Search <%= faqPresentation.entryCount %> answers</label>
            <div class="faq-search-control">
              <i data-lucide="search" aria-hidden="true"></i>
              <input id="faq-search-input" type="search" inputmode="search" autocomplete="off" placeholder="Try “pending distance” or “payment review”" aria-describedby="faq-search-help faq-search-status" data-faq-search>
              <button type="button" class="faq-search-clear" data-faq-clear hidden>Clear <span class="sr-only">FAQ search</span></button>
            </div>
            <div class="faq-search-meta">
              <p id="faq-search-help">Search questions, answers, and related terms. All answers remain available without JavaScript.</p>
              <p id="faq-search-status" role="status" aria-live="polite" data-faq-status><%= faqPresentation.entryCount %> answers across <%= faqPresentation.categoryCount %> topics</p>
            </div>
          </div>

          <div class="faq-hero-links" aria-label="Other support resources">
            <a href="/how-it-works"><i data-lucide="route" aria-hidden="true"></i>See how events work</a>
            <a href="/contact"><i data-lucide="life-buoy" aria-hidden="true"></i>Contact support</a>
          </div>
        </div>

        <aside class="faq-start-card" aria-labelledby="faq-start-title">
          <span class="faq-start-icon"><i data-lucide="list-checks" aria-hidden="true"></i></span>
          <div>
            <span class="faq-eyebrow">Before you contact support</span>
            <h2 id="faq-start-title">Start with the event record</h2>
            <p>For an event question, have the event name, confirmation code, visible status, and the outcome you need. Do not post payment receipts or activity proof publicly.</p>
          </div>
          <a href="<%= faqPresentation.startAction.href %>"><%= faqPresentation.startAction.label %> <i data-lucide="arrow-right" aria-hidden="true"></i></a>
        </aside>
      </header>

      <nav class="faq-topic-strip" aria-label="FAQ topics">
        <% faqPresentation.categories.forEach((category) => { %>
          <a href="#<%= category.anchor %>" data-faq-category-link="<%= category.id %>">
            <i data-lucide="<%= category.icon %>" aria-hidden="true"></i>
            <span><%= category.shortLabel %></span>
            <small><%= category.count %></small>
          </a>
        <% }) %>
      </nav>

      <div class="faq-directory" id="faq-directory">
        <aside class="faq-directory-nav" aria-label="Browse FAQ topics">
          <div class="faq-directory-nav-inner">
            <span class="faq-eyebrow">Browse by topic</span>
            <ul>
              <% faqPresentation.categories.forEach((category) => { %>
                <li>
                  <a href="#<%= category.anchor %>" data-faq-category-link="<%= category.id %>">
                    <i data-lucide="<%= category.icon %>" aria-hidden="true"></i>
                    <span><%= category.shortLabel %></span>
                    <small><%= category.count %></small>
                  </a>
                </li>
              <% }) %>
            </ul>
            <p>Event pages remain authoritative for dates, prices, accepted activities, proof rules, and recognition.</p>
          </div>
        </aside>

        <div class="faq-content" data-faq-content>
          <% faqPresentation.categories.forEach((category) => { %>
            <section class="faq-category" id="<%= category.anchor %>" aria-labelledby="<%= category.anchor %>-title" data-faq-category="<%= category.id %>">
              <header class="faq-category-heading">
                <span class="faq-category-icon"><i data-lucide="<%= category.icon %>" aria-hidden="true"></i></span>
                <div>
                  <span class="faq-eyebrow"><%= category.count %> practical answers</span>
                  <h2 id="<%= category.anchor %>-title"><%= category.label %></h2>
                  <p><%= category.description %></p>
                </div>
              </header>

              <div class="faq-questions">
                <% category.questions.forEach((entry, entryIndex) => { %>
                  <details class="faq-question" id="<%= entry.anchor %>" data-faq-entry data-faq-keywords="<%= entry.keywords.join(' ') %>">
                    <summary>
                      <span class="faq-question-number"><%= String(entryIndex + 1).padStart(2, '0') %></span>
                      <span class="faq-question-title"><%= entry.question %></span>
                      <span class="faq-question-toggle" aria-hidden="true"><i data-lucide="plus"></i></span>
                    </summary>
                    <div class="faq-answer">
                      <p><%= entry.answer %></p>
                      <% if (entry.links && entry.links.length) { %>
                        <div class="faq-answer-links" aria-label="Related resources">
                          <% entry.links.forEach((link) => { %>
                            <a href="<%= link.href %>"><%= link.label %><i data-lucide="arrow-up-right" aria-hidden="true"></i></a>
                          <% }) %>
                        </div>
                      <% } %>
                      <a class="faq-answer-anchor" href="#<%= entry.anchor %>" aria-label="Link to: <%= entry.question %>"><i data-lucide="link-2" aria-hidden="true"></i>Link to this answer</a>
                    </div>
                  </details>
                <% }) %>
              </div>
            </section>
          <% }) %>

          <section class="faq-no-results" data-faq-empty hidden aria-labelledby="faq-no-results-title">
            <span><i data-lucide="search-x" aria-hidden="true"></i></span>
            <h2 id="faq-no-results-title">No matching answer yet</h2>
            <p>Try a shorter phrase, browse the topics above, or prepare a support request with the event and reference details.</p>
            <button type="button" class="btn btn-secondary" data-faq-empty-clear>Clear search</button>
          </section>
        </div>
      </div>

      <section class="faq-next-steps" aria-labelledby="faq-next-title">
        <div class="faq-next-copy">
          <span class="faq-next-icon"><i data-lucide="move-right" aria-hidden="true"></i></span>
          <div>
            <span class="faq-eyebrow">Your next step</span>
            <h2 id="faq-next-title">Move from an answer to the right action</h2>
            <p>Use the relevant account area when possible. Support can help faster when your message includes the event, reference code, visible status, and expected outcome.</p>
          </div>
        </div>
        <div class="faq-next-actions">
          <% faqPresentation.actions.forEach((action, index) => { %>
            <a class="<%= index === 0 ? 'faq-action-primary' : 'faq-action-secondary' %>" href="<%= action.href %>">
              <i data-lucide="<%= action.icon %>" aria-hidden="true"></i><%= action.label %>
            </a>
          <% }) %>
        </div>
      </section>

      <p class="faq-boundary-note"><i data-lucide="info" aria-hidden="true"></i>FAQ guidance is general. The published event page and applicable HelloRun policies control event-specific requirements.</p>
    </div>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/faq-page.js"></script>
</body>
</html>
