<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/my-registrations.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <% const _csrfToken = typeof csrfToken !== 'undefined' ? csrfToken : ''; %>

  <main class="my-reg-page">
    <section class="my-reg-shell">
      <header class="my-reg-header">
        <h1>My Registrations</h1>
        <p>Track your registered events and confirmation details.</p>
      </header>

      <% if (message) { %>
        <div class="page-message page-message-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <% if (registrations && registrations.length) { %>
        <div class="my-reg-grid">
          <% registrations.forEach((registration) => { %>
            <article class="my-reg-card">
              <% const paymentLabelMap = {
                unpaid: 'Unpaid',
                proof_submitted: 'Payment Receipt Submitted',
                proof_rejected: 'Payment Receipt Rejected',
                paid: 'Paid',
                failed: 'Failed',
                refunded: 'Refunded'
              }; %>
              <%
                const eventFeeMode = String(registration.eventId?.feeMode || 'free').toLowerCase();
                const isPaidEvent = eventFeeMode === 'paid';
                const needsPaymentVerification = isPaidEvent || ['unpaid', 'proof_submitted', 'proof_rejected', 'failed', 'refunded'].includes(String(registration.paymentStatus || ''));
              %>

              <!-- Card Header -->
              <div class="card-header">
                <h3>
                  <% if (registration.eventId && registration.eventId.slug) { %>
                    <a href="/events/<%= registration.eventId.slug %>"><%= registration.eventId.title %></a>
                  <% } else { %>
                    Event unavailable
                  <% } %>
                </h3>
                <span class="confirmation-code" title="Confirmation code">
                  <i data-lucide="hash"></i> <%= registration.confirmationCode %>
                </span>
              </div>

              <!-- Status Badges -->
              <div class="badge-row">
                <span class="badge badge-status"><%= registration.status %></span>
                <span class="badge badge-payment mode-<%= registration.paymentStatus %>">
                  <i data-lucide="credit-card"></i> <%= paymentLabelMap[registration.paymentStatus] || registration.paymentStatus %>
                </span>
                <% if (registration.submission) { %>
                  <span class="badge badge-submission mode-<%= registration.submission.status %>">
                    <i data-lucide="flag"></i> Run Result: <%= registration.submission.status %>
                  </span>
                <% } else if (registration.isAccumulatedChallenge && registration.accumulatedProgress) { %>
                  <span class="badge badge-submission mode-submitted">
                    <i data-lucide="flag"></i> Progress: <%= registration.accumulatedProgress.progressLabel %>
                  </span>
                <% } %>
              </div>

              <!-- Key Details Grid -->
              <div class="details-grid">
                <div class="detail-item">
                  <i data-lucide="ruler"></i>
                  <span><strong>Distance:</strong> <%= registration.raceDistance || 'N/A' %></span>
                </div>
                <div class="detail-item">
                  <i data-lucide="users"></i>
                  <span><strong>Mode:</strong> <%= registration.participationMode %></span>
                </div>
                <div class="detail-item">
                  <i data-lucide="calendar"></i>
                  <span><strong>Registered:</strong> <%= registration.registeredAt ? new Date(registration.registeredAt).toLocaleDateString('en-US') : 'N/A' %></span>
                </div>
                <div class="detail-item">
                  <i data-lucide="clock"></i>
                  <span><strong>Event start:</strong> <%= registration.eventId?.eventStartAt ? new Date(registration.eventId.eventStartAt).toLocaleDateString('en-US') : 'TBA' %></span>
                </div>
                <div class="detail-item">
                  <i data-lucide="map-pin"></i>
                  <span><strong>Location:</strong> <%= [registration.eventId?.venueName, registration.eventId?.city, countryName(registration.eventId?.country)].filter(Boolean).join(', ') || 'TBA' %></span>
                </div>
              </div>

              <!-- Participant Summary -->
              <details class="participant-details">
                <summary>
                  <i data-lucide="user"></i> Participant details
                </summary>
                <div class="participant-grid">
                  <div><strong>Age:</strong> <%= ageLabel(registration.participant?.dateOfBirth) %></div>
                  <div><strong>Gender:</strong> <%= genderLabel(registration.participant?.gender) %></div>
                  <div><strong>Emergency:</strong> <%= registration.participant?.emergencyContactName || 'N/A' %> <% if (registration.participant?.emergencyContactNumber) { %>(<%= registration.participant.emergencyContactNumber %>)<% } %></div>
                  <div><strong>Running group:</strong> <%= registration.participant?.runningGroup || 'N/A' %></div>
                </div>
              </details>

              <% if (needsPaymentVerification) { %>
                <!-- Payment Verification Section -->
                <section class="card-section payment-verification-section">
                  <h4><i data-lucide="receipt"></i> Payment Verification</h4>
                  <% if (isPaidEvent) { %>
                    <p>Submit a payment receipt that shows your payment confirmation or reference. Activity screenshots belong in Run Result, not here.</p>
                    <% if (registration.eventId?.feeAmount) { %>
                      <p><strong>Event fee:</strong> <%= registration.eventId.feeCurrency || 'PHP' %> <%= Number(registration.eventId.feeAmount || 0).toFixed(2) %></p>
                    <% } %>
                    <% if (registration.eventId?.paymentAccountName) { %>
                      <p><strong>Payee:</strong> <%= registration.eventId.paymentAccountName %></p>
                    <% } %>
                    <% if (registration.eventId?.paymentInstructions) { %>
                      <p><strong>Payment instructions:</strong> <%= registration.eventId.paymentInstructions %></p>
                    <% } %>
                  <% } else { %>
                    <p>This registration does not require payment. If a payment receipt was previously requested, review the status below.</p>
                  <% } %>
                  <% if (registration.paymentProof && registration.paymentProof.uploadedAt) { %>
                    <p><strong>Payment receipt submitted:</strong> <%= new Date(registration.paymentProof.uploadedAt).toLocaleString('en-US') %></p>
                  <% } %>
                  <% if (registration.paymentReviewedAt) { %>
                    <p><strong>Payment reviewed:</strong> <%= new Date(registration.paymentReviewedAt).toLocaleString('en-US') %></p>
                  <% } %>
                  <% if (registration.paymentRejectionReason) { %>
                    <p class="rejection"><strong>Payment rejection reason:</strong> <%= registration.paymentRejectionReason %></p>
                  <% } %>
                  <% if (registration.paymentReviewNotes) { %>
                    <p><strong>Payment review notes:</strong> <%= registration.paymentReviewNotes %></p>
                  <% } %>

                  <% if (registration.paymentStatus === 'unpaid' || registration.paymentStatus === 'proof_rejected') { %>
                    <form method="POST" action="/my-registrations/<%= registration._id %>/payment-proof" enctype="multipart/form-data" class="inline-form">
                      <input type="hidden" name="_csrf" value="<%= _csrfToken %>">
                      <label for="paymentProofFile-<%= registration._id %>">Upload payment receipt (JPG, PNG, PDF up to 5MB)</label>
                      <input type="file" id="paymentProofFile-<%= registration._id %>" name="paymentProofFile" accept=".jpg,.jpeg,.png,.pdf,image/jpeg,image/png,application/pdf" required>
                      <button type="submit" class="btn btn-secondary">Submit Payment Receipt</button>
                    </form>
                  <% } %>
                </section>
              <% } %>

              <!-- Result Submission Section -->
              <% const submission = registration.submission || null; %>
              <% const isAccumulatedChallenge = Boolean(registration.isAccumulatedChallenge); %>
              <% const canSubmitResult = registration.paymentStatus === 'paid' && registration.status !== 'cancelled' && registration.status !== 'refunded' && (isAccumulatedChallenge || !submission || submission.status === 'rejected'); %>
              <% if (submission || canSubmitResult || isAccumulatedChallenge) { %>
                <section class="card-section">
                  <h4><i data-lucide="flag"></i> <%= isAccumulatedChallenge ? 'Activity Progress' : 'Run Result' %></h4>
                  <% if (isAccumulatedChallenge && registration.accumulatedProgress) { %>
                    <p><strong>Progress:</strong> <%= registration.accumulatedProgress.progressLabel %></p>
                    <p>
                      <strong>Activities:</strong>
                      <%= registration.accumulatedProgress.approvedActivityCount %> approved,
                      <%= registration.accumulatedProgress.pendingActivityCount %> pending,
                      <%= registration.accumulatedProgress.rejectedActivityCount %> rejected
                    </p>
                    <% if (registration.accumulatedProgress.certificateActivityId) { %>
                      <p><a href="/my-submissions/<%= registration.accumulatedProgress.certificateActivityId %>/certificate" class="btn btn-link">Download certificate <i data-lucide="download"></i></a></p>
                    <% } %>
                  <% } %>
                  <% if (submission) { %>
                    <div class="details-grid">
                      <div class="detail-item"><strong>Distance:</strong> <%= Number(submission.distanceKm || 0).toFixed(2) %> km</div>
                      <div class="detail-item"><strong>Time:</strong> <%= new Date(Number(submission.elapsedMs || 0)).toISOString().slice(11, 19) %></div>
                      <div class="detail-item"><strong>Run date:</strong> <%= submission.runDate ? new Date(submission.runDate).toLocaleDateString('en-US') : 'N/A' %></div>
                      <div class="detail-item"><strong>Run location:</strong> <%= submission.runLocation || 'N/A' %></div>
                      <div class="detail-item"><strong>Proof type:</strong> <%= String(submission.proofType || 'manual').toUpperCase() %></div>
                    </div>
                    <% if (submission.proof?.url) { %>
                      <p><a href="<%= submission.proof.url %>" target="_blank" rel="noopener noreferrer" class="btn btn-link">View Run Result Evidence</a></p>
                    <% } %>
                    <% if (submission.status === 'approved' && submission.certificate?.url) { %>
                      <p><a href="/my-submissions/<%= submission._id %>/certificate" class="btn btn-link">Download certificate <i data-lucide="download"></i></a></p>
                    <% } %>
                    <% if (submission.rejectionReason) { %>
                      <p class="rejection"><strong>Rejection reason:</strong> <%= submission.rejectionReason %></p>
                    <% } %>
                    <% if (submission.reviewNotes) { %>
                      <p><strong>Review notes:</strong> <%= submission.reviewNotes %></p>
                    <% } %>
                  <% } %>

                  <% if (canSubmitResult) { %>
                    <div class="inline-form result-action-box">
                      <p>Use the run result modal to submit your activity distance, time, date, location, and screenshot or Strava evidence.</p>
                      <button
                        type="button"
                        class="btn btn-secondary"
                        data-open-run-proof-modal
                        data-registration-id="<%= registration._id %>">
                        <%= isAccumulatedChallenge ? 'Submit Activity' : (submission && submission.status === 'rejected' ? 'Resubmit Run Result' : 'Submit Run Result') %>
                      </button>
                    </div>
                  <% } %>
                </section>
              <% } %>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="no-events-message">
          <i data-lucide="clipboard-list"></i>
          <h3>No registrations yet</h3>
          <p>Browse published events and register to see them here.</p>
          <a href="/events" class="btn">Browse Events</a>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/my-reg.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
