<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/my-registrations.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <% const _csrfToken = typeof csrfToken !== 'undefined' ? csrfToken : ''; %>

  <main class="my-reg-page" id="main-content">
    <div class="my-reg-shell">
      <header class="my-reg-header">
        <div>
          <span class="my-reg-eyebrow"><i data-lucide="clipboard-list" aria-hidden="true"></i>Your events</span>
          <h1>My Registrations</h1>
          <p>See what needs your attention, follow active progress, and keep every registration record in one place.</p>
        </div>
        <nav class="my-reg-header-actions" aria-label="Registration tools">
          <a href="/events" class="btn btn-primary"><i data-lucide="calendar-search" aria-hidden="true"></i>Browse Events</a>
          <a href="/runner/submissions" class="btn btn-secondary"><i data-lucide="file-check" aria-hidden="true"></i>Submission History</a>
        </nav>
      </header>

      <% if (message) { %>
        <div class="page-message page-message-<%= message.type %>" role="<%= message.type === 'error' ? 'alert' : 'status' %>" aria-live="<%= message.type === 'error' ? 'assertive' : 'polite' %>"><%= message.text %></div>
      <% } %>

      <% if (registrations && registrations.length) { %>
        <section class="my-reg-summary" aria-label="Registration summary">
          <div><span>Total</span><strong><%= registrationCounts.total %></strong></div>
          <a href="#next-actions"><span>Next actions</span><strong><%= registrationCounts.nextActions %></strong></a>
          <a href="#active-registrations"><span>Active</span><strong><%= registrationCounts.active %></strong></a>
          <div><span>Under review</span><strong><%= registrationCounts.underReview %></strong></div>
        </section>

        <% if (registrationGroups.nextActions.length) { %>
          <section class="my-reg-group my-reg-group-attention" id="next-actions" aria-labelledby="nextActionsTitle">
            <header class="my-reg-group-header">
              <div>
                <span class="my-reg-group-icon my-reg-group-icon-attention"><i data-lucide="circle-alert" aria-hidden="true"></i></span>
                <div><h2 id="nextActionsTitle">Next actions</h2><p>Complete these tasks to keep your registrations moving.</p></div>
              </div>
              <span class="my-reg-count"><%= registrationGroups.nextActions.length %></span>
            </header>
            <div class="my-reg-list">
              <% registrationGroups.nextActions.forEach((item) => { %>
                <%- include('../partials/my-registration-card', { item, _csrfToken, countryName, genderLabel, ageLabel }) %>
              <% }) %>
            </div>
          </section>
        <% } %>

        <% if (registrationGroups.active.length) { %>
          <section class="my-reg-group" id="active-registrations" aria-labelledby="activeRegistrationsTitle">
            <header class="my-reg-group-header">
              <div>
                <span class="my-reg-group-icon"><i data-lucide="activity" aria-hidden="true"></i></span>
                <div><h2 id="activeRegistrationsTitle">Active registrations</h2><p>Upcoming events, challenges in progress, and reviews in motion.</p></div>
              </div>
              <span class="my-reg-count"><%= registrationGroups.active.length %></span>
            </header>
            <div class="my-reg-list">
              <% registrationGroups.active.forEach((item) => { %>
                <%- include('../partials/my-registration-card', { item, _csrfToken, countryName, genderLabel, ageLabel }) %>
              <% }) %>
            </div>
          </section>
        <% } %>

        <% if (!registrationGroups.nextActions.length && !registrationGroups.active.length) { %>
          <div class="my-reg-caught-up" role="status">
            <i data-lucide="circle-check-big" aria-hidden="true"></i>
            <div><strong>You’re all caught up.</strong><p>No registration needs an action right now. Your past records are available below.</p></div>
          </div>
        <% } %>

        <% if (registrationGroups.history.length) { %>
          <details class="my-reg-history" id="registration-history">
            <summary>
              <span><i data-lucide="archive" aria-hidden="true"></i><strong>Registration history</strong><small>Completed, missed, cancelled, refunded, and unavailable events</small></span>
              <span class="my-reg-count"><%= registrationGroups.history.length %></span>
            </summary>
            <div class="my-reg-list">
              <% registrationGroups.history.forEach((item) => { %>
                <%- include('../partials/my-registration-card', { item, _csrfToken, countryName, genderLabel, ageLabel }) %>
              <% }) %>
            </div>
          </details>
        <% } %>
      <% } else { %>
        <div class="no-events-message">
          <span><i data-lucide="clipboard-list" aria-hidden="true"></i></span>
          <h2>No registrations yet</h2>
          <p>Choose an event that fits your schedule and goal. Your confirmation, payment, and activity progress will appear here.</p>
          <a href="/events" class="btn btn-primary">Browse Events</a>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/my-reg.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
