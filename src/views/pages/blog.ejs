<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'Runner Stories & Guides - HelloRun', seo: seo }) %>
  <link rel="stylesheet" href="/css/blog.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <% const fallbackCover = '/images/helloRun-icon.webp'; %>

  <main class="blog-community-page">
    <section class="blog-community-header" aria-labelledby="blogPageTitle">
      <div class="container">
        <div class="blog-community-intro">
          <div>
            <p class="blog-kicker">HelloRun community</p>
            <h1 id="blogPageTitle"><%= pageContent?.heading || 'Stories from the running community' %></h1>
            <p class="blog-community-support"><%= pageContent?.supportCopy || 'Read real experiences, practical advice, and fresh perspectives—or share your own.' %></p>
          </div>
          <div class="blog-community-actions">
            <% if (locals.isAuthenticated) { %>
              <a href="/blogs/me/dashboard" class="btn btn-outline">
                <i data-lucide="layout-dashboard" aria-hidden="true"></i>
                My Blogs
              </a>
            <% } %>
            <a href="<%= locals.isAuthenticated ? '/blogs/me/new' : '/login?redirect=/blogs/me/new' %>" class="btn btn-primary">
              <i data-lucide="pen-square" aria-hidden="true"></i>
              Write a post
            </a>
          </div>
        </div>

        <form method="GET" action="/blog#blog-results" class="blog-discovery-form" id="blogFilterForm">
          <div class="blog-search-row">
            <div class="blog-search-field">
              <label for="blogSearch" class="sr-only">Search community stories</label>
              <i data-lucide="search" aria-hidden="true"></i>
              <input id="blogSearch" type="search" name="q" value="<%= filters?.q || '' %>" placeholder="Search stories, writers, or topics...">
            </div>
            <button type="submit" class="btn btn-primary">
              Search stories
              <i data-lucide="arrow-right" aria-hidden="true"></i>
            </button>
          </div>

          <nav class="blog-topic-paths" aria-label="Browse popular topics">
            <span>Explore:</span>
            <a href="/blog?category=Community">Community</a>
            <a href="/blog?category=Training">Training</a>
            <a href="/blog?category=Race+Tips">Race prep</a>
            <a href="/blog?category=Virtual+Run+Guide">Virtual runs</a>
            <a href="/blog?category=Organizer+Guide">Organiser stories</a>
          </nav>

          <div class="blog-control-row">
            <details class="blog-filter-panel" <%= filters?.category || filters?.author ? 'open' : '' %>>
              <summary>
                <span>
                  <i data-lucide="sliders-horizontal" aria-hidden="true"></i>
                  Filters
                  <% if (filterMeta?.activeFilterCount) { %>
                    <span class="blog-filter-count" aria-label="<%= filterMeta.activeFilterCount %> active <%= filterMeta.activeFilterCount === 1 ? 'filter' : 'filters' %>"><%= filterMeta.activeFilterCount %></span>
                  <% } %>
                </span>
                <small>Topic and writer</small>
              </summary>
              <div class="blog-filter-content">
                <div class="blog-filter-grid">
                  <div class="blog-field-group">
                    <label for="blogCategory">Topic</label>
                    <select id="blogCategory" name="category">
                      <option value="">All topics</option>
                      <% (categories || []).forEach((category) => { %>
                        <option value="<%= category %>" <%= filters?.category === category ? 'selected' : '' %>><%= category %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="blog-field-group">
                    <label for="blogAuthor">Writer</label>
                    <input id="blogAuthor" type="text" value="<%= filters?.authorName || 'All community writers' %>" disabled aria-describedby="blogAuthorHint">
                    <input type="hidden" name="author" value="<%= filters?.author || '' %>">
                    <small id="blogAuthorHint"><%= filters?.author ? 'Remove the writer chip below to browse everyone.' : 'Choose a writer from a story or Top Writers.' %></small>
                  </div>
                </div>
                <div class="blog-filter-actions">
                  <% if (filterMeta?.hasActiveFilters) { %>
                    <a href="<%= filterMeta.clearFiltersUrl %>#blog-results" class="btn btn-outline">Clear filters</a>
                  <% } %>
                  <button type="submit" class="btn btn-primary">Apply filters</button>
                </div>
              </div>
            </details>

            <div class="blog-sort-control">
              <label for="blogSort">Sort by</label>
              <select id="blogSort" name="sort">
                <option value="latest" <%= (filters?.sort || 'latest') === 'latest' ? 'selected' : '' %>>Latest</option>
                <option value="popular" <%= filters?.sort === 'popular' ? 'selected' : '' %>>Popular</option>
                <option value="oldest" <%= filters?.sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
              </select>
              <button type="submit" class="btn btn-outline">Apply sort</button>
            </div>
          </div>
        </form>
      </div>
    </section>

    <section class="blog-results" aria-labelledby="blog-results">
      <div class="container">
        <div class="blog-results-heading">
          <div>
            <p class="blog-kicker">Community feed</p>
            <h2 id="blog-results" tabindex="-1"><%= filterMeta?.summary || 'Community stories' %></h2>
          </div>
          <% if ((filterMeta?.totalPosts || 0) > 0) { %>
            <p>Showing <strong><%= pagination?.resultStart || 0 %>–<%= pagination?.resultEnd || 0 %></strong> of <strong><%= pagination?.totalPosts || 0 %></strong> feed stories</p>
          <% } else { %>
            <p>No matches yet</p>
          <% } %>
        </div>

        <% if (filterMeta?.activeFilters?.length) { %>
          <div class="blog-active-filters" aria-label="Active filters">
            <% filterMeta.activeFilters.forEach((activeFilter) => { %>
              <a href="<%= activeFilter.removeUrl %>#blog-results" class="blog-filter-chip" aria-label="Remove <%= activeFilter.label %> filter: <%= activeFilter.value %>">
                <span><strong><%= activeFilter.label %>:</strong> <%= activeFilter.value %></span>
                <span aria-hidden="true">×</span>
              </a>
            <% }) %>
            <a href="<%= filterMeta.clearFiltersUrl %>#blog-results" class="blog-filter-chip blog-filter-chip-clear">Clear filters</a>
          </div>
        <% } %>

        <% if (spotlight) { %>
          <section class="blog-spotlight" aria-labelledby="communitySpotlightTitle">
            <div class="blog-section-heading">
              <div>
                <p class="blog-kicker">Editor’s pick</p>
                <h2 id="communitySpotlightTitle">Community spotlight</h2>
              </div>
              <span>Selected from recent community voices</span>
            </div>
            <article class="blog-spotlight-card">
              <a href="<%= spotlight.href %>" class="blog-spotlight-image" tabindex="-1" aria-hidden="true">
                <img src="<%= spotlight.coverImageUrl || fallbackCover %>" alt="" loading="eager" data-blog-cover-image>
              </a>
              <div class="blog-spotlight-body">
                <span class="blog-topic-label"><%= spotlight.categoryLabel %></span>
                <h3><a href="<%= spotlight.href %>"><%= spotlight.title %></a></h3>
                <p><%= spotlight.excerpt || 'Read this featured perspective from the HelloRun community.' %></p>
                <div class="blog-writer-row">
                  <span class="blog-writer-avatar" aria-hidden="true">
                    <% if (spotlight.author.avatarUrl) { %><img src="<%= spotlight.author.avatarUrl %>" alt=""><% } else { %><%= spotlight.author.name.charAt(0) %><% } %>
                  </span>
                  <div>
                    <a href="<%= spotlight.author.id ? `/blog?author=${spotlight.author.id}` : spotlight.href %>" class="blog-writer-name"><%= spotlight.author.name %></a>
                    <% if (spotlight.author.verified) { %><i data-lucide="badge-check" class="blog-verified" aria-label="Verified writer"></i><% } %>
                    <small><%= spotlight.publishedAt ? new Date(spotlight.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %> · <%= spotlight.readingTimeLabel %></small>
                  </div>
                </div>
                <div class="blog-engagement-stats" aria-label="Story engagement">
                  <span><i data-lucide="eye" aria-hidden="true"></i><%= spotlight.viewsLabel %><span class="sr-only"> views</span></span>
                  <span><i data-lucide="heart" aria-hidden="true"></i><%= spotlight.likesLabel %><span class="sr-only"> likes</span></span>
                  <span><i data-lucide="message-circle" aria-hidden="true"></i><%= spotlight.commentsLabel %><span class="sr-only"> comments</span></span>
                  <a href="<%= spotlight.href %>" class="blog-read-link">Read story <i data-lucide="arrow-right" aria-hidden="true"></i></a>
                </div>
              </div>
            </article>
          </section>
        <% } %>

        <% if (topWriters && topWriters.length) { %>
          <section class="blog-top-writers" aria-labelledby="topWritersTitle">
            <div class="blog-section-heading">
              <div>
                <p class="blog-kicker">People to follow</p>
                <h2 id="topWritersTitle">Top writers</h2>
              </div>
              <span>Community members sharing consistently</span>
            </div>
            <div class="blog-writer-strip">
              <% topWriters.forEach((writer) => { %>
                <a href="<%= writer.href %>" class="blog-writer-card">
                  <span class="blog-writer-avatar" aria-hidden="true">
                    <% if (writer.avatarUrl) { %><img src="<%= writer.avatarUrl %>" alt=""><% } else { %><%= writer.name.charAt(0) %><% } %>
                  </span>
                  <span class="blog-writer-card-copy">
                    <strong><%= writer.name %> <% if (writer.verified) { %><i data-lucide="badge-check" aria-label="Verified writer"></i><% } %></strong>
                    <small><%= writer.publishedCount %> <%= writer.publishedCount === 1 ? 'story' : 'stories' %> · <%= writer.totalLikes.toLocaleString('en-US') %> likes</small>
                  </span>
                  <i data-lucide="chevron-right" aria-hidden="true"></i>
                </a>
              <% }) %>
            </div>
          </section>
        <% } %>

        <% if (posts && posts.length) { %>
          <section class="blog-feed" aria-labelledby="communityFeedTitle">
            <div class="blog-section-heading blog-feed-heading">
              <div>
                <p class="blog-kicker"><%= filterMeta?.hasActiveFilters ? 'Your results' : 'Latest voices' %></p>
                <h2 id="communityFeedTitle"><%= filterMeta?.hasActiveFilters ? 'Matching stories' : 'More from the community' %></h2>
              </div>
            </div>
            <div class="blog-card-grid">
              <% let blogFeedAdCount = 0; %>
              <% posts.forEach((post, postIndex) => { %>
                <article class="blog-story-card">
                  <a href="<%= post.href %>" class="blog-story-image" tabindex="-1" aria-hidden="true">
                    <img src="<%= post.coverImageUrl || fallbackCover %>" alt="" loading="lazy" data-blog-cover-image>
                  </a>
                  <div class="blog-story-body">
                    <div class="blog-story-topline">
                      <span class="blog-topic-label"><%= post.categoryLabel %></span>
                      <span><%= post.readingTimeLabel %></span>
                    </div>
                    <h3><a href="<%= post.href %>"><%= post.title %></a></h3>
                    <p class="blog-story-excerpt"><%= post.excerpt || 'Read this story from the HelloRun community.' %></p>
                    <div class="blog-writer-row">
                      <span class="blog-writer-avatar" aria-hidden="true">
                        <% if (post.author.avatarUrl) { %><img src="<%= post.author.avatarUrl %>" alt=""><% } else { %><%= post.author.name.charAt(0) %><% } %>
                      </span>
                      <div>
                        <a href="<%= post.author.id ? `/blog?author=${post.author.id}` : post.href %>" class="blog-writer-name"><%= post.author.name %></a>
                        <% if (post.author.verified) { %><i data-lucide="badge-check" class="blog-verified" aria-label="Verified writer"></i><% } %>
                        <small><%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %></small>
                      </div>
                    </div>
                    <div class="blog-engagement-stats" aria-label="Story engagement">
                      <span><i data-lucide="eye" aria-hidden="true"></i><%= post.viewsLabel %><span class="sr-only"> views</span></span>
                      <span><i data-lucide="heart" aria-hidden="true"></i><%= post.likesLabel %><span class="sr-only"> likes</span></span>
                      <span><i data-lucide="message-circle" aria-hidden="true"></i><%= post.commentsLabel %><span class="sr-only"> comments</span></span>
                      <a href="<%= post.href %>" class="blog-read-link" aria-label="Read <%= post.title %>">Read <i data-lucide="arrow-right" aria-hidden="true"></i></a>
                    </div>
                  </div>
                </article>
                <% if (filterMeta?.adSafe !== false && (postIndex + 1) % 4 === 0 && blogFeedAdCount < 2) { blogFeedAdCount += 1; %>
                  <div class="blog-feed-ad"><%- include('../partials/ad-unit', { group: 'blogListing', placement: 'in_feed', className: 'ad-unit-feed' }) %></div>
                <% } %>
              <% }) %>
            </div>
          </section>

          <% if (filterMeta?.adSafe !== false) { %>
            <%- include('../partials/ad-unit', { group: 'blogListing', placement: 'after_results_meta' }) %>
          <% } %>

          <% if (pagination && pagination.totalPages > 1) { %>
            <nav class="blog-pagination" aria-label="Blog pagination" data-page-label="Page <%= pagination.currentPage %> of <%= pagination.totalPages %>">
              <% const previousPage = Math.max(1, pagination.currentPage - 1); %>
              <% const nextPage = Math.min(pagination.totalPages, pagination.currentPage + 1); %>
              <a href="<%= pagination.getPageUrl(previousPage) %>" class="blog-page-button <%= pagination.currentPage === 1 ? 'is-disabled' : '' %>" aria-label="Previous page" <%= pagination.currentPage === 1 ? 'aria-disabled="true" tabindex="-1"' : '' %>><i data-lucide="chevron-left" aria-hidden="true"></i></a>
              <div class="blog-page-numbers">
                <% for (let pageNumber = 1; pageNumber <= pagination.totalPages; pageNumber += 1) { %>
                  <% if (pageNumber === 1 || pageNumber === pagination.totalPages || Math.abs(pageNumber - pagination.currentPage) <= 2) { %>
                    <a href="<%= pagination.getPageUrl(pageNumber) %>" class="blog-page-button <%= pageNumber === pagination.currentPage ? 'is-current' : '' %>" <%= pageNumber === pagination.currentPage ? 'aria-current="page"' : '' %>><%= pageNumber %></a>
                  <% } else if (Math.abs(pageNumber - pagination.currentPage) === 3) { %>
                    <span aria-hidden="true">…</span>
                  <% } %>
                <% } %>
              </div>
              <a href="<%= pagination.getPageUrl(nextPage) %>" class="blog-page-button <%= pagination.currentPage === pagination.totalPages ? 'is-disabled' : '' %>" aria-label="Next page" <%= pagination.currentPage === pagination.totalPages ? 'aria-disabled="true" tabindex="-1"' : '' %>><i data-lucide="chevron-right" aria-hidden="true"></i></a>
            </nav>
          <% } %>
        <% } else { %>
          <div class="blog-empty-state">
            <i data-lucide="messages-square" aria-hidden="true"></i>
            <h2><%= filterMeta?.hasActiveFilters ? 'No stories match yet' : 'The first story starts with you' %></h2>
            <p><%= filterMeta?.hasActiveFilters ? 'Try a broader search or return to all community stories.' : 'Share a running experience, lesson, race recap, or idea with the HelloRun community.' %></p>
            <a href="<%= filterMeta?.hasActiveFilters ? filterMeta.clearFiltersUrl : (locals.isAuthenticated ? '/blogs/me/new' : '/login?redirect=/blogs/me/new') %>" class="btn btn-primary"><%= filterMeta?.hasActiveFilters ? 'View all stories' : 'Write the first post' %></a>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    (function initBlogListing() {
      if (window.lucide) lucide.createIcons();
      const fallbackCover = '/images/helloRun-icon.webp';
      const applyCoverFallback = (image) => {
        if (image.dataset.fallbackApplied === '1') return;
        image.dataset.fallbackApplied = '1';
        image.src = fallbackCover;
        image.alt = 'HelloRun community story';
        image.closest('.blog-story-image, .blog-spotlight-image')?.classList.add('is-fallback');
      };
      document.querySelectorAll('[data-blog-cover-image]').forEach((image) => {
        image.addEventListener('error', () => applyCoverFallback(image));
        if (image.complete && image.naturalWidth === 0) applyCoverFallback(image);
      });
    })();
  </script>
</body>
</html>
