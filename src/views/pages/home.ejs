<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'HelloRun - Find Your Next Virtual Race', seo: seo }) %>
  <link rel="stylesheet" href="/css/helloRun.css">
</head>
<body>

  <%- include('../layouts/nav') %>

  <main class="home">

    <section class="hero">
      <div class="container hero-container<%= homeLeaderboard ? ' has-leaderboard' : '' %>">
        <div class="hero-text">
          <h1 class="hero-title">Run anywhere. <span class="highlight">Show up with purpose.</span></h1>
          <p class="hero-subtitle">
            Find virtual and on-site running events, submit your finish online, and keep results, certificates, and progress in one place — no GPS lock-in required.
          </p>

          <div class="hero-cta-row">
            <a href="/events" class="btn btn-primary">View Events</a>
            <a href="/signup" class="btn btn-outline">Sign Up Free</a>
          </div>

          <a class="hero-inline-action" href="/my-registrations">
            <i data-lucide="clipboard-list" aria-hidden="true"></i>
            <span>Already registered? Review your event entries.</span>
          </a>
        </div>

        <% if (homeLeaderboard) { %>
          <aside class="home-leaderboard" aria-labelledby="homeLeaderboardTitle">
            <header class="home-leaderboard-header">
              <div>
                <p class="home-leaderboard-kicker">
                  <span class="home-leaderboard-live-dot" aria-hidden="true"></span>
                  Verified results
                </p>
                <h2 id="homeLeaderboardTitle"><%= homeLeaderboard.eventTitle %></h2>
                <p class="home-leaderboard-context">
                  <span><%= homeLeaderboard.categoryLabel %></span>
                  <span aria-hidden="true">·</span>
                  <span><%= homeLeaderboard.leaderboardTypeLabel %></span>
                </p>
              </div>
              <i class="home-leaderboard-trophy" data-lucide="trophy" aria-hidden="true"></i>
            </header>

            <ol class="home-leaderboard-list" aria-label="Top verified finishers">
              <% homeLeaderboard.entries.forEach((entry) => { %>
                <li class="home-leaderboard-entry">
                  <span class="home-leaderboard-rank" aria-label="Rank <%= entry.rank %>"><%= entry.rank %></span>
                  <span class="home-leaderboard-runner"><%= entry.runnerName %></span>
                  <span class="home-leaderboard-metrics">
                    <strong><%= entry.primaryMetric %></strong>
                    <% if (entry.secondaryMetric) { %><small><%= entry.secondaryMetric %></small><% } %>
                  </span>
                </li>
              <% }) %>
            </ol>

            <footer class="home-leaderboard-footer">
              <span class="home-leaderboard-updated">
                <% if (homeLeaderboard.lastUpdatedAt) { %>
                  Updated <time datetime="<%= new Date(homeLeaderboard.lastUpdatedAt).toISOString() %>"><%= homeLeaderboard.lastUpdatedLabel %></time>
                <% } else { %>
                  Current verified standings
                <% } %>
              </span>
              <a href="<%= homeLeaderboard.href %>" class="home-leaderboard-link">
                <span>Full leaderboard</span>
                <i data-lucide="arrow-up-right" aria-hidden="true"></i>
              </a>
            </footer>
          </aside>
        <% } %>
      </div>
    </section>

    <section class="features">
      <div class="container">
        <div class="features-shell">
          <div class="features-intro">
            <h2 class="section-title section-title-left">What <span class="highlight">HelloRun</span> does</h2>
          </div>

          <div class="features-list" aria-label="HelloRun core capabilities">
            <article class="feature-item">
              <div class="feature-index" aria-hidden="true">01</div>
              <div class="feature-copy">
                <h3 class="feature-title">Find events that fit your pace</h3>
                <p>
                  Browse virtual fun runs and challenges, then choose events that match your distance, schedule, and goals.
                </p>
              </div>
            </article>

            <article class="feature-item">
              <div class="feature-index" aria-hidden="true">02</div>
              <div class="feature-copy">
                <h3 class="feature-title">Submit results without GPS lock-in</h3>
                <p>
                  Complete your run on your own terms, then submit your finish online without being locked to one tracking device or app.
                </p>
              </div>
            </article>

            <article class="feature-item">
              <div class="feature-index" aria-hidden="true">03</div>
              <div class="feature-copy">
                <h3 class="feature-title">Track progress, finishes, and recognition</h3>
                <p>
                  Keep your activity history, approved results, leaderboard progress, and recognition together instead of scattered across different places.
                </p>
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <% if (featuredEvents && featuredEvents.length) { %>
      <section class="featured-events" aria-labelledby="featuredEventsTitle">
        <div class="container">
          <div class="featured-events-header">
            <div>
              <p class="section-kicker">Featured events</p>
              <h2 id="featuredEventsTitle" class="section-title section-title-left">Find your next run</h2>
              <p class="featured-events-summary">
                Explore open and upcoming HelloRun events, compare formats, and choose the challenge that fits your next goal.
              </p>
            </div>
            <a href="/events" class="featured-events-view-all">
              <span>View all events</span>
              <i data-lucide="arrow-up-right"></i>
            </a>
          </div>

          <div class="featured-events-carousel" data-event-carousel data-carousel-loop="<%= carouselSettings?.loopEnabled === false ? '0' : '1' %>">
            <button type="button" class="featured-events-nav featured-events-nav-prev" data-carousel-prev aria-label="Previous featured events">
              <i data-lucide="chevron-left" aria-hidden="true"></i>
            </button>

            <div class="featured-events-track" data-carousel-track tabindex="0" aria-label="Featured event cards">
              <% featuredEvents.forEach((event) => { %>
                <article class="featured-event-card">
                  <a href="<%= event.href %>" class="featured-event-image-link" aria-label="<%= event.title %>">
                    <img
                      src="<%= event.imageUrl %>"
                      alt="<%= event.title %> banner"
                      loading="lazy"
                      onerror="this.onerror=null;this.src='<%= event.fallbackImageUrl %>';">
                  </a>

                  <div class="featured-event-body">
                    <div class="featured-event-tags">
                      <span class="featured-event-tag featured-event-tag-<%= event.displayState?.tone || 'neutral' %>"><%= event.displayState?.label || 'Event Listing' %></span>
                      <span class="featured-event-tag"><%= event.eventTypeLabel %></span>
                    </div>

                    <h3><a href="<%= event.href %>"><%= event.title %></a></h3>

                    <% if (event.displayState?.helper) { %>
                      <p class="featured-event-helper"><%= event.displayState.helper %></p>
                    <% } %>

                    <div class="featured-event-meta">
                      <span><i data-lucide="calendar"></i><%= event.dateLabel %></span>
                      <span><i data-lucide="map-pin"></i><%= event.locationLabel %></span>
                      <span><i data-lucide="flag"></i><%= event.distanceLabel %></span>
                    </div>

                    <p class="featured-event-description"><%= event.description %></p>

                    <a href="<%= event.href %>" class="featured-event-link">
                      <span>View Event</span>
                      <i data-lucide="arrow-right" aria-hidden="true"></i>
                    </a>
                  </div>
                </article>
              <% }) %>
            </div>

            <button type="button" class="featured-events-nav featured-events-nav-next" data-carousel-next aria-label="Next featured events">
              <i data-lucide="chevron-right" aria-hidden="true"></i>
            </button>
          </div>

          <div class="featured-events-dots" data-carousel-dots aria-label="Featured event pages"></div>
        </div>
      </section>
    <% } %>

    <section class="why-hellorun">
      <div class="container">
        <div class="why-shell">
          <div class="why-intro">
            <h2 class="section-title section-title-left">Why <span class="highlight">HelloRun</span></h2>
          </div>

          <div class="why-points" aria-label="Why HelloRun matters">
            <article class="why-point">
              <h3>Run on your own schedule</h3>
              <p>Train, walk, or race when it works for you instead of being tied to a fixed venue or one-time window.</p>
            </article>
            <article class="why-point">
              <h3>Still feel part of something bigger</h3>
              <p>Events, results, and shared progress give solo effort a visible community context.</p>
            </article>
            <article class="why-point">
              <h3>Focus on movement, not tool management</h3>
              <p>The platform stays lightweight so the experience centers on showing up, finishing, and keeping momentum.</p>
            </article>
            <article class="why-point">
              <h3>Know what happens after upload</h3>
              <p>Submitted proof is reviewed against the event rules. If something is unclear, runners can check status and follow guidance instead of guessing whether their activity counted.</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="audience">
      <div class="container">
        <h2 class="section-title">Built for everyone in the <span class="highlight">running community</span></h2>
        <div class="audience-grid">
          <div class="audience-card audience-card-runner">
            <h3 class="audience-card-heading">
              <span class="audience-icon"><i data-lucide="activity"></i></span>
              <span>For Runners</span>
            </h3>
            <p class="audience-card-summary">Find events, finish on your terms, and keep your results visible in one place.</p>
            <a href="/signup" class="btn btn-primary">Start Running</a>
          </div>
          <div class="audience-card audience-card-organizer">
            <h3 class="audience-card-heading">
              <span class="audience-icon"><i data-lucide="clipboard-check"></i></span>
              <span>For Organizers</span>
            </h3>
            <p class="audience-card-summary">Publish events, review results and payments, and manage participant progress in one workflow.</p>
            <a href="/signup" class="btn btn-primary">Create Events</a>
          </div>
        </div>
      </div>
    </section>

    <% if (recentPosts && recentPosts.length) { %>
      <section class="home-blog">
        <div class="container">
          <div class="home-blog-header">
            <div>
              <p class="section-kicker">From the blog</p>
              <h2 class="section-title section-title-left">Fresh stories, tips, and race recaps</h2>
            </div>
            <a href="/blog" class="home-blog-cta">
              <span>Visit Blog</span>
              <i data-lucide="arrow-up-right"></i>
            </a>
          </div>

          <div class="home-blog-grid">
            <% recentPosts.forEach((post) => { %>
              <article class="home-blog-card">
                <a href="/blog/<%= post.slug %>" class="home-blog-image" aria-label="<%= post.title %>">
                  <img
                    src="<%= post.coverImageUrl || '/images/helloRun-icon.webp' %>"
                    alt=""
                    loading="lazy"
                    onerror="this.onerror=null;this.src='/images/helloRun-icon.webp';">
                </a>
                <div class="home-blog-body">
                  <div class="home-blog-meta">
                    <span><i data-lucide="calendar"></i><%= post.publishedLabel %></span>
                    <span><i data-lucide="clock-3"></i><%= post.readingTime || 1 %> min read</span>
                  </div>
                  <div class="home-blog-title-row">
                    <span class="home-blog-category"><%= post.categoryLabel %></span>
                    <h3><a href="/blog/<%= post.slug %>"><%= post.title %></a></h3>
                  </div>
                  <p><%= post.excerpt || 'Read the latest story from the HelloRun community.' %></p>
                  <div class="home-blog-footer">
                    <span>By <strong><%= post.authorName %></strong></span>
                    <a href="/blog/<%= post.slug %>" class="home-blog-link">Read post</a>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      </section>
    <% } %>

    <%- include('../partials/ad-unit', { group: 'home', placement: 'before_cta' }) %>

    <section class="cta-section">
      <div class="container">
        <h2>Ready to move with us?</h2>
        <div class="cta-tagline">Move. Log. Finish.</div>
        <p>Create your free HelloRun account to keep event entries, submissions, and finishes in one place.</p>
        <div class="cta-actions">
          <a href="/signup" class="btn btn-primary btn-large">Start running today</a>
          <a href="/events" class="btn btn-outline btn-large">View Events</a>
        </div>
      </div>
    </section>

  </main>

  <%- include('../layouts/footer') %>

  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
