<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'helloRun - Find Your Next Virtual Race', seo: seo }) %>
  <link rel="stylesheet" href="/css/helloRun.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>

  <%- include('../layouts/nav') %>

  <main class="home">

    <section class="hero">
      <div class="container hero-container">
        <div class="hero-text">
          <h1 class="hero-title">Run anywhere. <span class="highlight">Show up with purpose.</span></h1>
          <p class="hero-subtitle">
            Discover events that match your pace, submit completed runs, and stay connected to a running community that keeps moving.
          </p>

          <div class="hero-stats">
            <% (stats || []).forEach((stat) => { %>
              <div class="stat-item">
                <div class="stat-heading">
                  <i data-lucide="<%= stat.icon %>" class="stat-icon"></i>
                  <span class="stat-value"><%= stat.value %></span>
                </div>
                <span class="stat-label"><%= stat.label %></span>
                <span class="stat-detail"><%= stat.detail %></span>
              </div>
            <% }) %>
          </div>

          <button type="button" class="hero-inline-action" data-open-run-proof-modal>
            <i data-lucide="plus-circle"></i>
            <span>Already registered? Log your latest run.</span>
          </button>
        </div>

        <div class="hero-visual">
          <div class="visual-placeholder">
            <div class="hero-visual-card">
              <div class="hero-visual-chip">
                <i data-lucide="trophy"></i>
                <span>Real finish tracking</span>
              </div>

              <img src="/images/helloRun-icon.webp" alt="helloRun - Virtual Running Platform" class="hero-logo">

              <div class="hero-buttons hero-buttons-panel">
                <a href="/events" class="btn btn-primary">View Events</a>
                <a href="/signup" class="btn btn-outline">Sign Up Free</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="container">
        <div class="features-shell">
          <div class="features-intro">
            <h2 class="section-title section-title-left">What <span class="highlight">helloRun</span> does</h2>
            <p class="features-summary">
              helloRun helps runners join virtual events, submit results online, and keep finishes in one place without forcing a specific watch, app, or GPS setup.
            </p>
          </div>

          <div class="features-list" aria-label="helloRun core capabilities">
            <article class="feature-item">
              <div class="feature-index" aria-hidden="true">01</div>
              <div class="feature-copy">
                <h3 class="feature-title">Find events that fit your pace</h3>
                <p>
                  Browse virtual fun runs and challenges, then choose events that match your distance, schedule, and goals.
                </p>
              </div>
            </article>

            <article class="feature-item">
              <div class="feature-index" aria-hidden="true">02</div>
              <div class="feature-copy">
                <h3 class="feature-title">Submit results without GPS lock-in</h3>
                <p>
                  Complete your run on your own terms, then submit your finish online without being locked to one tracking device or app.
                </p>
              </div>
            </article>

            <article class="feature-item">
              <div class="feature-index" aria-hidden="true">03</div>
              <div class="feature-copy">
                <h3 class="feature-title">Track progress, finishes, and recognition</h3>
                <p>
                  Keep your activity history, approved results, leaderboard progress, and recognition together instead of scattered across different places.
                </p>
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="why-hellorun">
      <div class="container">
        <div class="why-shell">
          <div class="why-intro">
            <h2 class="section-title section-title-left">Why <span class="highlight">helloRun</span></h2>
            <p class="why-summary">
              helloRun is built for runners who want flexibility without losing the feeling of being part of something shared.
            </p>
          </div>

          <div class="why-points" aria-label="Why helloRun matters">
            <article class="why-point">
              <h3>Run on your own schedule</h3>
              <p>Train, walk, or race when it works for you instead of being tied to a fixed venue or one-time window.</p>
            </article>
            <article class="why-point">
              <h3>Still feel part of something bigger</h3>
              <p>Events, results, and shared progress give solo effort a visible community context.</p>
            </article>
            <article class="why-point">
              <h3>Focus on movement, not tool management</h3>
              <p>The platform stays lightweight so the experience centers on showing up, finishing, and keeping momentum.</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section id="how-it-works" class="how-it-works">
      <div class="container">
        <h2 class="section-title">From start to finish in <span class="highlight">three steps</span></h2>
        <div class="steps">
          <div class="step">
            <div class="step-number">1</div>
            <h4>Choose an event</h4>
            <p>Browse upcoming virtual races - from 5Ks to marathons - and register in seconds.</p>
          </div>
          <div class="step">
            <div class="step-number">2</div>
            <h4>Run and track</h4>
            <p>Use any running app or log manually. We accept results from any device.</p>
          </div>
          <div class="step">
            <div class="step-number">3</div>
            <h4>See your rank</h4>
            <p>Your time appears on the leaderboard instantly. Celebrate your finish and aim higher.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="audience">
      <div class="container">
        <h2 class="section-title">Built for everyone in the <span class="highlight">running community</span></h2>
        <div class="audience-grid">
          <div class="audience-card audience-card-runner">
            <h3 class="audience-card-heading">
              <span class="audience-icon"><i data-lucide="activity"></i></span>
              <span>For Runners</span>
            </h3>
            <p class="audience-card-summary">Join events, submit finishes, and keep your progress visible without extra friction.</p>
            <ul>
              <li>Find virtual runs that match your pace and schedule</li>
              <li>Submit results online without being tied to one app or watch</li>
              <li>Keep rankings, finishes, and certificates in one place</li>
            </ul>
            <a href="/signup" class="btn btn-primary">Start Running</a>
          </div>
          <div class="audience-card audience-card-organizer">
            <h3 class="audience-card-heading">
              <span class="audience-icon"><i data-lucide="clipboard-check"></i></span>
              <span>For Organizers</span>
            </h3>
            <p class="audience-card-summary">Launch event pages and manage participant progress through one clearer workflow.</p>
            <ul>
              <li>Create event pages quickly and keep details clear</li>
              <li>Review payment proofs and run submissions in one workflow</li>
              <li>Track registrations, approvals, and event activity more easily</li>
            </ul>
            <a href="/signup" class="btn btn-primary">Create Events</a>
          </div>
        </div>
      </div>
    </section>

    <% if (recentPosts && recentPosts.length) { %>
      <section class="home-blog">
        <div class="container">
          <div class="home-blog-header">
            <div>
              <p class="section-kicker">From the blog</p>
              <h2 class="section-title section-title-left">Fresh stories, tips, and race recaps</h2>
            </div>
            <a href="/blog" class="home-blog-cta">
              <span>Visit Blog</span>
              <i data-lucide="arrow-up-right"></i>
            </a>
          </div>

          <div class="home-blog-grid">
            <% recentPosts.forEach((post) => { %>
              <article class="home-blog-card">
                <a href="/blog/<%= post.slug %>" class="home-blog-image" aria-label="<%= post.title %>">
                  <img
                    src="<%= post.coverImageUrl || '/images/helloRun-icon.webp' %>"
                    alt=""
                    loading="lazy"
                    onerror="this.onerror=null;this.src='/images/helloRun-icon.webp';">
                </a>
                <div class="home-blog-body">
                  <div class="home-blog-meta">
                    <span><i data-lucide="calendar"></i><%= post.publishedLabel %></span>
                    <span><i data-lucide="clock-3"></i><%= post.readingTime || 1 %> min read</span>
                  </div>
                  <div class="home-blog-title-row">
                    <span class="home-blog-category"><%= post.categoryLabel %></span>
                    <h3><a href="/blog/<%= post.slug %>"><%= post.title %></a></h3>
                  </div>
                  <p><%= post.excerpt || 'Read the latest story from the helloRun community.' %></p>
                  <div class="home-blog-footer">
                    <span>By <strong><%= post.authorName %></strong></span>
                    <a href="/blog/<%= post.slug %>" class="home-blog-link">Read post</a>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      </section>
    <% } %>

    <section class="testimonial">
      <div class="container">
        <div class="testimonial-card">
          <i class="fas fa-quote-left quote-icon"></i>
          <p class="testimonial-text">
            "helloRun changed the way I train. The real-time rankings push me to give my best, even when I'm running alone. I've already signed up for three events!"
          </p>
          <div class="testimonial-author">
            <img src="https://ui-avatars.com/api/?name=Henson+Sagorsor&size=50&background=fa9a4b&color=fff" alt="Henson Sagorsor" class="author-avatar">
            <div>
              <strong>Henson Sagorsor</strong>
              <span>member since 2026</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <h2>Ready to move with us?</h2>
        <div class="cta-tagline">Move. Log. Finish.</div>
        <p>Join a growing community of runners already tracking their progress and celebrating achievements through movement.</p>
        <div class="cta-actions">
          <a href="/signup" class="btn btn-primary btn-large">Start running today</a>
          <a href="/events" class="btn btn-outline btn-large">View Events</a>
        </div>
      </div>
    </section>

  </main>

  <%- include('../layouts/footer') %>

  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
