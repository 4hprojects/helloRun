<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title, seo }) %>
  <link rel="stylesheet" href="/css/badge-verification.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="runner-profile-public-page">
    <section class="runner-profile-hero">
      <div class="runner-profile-hero-inner">
        <div class="runner-profile-avatar-wrap">
          <% if (runner.avatarUrl) { %>
            <img src="<%= runner.avatarUrl %>" alt="" class="runner-profile-avatar" loading="lazy">
          <% } else { %>
            <span class="runner-profile-avatar-placeholder"><i data-lucide="user" aria-hidden="true"></i></span>
          <% } %>
        </div>
        <div class="runner-profile-identity">
          <h1><%= runner.name %></h1>
          <% if (runner.runningGroup) { %>
            <p class="runner-profile-group"><i data-lucide="users" aria-hidden="true"></i> <%= runner.runningGroup %></p>
          <% } %>
          <% if (runner.joinedAt) { %>
            <p class="runner-profile-joined">Member since <%= new Date(runner.joinedAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></p>
          <% } %>
        </div>
      </div>
    </section>

    <div class="runner-profile-body">

      <% if (metrics) { %>
        <section class="runner-profile-stats" aria-label="Lifetime stats">
          <div class="runner-stat-card">
            <p class="runner-stat-value"><%= Number(metrics.totalDistanceKm || 0).toFixed(1) %></p>
            <p class="runner-stat-label">km completed</p>
          </div>
          <div class="runner-stat-card">
            <p class="runner-stat-value"><%= metrics.completedEvents || 0 %></p>
            <p class="runner-stat-label">events finished</p>
          </div>
          <div class="runner-stat-card">
            <p class="runner-stat-value"><%= metrics.certificatesCount || 0 %></p>
            <p class="runner-stat-label">certificates</p>
          </div>
          <% if (metrics.fastestElapsedLabel) { %>
            <div class="runner-stat-card">
              <p class="runner-stat-value"><%= metrics.fastestElapsedLabel %></p>
              <p class="runner-stat-label">personal best</p>
            </div>
          <% } %>
        </section>
      <% } %>

      <% if (recentBadges && recentBadges.length) { %>
        <section class="runner-profile-badges-section">
          <div class="runner-profile-section-header">
            <h2>Recent Badges</h2>
            <a href="<%= runner.badgesHref %>" class="runner-profile-see-all">See all badges →</a>
          </div>
          <div class="runner-profile-badge-grid">
            <% recentBadges.forEach(function(badge) { %>
              <a href="/badges/<%= badge.userBadgeId %>" class="runner-profile-badge-card">
                <span class="runner-profile-badge-art">
                  <% if (badge.imageUrl) { %>
                    <img src="<%= badge.imageUrl %>" alt="" loading="lazy">
                  <% } else { %>
                    <i data-lucide="award" aria-hidden="true"></i>
                  <% } %>
                </span>
                <span class="runner-profile-badge-name"><%= badge.name %></span>
                <% if (badge.eventTitle) { %><span class="runner-profile-badge-event"><%= badge.eventTitle %></span><% } %>
              </a>
            <% }); %>
          </div>
        </section>
      <% } %>

      <section class="runner-profile-share">
        <p class="runner-profile-share-label">Share this profile</p>
        <div class="runner-profile-share-btns">
          <a href="<%= facebookShareUrl %>" target="_blank" rel="noopener noreferrer" class="cert-share-btn cert-share-facebook" aria-label="Share on Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="<%= xShareUrl %>" target="_blank" rel="noopener noreferrer" class="cert-share-btn cert-share-x" aria-label="Share on X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4 4l16 16M4 20L20 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
          </a>
          <a href="<%= linkedInShareUrl %>" target="_blank" rel="noopener noreferrer" class="cert-share-btn cert-share-linkedin" aria-label="Share on LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
        <a href="<%= runner.badgesHref %>" class="btn btn-outline btn-sm" style="margin-top:0.75rem">View full badge collection</a>
      </section>

    </div>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
