<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'My Blogs - HelloRun' }) %>
  <style>
    .dash-shell { padding: 2rem; max-width: 1080px; margin: 0 auto; }
    .dash-header { display:flex; justify-content:space-between; align-items:center; gap:.75rem; flex-wrap:wrap; margin-bottom:1rem; }
    .dash-header p { margin:0; color:#64748b; }
    .dash-btn { display:inline-flex; align-items:center; justify-content:center; gap:.35rem; min-height:38px; padding:.5rem .85rem; border-radius:10px; border:1px solid transparent; text-decoration:none; font-weight:600; }
    .dash-btn-primary { background:#2563eb; border-color:#1d4ed8; color:#fff; }
    .dash-btn-primary:hover { background:#1d4ed8; }
    .dash-btn-secondary { background:#f8fafc; border-color:#cbd5e1; color:#334155; }
    .dash-btn-secondary:hover { background:#f1f5f9; }
    .dash-btn-danger { background:#fff1f2; border-color:#fecdd3; color:#9f1239; }
    .dash-btn-danger:hover { background:#ffe4e6; }
    .dash-btn-sm { min-height:34px; padding:.4rem .7rem; font-size:.88rem; }
    .dash-filter { display:flex; align-items:center; gap:.5rem; margin-bottom:.9rem; flex-wrap:wrap; }
    .dash-filter select { padding:.45rem .55rem; border-radius:8px; border:1px solid #cbd5e1; }
    .dash-grid { display:grid; grid-template-columns:1fr; gap:.6rem; }
    .dash-card { border:1px solid #e2e8f0; border-radius:10px; padding:.8rem; background:#fff; }
    .dash-card-top { display:flex; justify-content:space-between; gap:.65rem; flex-wrap:wrap; }
    .dash-card h3 { margin:0 0 .35rem; }
    .dash-slug { margin:0; color:#64748b; font-size:.9rem; }
    .dash-status { align-self:start; text-transform:uppercase; font-size:.75rem; font-weight:700; padding:.2rem .5rem; border-radius:999px; background:#f1f5f9; color:#334155; }
    .dash-actions { display:flex; gap:.45rem; flex-wrap:wrap; margin-top:.65rem; }
    .dash-empty { padding:1.2rem; border:1px dashed #cbd5e1; border-radius:10px; text-align:center; color:#64748b; }
    .dash-metrics { display:flex; gap:.75rem; flex-wrap:wrap; margin:.55rem 0 0; color:#475569; font-size:.86rem; }
    .dash-metric strong { color:#0f172a; }
    .dash-note { margin:.45rem 0 0; color:#92400e; font-size:.86rem; }
    .blog-delete-dialog { width:min(480px,calc(100vw - 2rem)); margin:auto; padding:0; border:0; border-radius:16px; color:#1e293b; background:#fff; box-shadow:0 24px 70px rgba(15,23,42,.3); }
    .blog-delete-dialog::backdrop { background:rgba(15,23,42,.58); backdrop-filter:blur(2px); }
    .blog-delete-dialog-inner { padding:1.25rem; }
    .blog-delete-dialog-kicker { color:#9f1239; font-size:.72rem; font-weight:800; letter-spacing:.06em; text-transform:uppercase; }
    .blog-delete-dialog h2 { margin:.25rem 0 .45rem; color:#0f172a; font-size:1.3rem; text-align:left; }
    .blog-delete-dialog p { margin:.35rem 0; color:#64748b; line-height:1.55; }
    .blog-delete-post-title { display:block; margin:.85rem 0; padding:.75rem; border:1px solid #e2e8f0; border-radius:10px; color:#0f172a; background:#f8fafc; overflow-wrap:anywhere; }
    .blog-delete-dialog-actions { display:flex; justify-content:flex-end; gap:.65rem; margin-top:1rem; }
    .blog-delete-dialog-actions .dash-btn { min-height:44px; }
    @media(max-width:480px){.blog-delete-dialog-inner{padding:1rem}.blog-delete-dialog-actions{display:grid;grid-template-columns:1fr}.blog-delete-dialog-actions .dash-btn{width:100%}}
  </style>
</head>
<body>
  <%- include('../layouts/nav') %>
  <main class="dash-shell">
    <header class="dash-header">
      <div>
        <h1 style="margin-bottom: 0.3rem;">My Blogs</h1>
        <p>Create, update, and submit your running blog posts for review.</p>
      </div>
      <a href="/blogs/me/new" class="dash-btn dash-btn-primary">Write New Post</a>
    </header>

    <% if (message) { %>
      <div style="margin-bottom: 0.8rem; padding: 0.7rem; border-radius: 8px; font-weight: 600; border: 1px solid <%= message.type === 'error' ? '#fecaca' : '#86efac' %>; background: <%= message.type === 'error' ? '#fee2e2' : '#dcfce7' %>; color: <%= message.type === 'error' ? '#991b1b' : '#166534' %>;">
        <%= message.text %>
      </div>
    <% } %>

    <form method="GET" action="/blogs/me/dashboard" class="dash-filter">
      <label for="status" style="font-weight: 600;">Status</label>
      <select id="status" name="status">
        <option value="" <%= !selectedStatus ? 'selected' : '' %>>All</option>
        <option value="draft" <%= selectedStatus === 'draft' ? 'selected' : '' %>>Draft</option>
        <option value="pending" <%= selectedStatus === 'pending' ? 'selected' : '' %>>Pending</option>
        <option value="published" <%= selectedStatus === 'published' ? 'selected' : '' %>>Published</option>
        <option value="rejected" <%= selectedStatus === 'rejected' ? 'selected' : '' %>>Rejected</option>
        <option value="archived" <%= selectedStatus === 'archived' ? 'selected' : '' %>>Archived</option>
      </select>
      <button type="submit" class="dash-btn dash-btn-secondary dash-btn-sm">Apply</button>
      <a href="/blogs/me/dashboard" class="dash-btn dash-btn-secondary dash-btn-sm">Reset</a>
    </form>

    <% if (posts && posts.length) { %>
      <div class="dash-grid">
        <% posts.forEach((post) => { %>
          <article class="dash-card">
            <div class="dash-card-top">
              <div>
                <h3><%= post.title %></h3>
                <p class="dash-slug"><%= post.category === 'Other' && post.customCategory ? post.customCategory : post.category %> | /blog/<%= post.slug %></p>
              </div>
              <span class="dash-status"><%= post.status %></span>
            </div>

            <% if (post.status === 'rejected' && post.rejectionReason) { %>
              <p style="margin: 0.55rem 0 0; color: #991b1b;"><strong>Rejection reason:</strong> <%= post.rejectionReason %></p>
            <% } %>

            <p style="margin: 0.55rem 0 0; color: #64748b; font-size: 0.85rem;">
              Updated: <%= post.updatedAt ? new Date(post.updatedAt).toLocaleString('en-US') : 'N/A' %>
            </p>
            <div class="dash-metrics">
              <span class="dash-metric"><strong><%= Number(post.views || 0).toLocaleString('en-US') %></strong> views</span>
              <span class="dash-metric"><strong><%= Number(post.likesCount || 0).toLocaleString('en-US') %></strong> likes</span>
              <span class="dash-metric"><strong><%= Number(post.commentsCount || 0).toLocaleString('en-US') %></strong> comments</span>
            </div>
            <% if (post.activeRevisionStatus) { %>
              <p class="dash-note">
                Revision status: <strong><%= post.activeRevisionStatus %></strong>
                <% if (post.activeRevisionRejectionReason) { %>
                  | <%= post.activeRevisionRejectionReason %>
                <% } %>
              </p>
            <% } %>

            <div class="dash-actions">
              <% if (post.status === 'draft' || post.status === 'pending' || post.status === 'rejected') { %>
                <a href="/blogs/me/<%= post._id %>/edit" class="dash-btn dash-btn-secondary dash-btn-sm">Edit</a>
              <% } %>
              <% if (post.status === 'draft' || post.status === 'rejected') { %>
                <form method="POST" action="/blogs/me/<%= post._id %>/submit-form" style="display: inline;">
                  <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
                  <button type="submit" class="dash-btn dash-btn-primary dash-btn-sm">Submit for Review</button>
                </form>
                <form method="POST" action="/blogs/me/<%= post._id %>/delete-form" style="display: inline;" data-delete-post-form data-post-title="<%= post.title %>" onsubmit="return confirm('Delete this post permanently?');">
                  <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
                  <button type="submit" class="dash-btn dash-btn-danger dash-btn-sm">Delete</button>
                </form>
              <% } %>
              <% if (post.status === 'published') { %>
                <a href="/blogs/me/<%= post._id %>/edit" class="dash-btn dash-btn-secondary dash-btn-sm">Update Published Post</a>
                <a href="/blog/<%= post.slug %>" class="dash-btn dash-btn-secondary dash-btn-sm" target="_blank" rel="noopener noreferrer">View Public Post</a>
                <% if (post.activeRevisionStatus === 'draft' || post.activeRevisionStatus === 'rejected') { %>
                  <form method="POST" action="/blogs/me/<%= post._id %>/revision/discard-form" style="display: inline;" onsubmit="return confirm('Discard the saved revision draft?');">
                    <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
                    <button type="submit" class="dash-btn dash-btn-danger dash-btn-sm">Discard Revision</button>
                  </form>
                <% } %>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="dash-empty">
        No blog posts found.
      </div>
    <% } %>
  </main>
  <dialog class="blog-delete-dialog" id="blogDeleteDialog" aria-labelledby="blogDeleteDialogTitle" aria-describedby="blogDeleteDialogDescription">
    <div class="blog-delete-dialog-inner">
      <span class="blog-delete-dialog-kicker">Permanent action</span>
      <h2 id="blogDeleteDialogTitle">Delete this post?</h2>
      <p id="blogDeleteDialogDescription">This removes the draft and cannot be undone.</p>
      <strong class="blog-delete-post-title" id="blogDeletePostTitle"></strong>
      <p id="blogDeleteDialogStatus" role="status" aria-live="polite"></p>
      <div class="blog-delete-dialog-actions">
        <button type="button" class="dash-btn dash-btn-secondary" id="blogDeleteCancel">Cancel</button>
        <button type="button" class="dash-btn dash-btn-danger" id="blogDeleteConfirm">Delete post</button>
      </div>
    </div>
  </dialog>
  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    (function setupBlogDeleteConfirmation() {
      if (window.lucide) lucide.createIcons();
      const dialog = document.getElementById('blogDeleteDialog');
      const title = document.getElementById('blogDeletePostTitle');
      const cancel = document.getElementById('blogDeleteCancel');
      const confirmButton = document.getElementById('blogDeleteConfirm');
      let activeForm = null;
      let activeTrigger = null;
      document.querySelectorAll('[data-delete-post-form]').forEach((form) => {
        form.removeAttribute('onsubmit');
        form.addEventListener('submit', (event) => {
          event.preventDefault();
          activeForm = form;
          activeTrigger = form.querySelector('button[type="submit"]');
          if (!dialog?.showModal) {
            if (window.confirm('Delete this post permanently?')) form.submit();
            return;
          }
          if (title) title.textContent = form.dataset.postTitle || 'Untitled post';
          dialog.showModal();
          cancel?.focus();
        });
      });
      cancel?.addEventListener('click', () => dialog.close('cancelled'));
      confirmButton?.addEventListener('click', () => {
        if (!activeForm) return;
        confirmButton.disabled = true;
        confirmButton.setAttribute('aria-busy', 'true');
        confirmButton.textContent = 'Deleting…';
        activeForm.submit();
      });
      dialog?.addEventListener('close', () => {
        activeTrigger?.focus();
        activeForm = null;
      });
    })();
  </script>
</body>
</html>
