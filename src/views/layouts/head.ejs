<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<% const effectiveSeo = (typeof seo !== 'undefined' && seo) ? seo : (locals.seo || null); %>
<title><%= title || 'HelloRun - Virtual Running Events' %></title>
<link rel="icon" type="image/png" href="/images/helloRun-icon-browser.png">
<link rel="apple-touch-icon" href="/images/helloRun-icon-browser.png">
<% if (effectiveSeo && effectiveSeo.robots) { %>
  <meta name="robots" content="<%= effectiveSeo.robots %>">
<% } %>
<% if (effectiveSeo && effectiveSeo.description) { %>
  <meta name="description" content="<%= effectiveSeo.description %>">
<% } %>
<% if (effectiveSeo && effectiveSeo.canonicalUrl) { %>
  <link rel="canonical" href="<%= effectiveSeo.canonicalUrl %>">
<% } %>
<% if (effectiveSeo && (effectiveSeo.ogTitle || title)) { %>
  <meta property="og:type" content="<%= effectiveSeo.ogType || 'website' %>">
  <meta property="og:title" content="<%= effectiveSeo.ogTitle || title %>">
  <% if (effectiveSeo.description) { %><meta property="og:description" content="<%= effectiveSeo.description %>"><% } %>
  <% if (effectiveSeo.canonicalUrl) { %><meta property="og:url" content="<%= effectiveSeo.canonicalUrl %>"><% } %>
  <% if (effectiveSeo.ogImage) { %>
    <meta property="og:image" content="<%= effectiveSeo.ogImage %>">
    <meta property="og:image:width" content="<%= effectiveSeo.ogImageWidth || 1200 %>">
    <meta property="og:image:height" content="<%= effectiveSeo.ogImageHeight || 630 %>">
    <% if (effectiveSeo.ogImageType) { %><meta property="og:image:type" content="<%= effectiveSeo.ogImageType %>"><% } %>
  <% } %>
<% } %>
<% if (effectiveSeo && (effectiveSeo.twitterTitle || title)) { %>
  <meta name="twitter:card" content="<%= effectiveSeo.twitterCard || 'summary_large_image' %>">
  <meta name="twitter:title" content="<%= effectiveSeo.twitterTitle || effectiveSeo.ogTitle || title %>">
  <% if (effectiveSeo.description) { %><meta name="twitter:description" content="<%= effectiveSeo.description %>"><% } %>
  <% if (effectiveSeo.ogImage) { %><meta name="twitter:image" content="<%= effectiveSeo.ogImage %>"><% } %>
<% } %>
<meta name="google-adsense-account" content="ca-pub-4537208011192461">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/design-system.css">
<% if (locals.renderRunProofModal) { %>
  <link rel="stylesheet" href="/css/run-proof-modal.css">
<% } %>
<link rel="stylesheet" href="/css/project-buttons.css">
<link rel="stylesheet" href="/css/ads.css">
<link rel="stylesheet" href="/css/mobile-nav.css">
<link rel="stylesheet" href="/css/badge-display.css">
<link rel="stylesheet" href="/css/cookie-preferences.css">
<script src="https://unpkg.com/lucide@latest"></script>
<%- include('../partials/privacy-head') %>
<% if (locals.ads && locals.ads.renderScript && locals.ads.publisherId) { %>
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=<%= locals.ads.publisherId %>" crossorigin="anonymous"></script>
<% } %>

<!-- Organization structured data -->
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"HelloRun","url":"https://hellorun.online","logo":{"@type":"ImageObject","url":"https://hellorun.online/images/helloRun-icon.webp"},"description":"HelloRun is a running event management platform for virtual, on-site, and hybrid events."}</script>

<!-- Google Analytics -->
<% if (locals.canUseAnalytics && process.env.GA_MEASUREMENT_ID) { %>
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= process.env.GA_MEASUREMENT_ID %>"></script>
<script>
  gtag('js', new Date());
  gtag('config', '<%= process.env.GA_MEASUREMENT_ID %>');
</script>
<% } %>
