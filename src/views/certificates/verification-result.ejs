<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'Certificate Verification - HelloRun' }) %>
  <link rel="stylesheet" href="/css/static-pages.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="static-page">
  <section class="static-hero">
    <p class="eyebrow">Certificate Verification</p>
    <h1>Verification Result</h1>
  </section>

  <section class="static-content">
    <% if (!result.found) { %>
      <div class="alert alert-error">Certificate number <strong><%= certificateNumber %></strong> was not found.</div>
      <p><a href="/certificates/verify">Try another certificate number</a></p>
    <% } else if (result.certificate.status === 'revoked') { %>
      <div class="alert alert-error">This certificate is no longer valid.</div>
      <dl>
        <dt>Certificate number</dt><dd><%= result.certificate.certificateNumber %></dd>
        <dt>Runner</dt><dd><%= result.certificate.runnerName %></dd>
        <dt>Event</dt><dd><%= result.certificate.eventTitle %></dd>
      </dl>
    <% } else { %>
      <div class="alert alert-success">This certificate is valid.</div>
      <dl>
        <dt>Certificate number</dt><dd><%= result.certificate.certificateNumber %></dd>
        <dt>Runner</dt><dd><%= result.certificate.runnerName %></dd>
        <dt>Event</dt><dd><%= result.certificate.eventTitle %></dd>
        <dt>Organiser</dt><dd><%= result.certificate.organizerName || 'HelloRun' %></dd>
        <dt>Distance</dt><dd><%= result.certificate.distance || '-' %></dd>
        <dt>Finish time</dt><dd><%= result.certificate.finishTime || '-' %></dd>
        <dt>Generated</dt><dd><%= result.certificate.generatedAt ? new Date(result.certificate.generatedAt).toLocaleDateString('en-US') : '-' %></dd>
      </dl>
      <% if (shareUrls) { %>
        <div class="cert-share-block">
          <p class="cert-share-label">Share this achievement</p>
          <div class="cert-share-buttons">
            <a href="<%= shareUrls.facebook %>" target="_blank" rel="noopener noreferrer" class="cert-share-btn cert-share-facebook" aria-label="Share on Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook
            </a>
            <a href="<%= shareUrls.x %>" target="_blank" rel="noopener noreferrer" class="cert-share-btn cert-share-x" aria-label="Share on X">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 4l16 16M4 20L20 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
              X (Twitter)
            </a>
            <a href="<%= shareUrls.linkedin %>" target="_blank" rel="noopener noreferrer" class="cert-share-btn cert-share-linkedin" aria-label="Share on LinkedIn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <a href="<%= shareUrls.mail %>" class="cert-share-btn cert-share-email" aria-label="Share via email">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              Email
            </a>
            <button type="button" class="cert-share-btn cert-share-copy" data-copy-url="<%= canonicalUrl %>" aria-label="Copy link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy link
            </button>
          </div>
        </div>
        <script>
          document.querySelector('.cert-share-copy')?.addEventListener('click', function() {
            navigator.clipboard.writeText(this.dataset.copyUrl).then(() => {
              this.textContent = 'Copied!';
              setTimeout(() => { this.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy link'; }, 2000);
            });
          });
        </script>
      <% } %>
    <% } %>
  </section>
  </main>

  <%- include('../layouts/footer') %>
</body>
</html>
