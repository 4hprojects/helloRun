<!-- Public Blog Post - Growth Features UI -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= post.title %> | HelloRun Blog</title>
  <link rel="stylesheet" href="/css/runner-dashboard.css">
</head>
<body>
  <header>
    <h1><a href="/blog">HelloRun Blog</a></h1>
    <nav>
      <a href="/blog">Home</a>
      <a href="/blog/trending">Trending</a>
      <a href="/blog/top-writers">Top Writers</a>
      <a href="/blog/guides">Guides & Resources</a>
      <a href="/feed.xml" target="_blank">Newsletter/Feed</a>
    </nav>
  </header>
  <main>
    <article>
      <h2><%= post.title %></h2>
      <div class="meta">
        <span>By <%= post.authorName %></span>
        <span>Published: <%= post.publishedAt.toDateString() %></span>
        <span>Trending Score: <%= post.trendingScore %></span>
        <span>Views: <%= post.views %></span>
        <span>Likes: <%= post.likes %></span>
      </div>
      <div class="content">
        <%- post.contentHtml %>
      </div>
      <% if (post.tags && post.tags.length) { %>
        <div class="tags">
          <strong>Tags:</strong>
          <% post.tags.forEach(function(tag) { %>
            <span><%= tag %></span>
          <% }); %>
        </div>
      <% } %>
    </article>
    <section id="comments">
      <h3>Comments</h3>
      <% if (comments && comments.length) { %>
        <ul>
          <% comments.forEach(function(comment) { %>
            <li>
              <span><%= comment.authorName %>:</span>
              <span><%= comment.content %></span>
              <span>(<%= comment.createdAt.toLocaleString() %>)</span>
            </li>
          <% }); %>
        </ul>
      <% } else { %>
        <p>No comments yet.</p>
      <% } %>
    </section>
  </main>
</body>
</html>
