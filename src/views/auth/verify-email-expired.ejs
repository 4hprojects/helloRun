<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: 'Verification Link Expired - HelloRun' }) %>
  <link rel="stylesheet" href="/css/email-verification.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  
  <main class="auth-page">
    <div class="auth-container">
      <div class="auth-card">
        <div class="auth-icon error">
          <i data-lucide="clock"></i>
        </div>
        
        <h1>Verification Link Expired</h1>
        <p class="auth-subtitle">This email verification link has expired. Don't worry, we can send you a new one!</p>
        
        <div class="auth-info">
          <p><strong>Email:</strong> <%= email %></p>
          <p><small>Verification links expire after 24 hours for security.</small></p>
        </div>
        
        <div class="auth-actions">
          <a href="/resend-verification?email=<%= email %>" class="btn btn-full">Request New Link</a>
          <a href="/login" class="btn btn-secondary btn-full">Back to Login</a>
        </div>
      </div>
    </div>
  </main>
  
  <%- include('../layouts/footer') %>
  
  <script src="/js/main.js"></script>
  <script>
    lucide.createIcons();
  </script>
</body>
</html>