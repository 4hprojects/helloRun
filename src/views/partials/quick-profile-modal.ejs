<%
  const quickCollectEmergencyContact = typeof collectEmergencyContact !== 'undefined' ? collectEmergencyContact : true;
  const quickRequiresEmergencyContact = typeof requiresEmergencyContact !== 'undefined' ? requiresEmergencyContact : quickCollectEmergencyContact;
%>
<div
  class="quick-profile-modal-backdrop"
  id="quickProfileModal"
  data-update-endpoint="/profile/quick-update"
  hidden
  aria-hidden="true"
>
  <section class="quick-profile-modal" role="dialog" aria-modal="true" aria-labelledby="quickProfileTitle" tabindex="-1">
    <header class="quick-profile-modal-header">
      <div>
        <h2 id="quickProfileTitle">Update Profile Snapshot</h2>
        <p>Review the participant details that will be saved with this registration.</p>
      </div>
      <button type="button" class="dialog-icon-button" id="quickProfileCloseBtn" aria-label="Close profile editor"><i data-lucide="x" aria-hidden="true"></i></button>
    </header>
    <form id="quickProfileForm" class="quick-profile-form" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
      <input type="hidden" name="requiresEmergencyContact" id="quickRequiresEmergencyContact" value="<%= quickRequiresEmergencyContact ? '1' : '0' %>">

      <div class="quick-profile-grid">
        <label class="form-group">
          <span>First Name</span>
          <input type="text" value="<%= formData.firstName || '' %>" readonly disabled>
        </label>
        <label class="form-group">
          <span>Last Name</span>
          <input type="text" value="<%= formData.lastName || '' %>" readonly disabled>
        </label>
        <label class="form-group">
          <span>Email</span>
          <input type="email" value="<%= formData.email || '' %>" readonly disabled>
        </label>
        <label class="form-group">
          <span>Mobile *</span>
          <input type="tel" id="quickMobile" name="mobile" value="<%= formData.mobile || '' %>" required autocomplete="tel">
          <small class="error-text" data-error-for="mobile"></small>
        </label>
        <label class="form-group">
          <span>Country *</span>
          <select id="quickCountry" name="country" autocomplete="country" required>
            <option value="">Select country</option>
            <% (countries || []).forEach((country) => { %>
              <option value="<%= country.code %>" <%= formData.country === country.code ? 'selected' : '' %>><%= country.name %></option>
            <% }) %>
          </select>
          <small class="error-text" data-error-for="country"></small>
        </label>
        <label class="form-group">
          <span>Date of birth</span>
          <input type="date" id="quickDateOfBirth" name="dateOfBirth" value="<%= formData.dateOfBirth || '' %>" autocomplete="bday">
          <small class="error-text" data-error-for="dateOfBirth"></small>
        </label>
        <label class="form-group">
          <span>Gender</span>
          <select id="quickGender" name="gender">
            <option value="">Not set</option>
            <% [['male','Male'],['female','Female'],['non_binary','Non-binary'],['prefer_not_to_say','Prefer not to say']].forEach(([value,label]) => { %>
              <option value="<%= value %>" <%= formData.gender === value ? 'selected' : '' %>><%= label %></option>
            <% }) %>
          </select>
          <small class="error-text" data-error-for="gender"></small>
        </label>
        <% if (quickCollectEmergencyContact) { %>
          <label class="form-group" data-quick-emergency-contact-field <%= quickRequiresEmergencyContact ? '' : 'hidden' %>>
            <span>Emergency Contact Name *</span>
            <input type="text" id="quickEmergencyName" name="emergencyContactName" value="<%= formData.emergencyContactName || '' %>" <%= quickRequiresEmergencyContact ? 'required' : 'disabled' %> maxlength="120">
            <small class="error-text" data-error-for="emergencyContactName"></small>
          </label>
          <label class="form-group" data-quick-emergency-contact-field <%= quickRequiresEmergencyContact ? '' : 'hidden' %>>
            <span>Emergency Contact Number *</span>
            <input type="text" id="quickEmergencyNumber" name="emergencyContactNumber" value="<%= formData.emergencyContactNumber || '' %>" <%= quickRequiresEmergencyContact ? 'required' : 'disabled' %> maxlength="25">
            <small class="error-text" data-error-for="emergencyContactNumber"></small>
          </label>
        <% } %>
        <label class="form-group quick-profile-full">
          <span>Running groups</span>
          <input type="text" id="quickRunningGroups" name="runningGroupsText" value="<%= (formData.runningGroups || []).join(', ') %>" placeholder="Separate multiple groups with commas">
          <small>Optional. Separate multiple groups with commas.</small>
          <small class="error-text" data-error-for="runningGroups"></small>
        </label>
      </div>

      <p class="page-message page-message-error" id="quickProfileMessage" hidden></p>
      <div class="register-actions">
        <button type="button" class="btn btn-outline" id="quickProfileCancelBtn">Cancel</button>
        <button type="submit" class="btn btn-primary" id="quickProfileSaveBtn">Save Profile</button>
      </div>
    </form>
  </section>
</div>
