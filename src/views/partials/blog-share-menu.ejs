<%
  const shareId = String(instanceId || 'blog');
  const shareUrl = String(canonicalUrl || '');
  const shareTitle = String(articleTitle || 'HelloRun article');
  const encodedShareUrl = encodeURIComponent(shareUrl);
  const encodedShareTitle = encodeURIComponent(shareTitle);
  const wrapperClass = String(containerClass || '').trim();
  const summaryClass = String(triggerClass || 'btn btn-icon share-mobile-toggle').trim();
%>
<details class="blog-share-row<%= wrapperClass ? ` ${wrapperClass}` : '' %>" id="<%= shareId %>ShareRow" data-blog-share data-share-url="<%= shareUrl %>">
  <summary class="<%= summaryClass %>" id="<%= shareId %>ShareToggle" aria-label="<%= triggerLabel || 'Share this article' %>" aria-haspopup="menu" aria-controls="<%= shareId %>ShareOptions">
    <i data-lucide="share-2" aria-hidden="true"></i><span><%= triggerLabel || 'Share' %></span>
  </summary>
  <div class="share-options" id="<%= shareId %>ShareOptions" role="menu" aria-label="Share this article">
    <button type="button" class="btn btn-icon" id="<%= shareId %>CopyLinkBtn" data-copy-blog-link role="menuitem"><i data-lucide="link" aria-hidden="true"></i><span>Copy link</span></button>
    <a class="btn btn-icon" target="_blank" rel="noopener noreferrer" href="https://www.facebook.com/sharer/sharer.php?u=<%= encodedShareUrl %>" role="menuitem"><span class="blog-share-brand" aria-hidden="true">f</span><span>Facebook</span></a>
    <a class="btn btn-icon" target="_blank" rel="noopener noreferrer" href="https://twitter.com/intent/tweet?url=<%= encodedShareUrl %>&amp;text=<%= encodedShareTitle %>" role="menuitem"><span class="blog-share-brand" aria-hidden="true">X</span><span>X</span></a>
    <a class="btn btn-icon" target="_blank" rel="noopener noreferrer" href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodedShareUrl %>" role="menuitem"><span class="blog-share-brand" aria-hidden="true">in</span><span>LinkedIn</span></a>
    <a class="btn btn-icon" target="_blank" rel="noopener noreferrer" href="https://api.whatsapp.com/send?text=<%= encodedShareTitle %>%20<%= encodedShareUrl %>" role="menuitem"><i data-lucide="message-circle" aria-hidden="true"></i><span>WhatsApp</span></a>
    <a class="btn btn-icon" href="mailto:?subject=<%= encodedShareTitle %>&amp;body=<%= encodedShareUrl %>" role="menuitem"><i data-lucide="mail" aria-hidden="true"></i><span>Email</span></a>
  </div>
</details>
