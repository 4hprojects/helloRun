<%
  const privacyChoices = locals.cookiePreferences || {
    essential: true,
    functional: false,
    analytics: false,
    advertising: false,
    hasChoice: false,
    schemaVersion: 1
  };
%>
<script>
  window.HelloRunPrivacy = Object.freeze({
    essential: true,
    functional: <%= privacyChoices.functional ? 'true' : 'false' %>,
    analytics: <%= privacyChoices.analytics ? 'true' : 'false' %>,
    advertising: <%= privacyChoices.advertising ? 'true' : 'false' %>,
    hasChoice: <%= privacyChoices.hasChoice ? 'true' : 'false' %>,
    schemaVersion: <%= Number(privacyChoices.schemaVersion || 1) %>,
    canUse: function (category) { return category === 'essential' || this[category] === true; }
  });
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('consent', 'default', {
    analytics_storage: 'denied',
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied'
  });
  gtag('consent', 'update', {
    analytics_storage: window.HelloRunPrivacy.analytics ? 'granted' : 'denied',
    ad_storage: window.HelloRunPrivacy.advertising ? 'granted' : 'denied',
    ad_user_data: window.HelloRunPrivacy.advertising ? 'granted' : 'denied',
    ad_personalization: window.HelloRunPrivacy.advertising ? 'granted' : 'denied'
  });
</script>
