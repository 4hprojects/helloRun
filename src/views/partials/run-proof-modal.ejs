<%
  const isRunnerAuthenticated = Boolean(locals && locals.isAuthenticated && !locals.isAdmin && !locals.isOrganizer);
  const modalConfig = (locals && locals.runProofModalConfig) || {};
  const defaultMode = String(modalConfig.mode || 'submit').trim() || 'submit';
  const modalTitle = String(modalConfig.title || 'Submit Run').trim() || 'Submit Run';
  const submitLabel = String(modalConfig.submitLabel || 'Submit Run').trim() || 'Submit Run';
  const submitEndpoint = String(modalConfig.submitEndpoint || '').trim();
  const modalDescription = String(modalConfig.description || 'Submit your run details and proof image for review.').trim();
  const initialEvents = Array.isArray(modalConfig.initialEvents) ? modalConfig.initialEvents : [];
  const defaultSelectedEventIds = Array.isArray(modalConfig.defaultSelectedEventIds) ? modalConfig.defaultSelectedEventIds : [];
%>
<div
  class="run-proof-modal-backdrop"
  id="runProofModal"
  hidden
  aria-hidden="true"
  data-authenticated="<%= isRunnerAuthenticated ? '1' : '0' %>"
  data-login-url="/login"
  data-default-mode="<%= defaultMode %>"
  data-default-title="<%= modalTitle %>"
  data-default-description="<%= modalDescription %>"
  data-default-submit-label="<%= submitLabel %>"
  data-default-endpoint="<%= submitEndpoint %>"
>
  <section
    class="run-proof-modal-dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="runProofModalTitle"
    aria-describedby="runProofModalDesc"
    tabindex="-1"
  >
    <header class="run-proof-modal-header">
      <div class="run-proof-header-top">
        <div>
          <h2 id="runProofModalTitle"><%= modalTitle %></h2>
          <p class="run-proof-modal-desc" id="runProofModalDesc"><%= modalDescription %></p>
          <p class="run-proof-step-indicator" id="runProofStepIndicator">Step 1 of 2 &mdash; Upload your screenshot</p>
        </div>
        <div class="run-proof-header-actions">
          <button type="button" class="btn btn-outline run-proof-back-btn" id="runProofBackBtn" aria-label="Close" data-tooltip="Close">
            <i data-lucide="x" class="run-proof-btn-icon" aria-hidden="true"></i>
            <span class="run-proof-btn-text">Close</span>
          </button>
          <button
            type="submit"
            class="btn btn-primary"
            id="runProofSubmitBtn"
            form="runProofForm"
            data-default-label="<%= submitLabel %>"
            hidden
          ><%= submitLabel %></button>
        </div>
      </div>
    </header>

    <div class="run-proof-modal-body">
      <form id="runProofForm" method="POST" enctype="multipart/form-data" class="run-proof-form" novalidate>
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
        <input type="hidden" name="proofType" value="photo">
        <input type="hidden" id="runProofMode" name="modalMode" value="<%= defaultMode %>">
        <input type="hidden" id="runProofSelectedRegistrationIds" name="selectedRegistrationIds" value="">
        <input type="hidden" id="runProofPrimaryRegistrationId" name="registrationId" value="">
        <input type="hidden" id="runProofElapsedTime" name="elapsedTime" value="">
        <input type="hidden" id="runProofOcrDistance" name="ocrDistance" value="">
        <input type="hidden" id="runProofOcrTime" name="ocrTime" value="">
        <input type="hidden" id="runProofOcrRawText" name="ocrRawText" value="">
        <input type="hidden" id="runProofOcrConfidence" name="ocrConfidence" value="">
        <input type="hidden" id="runProofOcrDistanceMismatch" name="ocrDistanceMismatch" value="">
        <input type="hidden" id="runProofOcrTimeMismatch" name="ocrTimeMismatch" value="">
        <input type="hidden" id="runProofImageHash" name="proofImageHash" value="">

        <div id="runProofStep1">
          <section class="run-proof-section" aria-labelledby="runProofSectionMedia">
            <div class="run-proof-section-heading">
              <h3 id="runProofSectionMedia">Upload Screenshot</h3>
              <span class="run-proof-required-tag">Required</span>
            </div>
            <div class="run-proof-upload" id="runProofUploadDropzone" tabindex="0" role="button" aria-label="Upload proof image">
              <input id="runProofImage" name="resultProofFile" type="file" accept="image/jpeg,image/png" required>
              <div class="run-proof-upload-initial" id="runProofUploadInitial">
                <i data-lucide="image" class="run-proof-upload-icon" aria-hidden="true"></i>
                <strong>Drop image here or click to upload</strong>
                <small>JPG or PNG, up to 5MB</small>
              </div>
              <div class="run-proof-upload-preview" id="runProofUploadPreview" hidden>
                <img id="runProofPreviewImage" alt="Run proof preview">
                <div class="run-proof-upload-actions">
                  <button type="button" class="btn btn-outline" id="runProofReplaceImageBtn">Replace</button>
                  <button type="button" class="btn btn-outline" id="runProofRemoveImageBtn">Remove</button>
                </div>
              </div>
            </div>
            <p class="run-proof-field-error" id="runProofImageError" aria-live="polite"></p>
            <p class="run-proof-ocr-status" id="runProofOcrStatus" hidden aria-live="polite">Analysing image...</p>
          </section>
          <div class="run-proof-analyse-row">
            <button type="button" class="btn btn-primary" id="runProofAnalyseBtn" disabled>Submit Screenshot</button>
            <p class="run-proof-analyse-hint" id="runProofAnalyseHint" hidden>Upload a screenshot to enable analysis</p>
          </div>
        </div>

        <div id="runProofStep2" hidden>
          <p class="run-proof-autofill-banner" id="runProofAutoFillBanner" hidden role="status">Auto-filled from your screenshot. Review and adjust if needed.</p>
          <div class="run-proof-ocr-results" id="runProofOcrResults" hidden aria-live="polite">
            <span class="run-proof-detected-source" id="runProofDetectedSource" hidden></span>
          </div>
          <div class="run-proof-ocr-warning" id="runProofOcrWarning" hidden role="alert"></div>

          <section class="run-proof-section" aria-labelledby="runProofSectionEvents">
            <div class="run-proof-section-heading">
              <h3 id="runProofSectionEvents">Event Selection</h3>
              <span class="run-proof-required-tag">Required</span>
            </div>
            <p class="run-proof-helper" id="runProofEventsHelper">Select the event result you want to submit. Personal record stays selected by default.</p>

            <div class="run-proof-event-list" id="runProofEventsList" role="group" aria-describedby="runProofEventsError">
              <label class="run-proof-event-card is-locked" for="runProofPersonalRecord">
                <span class="run-proof-event-main">
                  <input id="runProofPersonalRecord" type="checkbox" checked disabled aria-disabled="true">
                  <span>
                    <strong>Personal Record</strong>
                    <small>Always included in your run log</small>
                  </span>
                </span>
                <span class="run-proof-event-pill">Default</span>
              </label>
            </div>
            <p class="run-proof-field-error" id="runProofEventsError" aria-live="polite"></p>
          </section>

          <section class="run-proof-section" aria-labelledby="runProofSectionType">
            <div class="run-proof-section-heading">
              <h3 id="runProofSectionType">Run Classification</h3>
              <span class="run-proof-required-tag">Required</span>
            </div>
            <div class="run-proof-chip-list" id="runProofTypeChips" role="radiogroup" aria-describedby="runProofRunTypeError">
              <button type="button" class="run-proof-chip" role="radio" aria-checked="false" data-run-type="run">Run</button>
              <button type="button" class="run-proof-chip" role="radio" aria-checked="false" data-run-type="walk">Walk</button>
              <button type="button" class="run-proof-chip" role="radio" aria-checked="false" data-run-type="hike">Hike</button>
              <button type="button" class="run-proof-chip" role="radio" aria-checked="false" data-run-type="trail_run">Trail Run</button>
            </div>
            <input type="hidden" id="runProofRunType" name="runType" value="">
            <p class="run-proof-field-error" id="runProofRunTypeError" aria-live="polite"></p>
          </section>

          <section class="run-proof-section" aria-labelledby="runProofSectionDetails">
            <div class="run-proof-section-heading">
              <h3 id="runProofSectionDetails">Run Details</h3>
            </div>

            <div class="run-proof-field run-proof-field-row" data-field-wrapper="runDate">
              <label for="runProofDate">Date</label>
              <div class="run-proof-field-row-input">
                <input id="runProofDate" name="runDate" type="date" required>
                <p class="run-proof-field-error" id="runProofDateError" aria-live="polite"></p>
              </div>
            </div>

            <div class="run-proof-field run-proof-field-row" data-field-wrapper="distanceKm">
              <label for="runProofDistanceKm">Distance (km)</label>
              <div class="run-proof-field-row-input">
                <input id="runProofDistanceKm" name="distanceKm" type="number" min="0.1" max="500" step="0.01" placeholder="5.00" required>
                <p class="run-proof-field-error" id="runProofDistanceError" aria-live="polite"></p>
              </div>
            </div>

            <fieldset class="run-proof-duration" data-field-wrapper="elapsedTime">
              <legend>Duration (hh mm ss)</legend>
              <div class="run-proof-duration-grid">
                <div class="run-proof-duration-cell">
                  <label for="runProofHours">Hours</label>
                  <div class="run-proof-duration-input-wrap">
                    <input id="runProofHours" type="text" inputmode="numeric" maxlength="2" placeholder="00" autocomplete="off" required>
                    <span class="run-proof-duration-unit" aria-hidden="true">hr</span>
                  </div>
                </div>
                <div class="run-proof-duration-cell">
                  <label for="runProofMinutes">Minutes</label>
                  <div class="run-proof-duration-input-wrap">
                    <input id="runProofMinutes" type="text" inputmode="numeric" maxlength="2" placeholder="30" autocomplete="off" required>
                    <span class="run-proof-duration-unit" aria-hidden="true">min</span>
                  </div>
                </div>
                <div class="run-proof-duration-cell">
                  <label for="runProofSeconds">Seconds</label>
                  <div class="run-proof-duration-input-wrap">
                    <input id="runProofSeconds" type="text" inputmode="numeric" maxlength="2" placeholder="00" autocomplete="off" required>
                    <span class="run-proof-duration-unit" aria-hidden="true">sec</span>
                  </div>
                </div>
              </div>
              <p class="run-proof-field-error" id="runProofDurationError" aria-live="polite"></p>
            </fieldset>

            <div class="run-proof-field run-proof-field-row" data-field-wrapper="runLocation">
              <label for="runProofLocation">Location</label>
              <div class="run-proof-field-row-input">
                <input id="runProofLocation" name="runLocation" type="text" maxlength="200" placeholder="City, route, or venue" required>
                <p class="run-proof-field-error" id="runProofLocationError" aria-live="polite"></p>
              </div>
            </div>

            <div class="run-proof-field run-proof-field-row" data-field-wrapper="elevationGain">
              <label for="runProofElevationGain">Elevation Gain (m)</label>
              <div class="run-proof-field-row-input">
                <input id="runProofElevationGain" name="elevationGain" type="number" min="0" max="20000" step="1" placeholder="Optional">
              </div>
            </div>

            <div class="run-proof-field run-proof-field-row" data-field-wrapper="steps">
              <label for="runProofSteps">Steps</label>
              <div class="run-proof-field-row-input">
                <input id="runProofSteps" name="steps" type="number" min="0" max="200000" step="1" placeholder="Optional">
              </div>
            </div>
          </section>

          <div class="run-proof-submit-row">
            <button
              type="submit"
              class="btn btn-primary run-proof-submit-inline-btn"
              id="runProofSubmitInlineBtn"
              form="runProofForm"
              data-default-label="<%= submitLabel %>"
              aria-label="<%= submitLabel %>"
              aria-busy="false"
            ><%= submitLabel %></button>
          </div>
        </div>

        <p class="run-proof-message" id="runProofMessage" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <!-- Close / discard confirmation dialog — uses the app modal template -->
  <div class="run-proof-close-confirm" id="runProofCloseConfirm" hidden>
    <div class="run-proof-close-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="runProofCloseConfirmTitle" aria-describedby="runProofCloseConfirmDesc" tabindex="-1">
      <h3 id="runProofCloseConfirmTitle">Discard submission?</h3>
      <p id="runProofCloseConfirmDesc">Your upload and any details you've entered will be lost.</p>
      <div class="run-proof-close-confirm-actions">
        <button type="button" class="btn btn-outline" id="runProofCloseConfirmCancel">Keep editing</button>
        <button type="button" class="btn btn-danger" id="runProofCloseConfirmOk">Discard and close</button>
      </div>
    </div>
  </div>
</div>

<script id="runProofModalInitialData" type="application/json"><%- JSON.stringify({
  mode: defaultMode,
  title: modalTitle,
  description: modalDescription,
  submitLabel,
  submitEndpoint,
  initialEvents,
  defaultSelectedEventIds
}) %></script>
