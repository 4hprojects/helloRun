<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error - HelloRun</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/project-buttons.css">
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
  <%- include('./layouts/nav') %>
  
  <main class="error-page">
    <div class="error-container">
      <div class="error-card">
        <div class="error-icon">
          <i data-lucide="alert-triangle"></i>
        </div>
        <p class="error-status">Error <%= status || '' %></p>
        <h1><%= locals.heading || 'Something went wrong' %></h1>
        <p class="error-message"><%= message || 'Something went wrong' %></p>
        <% if (locals.detail) { %>
          <p class="error-guidance"><%= detail %></p>
        <% } %>
        
        <% if (locals.error && process.env.NODE_ENV === 'development') { %>
          <div class="error-details">
            <pre><%= error.stack %></pre>
          </div>
        <% } %>
        
        <div class="error-actions">
          <a href="<%= locals.actionHref || '/' %>" class="btn btn-full"><%= locals.actionLabel || 'Go to Homepage' %></a>
          <% if ((locals.actionHref || '/') !== '/') { %>
            <a href="/" class="btn btn-secondary btn-full">Go to Homepage</a>
          <% } %>
        </div>
      </div>
    </div>
  </main>
  
  <%- include('./layouts/footer') %>
  
  <script src="/js/main.js"></script>
  <script>
    lucide.createIcons();
  </script>
</body>
</html>
