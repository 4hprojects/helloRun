<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/organizer-events.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="events-page organizer-registrants-page">
    <section class="events-shell">
      <header class="events-header">
        <div class="registrants-header-content">
          <h1>Registrants: <%= event.title %></h1>
          <div class="registrants-header-meta">
            <p>View participants registered for this event.</p>
            <div class="header-actions">
              <a href="/organizer/events/<%= event._id %>/registrants/export<%= exportQuery ? `?${exportQuery}` : '' %>" class="nav-login-btn registrant-header-btn registrant-toolbar-btn registrant-toolbar-btn-secondary" aria-label="Export CSV" data-tooltip="Export CSV" title="Export CSV">
                <i data-lucide="file-down" aria-hidden="true"></i>
              </a>
              <a href="/organizer/events/<%= event._id %>/registrants/export-xlsx<%= exportQuery ? `?${exportQuery}` : '' %>" class="nav-login-btn registrant-header-btn registrant-toolbar-btn registrant-toolbar-btn-secondary" aria-label="Export XLSX" data-tooltip="Export XLSX" title="Export XLSX">
                <i data-lucide="sheet" aria-hidden="true"></i>
              </a>
              <% if (!isAdminViewer && (summary.unpaidCount || (summary.proofRejectedCount))) { %>
                <% const unpaidTotal = (summary.unpaidCount || 0) + (summary.proofRejectedCount || 0); %>
                <button type="button" class="nav-login-btn registrant-header-btn registrant-toolbar-btn registrant-toolbar-btn-secondary" id="js-email-unpaid-btn" data-unpaid-count="<%= unpaidTotal %>" data-event-title="<%= event.title %>" aria-label="Email Unpaid Runners" data-tooltip="Email Unpaid" title="Email <%= unpaidTotal %> unpaid runner<%= unpaidTotal !== 1 ? 's' : ''%>">
                  <i data-lucide="mail" aria-hidden="true"></i>
                </button>
              <% } %>
              <% if (isAdminViewer) { %>
                <a href="/admin/dashboard" class="nav-login-btn registrant-header-btn registrant-toolbar-btn registrant-toolbar-btn-primary" aria-label="Admin Dashboard" data-tooltip="Admin Dashboard" title="Admin Dashboard">
                  <i data-lucide="layout-dashboard" aria-hidden="true"></i>
                </a>
              <% } else { %>
                <a href="/organizer/events/<%= event._id %>" class="nav-login-btn registrant-header-btn registrant-toolbar-btn registrant-toolbar-btn-primary" aria-label="Back to Event" data-tooltip="Back to Event" title="Back to Event">
                  <i data-lucide="arrow-left" aria-hidden="true"></i>
                </a>
                <a href="/organizer/events" class="nav-login-btn registrant-header-btn registrant-toolbar-btn registrant-toolbar-btn-secondary" aria-label="My Events" data-tooltip="My Events" title="My Events">
                  <i data-lucide="calendar-days" aria-hidden="true"></i>
                </a>
              <% } %>
            </div>
          </div>
        </div>
      </header>

      <% if (message) { %>
        <div class="page-message page-message-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <section class="registrant-summary">
        <div class="summary-card">
          <strong>Total Registrants</strong>
          <span><%= summary.totalRegistrants %></span>
        </div>
        <div class="summary-card">
          <strong>Virtual</strong>
          <span><%= summary.virtualCount %></span>
        </div>
        <div class="summary-card">
          <strong>On-site</strong>
          <span><%= summary.onsiteCount %></span>
        </div>
        <div class="summary-card">
          <strong>Payment Receipts Submitted</strong>
          <span><%= summary.proofSubmittedCount %></span>
        </div>
        <div class="summary-card">
          <strong>Paid</strong>
          <span><%= summary.paidCount %></span>
        </div>
        <div class="summary-card">
          <strong>Payment Receipts Rejected</strong>
          <span><%= summary.proofRejectedCount %></span>
        </div>
        <div class="summary-card">
          <strong>Run Results Submitted</strong>
          <span><%= summary.submissionSubmittedCount %></span>
        </div>
        <div class="summary-card">
          <strong>Run Results Approved</strong>
          <span><%= summary.submissionApprovedCount %></span>
        </div>
        <div class="summary-card">
          <strong>Run Results Rejected</strong>
          <span><%= summary.submissionRejectedCount %></span>
        </div>
      </section>

      <form method="GET" action="/organizer/events/<%= event._id %>/registrants" class="filter-bar registrant-filter-bar" data-registrant-filter-form>
        <div class="registrant-search-field">
          <label for="q">Search registrants</label>
          <div class="registrant-search-control">
            <input id="q" name="q" type="search" placeholder="Code, name, email, group, emergency contact" value="<%= searchQuery || '' %>">
            <button type="submit" class="nav-signup-btn registrant-search-btn">Search</button>
          </div>
        </div>

        <div class="registrant-filter-fields">
          <div class="registrant-filter-field">
            <label for="mode">Mode</label>
            <select id="mode" name="mode" data-auto-submit-filter>
              <option value="" <%= !selectedMode ? 'selected' : '' %>>All modes</option>
              <option value="virtual" <%= selectedMode === 'virtual' ? 'selected' : '' %>>Virtual</option>
              <option value="onsite" <%= selectedMode === 'onsite' ? 'selected' : '' %>>On-site</option>
            </select>
          </div>

          <div class="registrant-filter-field">
            <label for="distance">Distance</label>
            <select id="distance" name="distance" data-auto-submit-filter>
              <option value="" <%= !selectedDistance ? 'selected' : '' %>>All distances</option>
              <% (eventRaceDistances || []).forEach((distance) => { %>
                <option value="<%= distance %>" <%= selectedDistance === distance ? 'selected' : '' %>><%= distance %></option>
              <% }) %>
            </select>
          </div>

          <div class="registrant-filter-field">
            <label for="payment">Payment</label>
            <select id="payment" name="payment" data-auto-submit-filter>
              <option value="" <%= !selectedPaymentStatus ? 'selected' : '' %>>All payments</option>
              <option value="unpaid" <%= selectedPaymentStatus === 'unpaid' ? 'selected' : '' %>>Unpaid</option>
              <option value="proof_submitted" <%= selectedPaymentStatus === 'proof_submitted' ? 'selected' : '' %>>Payment Receipt Submitted</option>
              <option value="proof_rejected" <%= selectedPaymentStatus === 'proof_rejected' ? 'selected' : '' %>>Payment Receipt Rejected</option>
              <option value="paid" <%= selectedPaymentStatus === 'paid' ? 'selected' : '' %>>Paid</option>
              <option value="failed" <%= selectedPaymentStatus === 'failed' ? 'selected' : '' %>>Failed</option>
              <option value="refunded" <%= selectedPaymentStatus === 'refunded' ? 'selected' : '' %>>Refunded</option>
            </select>
          </div>

          <div class="registrant-filter-field">
            <label for="result">Run Result</label>
            <select id="result" name="result" data-auto-submit-filter>
              <option value="" <%= !selectedResultStatus ? 'selected' : '' %>>All results</option>
              <option value="submitted" <%= selectedResultStatus === 'submitted' ? 'selected' : '' %>>Submitted</option>
              <option value="approved" <%= selectedResultStatus === 'approved' ? 'selected' : '' %>>Approved</option>
              <option value="rejected" <%= selectedResultStatus === 'rejected' ? 'selected' : '' %>>Rejected</option>
            </select>
          </div>

          <a href="/organizer/events/<%= event._id %>/registrants" class="nav-login-btn registrant-filter-reset registrant-reset-btn">Reset</a>
        </div>
      </form>

      <% if (selectedPaymentStatus === 'proof_submitted') { %>
        <div class="page-message page-message-warning">
          Review payment receipts only in this queue. If the uploaded file is an activity screenshot or run result, reject it and ask the runner to submit it through Run Result after payment is verified.
          <a href="/organizer/events/<%= event._id %>/payment-proofs/review">Open focused payment-proof review page</a>
        </div>
      <% } %>

      <% if (selectedResultStatus === 'submitted') { %>
        <div class="page-message page-message-warning">
          Use the focused Run Proof Review queue to check each submitted proof, activity evidence, and validation signal.
          <a href="/organizer/events/<%= event._id %>/run-proofs/review">Open Run Proof Review</a>
        </div>
      <% } %>

      <% if (registrations && registrations.length) { %>
        <div class="registrants-table-toolbar">
          <span>Showing <strong><%= registrations.length %></strong> of <strong><%= pagination.totalItems %></strong> registrant<%= pagination.totalItems === 1 ? '' : 's' %></span>
          <div class="registrant-column-menu" data-registrant-column-menu>
            <button type="button" class="nav-login-btn registrant-columns-btn" id="registrantColumnsMenuBtn" aria-expanded="false" aria-controls="registrantColumnsMenu">
              <i data-lucide="columns-3" aria-hidden="true"></i>
              Columns
              <span class="registrant-column-count" id="registrantColumnCount">11</span>
            </button>
            <div class="registrant-column-menu-panel" id="registrantColumnsMenu" hidden>
              <label><input type="checkbox" data-registrant-column-toggle="confirmation"> Confirmation</label>
              <label><input type="checkbox" data-registrant-column-toggle="name" checked> Name</label>
              <label><input type="checkbox" data-registrant-column-toggle="email" checked> Email</label>
              <label><input type="checkbox" data-registrant-column-toggle="mobile"> Mobile</label>
              <label><input type="checkbox" data-registrant-column-toggle="country" checked> Country</label>
              <label><input type="checkbox" data-registrant-column-toggle="age" checked> Age</label>
              <label><input type="checkbox" data-registrant-column-toggle="gender" checked> Gender</label>
              <label><input type="checkbox" data-registrant-column-toggle="emergencyContact"> Emergency Contact</label>
              <label><input type="checkbox" data-registrant-column-toggle="runningGroup" checked> Running Group</label>
              <label><input type="checkbox" data-registrant-column-toggle="waiver"> Waiver</label>
              <label><input type="checkbox" data-registrant-column-toggle="mode"> Mode</label>
              <label><input type="checkbox" data-registrant-column-toggle="distance" checked> Distance</label>
              <label><input type="checkbox" data-registrant-column-toggle="status" checked> Status</label>
              <label><input type="checkbox" data-registrant-column-toggle="payment" checked> Payment</label>
              <label><input type="checkbox" data-registrant-column-toggle="expectedPayment"> Expected Payment</label>
              <label><input type="checkbox" data-registrant-column-toggle="paymentReceipt"> Payment Receipt</label>
              <label><input type="checkbox" data-registrant-column-toggle="paymentReview"> Payment Review</label>
              <label><input type="checkbox" data-registrant-column-toggle="runResult" checked> Run Result</label>
              <label><input type="checkbox" data-registrant-column-toggle="runResultEvidence"> Run Result Evidence</label>
              <label><input type="checkbox" data-registrant-column-toggle="runResultReview"> Run Result Review</label>
              <label><input type="checkbox" data-registrant-column-toggle="registeredAt" checked> Registered At</label>
              <button type="button" class="registrant-column-reset" data-registrant-column-reset>Reset columns</button>
            </div>
          </div>
        </div>
        <div class="registrants-table-wrap">
          <table class="registrants-table">
            <thead>
              <tr>
                <th data-registrant-column="confirmation" class="is-column-hidden">Confirmation</th>
                <th data-registrant-column="name">Name</th>
                <th data-registrant-column="email">Email</th>
                <th data-registrant-column="mobile" class="is-column-hidden">Mobile</th>
                <th data-registrant-column="country">Country</th>
                <th data-registrant-column="age">Age</th>
                <th data-registrant-column="gender">Gender</th>
                <th data-registrant-column="emergencyContact" class="is-column-hidden">Emergency Contact</th>
                <th data-registrant-column="runningGroup">Running Group</th>
                <th data-registrant-column="waiver" class="is-column-hidden">Waiver</th>
                <th data-registrant-column="mode" class="is-column-hidden">Mode</th>
                <th data-registrant-column="distance">Distance</th>
                <th data-registrant-column="status">Status</th>
                <th data-registrant-column="payment">Payment</th>
                <th data-registrant-column="expectedPayment" class="is-column-hidden">Expected Payment</th>
                <th data-registrant-column="paymentReceipt" class="is-column-hidden">Payment Receipt</th>
                <th data-registrant-column="paymentReview" class="is-column-hidden">Review</th>
                <th data-registrant-column="runResult">Run Result</th>
                <th data-registrant-column="runResultEvidence" class="is-column-hidden">Run Result Evidence</th>
                <th data-registrant-column="runResultReview" class="is-column-hidden">Run Result Review</th>
                <th data-registrant-column="registeredAt">Registered At</th>
              </tr>
            </thead>
            <tbody>
              <% registrations.forEach((registration) => { %>
                <%
                  const selectedRaceCategoryName = registration.pricingSnapshot?.raceCategoryName || '';
                  const selectedRaceCategoryType = registration.pricingSnapshot?.raceCategoryType || '';
                %>
                <tr>
                  <td data-registrant-column="confirmation" class="is-column-hidden"><code><%= registration.confirmationCode %></code></td>
                  <td data-registrant-column="name"><%= [registration.participant?.firstName, registration.participant?.lastName].filter(Boolean).join(' ') || 'N/A' %></td>
                  <td data-registrant-column="email"><%= registration.participant?.email || 'N/A' %></td>
                  <td data-registrant-column="mobile" class="is-column-hidden"><%= registration.participant?.mobile || 'N/A' %></td>
                  <td data-registrant-column="country"><%= registration.participant?.countryLabel || registration.participant?.country || 'N/A' %></td>
                  <td data-registrant-column="age"><%= registration.participant?.ageLabel || 'N/A' %></td>
                  <td data-registrant-column="gender"><%= registration.participant?.genderLabel || 'N/A' %></td>
                  <td data-registrant-column="emergencyContact" class="is-column-hidden">
                    <%= registration.participant?.emergencyContactName || 'N/A' %>
                    <% if (registration.participant?.emergencyContactNumber) { %>
                      <br>
                      <small><%= registration.participant.emergencyContactNumber %></small>
                    <% } %>
                  </td>
                  <td data-registrant-column="runningGroup"><%= registration.participant?.runningGroup || 'N/A' %></td>
                  <td data-registrant-column="waiver" class="is-column-hidden">
                    v<%= registration.waiver?.version || 'N/A' %>
                    <br>
                    <small><%= registration.waiver?.signature || 'No signature' %></small>
                    <% if (registration.waiverAcceptedAtLabel) { %>
                      <br>
                      <small><%= registration.waiverAcceptedAtLabel %></small>
                    <% } %>
                  </td>
                  <td data-registrant-column="mode" class="is-column-hidden"><span class="mode-badge mode-<%= registration.participationMode %>"><%= registration.participationMode %></span></td>
                  <td data-registrant-column="distance">
                    <%= selectedRaceCategoryName || registration.raceDistance || 'N/A' %>
                    <% if (selectedRaceCategoryName && registration.raceDistance && selectedRaceCategoryName !== registration.raceDistance) { %>
                      <br>
                      <small><%= registration.raceDistance %></small>
                    <% } %>
                    <% if (selectedRaceCategoryType) { %>
                      <br>
                      <small><%= selectedRaceCategoryType %></small>
                    <% } %>
                  </td>
                  <td data-registrant-column="status"><%= registration.status %></td>
                  <td data-registrant-column="payment"><%= registration.paymentStatus || 'N/A' %></td>
                  <td data-registrant-column="expectedPayment" class="is-column-hidden">
                    <%= registration.expectedPaymentLabel || 'N/A' %>
                    <% if (registration.pricingSnapshot?.packageName) { %>
                      <br>
                      <small><%= registration.pricingSnapshot.packageName %></small>
                    <% } %>
                    <% if (registration.signupOptionLabel) { %>
                      <br>
                      <small><%= registration.signupOptionLabel %></small>
                    <% } %>
                    <% if (registration.pricingPeriodLabel) { %>
                      <br>
                      <small><%= registration.pricingPeriodLabel %></small>
                    <% } %>
                  </td>
                  <td data-registrant-column="paymentReceipt" class="is-column-hidden">
                    <% if (registration.paymentProof && registration.paymentProof.url) { %>
                      <a href="<%= registration.paymentProof.url %>" target="_blank" rel="noopener noreferrer" class="proof-link">View payment receipt</a>
                      <% if (registration.paymentProofUploadedAtLabel) { %>
                        <br>
                        <small><%= registration.paymentProofUploadedAtLabel %></small>
                      <% } %>
                      <br>
                      <small><strong>Confirmation:</strong> <%= registration.confirmationCode %></small>
                      <% if (registration.expectedPaymentLabel) { %>
                        <br>
                        <small><strong>Expected payment:</strong> <%= registration.expectedPaymentLabel %></small>
                      <% } %>
                      <% if (event.paymentAccountName) { %>
                        <br>
                        <small><strong>Payee:</strong> <%= event.paymentAccountName %></small>
                      <% } %>
                      <% if (event.paymentInstructions) { %>
                        <br>
                        <small><strong>Instructions:</strong> <%= event.paymentInstructions %></small>
                      <% } %>
                    <% } else { %>
                      <span>N/A</span>
                    <% } %>
                  </td>
                  <td data-registrant-column="paymentReview" class="is-column-hidden">
                    <% if (registration.paymentStatus === 'proof_submitted') { %>
                      <small class="rejection">Reject activity screenshots here. This queue is only for payment receipts.</small>
                      <form method="POST" action="/organizer/events/<%= event._id %>/registrants/<%= registration._id %>/payment/approve" class="payment-action-form">
                        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
                        <textarea name="reviewNotes" rows="2" maxlength="1000" placeholder="Optional review notes"></textarea>
                        <button type="submit" class="nav-signup-btn table-action-btn registrant-row-btn registrant-row-btn-approve">Approve</button>
                      </form>
                      <form method="POST" action="/organizer/events/<%= event._id %>/registrants/<%= registration._id %>/payment/reject" class="payment-action-form">
                        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
                        <textarea name="rejectionReason" rows="2" maxlength="500" required placeholder="Required rejection reason"></textarea>
                        <textarea name="reviewNotes" rows="2" maxlength="1000" placeholder="Optional review notes"></textarea>
                        <button type="submit" class="nav-login-btn table-action-btn registrant-row-btn registrant-row-btn-reject">Reject</button>
                      </form>
                    <% } else { %>
                      <% if (registration.paymentReviewedAtLabel) { %>
                        <small>Reviewed: <%= registration.paymentReviewedAtLabel %></small>
                      <% } else { %>
                        <small>No pending action</small>
                      <% } %>
                      <% if (registration.paymentRejectionReason) { %>
                        <br>
                        <small>Reason: <%= registration.paymentRejectionReason %></small>
                      <% } %>
                      <% if (registration.paymentReviewNotes) { %>
                        <br>
                        <small>Notes: <%= registration.paymentReviewNotes %></small>
                      <% } %>
                    <% } %>
                  </td>
                  <td data-registrant-column="runResult">
                    <% if (registration.accumulatedProgress) { %>
                      <small><strong>Progress:</strong> <%= registration.accumulatedProgress.progressLabel %></small>
                      <br>
                      <small><strong>Activity counts:</strong> <%= registration.accumulatedProgress.approvedActivityCount %> approved, <%= registration.accumulatedProgress.pendingActivityCount %> pending, <%= registration.accumulatedProgress.rejectedActivityCount %> rejected</small>
                    <% } else if (registration.submission) { %>
                      <span class="mode-badge mode-<%= registration.submission.status %>"><%= registration.submission.isAccumulatedActivity ? 'activity ' : '' %><%= registration.submission.status %></span>
                      <% if (registration.submission.suspiciousFlag) { %>
                        <span class="mode-badge mode-warning" title="<%= registration.submission.reviewSignal?.description || registration.submission.suspiciousFlagReason %>">&#9888; <%= registration.submission.reviewSignal?.label || 'Suspicious' %></span>
                      <% } else if (registration.submission.reviewSignal && registration.submission.reviewSignal.label) { %>
                        <span class="mode-badge mode-warning" title="<%= registration.submission.reviewSignal.description || '' %>">&#9888; <%= registration.submission.reviewSignal.label %></span>
                      <% } %>
                      <% if (registration.submission.ocrData && (registration.submission.ocrData.distanceMismatch || registration.submission.ocrData.timeMismatch)) { %>
                        <span class="mode-badge mode-warning" title="OCR detected possible mismatch">&#9888; Mismatch</span>
                      <% } %>
                      <br>
                      <small><strong>Distance:</strong> <%= Number(registration.submission.distanceKm || 0).toFixed(2) %> km</small>
                      <br>
                      <small><strong>Elapsed:</strong> <%= registration.submission.elapsedLabel || 'N/A' %></small>
                      <br>
                      <small><strong>Run date:</strong> <%= registration.submission.runDateLabel || 'N/A' %></small>
                      <br>
                      <small><strong>Run location:</strong> <%= registration.submission.runLocation || 'N/A' %></small>
                      <br>
                      <small><strong>Run type:</strong> <%= String(registration.submission.runType || 'run').replace('_', ' ') %></small>
                      <br>
                      <small><strong>Evidence type:</strong> <%= String(registration.submission.proofType || 'manual').toUpperCase() %></small>
                      <% if (registration.submission.elevationGain != null) { %>
                        <br>
                        <small><strong>Elevation:</strong> <%= registration.submission.elevationGain %> m</small>
                      <% } %>
                      <% if (registration.submission.submittedAtLabel) { %>
                        <br>
                        <small><strong>Submitted:</strong> <%= registration.submission.submittedAtLabel %></small>
                      <% } %>
                      <% if (registration.submission.suspiciousFlag) { %>
                        <br>
                        <details class="ocr-analysis-details">
                          <summary><strong>&#9888; <%= registration.submission.reviewSignal?.label || 'Suspicious activity flag' %></strong></summary>
                          <div class="ocr-analysis-body">
                            <% if (registration.submission.reviewSignal?.description) { %>
                              <small><%= registration.submission.reviewSignal.description %></small><br>
                            <% } %>
                            <small><%= registration.submission.suspiciousFlagReason %></small>
                          </div>
                        </details>
                      <% } %>
                      <% if (registration.submission.ocrData && registration.submission.ocrData.confidence > 0) { %>
                        <br>
                        <details class="ocr-analysis-details">
                          <summary><strong>OCR Analysis</strong> (confidence: <%= Math.round((registration.submission.ocrData.confidence || 0) * 100) %>%)</summary>
                          <div class="ocr-analysis-body">
                            <% if (registration.submission.ocrData.extractedDistanceKm != null) { %>
                              <small><strong>Image distance:</strong> <%= Number(registration.submission.ocrData.extractedDistanceKm).toFixed(2) %> km
                                <% if (registration.submission.ocrData.distanceMismatch) { %>
                                  <span class="ocr-mismatch-flag">&#9888; mismatch vs <%= Number(registration.submission.distanceKm || 0).toFixed(2) %> km entered</span>
                                <% } else { %>
                                  <span class="ocr-match-flag">&#10003; matches</span>
                                <% } %>
                              </small><br>
                            <% } %>
                            <% if (registration.submission.ocrData.extractedTimeMs != null) { %>
                              <small><strong>Image time:</strong> <%= registration.submission.ocrTimeLabel || 'N/A' %>
                                <% if (registration.submission.ocrData.timeMismatch) { %>
                                  <span class="ocr-mismatch-flag">&#9888; mismatch vs <%= registration.submission.elapsedLabel || 'N/A' %> entered</span>
                                <% } else { %>
                                  <span class="ocr-match-flag">&#10003; matches</span>
                                <% } %>
                              </small><br>
                            <% } %>
                            <% if (registration.submission.ocrData.extractedElevationGain != null) { %>
                              <small><strong>Image elevation:</strong> <%= registration.submission.ocrData.extractedElevationGain %> m
                                <% if (registration.submission.ocrData.elevationMismatch) { %>
                                  <span class="ocr-mismatch-flag">&#9888; mismatch vs <%= registration.submission.elevationGain != null ? registration.submission.elevationGain + ' m' : 'not entered' %></span>
                                <% } else { %>
                                  <span class="ocr-match-flag">&#10003; matches</span>
                                <% } %>
                              </small><br>
                            <% } %>
                            <% if (registration.submission.ocrData.extractedSteps != null) { %>
                              <small><strong>Image steps:</strong> <%= Number(registration.submission.ocrData.extractedSteps || 0).toLocaleString() %>
                                <% if (registration.submission.ocrData.stepsMismatch) { %>
                                  <span class="ocr-mismatch-flag">&#9888; mismatch vs <%= registration.submission.steps != null ? Number(registration.submission.steps || 0).toLocaleString() : 'not entered' %></span>
                                <% } else { %>
                                  <span class="ocr-match-flag">&#10003; matches</span>
                                <% } %>
                              </small><br>
                            <% } %>
                            <% if (registration.submission.ocrData.extractedRunDate) { %>
                              <small><strong>Image date:</strong> <%= registration.submission.ocrData.extractedRunDate %>
                                <% if (registration.submission.ocrData.dateMismatch) { %>
                                  <span class="ocr-mismatch-flag">&#9888; mismatch vs submitted date</span>
                                <% } else { %>
                                  <span class="ocr-match-flag">&#10003; matches</span>
                                <% } %>
                              </small><br>
                            <% } %>
                            <% if (registration.submission.ocrData.extractedRunType) { %>
                              <small><strong>Image activity type:</strong> <%= String(registration.submission.ocrData.extractedRunType).replace('_', ' ') %>
                                <% if (registration.submission.ocrData.runTypeMismatch) { %>
                                  <span class="ocr-mismatch-flag">&#9888; mismatch vs <%= String(registration.submission.runType || 'run').replace('_', ' ') %></span>
                                <% } else { %>
                                  <span class="ocr-match-flag">&#10003; matches</span>
                                <% } %>
                              </small><br>
                            <% } %>
                            <% if (registration.submission.ocrData.extractedRunLocation) { %>
                              <small><strong>Image location:</strong> <%= registration.submission.ocrData.extractedRunLocation %>
                                <% if (registration.submission.ocrData.locationMismatch) { %>
                                  <span class="ocr-mismatch-flag">&#9888; mismatch vs submitted location</span>
                                <% } else { %>
                                  <span class="ocr-match-flag">&#10003; similar</span>
                                <% } %>
                              </small><br>
                            <% } %>
                            <% if (registration.submission.ocrData.nameMatchStatus && registration.submission.ocrData.nameMatchStatus !== 'not_checked') { %>
                              <small><strong>Name analysis:</strong>
                                <% if (registration.submission.ocrData.nameMatchStatus === 'matched') { %>
                                  <span class="ocr-match-flag">&#10003; matches account</span>
                                <% } else if (registration.submission.ocrData.nameMatchStatus === 'mismatched') { %>
                                  <span class="ocr-mismatch-flag">&#9888; different name detected</span>
                                <% } else if (registration.submission.ocrData.nameMatchStatus === 'not_detected') { %>
                                  <span class="text-muted">name not detected</span>
                                <% } %>
                                <% if (registration.submission.ocrData.extractedName) { %>
                                  <span class="text-muted">(<%= registration.submission.ocrData.extractedName %>)</span>
                                <% } %>
                              </small><br>
                            <% } %>
                          </div>
                        </details>
                      <% } %>
                    <% } else { %>
                      <small>No submission</small>
                    <% } %>
                  </td>
                  <td data-registrant-column="runResultEvidence" class="is-column-hidden">
                    <% if (registration.submission?.proof?.url) { %>
                      <a href="<%= registration.submission.proof.url %>" target="_blank" rel="noopener noreferrer" class="proof-link">View run result evidence</a>
                    <% } else { %>
                      <small>N/A</small>
                    <% } %>
                  </td>
                  <td data-registrant-column="runResultReview" class="is-column-hidden">
                    <% if (registration.submission && registration.submission.status === 'submitted') { %>
                      <a href="/organizer/events/<%= event._id %>/submissions/<%= registration.submission._id %>/review" class="nav-signup-btn table-action-btn registrant-row-btn registrant-row-btn-review">Open Review</a>
                    <% } else if (registration.submission) { %>
                      <% if (registration.submission.reviewedAtLabel) { %>
                        <small>Reviewed: <%= registration.submission.reviewedAtLabel %></small>
                        <% if (registration.submission.reviewerName) { %>
                          <br>
                          <small>By: <%= registration.submission.reviewerName %></small>
                        <% } %>
                      <% } else { %>
                        <small>No pending action</small>
                      <% } %>
                      <% if (registration.submission.rejectionReason) { %>
                        <br>
                        <small>Reason: <%= registration.submission.rejectionReason %></small>
                      <% } %>
                      <% if (registration.submission.reviewNotes) { %>
                        <br>
                        <small>Notes: <%= registration.submission.reviewNotes %></small>
                      <% } %>
                    <% } else { %>
                      <small>No submission</small>
                    <% } %>
                  </td>
                  <td data-registrant-column="registeredAt"><%= registration.registeredAt ? new Date(registration.registeredAt).toLocaleString('en-US') : 'N/A' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% if (pagination.totalPages > 1) { %>
          <nav class="run-proof-pagination" aria-label="Registrants pagination">
            <% if (pagination.prevHref) { %>
              <a href="<%= pagination.prevHref %>" class="nav-login-btn">Previous</a>
            <% } else { %>
              <span class="nav-login-btn disabled">Previous</span>
            <% } %>
            <span>Page <%= pagination.page %> of <%= pagination.totalPages %></span>
            <% if (pagination.nextHref) { %>
              <a href="<%= pagination.nextHref %>" class="nav-login-btn">Next</a>
            <% } else { %>
              <span class="nav-login-btn disabled">Next</span>
            <% } %>
          </nav>
        <% } %>
      <% } else { %>
        <div class="empty-state">
          <i data-lucide="users"></i>
          <h3>No registrants found</h3>
          <p>No registrations match your current filters.</p>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    document.querySelectorAll('[data-registrant-filter-form] [data-auto-submit-filter]').forEach((filter) => {
      filter.addEventListener('change', () => filter.form.requestSubmit());
    });

    (function initRegistrantColumns() {
      const menu = document.querySelector('[data-registrant-column-menu]');
      const menuButton = document.getElementById('registrantColumnsMenuBtn');
      const menuPanel = document.getElementById('registrantColumnsMenu');
      const toggles = Array.from(document.querySelectorAll('[data-registrant-column-toggle]'));
      const columnCount = document.getElementById('registrantColumnCount');
      const resetButton = document.querySelector('[data-registrant-column-reset]');
      const defaultColumns = {
        confirmation: false,
        name: true,
        email: true,
        mobile: false,
        country: true,
        age: true,
        gender: true,
        emergencyContact: false,
        runningGroup: true,
        waiver: false,
        mode: false,
        distance: true,
        status: true,
        payment: true,
        expectedPayment: false,
        paymentReceipt: false,
        paymentReview: false,
        runResult: true,
        runResultEvidence: false,
        runResultReview: false,
        registeredAt: true
      };
      const storageKey = 'organizerRegistrantsVisibleColumns';

      function getStoredState() {
        try {
          const stored = JSON.parse(window.localStorage.getItem(storageKey) || '{}');
          return { ...defaultColumns, ...stored };
        } catch (_) {
          return { ...defaultColumns };
        }
      }

      function saveState(state) {
        try {
          window.localStorage.setItem(storageKey, JSON.stringify(state));
        } catch (_) {
          // Controls still work for this page load when storage is unavailable.
        }
      }

      function getCurrentState() {
        return toggles.reduce((state, toggle) => {
          state[toggle.dataset.registrantColumnToggle] = toggle.checked;
          return state;
        }, { ...defaultColumns });
      }

      function applyState(state, shouldSave) {
        toggles.forEach((toggle) => {
          toggle.checked = Boolean(state[toggle.dataset.registrantColumnToggle]);
        });

        Object.keys(defaultColumns).forEach((key) => {
          document.querySelectorAll(`[data-registrant-column="${key}"]`).forEach((element) => {
            element.classList.toggle('is-column-hidden', !state[key]);
          });
        });

        if (columnCount) {
          columnCount.textContent = String(Object.keys(defaultColumns).filter((key) => Boolean(state[key])).length);
        }

        if (shouldSave) saveState(state);
      }

      function setMenuOpen(isOpen) {
        if (!menuButton || !menuPanel) return;
        menuPanel.hidden = !isOpen;
        menuButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      }

      if (menuButton && menuPanel) {
        menuButton.addEventListener('click', () => setMenuOpen(menuPanel.hidden));
      }

      toggles.forEach((toggle) => {
        toggle.addEventListener('change', () => applyState(getCurrentState(), true));
      });

      if (resetButton) {
        resetButton.addEventListener('click', () => applyState({ ...defaultColumns }, true));
      }

      document.addEventListener('click', (event) => {
        if (menu && !menu.contains(event.target)) setMenuOpen(false);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setMenuOpen(false);
      });

      applyState(getStoredState(), false);
    })();
  </script>
  <script>if (window.lucide) lucide.createIcons();</script>

  <!-- Email Unpaid Modal -->
  <div id="js-email-unpaid-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:500;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:10px;padding:2rem;max-width:440px;width:90%;position:relative">
      <button type="button" id="js-close-email-modal" style="position:absolute;top:0.75rem;right:0.75rem;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#64748b">×</button>
      <h2 style="margin:0 0 0.5rem;font-size:1.1rem">Send Payment Reminder</h2>
      <p id="js-email-modal-desc" style="margin:0 0 1rem;color:#475569;font-size:0.875rem"></p>
      <p style="margin:0 0 1.25rem;font-size:0.875rem;color:#1e293b;background:#f8fafc;border:1px solid #e5e7eb;border-radius:6px;padding:0.75rem">
        <strong>Message preview:</strong><br>
        "Your payment for <em id="js-email-modal-event"></em> is pending. Please upload your payment receipt to complete your registration."
      </p>
      <form method="POST" action="/organizer/events/<%= event._id %>/registrants/email-unpaid">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
        <div style="display:flex;gap:0.5rem;justify-content:flex-end">
          <button type="button" id="js-cancel-email-modal" class="nav-login-btn">Cancel</button>
          <button type="submit" class="nav-signup-btn" id="js-confirm-email-btn">Send Reminder</button>
        </div>
      </form>
    </div>
  </div>
  <script>
    (function () {
      var openBtn = document.getElementById('js-email-unpaid-btn');
      var modal = document.getElementById('js-email-unpaid-modal');
      var closeBtn = document.getElementById('js-close-email-modal');
      var cancelBtn = document.getElementById('js-cancel-email-modal');
      var desc = document.getElementById('js-email-modal-desc');
      var eventEl = document.getElementById('js-email-modal-event');
      if (!openBtn || !modal) return;

      openBtn.addEventListener('click', function () {
        var count = openBtn.dataset.unpaidCount || '0';
        var title = openBtn.dataset.eventTitle || 'this event';
        if (desc) desc.textContent = 'This will send a payment reminder email to ' + count + ' runner' + (count !== '1' ? 's' : '') + ' who have not yet paid.';
        if (eventEl) eventEl.textContent = title;
        modal.style.display = 'flex';
      });

      function closeModal() { modal.style.display = 'none'; }
      if (closeBtn) closeBtn.addEventListener('click', closeModal);
      if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
      modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
    })();
  </script>
</body>
</html>
