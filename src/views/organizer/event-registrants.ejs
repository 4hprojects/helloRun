<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/organizer-events.css">
  <link rel="stylesheet" href="/css/organizer-registrants.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <% const basePath = `/organizer/events/${event._id}/registrants`; %>
  <% const resetPath = fieldMode ? `${basePath}?fieldMode=1` : basePath; %>
  <main class="organizer-roster-page <%= capabilities.isPaidEvent ? 'is-paid-event' : '' %>" id="main-content" data-organizer-event-id="<%= event._id %>" data-registrant-roster>
    <div class="organizer-roster-shell">
      <header class="organizer-roster-header">
        <div class="organizer-roster-heading">
          <p class="organizer-roster-kicker">Participant roster</p>
          <h1><%= event.title %></h1>
          <p>Find registrations, inspect progress, and contact runners without mixing roster work with evidence moderation.</p>
        </div>
        <nav class="organizer-roster-header-actions" aria-label="Registrant workspace actions">
          <% if (!isAdminViewer) { %>
            <a href="/organizer/events/<%= event._id %>" class="nav-login-btn"><i data-lucide="arrow-left" aria-hidden="true"></i><span>Back to event</span></a>
            <a href="/organizer/events" class="nav-login-btn"><i data-lucide="calendar-days" aria-hidden="true"></i><span>My events</span></a>
          <% } else { %>
            <a href="/admin/dashboard" class="nav-login-btn"><i data-lucide="layout-dashboard" aria-hidden="true"></i><span>Admin dashboard</span></a>
          <% } %>
          <% if (!isAdminViewer && capabilities.supportsOnsite) { %>
            <a href="<%= basePath %>?fieldMode=1" class="nav-login-btn"><i data-lucide="smartphone" aria-hidden="true"></i><span>Field mode</span></a>
          <% } %>
          <details class="organizer-roster-export" data-export-menu>
            <summary class="nav-login-btn"><i data-lucide="download" aria-hidden="true"></i><span>Export</span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
            <div class="organizer-roster-export-menu">
              <a href="<%= basePath %>/export<%= exportQuery ? `?${exportQuery}` : '' %>"><i data-lucide="file-down" aria-hidden="true"></i><span>Download CSV</span></a>
              <a href="<%= basePath %>/export-xlsx<%= exportQuery ? `?${exportQuery}` : '' %>"><i data-lucide="sheet" aria-hidden="true"></i><span>Download XLSX</span></a>
            </div>
          </details>
        </nav>
      </header>

      <% if (message) { %><div class="page-message page-message-<%= message.type %>" role="status"><%= message.text %></div><% } %>

      <section class="organizer-roster-status-strip" aria-label="Event registration summary">
        <div><span>Total</span><strong><%= summary.totalRegistrants %></strong></div>
        <% if (capabilities.showModeFilter) { %>
          <div><span>Virtual</span><strong><%= summary.virtualCount %></strong></div>
          <div><span>On-site</span><strong><%= summary.onsiteCount %></strong></div>
        <% } %>
        <% if (capabilities.isPaidEvent) { %>
          <a href="/organizer/events/<%= event._id %>/payment-proofs/review"><span>Payment review</span><strong><%= summary.proofSubmittedCount %></strong></a>
          <div><span>Paid</span><strong><%= summary.paidCount %></strong></div>
        <% } %>
        <a href="/organizer/events/<%= event._id %>/run-proofs/review"><span><%= capabilities.isAccumulatedEvent ? 'Pending activities' : 'Result review' %></span><strong><%= summary.submissionSubmittedCount %></strong></a>
        <div><span><%= capabilities.isAccumulatedEvent ? 'Approved activities' : 'Approved results' %></span><strong><%= summary.submissionApprovedCount %></strong></div>
        <div><span>Rejected</span><strong><%= summary.submissionRejectedCount %></strong></div>
      </section>

      <section class="organizer-roster-discovery" aria-labelledby="roster-filter-title">
        <h2 class="visually-hidden" id="roster-filter-title">Search and filter registrants</h2>
        <form method="GET" action="<%= basePath %>" class="organizer-roster-filter-form" data-registrant-filter-form>
          <% if (fieldMode) { %><input type="hidden" name="fieldMode" value="1"><% } %>
          <div class="organizer-roster-search">
            <label for="registrantSearch">Search registrants</label>
            <div>
              <input id="registrantSearch" name="q" type="search" value="<%= searchQuery || '' %>" placeholder="Name, email, code, group, or contact">
              <button type="submit" class="nav-signup-btn"><i data-lucide="search" aria-hidden="true"></i><span>Search</span></button>
            </div>
          </div>
          <details class="organizer-roster-filters" <%= capabilities.hasAdvancedFilters ? 'open' : '' %>>
            <summary><span><i data-lucide="sliders-horizontal" aria-hidden="true"></i>Filters &amp; sort</span><i data-lucide="chevron-down" class="organizer-roster-filter-chevron" aria-hidden="true"></i></summary>
            <div class="organizer-roster-filter-grid">
              <label>Registration status
                <select name="registrationStatus">
                  <option value="">All registrations</option>
                  <% [['confirmed','Confirmed'],['pending_payment','Pending payment'],['paid','Paid'],['cancelled','Cancelled'],['refunded','Refunded']].forEach(([value,label]) => { %><option value="<%= value %>" <%= selectedRegistrationStatus === value ? 'selected' : '' %>><%= label %></option><% }) %>
                </select>
              </label>
              <% if (capabilities.showModeFilter) { %>
                <label>Mode
                  <select name="mode"><option value="">All modes</option><option value="virtual" <%= selectedMode === 'virtual' ? 'selected' : '' %>>Virtual</option><option value="onsite" <%= selectedMode === 'onsite' ? 'selected' : '' %>>On-site</option></select>
                </label>
              <% } %>
              <% if ((eventRaceDistances || []).length > 1) { %>
                <label>Category or goal
                  <select name="distance"><option value="">All categories</option><% eventRaceDistances.forEach((distance) => { %><option value="<%= distance %>" <%= selectedDistance === distance ? 'selected' : '' %>><%= distance %></option><% }) %></select>
                </label>
              <% } %>
              <% if (capabilities.isPaidEvent) { %>
                <label>Payment
                  <select name="payment"><option value="">All payments</option><% [['unpaid','Unpaid'],['proof_submitted','Receipt submitted'],['proof_rejected','Receipt rejected'],['paid','Paid'],['failed','Failed'],['refunded','Refunded']].forEach(([value,label]) => { %><option value="<%= value %>" <%= selectedPaymentStatus === value ? 'selected' : '' %>><%= label %></option><% }) %></select>
                </label>
              <% } %>
              <label>Result
                <select name="result"><option value="">All results</option><option value="submitted" <%= selectedResultStatus === 'submitted' ? 'selected' : '' %>>Pending review</option><option value="approved" <%= selectedResultStatus === 'approved' ? 'selected' : '' %>>Approved</option><option value="rejected" <%= selectedResultStatus === 'rejected' ? 'selected' : '' %>>Rejected</option></select>
              </label>
              <label>Sort
                <select name="sort"><option value="newest" <%= selectedSort === 'newest' ? 'selected' : '' %>>Newest registration</option><option value="oldest" <%= selectedSort === 'oldest' ? 'selected' : '' %>>Oldest registration</option><option value="name_asc" <%= selectedSort === 'name_asc' ? 'selected' : '' %>>Name A–Z</option><option value="name_desc" <%= selectedSort === 'name_desc' ? 'selected' : '' %>>Name Z–A</option><option value="category" <%= selectedSort === 'category' ? 'selected' : '' %>>Category</option></select>
              </label>
              <label>Per page
                <select name="pageSize"><% [25,50,100].forEach((size) => { %><option value="<%= size %>" <%= pageSize === size ? 'selected' : '' %>><%= size %></option><% }) %></select>
              </label>
              <div class="organizer-roster-filter-actions"><button type="submit" class="nav-signup-btn">Apply</button><a href="<%= resetPath %>" class="nav-login-btn">Clear</a></div>
            </div>
          </details>
        </form>
        <% const activeFilters = [
          searchQuery ? `Search: ${searchQuery}` : '',
          selectedRegistrationStatus ? `Registration: ${selectedRegistrationStatus.replaceAll('_', ' ')}` : '',
          selectedMode ? `Mode: ${selectedMode}` : '',
          selectedDistance ? `Category: ${selectedDistance}` : '',
          capabilities.isPaidEvent && selectedPaymentStatus ? `Payment: ${selectedPaymentStatus.replaceAll('_', ' ')}` : '',
          selectedResultStatus ? `Result: ${selectedResultStatus}` : '',
          selectedSort !== 'newest' ? `Sort: ${selectedSort.replaceAll('_', ' ')}` : '',
          pageSize !== 25 ? `${pageSize} per page` : ''
        ].filter(Boolean); %>
        <% if (activeFilters.length) { %><div class="organizer-roster-active-filters" aria-label="Active filters"><% activeFilters.forEach((label) => { %><span><%= label %></span><% }) %><a href="<%= resetPath %>">Clear all</a></div><% } %>
      </section>

      <% if (capabilities.isPaidEvent && !isAdminViewer && (summary.unpaidCount || summary.proofRejectedCount)) { %>
        <% const unpaidTotal = Number(summary.unpaidCount || 0) + Number(summary.proofRejectedCount || 0); %>
        <aside class="organizer-roster-attention">
          <div><i data-lucide="mail-warning" aria-hidden="true"></i><p><strong><%= unpaidTotal %> runner<%= unpaidTotal === 1 ? '' : 's' %> may need a payment reminder.</strong><span>Reminders are sent only to currently unpaid or receipt-rejected registrations.</span></p></div>
          <button type="button" class="nav-login-btn" data-open-reminder data-unpaid-count="<%= unpaidTotal %>" data-event-title="<%= event.title %>">Review reminder</button>
          <noscript><form method="POST" action="<%= basePath %>/email-unpaid"><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><button type="submit" class="nav-login-btn">Send reminders</button></form></noscript>
        </aside>
      <% } %>

      <div class="organizer-roster-result-count">
        <% const resultStart = pagination.totalItems ? ((pagination.page - 1) * pagination.pageSize) + 1 : 0; %>
        <% const resultEnd = pagination.totalItems ? resultStart + registrations.length - 1 : 0; %>
        <span>Showing <strong><%= resultStart %>–<%= resultEnd %></strong> of <strong><%= pagination.totalItems %></strong> matching registrants</span>
      </div>

      <% if (registrations && registrations.length) { %>
        <section class="organizer-roster-list" aria-label="Registrant roster">
          <div class="organizer-roster-column-labels" aria-hidden="true">
            <span>Runner</span><span>Category</span><span>Registered</span><% if (capabilities.isPaidEvent) { %><span>Payment</span><% } %><span>Result or progress</span><span>Actions</span>
          </div>
          <% registrations.forEach((registration) => { %>
            <% const runnerName = [registration.participant?.firstName, registration.participant?.lastName].filter(Boolean).join(' ') || 'Unnamed runner'; %>
            <% const detailId = `registrant-details-${registration._id}`; %>
            <article class="organizer-roster-record" data-registrant-record>
              <div class="organizer-roster-record-summary">
                <div class="organizer-roster-runner" data-label="Runner"><strong><%= runnerName %></strong><span><%= registration.participant?.email || 'No email' %></span><code><%= registration.confirmationCode %></code></div>
                <div data-label="Category"><strong><%= registration.categoryLabel %></strong><span><%= registration.participationMode || 'N/A' %></span></div>
                <div data-label="Registered"><strong><%= registration.registeredAtLabel || 'N/A' %></strong><span class="organizer-roster-badge status-<%= registration.status %>"><%= registration.registrationStatusLabel %></span></div>
                <% if (capabilities.isPaidEvent) { %><div data-label="Payment"><strong><%= registration.paymentStatusLabel %></strong><% if (registration.paymentReviewHref) { %><a href="<%= registration.paymentReviewHref %>">Review receipt</a><% } else { %><span><%= registration.expectedPaymentLabel %></span><% } %></div><% } %>
                <div data-label="Result or progress" class="organizer-roster-progress">
                  <% if (registration.accumulatedProgress) { %>
                    <strong><%= registration.accumulatedProgress.progressLabel %></strong>
                    <progress value="<%= Math.min(100, registration.accumulatedProgress.progressPercent || 0) %>" max="100"><%= Math.round(registration.accumulatedProgress.progressPercent || 0) %>%</progress>
                    <span><%= registration.resultStatusLabel %></span>
                  <% } else { %>
                    <strong><%= registration.resultStatusLabel %></strong>
                    <% if (registration.submission) { %><span><%= Number(registration.submission.distanceKm || 0).toFixed(2) %> km · <%= registration.submission.elapsedLabel || 'No elapsed time' %></span><% } %>
                  <% } %>
                  <% if (registration.resultReviewHref) { %><a href="<%= registration.resultReviewHref %>">Review result</a><% } %>
                </div>
                <div class="organizer-roster-record-actions" data-label="Actions">
                  <button type="button" class="nav-login-btn organizer-roster-icon-action" data-message-runner data-registration-id="<%= registration._id %>" data-runner-name="<%= runnerName %>" aria-label="Message <%= runnerName %>"><i data-lucide="message-square" aria-hidden="true"></i><span>Message</span></button>
                  <button type="button" class="nav-login-btn organizer-roster-icon-action" data-toggle-registrant-details aria-expanded="false" aria-controls="<%= detailId %>" aria-label="Show details for <%= runnerName %>"><i data-lucide="chevron-down" aria-hidden="true"></i><span>Details</span></button>
                </div>
              </div>
              <div class="organizer-roster-record-details" id="<%= detailId %>">
                <section><h3>Runner profile</h3><dl><div><dt>Mobile</dt><dd><%= registration.participant?.mobile || 'Not provided' %></dd></div><div><dt>Country</dt><dd><%= registration.participant?.countryLabel || 'Not provided' %></dd></div><div><dt>Age</dt><dd><%= registration.participant?.ageLabel || 'Not provided' %></dd></div><div><dt>Gender</dt><dd><%= registration.participant?.genderLabel || 'Not provided' %></dd></div><div><dt>Running group</dt><dd><%= registration.participant?.runningGroup || 'Not provided' %></dd></div><div><dt>Emergency contact</dt><dd><%= registration.participant?.emergencyContactName || 'Not provided' %><% if (registration.participant?.emergencyContactNumber) { %><br><small><%= registration.participant.emergencyContactNumber %></small><% } %></dd></div></dl><noscript><form method="POST" action="<%= basePath %>/<%= registration._id %>/send-message" class="organizer-roster-noscript-message"><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><label>Subject<input name="subject" maxlength="200"></label><label>Message<textarea name="message" maxlength="1000" required></textarea></label><button type="submit" class="nav-login-btn">Send message</button></form></noscript></section>
                <section><h3>Registration</h3><dl><div><dt>Mode</dt><dd><%= registration.participationMode %></dd></div><div><dt>Distance</dt><dd><%= registration.raceDistance %></dd></div><div><dt>Package</dt><dd><%= registration.pricingSnapshot?.packageName || 'None' %></dd></div><div><dt>Signup option</dt><dd><%= registration.signupOptionLabel || 'None' %></dd></div><div><dt>Pricing period</dt><dd><%= registration.pricingPeriodLabel || 'None' %></dd></div><div><dt>Add-ons</dt><dd><%= (registration.addOns || []).length ? registration.addOns.map((item) => `${item.quantity || 1}× ${item.name}`).join(', ') : 'None' %></dd></div><div><dt>Waiver</dt><dd>Version <%= registration.waiver?.version || 'N/A' %> · <%= registration.waiver?.signature || 'No signature' %><% if (registration.waiverAcceptedAtLabel) { %><br><small>Accepted <%= registration.waiverAcceptedAtLabel %></small><% } %></dd></div></dl></section>
                <% if (capabilities.isPaidEvent) { %><section><h3>Payment history</h3><dl><div><dt>Expected</dt><dd><%= registration.expectedPaymentLabel %></dd></div><div><dt>Status</dt><dd><%= registration.paymentStatusLabel %></dd></div><div><dt>Receipt</dt><dd><% if (registration.paymentProof?.url) { %><a href="<%= registration.paymentProof.url %>" target="_blank" rel="noopener noreferrer">View payment receipt</a><% if (registration.paymentProofUploadedAtLabel) { %><br><small>Uploaded <%= registration.paymentProofUploadedAtLabel %></small><% } %><% } else { %>Not submitted<% } %></dd></div><div><dt>Reviewed</dt><dd><%= registration.paymentReviewedAtLabel || 'Not reviewed' %></dd></div><% if (registration.paymentRejectionReason) { %><div><dt>Rejection reason</dt><dd><%= registration.paymentRejectionReason %></dd></div><% } %><% if (registration.paymentReviewNotes) { %><div><dt>Review notes</dt><dd><%= registration.paymentReviewNotes %></dd></div><% } %></dl></section><% } %>
                <section><h3><%= capabilities.isAccumulatedEvent ? 'Accumulated progress' : 'Run result' %></h3>
                  <% if (registration.accumulatedProgress) { %><dl><div><dt>Goal</dt><dd><%= registration.accumulatedProgress.targetDistanceKm %> km</dd></div><div><dt>Approved</dt><dd><%= registration.accumulatedProgress.approvedDistanceKm.toFixed(2) %> km from <%= registration.accumulatedProgress.approvedActivityCount %> activities</dd></div><div><dt>Pending</dt><dd><%= registration.accumulatedProgress.pendingDistanceKm.toFixed(2) %> km from <%= registration.accumulatedProgress.pendingActivityCount %> activities</dd></div><div><dt>Rejected</dt><dd><%= registration.accumulatedProgress.rejectedDistanceKm.toFixed(2) %> km</dd></div><div><dt>Remaining</dt><dd><%= registration.accumulatedProgress.remainingDistanceKm.toFixed(2) %> km</dd></div><% if (registration.accumulatedProgress.overGoalDistanceKm > 0) { %><div><dt>Beyond goal</dt><dd><%= registration.accumulatedProgress.overGoalDistanceKm.toFixed(2) %> km</dd></div><% } %></dl><a href="/organizer/events/<%= event._id %>/run-proofs/review?q=<%= encodeURIComponent(registration.confirmationCode || '') %>">Open activity history</a>
                  <% } else if (registration.submission) { %><dl><div><dt>Status</dt><dd><%= registration.resultStatusLabel %></dd></div><div><dt>Distance</dt><dd><%= Number(registration.submission.distanceKm || 0).toFixed(2) %> km</dd></div><div><dt>Elapsed</dt><dd><%= registration.submission.elapsedLabel || 'N/A' %></dd></div><div><dt>Run date</dt><dd><%= registration.submission.runDateLabel || 'N/A' %></dd></div><div><dt>Submitted</dt><dd><%= registration.submission.submittedAtLabel || 'N/A' %></dd></div><div><dt>Location</dt><dd><%= registration.submission.runLocation || 'N/A' %></dd></div><div><dt>Evidence</dt><dd><% if (registration.submission.proof?.url) { %><a href="<%= registration.submission.proof.url %>" target="_blank" rel="noopener noreferrer">View run evidence</a><% } else { %><%= registration.submission.proofType || 'N/A' %><% } %></dd></div><% if (registration.submission.rejectionReason) { %><div><dt>Rejection reason</dt><dd><%= registration.submission.rejectionReason %></dd></div><% } %><% if (registration.submission.reviewNotes) { %><div><dt>Review notes</dt><dd><%= registration.submission.reviewNotes %></dd></div><% } %></dl>
                  <% } else { %><p>No run result has been submitted.</p><% } %>
                </section>
              </div>
            </article>
          <% }) %>
        </section>

        <% if (pagination.totalPages > 1) { %><nav class="organizer-roster-pagination" aria-label="Registrants pagination"><% if (pagination.prevHref) { %><a href="<%= pagination.prevHref %>" class="nav-login-btn"><i data-lucide="chevron-left" aria-hidden="true"></i>Previous</a><% } else { %><span></span><% } %><p>Page <strong><%= pagination.page %></strong> of <strong><%= pagination.totalPages %></strong></p><% if (pagination.nextHref) { %><a href="<%= pagination.nextHref %>" class="nav-login-btn">Next<i data-lucide="chevron-right" aria-hidden="true"></i></a><% } else { %><span></span><% } %></nav><% } %>
      <% } else { %>
        <section class="organizer-roster-empty"><i data-lucide="users" aria-hidden="true"></i><h2><%= summary.totalRegistrants ? 'No matching registrants' : 'No registrations yet' %></h2><p><%= summary.totalRegistrants ? 'Try another search or clear the current filters.' : 'Registrations will appear here after runners join this event.' %></p><% if (summary.totalRegistrants) { %><a href="<%= resetPath %>" class="nav-login-btn">Clear filters</a><% } %></section>
      <% } %>
    </div>
  </main>

  <div class="organizer-roster-dialog-backdrop" data-message-dialog hidden><section class="organizer-roster-dialog" role="dialog" aria-modal="true" aria-labelledby="messageDialogTitle" tabindex="-1"><h2 id="messageDialogTitle" data-message-title>Message runner</h2><form method="POST" data-message-form><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><label>Subject<input type="text" name="subject" maxlength="200" placeholder="About your registration"></label><label>Message<textarea name="message" rows="5" maxlength="1000" required placeholder="Write a concise message to the runner"></textarea></label><div class="organizer-roster-dialog-actions"><button type="button" class="nav-login-btn" data-dialog-cancel>Cancel</button><button type="submit" class="nav-signup-btn">Send message</button></div></form></section></div>

  <% if (capabilities.isPaidEvent && !isAdminViewer && (summary.unpaidCount || summary.proofRejectedCount)) { %><div class="organizer-roster-dialog-backdrop" data-reminder-dialog hidden><section class="organizer-roster-dialog" role="dialog" aria-modal="true" aria-labelledby="reminderDialogTitle" tabindex="-1"><h2 id="reminderDialogTitle">Send payment reminders?</h2><p data-reminder-description></p><div class="organizer-roster-message-preview">Your payment for <strong data-reminder-event></strong> is pending. Please upload your payment receipt to complete your registration.</div><form method="POST" action="<%= basePath %>/email-unpaid"><input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>"><div class="organizer-roster-dialog-actions"><button type="button" class="nav-login-btn" data-dialog-cancel>Cancel</button><button type="submit" class="nav-signup-btn">Send reminders</button></div></form></section></div><% } %>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/organizer-registrants.js"></script>
</body>
</html>
