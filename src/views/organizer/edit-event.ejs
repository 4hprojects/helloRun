<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/create-event.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="create-event-page">
    <section class="create-event-shell">
      <header class="page-header">
        <h1><%= typeof pageHeading !== 'undefined' ? pageHeading : 'Edit Event' %></h1>
        <p><%= typeof pageDescription !== 'undefined' ? pageDescription : 'Update setup, preview changes, and submit drafts for review.' %></p>
      </header>

      <% if (message) { %>
        <div class="status-note status-note-<%= message.type %>" role="status">
          <i data-lucide="<%= message.type === 'success' ? 'check-circle' : 'alert-circle' %>"></i>
          <div>
            <strong><%= message.type === 'success' ? 'Success' : 'Attention' %></strong>
            <p><%= message.text %></p>
          </div>
        </div>
      <% } %>

      <% if (Object.keys(errors || {}).length) { %>
        <div class="form-errors" role="alert">
          <strong>Please fix the highlighted fields before saving.</strong>
          <ul>
            <% Object.values(errors || {}).forEach((errorText) => { %>
              <li><%= errorText %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div id="actionConfirmOverlay" class="draft-confirm-overlay" hidden>
        <div class="draft-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="actionConfirmTitle" aria-describedby="actionConfirmDesc" tabindex="-1">
          <div class="draft-confirm-icon" id="actionConfirmIconWrap"><i data-lucide="help-circle"></i></div>
          <h3 id="actionConfirmTitle"></h3>
          <p id="actionConfirmDesc"></p>
          <div class="draft-confirm-actions">
            <button type="button" id="actionConfirmCancelBtn" class="draft-confirm-btn draft-confirm-btn--cancel">Cancel</button>
            <button type="button" id="actionConfirmOkBtn" class="draft-confirm-btn draft-confirm-btn--primary">Confirm</button>
          </div>
        </div>
      </div>

      <form class="create-event-form" method="POST" action="<%= typeof formAction !== 'undefined' ? formAction : `/organizer/events/${event._id}/edit` %>" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
        <aside class="wizard-progress" aria-label="Edit event progress">
          <div class="wizard-progress-heading">Event Builder</div>
          <ol>
            <li><a href="#event-type-step" data-step-link="event-type-step"><span>1</span> Event Type</a></li>
            <li><a href="#core-details-step" data-step-link="core-details-step"><span>2</span> Core Details</a></li>
            <li><a href="#schedule-step" data-step-link="schedule-step"><span>3</span> Schedule</a></li>
            <li><a href="#location-virtual-step" data-step-link="location-virtual-step"><span>4</span> Location or Virtual Rules</a></li>
            <li><a href="#race-categories-step" data-step-link="race-categories-step"><span>5</span> Race Categories</a></li>
            <li><a href="#rewards-step" data-step-link="rewards-step"><span>6</span> Rewards and Inclusions</a></li>
            <li><a href="#pricing-step" data-step-link="pricing-step"><span>7</span> Pricing</a></li>
            <li><a href="#payment-setup-step" data-step-link="payment-setup-step"><span>8</span> Payment Setup</a></li>
            <li><a href="#event-details-step" data-step-link="event-details-step"><span>9</span> Event Details</a></li>
            <li><a href="#media-step" data-step-link="media-step"><span>10</span> Branding and Media</a></li>
            <li><a href="#waiver-step" data-step-link="waiver-step"><span>11</span> Waiver</a></li>
            <li><a href="#review-step" data-step-link="review-step"><span>12</span> Review</a></li>
          </ol>
        </aside>

        <div class="wizard-main">
        <nav class="wizard-pills-bar" aria-label="Event builder steps">
          <ol class="wizard-pills-list">
            <li><a href="#event-type-step" class="wizard-pill" data-pill-step="event-type-step"><span class="pill-num">1</span><span class="pill-label">Event Type</span></a></li>
            <li><a href="#core-details-step" class="wizard-pill" data-pill-step="core-details-step"><span class="pill-num">2</span><span class="pill-label">Core Details</span></a></li>
            <li><a href="#schedule-step" class="wizard-pill" data-pill-step="schedule-step"><span class="pill-num">3</span><span class="pill-label">Schedule</span></a></li>
            <li><a href="#location-virtual-step" class="wizard-pill" data-pill-step="location-virtual-step"><span class="pill-num">4</span><span class="pill-label">Location / Virtual</span></a></li>
            <li><a href="#race-categories-step" class="wizard-pill" data-pill-step="race-categories-step"><span class="pill-num">5</span><span class="pill-label">Race Categories</span></a></li>
            <li><a href="#rewards-step" class="wizard-pill" data-pill-step="rewards-step"><span class="pill-num">6</span><span class="pill-label">Rewards</span></a></li>
            <li><a href="#pricing-step" class="wizard-pill" data-pill-step="pricing-step"><span class="pill-num">7</span><span class="pill-label">Pricing</span></a></li>
            <li><a href="#payment-setup-step" class="wizard-pill" data-pill-step="payment-setup-step"><span class="pill-num">8</span><span class="pill-label">Payment</span></a></li>
            <li><a href="#event-details-step" class="wizard-pill" data-pill-step="event-details-step"><span class="pill-num">9</span><span class="pill-label">Event Details</span></a></li>
            <li><a href="#media-step" class="wizard-pill" data-pill-step="media-step"><span class="pill-num">10</span><span class="pill-label">Media</span></a></li>
            <li><a href="#waiver-step" class="wizard-pill" data-pill-step="waiver-step"><span class="pill-num">11</span><span class="pill-label">Waiver</span></a></li>
            <li><a href="#review-step" class="wizard-pill" data-pill-step="review-step"><span class="pill-num">12</span><span class="pill-label">Review</span></a></li>
          </ol>
        </nav>

        <div class="wizard-mini-strip" id="wizardMiniStrip" role="navigation" aria-label="Event builder progress">
          <div class="wizard-mini-info">
            <span class="wizard-mini-step" id="wizardMiniStep">Step 1 of 12</span>
            <span class="wizard-mini-title" id="wizardMiniTitle">Event Type</span>
          </div>
          <button type="button" class="wizard-mini-toggle" id="wizardMiniToggle" aria-label="Show all steps" aria-expanded="false">
            <i data-lucide="chevron-down"></i>
          </button>
          <div class="wizard-mini-progress" aria-hidden="true">
            <div class="wizard-mini-progress-fill" id="wizardMiniProgressFill" style="width:8.33%"></div>
          </div>
        </div>

        <div id="event-type-step" class="form-section form-section-event-type" tabindex="-1" data-wizard-step="event-type-step">
          <div class="section-kicker">Step 1 of 12</div>
          <div class="section-title">Event Type</div>
          <p class="section-helper">Choose the participation format. Later sections adjust based on this choice.</p>
          <div class="form-grid">
            <div class="form-group form-group-full">
              <label for="eventType">Event Type *</label>
              <select id="eventType" name="eventType" required>
                <option value="">Select event type</option>
                <option value="virtual" <%= formData.eventType === 'virtual' ? 'selected' : '' %>>Virtual</option>
                <option value="onsite" <%= formData.eventType === 'onsite' ? 'selected' : '' %>>On-site</option>
                <option value="hybrid" <%= formData.eventType === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
              </select>
            </div>
            <div class="event-type-guidance form-group-full" aria-live="polite">
              <div class="event-type-card" data-event-type-card="virtual">
                <strong>Virtual Event</strong>
                <span>Best for accumulated runs, screenshot-based submissions, and online participation.</span>
              </div>
              <div class="event-type-card" data-event-type-card="onsite">
                <strong>Onsite Event</strong>
                <span>Best for physical races with venue, race categories, and registration fees.</span>
              </div>
              <div class="event-type-card" data-event-type-card="hybrid">
                <strong>Hybrid Event</strong>
                <span>Best for events that allow both onsite and virtual participation.</span>
              </div>
            </div>
          </div>
        </div>

        <!-- CORE DETAILS SECTION (same as create) -->
        <div id="core-details-step" class="form-section form-section-core" tabindex="-1" data-wizard-step="core-details-step">
          <div class="section-kicker">Step 2 of 12</div>
          <div class="section-title">Core Details</div>
          <div class="form-grid">
            <div class="form-group">
              <label for="title">Event Title *</label>
              <input id="title" name="title" type="text" value="<%= formData.title %>" required>
            </div>
            <div class="form-group">
              <label for="organiserName" class="label-with-help">
                Organizer Name
                <span class="field-help-icon" tabindex="0" aria-label="Defaults to the account owner's name for new events. Change this if the event should display a club, brand, or team name instead.">?</span>
              </label>
              <input id="organiserName" name="organiserName" type="text" value="<%= formData.organiserName %>">
            </div>
            <div class="form-group form-group-full">
              <label for="description" class="label-with-help">
                Description *
                <span class="field-help-icon" tabindex="0" aria-label="This is the short public summary shown in event listings and previews. Put full rules, inclusions, FAQs, and proof instructions in Event Details.">?</span>
              </label>
              <textarea id="description" name="description" rows="4" required><%= formData.description %></textarea>
            </div>
          </div>
        </div>

        <!-- PRICING PER DISTANCE SECTION -->
        <div id="pricing-step" class="form-section form-section-fees" tabindex="-1" data-wizard-step="pricing-step">
          <div class="section-kicker">Step 7 of 12</div>
          <div class="section-title">Pricing Per Distance</div>
          <p class="section-helper">Set whether this event is free or paid, and the registration fee for each distance or race category.</p>
          <input type="hidden" id="pricingMode" name="pricingMode" value="<%= ['per_distance', 'per_distance_period'].includes(formData.pricingMode) ? formData.pricingMode : (formData.feeMode === 'paid' ? 'per_distance' : 'free') %>">
          <div class="form-grid">
            <div class="form-group <%= errors.feeMode ? 'has-error' : '' %>">
              <label for="feeMode">Event Fee *</label>
              <select id="feeMode" name="feeMode">
                <option value="free" <%= formData.feeMode !== 'paid' ? 'selected' : '' %>>Free</option>
                <option value="paid" <%= formData.feeMode === 'paid' ? 'selected' : '' %>>Paid</option>
              </select>
              <% if (errors.feeMode) { %><small class="error-text"><%= errors.feeMode %></small><% } %>
            </div>
            <div class="form-group payment-fields <%= errors.feeCurrency ? 'has-error' : '' %>">
              <label for="feeCurrency">Currency</label>
              <input id="feeCurrency" name="feeCurrency" type="text" value="<%= formData.feeCurrency || 'PHP' %>" maxlength="3" placeholder="PHP">
              <% if (errors.feeCurrency) { %><small class="error-text"><%= errors.feeCurrency %></small><% } %>
            </div>
          </div>
          <p class="pricing-free-note field-hint" style="display:none;">&#10003; This event is free &mdash; runners will not be asked to pay or upload a payment receipt.</p>
          <div class="per-distance-fields payment-fields" style="display:none; margin-top:1.25rem;">
            <div class="subsection-divider">Per-Distance Fees</div>
            <p class="field-hint" style="margin-bottom:0.75rem;">Set a fee for each race distance. Distances are populated from your Race Categories (Step 5). These fees override the base registration fee for individual distances.</p>
            <div class="pricing-periods-toggle" style="display:none; margin-bottom:0.75rem;">
              <label>
                <input type="checkbox" id="enablePricingPeriods" <%= formData.pricingMode === 'per_distance_period' ? 'checked' : '' %>>
                Add early bird and late registration pricing
              </label>
              <small class="field-hint">When enabled, you can set different prices for early bird, regular, and late registration windows per distance.</small>
            </div>
            <div id="perDistanceFeeRows" class="per-distance-fee-grid">
              <p class="field-hint per-distance-empty-hint">No race distances selected yet. Add distances in Step 5, then come back here to set fees per distance.</p>
            </div>
          </div>
        </div>

        <!-- PAYMENT SETUP SECTION -->
        <div id="payment-setup-step" class="form-section form-section-payment" tabindex="-1" data-wizard-step="payment-setup-step">
          <div class="section-kicker">Step 8 of 12</div>
          <div class="section-title">Payment Setup</div>
          <p class="section-helper">Define how runners will pay. Required only for paid events.</p>
          <p class="payment-free-note field-hint" style="display:none;">&#10003; This event is free &mdash; payment setup is not required.</p>
          <div class="payment-fields">
            <div class="form-grid">
              <div class="form-group">
                <label for="paymentAccountName">Account Name</label>
                <input id="paymentAccountName" name="paymentAccountName" type="text" value="<%= formData.paymentAccountName || '' %>" placeholder="Optional">
                <small class="field-hint">Name associated with your GCash, bank, or payment account.</small>
              </div>
              <div class="form-group form-group-full <%= errors.paymentQrImageUrl ? 'has-error' : '' %>">
                <label for="paymentQrImageFile">Payment QR Image <span class="field-help-icon" tabindex="0" aria-label="Upload a QR code image that runners will use to complete payment. Required for paid events before submitting for review.">?</span></label>
                <% if (formData.paymentQrImageUrl) { %>
                <div class="branding-preview-wrap" id="qrPreviewWrap">
                  <button type="button" class="branding-remove-btn" id="removeQrBtn" aria-label="Remove current QR image">x</button>
                  <img src="<%= formData.paymentQrImageUrl %>" alt="Current payment QR" style="max-width:160px;max-height:160px;border-radius:8px;margin-bottom:1rem;">
                </div>
                <input type="hidden" id="removePaymentQrImage" name="removePaymentQrImage" value="0">
                <% } %>
                <div class="upload-area" id="qrUploadArea">
                  <input type="file" id="paymentQrImageFile" name="paymentQrImageFile" accept="image/jpeg,image/png,image/webp">
                  <div class="upload-placeholder">
                    <i data-lucide="upload-cloud"></i>
                    <p>Drag &amp; drop or click to upload QR image</p>
                    <small>JPG/PNG only, max 5 MB</small>
                  </div>
                  <div class="upload-preview" id="qrPreviewContainer" style="display:none;">
                    <img id="qrPreviewImg" src="#" alt="New QR preview">
                    <button type="button" class="remove-upload" aria-label="Remove new QR" data-for="qr">x</button>
                  </div>
                </div>
                <input id="paymentQrImageUrl" name="paymentQrImageUrl" type="hidden" value="<%= formData.paymentQrImageUrl || '' %>">
                <input id="paymentQrImageKey" name="paymentQrImageKey" type="hidden" value="<%= formData.paymentQrImageKey || '' %>">
                <small class="field-hint">Required before submitting a paid event for review. JPG/PNG only, max 5 MB.</small>
                <% if (errors.paymentQrImageUrl) { %><small class="error-text"><%= errors.paymentQrImageUrl %></small><% } %>
              </div>
              <div class="form-group form-group-full">
                <label for="paymentInstructions">Payment Instructions</label>
                <textarea id="paymentInstructions" name="paymentInstructions" rows="3" placeholder="Optional payment notes for runners."><%= formData.paymentInstructions || '' %></textarea>
                <small class="field-hint">Tell runners where to pay, what reference to include, and when payment receipts will be reviewed.</small>
              </div>
            </div>
          </div>
        </div>

        <!-- REWARDS AND INCLUSIONS SECTION -->
        <div id="rewards-step" class="form-section form-section-rewards" tabindex="-1" data-wizard-step="rewards-step">
          <div class="section-kicker">Step 6 of 12</div>
          <div class="section-title">Rewards and Inclusions</div>
          <p class="section-helper">Define what runners receive. These inclusions apply across all distances or categories. Per-category package pricing will be available in a later update.</p>
          <div class="form-grid">
            <div class="form-group form-group-full">
              <div class="subsection-divider">Digital Recognition</div>
              <div class="checkbox-row">
                <label><input type="checkbox" name="digitalBadgeEnabled" value="1" <%= formData.digitalBadgeEnabled ? 'checked' : '' %>> Digital Badge</label>
                <label><input type="checkbox" name="digitalCertificateEnabled" value="1" <%= formData.digitalCertificateEnabled ? 'checked' : '' %>> Digital Finisher Certificate</label>
              </div>
              <small class="field-hint">Enable only the recognition items this event will actually provide to finishers.</small>
            </div>
            <div class="form-group form-group-full">
              <div class="subsection-divider">Physical Rewards</div>
              <div class="toggle-section-label"><input type="checkbox" id="physicalRewardsEnabled" name="physicalRewardsEnabled" value="1" <%= formData.physicalRewardsEnabled ? 'checked' : '' %>><label for="physicalRewardsEnabled" class="toggle-label-text">Physical Rewards Available <span class="field-help-icon" tabindex="0" aria-label="Tick this if your event includes physical items such as medals, shirts, patches, or a finisher kit.">?</span></label></div>
              <div class="physical-reward-fields" style="display:<%= formData.physicalRewardsEnabled ? '' : 'none' %>;">
                <small class="field-hint">Mark which items are included. Amounts are optional reference costs that can help calculate a suggested entry fee.</small>
                <div class="reward-cost-grid">
                  <label><input type="checkbox" name="physicalRewardMedalEnabled" value="1" <%= formData.physicalRewardMedalEnabled ? 'checked' : '' %>> Medal <input name="physicalRewardMedalAmount" type="number" min="0" step="0.01" value="<%= formData.physicalRewardMedalAmount ?? '' %>" placeholder="0.00"></label>
                  <label><input type="checkbox" name="physicalRewardShirtEnabled" value="1" <%= formData.physicalRewardShirtEnabled ? 'checked' : '' %>> Shirt <input name="physicalRewardShirtAmount" type="number" min="0" step="0.01" value="<%= formData.physicalRewardShirtAmount ?? '' %>" placeholder="0.00"></label>
                  <label><input type="checkbox" name="physicalRewardPatchEnabled" value="1" <%= formData.physicalRewardPatchEnabled ? 'checked' : '' %>> Patch <input name="physicalRewardPatchAmount" type="number" min="0" step="0.01" value="<%= formData.physicalRewardPatchAmount ?? '' %>" placeholder="0.00"></label>
                  <label><input type="checkbox" name="physicalRewardTowelEnabled" value="1" <%= formData.physicalRewardTowelEnabled ? 'checked' : '' %>> Towel <input name="physicalRewardTowelAmount" type="number" min="0" step="0.01" value="<%= formData.physicalRewardTowelAmount ?? '' %>" placeholder="0.00"></label>
                  <label><input type="checkbox" name="physicalRewardFinisherKitEnabled" value="1" <%= formData.physicalRewardFinisherKitEnabled ? 'checked' : '' %>> Finisher Kit <input name="physicalRewardFinisherKitAmount" type="number" min="0" step="0.01" value="<%= formData.physicalRewardFinisherKitAmount ?? '' %>" placeholder="0.00"></label>
                </div>
                <% const otherItems = formData.physicalRewardOtherItems || []; %>
                <% const hasOtherItems = otherItems.some(function(i){ return i && i.name; }); %>
                <div class="toggle-section-label" style="margin-top:0.75rem;">
                  <input type="checkbox" id="customMerchandiseEnabled" <%= hasOtherItems ? 'checked' : '' %>>
                  <label for="customMerchandiseEnabled" class="toggle-label-text">Custom Merchandise</label>
                </div>
                <div id="customMerchandiseFields" style="display:<%= hasOtherItems ? '' : 'none' %>;">
                  <% for (let itemIndex = 0; itemIndex < 3; itemIndex += 1) { const item = otherItems[itemIndex] || {}; %>
                    <div class="inline-field-row">
                      <input name="physicalRewardOtherItemName" type="text" value="<%= item.name || '' %>" placeholder="Item name">
                      <input name="physicalRewardOtherItemAmount" type="number" min="0" step="0.01" value="<%= item.amount ?? '' %>" placeholder="0.00">
                    </div>
                  <% } %>
                </div>
                <div class="reward-text-fields">
                  <label for="physicalRewardsDescription">Rewards Description</label>
                  <textarea id="physicalRewardsDescription" name="physicalRewardsDescription" rows="3" placeholder="Describe the physical rewards runners will receive, e.g. finisher medal, shirt, patch."><%= formData.physicalRewardsDescription || '' %></textarea>
                  <% if (errors.physicalRewardsDescription) { %><small class="error-text"><%= errors.physicalRewardsDescription %></small><% } %>
                  <label for="physicalRewardsClaimingNotes">Claiming Instructions (Optional)</label>
                  <textarea id="physicalRewardsClaimingNotes" name="physicalRewardsClaimingNotes" rows="2" placeholder="How and where runners claim their rewards or merchandise."><%= formData.physicalRewardsClaimingNotes || '' %></textarea>
                </div>
              </div>
            </div>
            <details class="subsection-toolkit form-group form-group-full physical-reward-fields" style="display:<%= formData.physicalRewardsEnabled ? '' : 'none' %>;" <%= (formData.claimingMethod && formData.claimingMethod !== 'pickup') || formData.deliveryFeeDescription || formData.requiresDeliveryAddress ? 'open' : '' %>>
              <summary class="subsection-toolkit-summary">Delivery &amp; Fulfilment</summary>
              <div class="subsection-toolkit-body">
                <div class="form-grid compact-grid">
                  <div class="form-group">
                    <label for="claimingMethod">Claiming Method</label>
                    <select id="claimingMethod" name="claimingMethod">
                      <option value="pickup" <%= (!formData.claimingMethod || formData.claimingMethod === 'pickup') ? 'selected' : '' %>>Pickup only (no delivery fee)</option>
                      <option value="delivery" <%= formData.claimingMethod === 'delivery' ? 'selected' : '' %>>Delivery only</option>
                      <option value="both" <%= formData.claimingMethod === 'both' ? 'selected' : '' %>>Delivery or Pickup</option>
                    </select>
                  </div>
                  <div class="form-group" id="deliveryFeeAmountGroup" style="display:<%= (formData.claimingMethod === 'delivery' || formData.claimingMethod === 'both') ? '' : 'none' %>;">
                    <label for="deliveryFeeAmount">Delivery Fee</label>
                    <input id="deliveryFeeAmount" name="deliveryFeeAmount" type="number" min="0" step="0.01" value="<%= formData.deliveryFeeAmount ?? '' %>" placeholder="0.00">
                    <input type="hidden" name="deliveryFeeEnabled" value="1">
                  </div>
                </div>
                <textarea name="deliveryFeeDescription" rows="2" placeholder="Claiming or delivery instructions for runners."><%= formData.deliveryFeeDescription || '' %></textarea>
                <div id="deliveryAddressFields" style="display:<%= (formData.claimingMethod === 'delivery' || formData.claimingMethod === 'both') ? '' : 'none' %>;">
                  <div class="checkbox-row">
                    <label><input type="checkbox" name="requiresDeliveryAddress" value="1" <%= formData.requiresDeliveryAddress ? 'checked' : '' %>> Require delivery address from runner</label>
                    <label><input type="checkbox" name="requiresPhilippineDeliveryAddress" value="1" <%= formData.requiresPhilippineDeliveryAddress ? 'checked' : '' %>> Philippines addresses only</label>
                  </div>
                </div>
                <div class="checkbox-row">
                  <input type="hidden" name="internationalRunnersAllowed" value="0">
                  <label><input type="checkbox" name="internationalRunnersAllowed" value="1" <%= formData.internationalRunnersAllowed ? 'checked' : '' %>> International runners allowed</label>
                </div>
              </div>
            </details>
          </div>
        </div>

        <!-- EVENT DETAILS SECTION -->
        <div id="event-details-step" class="form-section form-section-details" tabindex="-1" data-wizard-step="event-details-step">
          <div class="section-kicker">Step 9 of 12</div>
          <div class="section-title">Event Details</div>
          <p class="section-helper">Use this section for full event rules, FAQs, pricing explanation, submission rules, and runner guidance.</p>
          <div class="waiver-panels">
            <div class="waiver-panel <%= errors.eventDetailsMarkdown ? 'has-error' : '' %>">
              <div class="waiver-label-row">
                <label for="eventDetailsEditor">Event Details</label>
                <button type="button" id="clearEventDetailsBtn" class="btn btn-outline waiver-icon-btn" aria-label="Clear content" title="Clear all content">
                  <i data-lucide="eraser"></i>
                </button>
              </div>
              <div id="eventDetailsEditor" class="waiver-editor"></div>
              <input type="hidden" id="eventDetailsMarkdown" name="eventDetailsMarkdown" value="<%= formData.eventDetailsMarkdown || '' %>">
              <small class="field-hint">Full editable content shown on the public event page. Add rules, reward inclusions, FAQs, proof instructions, and important deadlines here.</small>
              <% if (errors.eventDetailsMarkdown) { %><small class="error-text"><%= errors.eventDetailsMarkdown %></small><% } %>
            </div>
            <div class="waiver-panel">
              <label>Preview</label>
              <div id="eventDetailsPreview" class="waiver-preview-box" aria-live="polite"></div>
              <small class="field-hint">Preview of the formatted content as it will appear on the event page.</small>
            </div>
          </div>
        </div>

        <!-- WAIVER SECTION (same as create) -->
        <div id="waiver-step" class="form-section form-section-waiver" tabindex="-1" data-wizard-step="waiver-step">
          <div class="section-kicker">Step 11 of 12</div>
          <div class="section-title">Waiver (Required for publishing)</div>
          <div class="waiver-panels">
            <div class="waiver-panel <%= errors.waiverTemplate ? 'has-error' : '' %>">
              <label for="waiverEditor">Waiver Template *</label>
              <div class="waiver-toolbar">
                <button type="button" id="insertOrganizerPlaceholderBtn" class="btn btn-outline waiver-icon-btn" aria-label="Insert Organizer Name" title="Insert Organizer Name">
                  <i data-lucide="user-round"></i>
                </button>
                <button type="button" id="insertEventPlaceholderBtn" class="btn btn-outline waiver-icon-btn" aria-label="Insert Event Title" title="Insert Event Title">
                  <i data-lucide="file-text"></i>
                </button>
                <button type="button" id="resetWaiverBtn" class="btn btn-outline waiver-icon-btn" aria-label="Reset to Default Waiver" title="Reset to Default Waiver">
                  <i data-lucide="rotate-ccw"></i>
                </button>
              </div>
              <div id="waiverEditor" class="waiver-editor"></div>
              <input type="hidden" id="waiverTemplate" name="waiverTemplate" value="<%= formData.waiverTemplate || '' %>">
              <small class="field-hint">
                Use placeholders: <code>{{ORGANIZER_NAME}}</code> and <code>{{EVENT_TITLE}}</code>.
                Changing this will bump waiver version for new registrants.
              </small>
              <% if (errors.waiverTemplate) { %><small class="error-text"><%= errors.waiverTemplate %></small><% } %>
            </div>
            <div class="waiver-panel">
              <label>Waiver Preview</label>
              <div id="waiverPreview" class="waiver-preview-box" aria-live="polite"></div>
              <small class="field-hint">
                Preview replaces placeholders using current Organizer Name and Event Title values.
              </small>
            </div>
          </div>
        </div>

        <!-- SCHEDULE SECTION (same as create) -->
        <div id="schedule-step" class="form-section form-section-schedule" tabindex="-1" data-wizard-step="schedule-step">
          <div class="section-kicker">Step 3 of 12</div>
          <div class="section-title">Schedule</div>
          <div class="form-grid">
            <div class="form-group">
              <label for="registrationOpenAt">Registration Open *</label>
              <div class="input-with-button">
                <input id="registrationOpenAt" name="registrationOpenAt" type="datetime-local" value="<%= formData.registrationOpenAt %>" required>
                <button type="button" class="btn-now" data-target="registrationOpenAt">Now</button>
              </div>
            </div>
            <div class="form-group">
              <label for="registrationCloseAt">Registration Close *</label>
              <div class="input-with-button">
                <input id="registrationCloseAt" name="registrationCloseAt" type="datetime-local" value="<%= formData.registrationCloseAt %>" required>
                <button type="button" class="btn-now" data-target="registrationCloseAt">Now</button>
              </div>
              <small class="field-hint">For virtual events, registration can stay open after the event starts.</small>
            </div>
            <div class="form-group">
              <label for="eventStartAt">Event Start *</label>
              <div class="input-with-button">
                <input id="eventStartAt" name="eventStartAt" type="datetime-local" value="<%= formData.eventStartAt %>" required>
                <button type="button" class="btn-now" data-target="eventStartAt">Now</button>
              </div>
            </div>
            <div class="form-group">
              <label for="eventEndAt">Event End *</label>
              <div class="input-with-button">
                <input id="eventEndAt" name="eventEndAt" type="datetime-local" value="<%= formData.eventEndAt %>" required>
                <button type="button" class="btn-now" data-target="eventEndAt">Now</button>
              </div>
            </div>
          </div>
        </div>

        <!-- LOCATION SECTION (conditional) -->
        <div id="location-virtual-step" class="wizard-step-anchor" aria-hidden="true"></div>
        <div class="form-section form-section-location location-section" tabindex="-1" data-wizard-step="location-virtual-step" style="display: none;">
          <div class="section-kicker">Step 4 of 12</div>
          <div class="section-title">Location (required for on-site/hybrid publishing)</div>
          <div class="form-grid">
            <div class="form-group">
              <label for="venueName">Venue Name</label>
              <input id="venueName" name="venueName" type="text" value="<%= formData.venueName %>">
            </div>
            <div class="form-group">
              <label for="city">City</label>
              <input id="city" name="city" type="text" value="<%= formData.city %>">
            </div>
            <div class="form-group form-group-full">
              <label for="venueAddress">Venue Address</label>
              <input id="venueAddress" name="venueAddress" type="text" value="<%= formData.venueAddress %>">
            </div>
            <div class="form-group">
              <label for="province">Province/State</label>
              <input id="province" name="province" type="text" value="<%= formData.province %>">
            </div>
            <div class="form-group">
              <label for="country">Country</label>
              <% const countryCodes = (countries || []).map((item) => item.code); %>
              <select id="country" name="country">
                <option value="">Select country</option>
                <% (countries || []).forEach((item) => { %>
                  <option value="<%= item.code %>" <%= formData.country === item.code ? 'selected' : '' %>><%= item.name %></option>
                <% }); %>
                <% if (formData.country && !countryCodes.includes(formData.country)) { %>
                  <option value="<%= formData.country %>" selected><%= formData.country %> (legacy)</option>
                <% } %>
              </select>
            </div>
            <div class="form-group">
              <label for="geoLat">Latitude (optional)</label>
              <input id="geoLat" name="geoLat" type="text" value="<%= formData.geoLat %>" placeholder="e.g., 14.5995">
            </div>
            <div class="form-group">
              <label for="geoLng">Longitude (optional)</label>
              <input id="geoLng" name="geoLng" type="text" value="<%= formData.geoLng %>" placeholder="e.g., 120.9842">
            </div>
          </div>
        </div>

        <!-- VIRTUAL RULES SECTION (conditional) -->
        <div class="form-section form-section-virtual virtual-section" tabindex="-1" data-wizard-step="location-virtual-step" style="display: none;">
          <div class="section-kicker">Step 4 of 12</div>
          <div class="section-title">Virtual Rules (required for virtual/hybrid publishing)</div>
          <div class="form-grid">
            <div class="form-group form-group-full <%= errors.virtualCompletionMode ? 'has-error' : '' %>">
              <label for="virtualCompletionMode" class="label-with-help">
                Event Format
                <span class="field-help-icon" tabindex="0" aria-label="Single activity means each runner submits one final run result. Accumulated distance means runners can submit multiple activity entries that add up toward the target distance.">?</span>
              </label>
              <select id="virtualCompletionMode" name="virtualCompletionMode">
                <option value="single_activity" <%= formData.virtualCompletionMode === 'single_activity' ? 'selected' : '' %>>Single activity</option>
                <option value="accumulated_distance" <%= formData.virtualCompletionMode === 'accumulated_distance' ? 'selected' : '' %>>Accumulated distance challenge</option>
              </select>
              <small class="field-hint">Accumulated distance challenges accept multiple activity proofs and track approved progress toward the target.</small>
              <% if (errors.virtualCompletionMode) { %><small class="error-text"><%= errors.virtualCompletionMode %></small><% } %>
            </div>

            <div class="form-group form-group-full accumulated-settings" style="display: none;">
              <label>Accumulated Challenge Setup</label>
              <div class="form-grid">
                <div class="form-group <%= errors.targetDistanceKm ? 'has-error' : '' %>">
                  <label for="targetDistanceKm" class="label-with-help">
                    Target Distance
                    <span class="field-help-icon" tabindex="0" aria-label="Target Distance is the numeric completion goal used for accumulated progress. Race Distances are registration labels; this value controls when the runner reaches completion.">?</span>
                  </label>
                  <div class="distance-input-shell">
                    <input id="targetDistanceKm" name="targetDistanceKm" type="number" min="0" step="0.01" value="<%= formData.targetDistanceKm || '' %>" placeholder="100" aria-describedby="targetDistanceHint">
                    <span>km</span>
                  </div>
                  <small id="targetDistanceHint" class="field-hint distance-auto-hint">If exactly one race distance is selected, this can be auto-filled from that distance.</small>
                  <% if (errors.targetDistanceKm) { %><small class="error-text"><%= errors.targetDistanceKm %></small><% } %>
                </div>
                <div class="form-group">
                  <label for="finalSubmissionDeadlineAt" class="label-with-help">
                    Final Submission Deadline
                    <span class="field-help-icon" tabindex="0" aria-label="Defaults to 14 days after Event End, giving runners time to upload proof while the event itself still ends on the Event End date.">?</span>
                  </label>
                  <input id="finalSubmissionDeadlineAt" name="finalSubmissionDeadlineAt" type="datetime-local" value="<%= formData.finalSubmissionDeadlineAt || '' %>">
                  <small id="finalSubmissionDeadlineHint" class="field-hint">Auto-filled from Event End plus 14 days unless you edit it.</small>
                </div>
                <div class="form-group form-group-full">
                  <label>Accepted Activity Types</label>
                  <div class="checkbox-row">
                    <% const selectedRunTypes = formData.acceptedRunTypes || []; %>
                    <label><input type="checkbox" name="acceptedRunTypes" value="run" <%= selectedRunTypes.includes('run') ? 'checked' : '' %>> Run</label>
                    <label><input type="checkbox" name="acceptedRunTypes" value="walk" <%= selectedRunTypes.includes('walk') ? 'checked' : '' %>> Walk</label>
                    <label><input type="checkbox" name="acceptedRunTypes" value="hike" <%= selectedRunTypes.includes('hike') ? 'checked' : '' %>> Hike</label>
                    <label><input type="checkbox" name="acceptedRunTypes" value="trail_run" <%= selectedRunTypes.includes('trail_run') ? 'checked' : '' %>> Trail run</label>
                  </div>
                  <% if (errors.acceptedRunTypes) { %><small class="error-text"><%= errors.acceptedRunTypes %></small><% } %>
                </div>
                <div class="form-group">
                  <label for="recognitionMode">Recognition Mode</label>
                  <select id="recognitionMode" name="recognitionMode">
                    <option value="completion_only" <%= formData.recognitionMode === 'completion_only' ? 'selected' : '' %>>Completion only</option>
                    <option value="completion_with_optional_ranking" <%= formData.recognitionMode === 'completion_with_optional_ranking' ? 'selected' : '' %>>Completion with optional ranking</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="leaderboardMode">Leaderboard Mode</label>
                  <select id="leaderboardMode" name="leaderboardMode">
                    <option value="finishers" <%= formData.leaderboardMode === 'finishers' ? 'selected' : '' %>>Finishers</option>
                    <option value="top_distance" <%= formData.leaderboardMode === 'top_distance' ? 'selected' : '' %>>Top distance</option>
                    <option value="finishers_and_top_distance" <%= formData.leaderboardMode === 'finishers_and_top_distance' ? 'selected' : '' %>>Finishers and top distance</option>
                  </select>
                </div>
                <div class="form-group form-group-full">
                  <label>Leaderboard Recognition</label>
                  <div class="checkbox-row">
                    <label><input type="checkbox" name="leaderboardRecognitionEnabled" value="1" <%= formData.leaderboardRecognitionEnabled ? 'checked' : '' %>> Include participants in leaderboard recognition</label>
                  </div>
                  <small class="field-hint">Controls whether leaderboard recognition is advertised for this accumulated challenge.</small>
                </div>
              </div>
            </div>
            <div class="form-group">
              <label for="virtualStartAt" class="label-with-help">
                Virtual Window Start
                <span class="field-help-icon" tabindex="0" aria-label="Defaults to Event Start when left blank. Change this only if virtual proof should open earlier or later than the public event start.">?</span>
              </label>
              <div class="input-with-button">
                <input id="virtualStartAt" name="virtualStartAt" type="datetime-local" value="<%= formData.virtualStartAt %>">
                <button type="button" class="btn-now" data-target="virtualStartAt">Now</button>
              </div>
              <small class="field-hint">First date and time runners can complete or submit virtual activity proof.</small>
            </div>
            <div class="form-group">
              <label for="virtualEndAt" class="label-with-help">
                Virtual Window End
                <span class="field-help-icon" tabindex="0" aria-label="Defaults to Event End when left blank. For accumulated challenges, the separate final submission deadline can still give runners extra upload time.">?</span>
              </label>
              <div class="input-with-button">
                <input id="virtualEndAt" name="virtualEndAt" type="datetime-local" value="<%= formData.virtualEndAt %>">
                <button type="button" class="btn-now" data-target="virtualEndAt">Now</button>
              </div>
              <small class="field-hint">Last date and time eligible virtual activity proof can count.</small>
            </div>
            <div class="form-group form-group-full">
              <label>Proof Types Allowed</label>
              <div class="checkbox-row">
                <% const selectedProofs = formData.proofTypesAllowed || []; %>
                <label><input type="checkbox" name="proofTypesAllowed" value="gps" <%= selectedProofs.includes('gps') ? 'checked' : '' %>> GPS</label>
                <label><input type="checkbox" name="proofTypesAllowed" value="photo" <%= selectedProofs.includes('photo') ? 'checked' : '' %>> Photo</label>
                <label><input type="checkbox" name="proofTypesAllowed" value="manual" <%= selectedProofs.includes('manual') ? 'checked' : '' %>> Manual</label>
              </div>
            </div>
          </div>
        </div>

        <div id="race-categories-step" class="form-section form-section-race-categories" tabindex="-1" data-wizard-step="race-categories-step">
          <div class="section-kicker">Step 5 of 12</div>
          <div class="section-title">Race Categories</div>
          <p class="section-helper" id="raceCategoryHelper">Select the distances or categories runners can join.</p>
          <div class="form-grid">
            <div class="form-group form-group-full">
              <label>Race Distances *</label>
              <div class="checkbox-row">
                <% const selectedDistances = formData.raceDistancePresets || []; %>
                <label><input type="checkbox" name="raceDistancePresets" value="3K" <%= selectedDistances.includes('3K') ? 'checked' : '' %>> 3K</label>
                <label><input type="checkbox" name="raceDistancePresets" value="5K" <%= selectedDistances.includes('5K') ? 'checked' : '' %>> 5K</label>
                <label><input type="checkbox" name="raceDistancePresets" value="10K" <%= selectedDistances.includes('10K') ? 'checked' : '' %>> 10K</label>
                <label><input type="checkbox" name="raceDistancePresets" value="21K" <%= selectedDistances.includes('21K') ? 'checked' : '' %>> 21K</label>
              </div>
              <label for="raceDistanceCustom" style="margin-top:0.5rem;">Custom Distances (comma-separated)</label>
              <input id="raceDistanceCustom" name="raceDistanceCustom" type="text" value="<%= formData.raceDistanceCustom || '' %>" placeholder="e.g., 42K, 50K">
              <small class="field-hint">Final values are normalized like 3K, 5K, 10K.</small>
            </div>
          </div>
        </div>

        <!-- BRANDING & MEDIA SECTION (adapted for edit) -->
        <div id="media-step" class="form-section form-section-media" tabindex="-1" data-wizard-step="media-step">
          <div class="section-kicker">Step 10 of 12</div>
          <div class="section-title">Branding & Media</div>

          <!-- Logo -->
          <div class="media-block">
            <h3>1) Event Logo</h3>
            <p>Small square or transparent image.</p>
            <p class="media-used-in"><strong>Used in:</strong> Event listings, leaderboard header, search results.</p>
            <p class="media-rules">Optional. JPG/PNG only, max 5MB.</p>

            <!-- Existing logo preview if any -->
            <% if (formData.logoUrl) { %>
            <div class="branding-preview-wrap" id="logoPreviewWrap">
              <button type="button" class="branding-remove-btn" id="removeLogoBtn" aria-label="Remove current logo image">x</button>
              <img src="<%= formData.logoUrl %>" alt="Current logo" style="max-width:80px;max-height:80px;border-radius:8px;margin-bottom:1rem;">
            </div>
            <input type="hidden" id="removeLogoImage" name="removeLogoImage" value="0">
            <% } %>

            <!-- Upload area for new logo -->
            <div class="upload-area" id="logoUploadArea">
              <input type="file" id="logoFile" name="logoFile" accept="image/jpeg,image/png,image/webp">
              <div class="upload-placeholder">
                <i data-lucide="upload-cloud"></i>
                <p>Drag & drop or click to upload new logo</p>
                <small>Square image recommended (200x200+), JPG/PNG, max 5MB</small>
              </div>
              <div class="upload-preview" id="logoPreviewContainer" style="display: none;">
                <img id="logoPreviewImg" src="#" alt="New logo preview">
                <button type="button" class="remove-upload" aria-label="Remove new logo" data-for="logo">x</button>
              </div>
            </div>
            <label for="logoUrl" style="margin-top:0.75rem; display:block;">Logo URL (optional)</label>
            <input id="logoUrl" name="logoUrl" type="url" value="<%= formData.logoUrl %>" placeholder="https://...">
            <small class="field-hint">If both URL and file are provided, uploaded file will be used.</small>
          </div>

          <!-- Banner -->
          <div class="media-block">
            <h3>2) Event Banner</h3>
            <p>Wide rectangular image for event branding.</p>
            <p class="media-used-in"><strong>Used in:</strong> Event page hero section, landing page, promotional header.</p>
            <p class="media-rules">Optional. JPG/PNG only, max 5MB. Recommended ratio: 3:1.</p>

            <% if (formData.bannerImageUrl) { %>
            <div class="branding-preview-wrap" id="bannerPreviewWrap">
              <button type="button" class="branding-remove-btn" id="removeBannerBtn" aria-label="Remove current banner image">x</button>
              <img src="<%= formData.bannerImageUrl %>" alt="Current banner" style="max-width:100%;max-height:120px;border-radius:6px;margin-bottom:1rem;">
            </div>
            <input type="hidden" id="removeBannerImage" name="removeBannerImage" value="0">
            <% } %>

            <div class="upload-area" id="bannerUploadArea">
              <input type="file" id="bannerFile" name="bannerImageFile" accept="image/jpeg,image/png,image/webp">
              <div class="upload-placeholder">
                <i data-lucide="upload-cloud"></i>
                <p>Drag & drop or click to upload new banner</p>
                <small>Recommended ratio 3:1, JPG/PNG, max 5MB</small>
              </div>
              <div class="upload-preview" id="bannerPreviewContainer" style="display: none;">
                <img id="bannerPreviewImg" src="#" alt="New banner preview">
                <button type="button" class="remove-upload" aria-label="Remove new banner" data-for="banner">x</button>
              </div>
            </div>
            <label for="bannerImageUrl" style="margin-top:0.75rem; display:block;">Banner URL (optional)</label>
            <input id="bannerImageUrl" name="bannerImageUrl" type="url" value="<%= formData.bannerImageUrl %>" placeholder="https://...">
          </div>

          <!-- Poster -->
          <div class="media-block">
            <h3>3) Promotional Poster</h3>
            <p>Edited promotional image (details, dates, sponsors, prizes, instructions).</p>
            <p class="media-used-in"><strong>Used in:</strong> Event details page and promotional header blocks.</p>
            <p class="media-rules">Optional. JPG/PNG only, max 5MB.</p>

            <% if (formData.posterImageUrl) { %>
            <div class="branding-preview-wrap" id="posterPreviewWrap">
              <button type="button" class="branding-remove-btn" id="removePosterBtn" aria-label="Remove current poster">x</button>
              <img src="<%= formData.posterImageUrl %>" alt="Current poster" style="max-width:100%;max-height:220px;border-radius:8px;margin-bottom:1rem;">
            </div>
            <input type="hidden" id="removePosterImage" name="removePosterImage" value="0">
            <% } %>

            <div class="upload-area" id="posterUploadArea">
              <input type="file" id="posterFile" name="posterImageFile" accept="image/jpeg,image/png,image/webp">
              <div class="upload-placeholder">
                <i data-lucide="upload-cloud"></i>
                <p>Drag & drop or click to upload new poster</p>
                <small>JPG/PNG, max 5MB</small>
              </div>
              <div class="upload-preview" id="posterPreviewContainer" style="display: none;">
                <img id="posterPreviewImg" src="#" alt="New poster preview">
                <button type="button" class="remove-upload" aria-label="Remove new poster" data-for="poster">x</button>
              </div>
            </div>
            <label for="posterImageUrl" style="margin-top:0.75rem; display:block;">Poster URL (optional)</label>
            <input id="posterImageUrl" name="posterImageUrl" type="url" value="<%= formData.posterImageUrl %>" placeholder="https://...">
          </div>

          <!-- Gallery -->
          <div class="media-block">
            <h3>4) Gallery Images (Optional)</h3>
            <p>Past event photos, route preview, medal preview.</p>
            <p class="media-used-in"><strong>Used in:</strong> Event details gallery section.</p>
            <p class="media-rules">Optional. JPG/PNG only, max 5MB each, up to 12 images.</p>

            <input type="hidden" id="removeGalleryImages" name="removeGalleryImages" value="0">

            <!-- Existing gallery images -->
            <% if (formData.galleryImageUrls && formData.galleryImageUrls.length) { %>
            <div class="gallery-preview-grid" id="galleryPreviewGrid">
              <% formData.galleryImageUrls.forEach((galleryUrl, galleryIndex) => { %>
                <div class="gallery-thumb-wrap" data-gallery-url="<%- galleryUrl %>">
                  <button type="button" class="gallery-remove-btn" data-gallery-url="<%- galleryUrl %>" aria-label="Remove gallery image <%= galleryIndex + 1 %>">x</button>
                  <img src="<%= galleryUrl %>" alt="Gallery Preview <%= galleryIndex + 1 %>" class="gallery-preview-thumb">
                </div>
              <% }) %>
            </div>
            <button type="button" class="btn btn-outline btn-remove-all-gallery" id="removeAllGalleryBtn">Remove all gallery images</button>
            <% } else { %>
            <div class="gallery-preview-grid" id="galleryPreviewGrid"></div>
            <% } %>

            <!-- Upload area for new gallery images -->
            <div class="upload-area" id="galleryUploadArea">
              <input type="file" id="galleryFiles" name="galleryImageFiles" accept="image/jpeg,image/png,image/webp" multiple>
              <div class="upload-placeholder">
                <i data-lucide="images"></i>
                <p>Drag & drop or click to upload up to 12 new images</p>
                <small>JPG/PNG, max 5MB each</small>
              </div>
            </div>

            <label for="galleryImageUrlsText" style="margin-top:0.75rem; display:block;">Gallery Image URLs (optional)</label>
            <textarea id="galleryImageUrlsText" name="galleryImageUrlsText" rows="5" placeholder="One URL per line, or comma-separated"><%= formData.galleryImageUrlsText || '' %></textarea>
          </div>
        </div>

        <div id="review-step" class="form-section form-section-review" tabindex="-1" data-wizard-step="review-step">
          <div class="section-kicker">Step 12 of 12</div>
          <div class="section-title">Review Changes</div>
          <p class="section-helper">Preview the event page, save your updates, or submit this draft for admin review.</p>
          <div id="submitReadinessChecklist" class="submit-readiness-checklist" aria-live="polite"></div>
          <div class="review-summary-notes">
            <p class="field-hint"><strong>Save Changes</strong> keeps the current event status.</p>
            <% if (event.status === 'draft') { %>
              <p class="field-hint"><strong>Submit for Review</strong> saves changes and validates required publishing fields before moving the draft to admin review.</p>
            <% } %>
          </div>
          <div class="actions">
            <div class="action-btn-group">
              <a href="<%= typeof backHref !== 'undefined' ? backHref : `/organizer/events/${event._id}` %>" class="btn btn-secondary btn-adaptive" aria-label="Back to Event" data-tooltip="Back to Event">
                <i data-lucide="arrow-left"></i><span class="btn-label">Back to Event</span>
              </a>
              <button type="button" class="btn btn-outline btn-adaptive" id="previewBtn" aria-label="Preview" data-tooltip="Preview">
                <i data-lucide="eye"></i><span class="btn-label">Preview</span>
              </button>
              <button type="submit" name="actionType" value="draft" class="btn btn-outline btn-adaptive" id="saveBtn" aria-label="Save Changes" data-tooltip="Save Changes">
                <i data-lucide="save"></i><span class="btn-label">Save Changes</span>
                <span class="spinner" style="display: none;"></span>
              </button>
              <% if (event.status === 'draft') { %>
                <button type="submit" name="actionType" value="publish" id="submitReviewBtn" class="btn btn-primary btn-adaptive" aria-label="Submit for Review" data-tooltip="Submit for Review">
                  <i data-lucide="send"></i><span class="btn-label">Submit for Review</span>
                  <span class="spinner" style="display: none;"></span>
                </button>
              <% } %>
            </div>
          </div>
        </div>

        <div class="wizard-nav-overlay" id="wizardNavOverlay" aria-hidden="true">
          <button type="button" class="wizard-nav-overlay-backdrop" id="wizardNavOverlayBackdrop" aria-label="Close steps panel"></button>
          <div class="wizard-nav-overlay-panel" role="dialog" aria-label="Event builder steps">
            <div class="wizard-nav-overlay-header">
              <span>Event Builder</span>
              <button type="button" class="wizard-nav-overlay-close" id="wizardNavOverlayClose" aria-label="Close steps panel">
                <i data-lucide="x"></i>
              </button>
            </div>
            <ol class="wizard-nav-overlay-list">
              <li><a href="#event-type-step" data-overlay-step="event-type-step"><span class="overlay-step-num">1</span> Event Type</a></li>
              <li><a href="#core-details-step" data-overlay-step="core-details-step"><span class="overlay-step-num">2</span> Core Details</a></li>
              <li><a href="#schedule-step" data-overlay-step="schedule-step"><span class="overlay-step-num">3</span> Schedule</a></li>
              <li><a href="#location-virtual-step" data-overlay-step="location-virtual-step"><span class="overlay-step-num">4</span> Location or Virtual Rules</a></li>
              <li><a href="#race-categories-step" data-overlay-step="race-categories-step"><span class="overlay-step-num">5</span> Race Categories</a></li>
              <li><a href="#rewards-step" data-overlay-step="rewards-step"><span class="overlay-step-num">6</span> Rewards &amp; Inclusions</a></li>
              <li><a href="#pricing-step" data-overlay-step="pricing-step"><span class="overlay-step-num">7</span> Pricing</a></li>
              <li><a href="#payment-setup-step" data-overlay-step="payment-setup-step"><span class="overlay-step-num">8</span> Payment Setup</a></li>
              <li><a href="#event-details-step" data-overlay-step="event-details-step"><span class="overlay-step-num">9</span> Event Details</a></li>
              <li><a href="#media-step" data-overlay-step="media-step"><span class="overlay-step-num">10</span> Branding &amp; Media</a></li>
              <li><a href="#waiver-step" data-overlay-step="waiver-step"><span class="overlay-step-num">11</span> Waiver</a></li>
              <li><a href="#review-step" data-overlay-step="review-step"><span class="overlay-step-num">12</span> Review</a></li>
            </ol>
          </div>
        </div>
        </div>
      </form>
    </section>
  </main>

  <%- include('../layouts/footer') %>

  <script src="/js/main.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
  <script>
    (function() {
      lucide.createIcons();

      const nav = document.querySelector('nav');
      function setWizardNavOffset() {
        const navHeight = nav ? nav.offsetHeight : 0;
        document.documentElement.style.setProperty('--nav-h', navHeight + 'px');
      }
      setWizardNavOffset();
      window.addEventListener('resize', setWizardNavOffset);

      const WIZARD_TOTAL_STEPS = 12;
      const wizardSections = Array.from(document.querySelectorAll('[data-wizard-step]'));
      const progressLinks = Array.from(document.querySelectorAll('[data-step-link]'));
      const pillLinks = Array.from(document.querySelectorAll('[data-pill-step]'));
      const overlayLinks = Array.from(document.querySelectorAll('[data-overlay-step]'));
      const wizardMiniStepEl = document.getElementById('wizardMiniStep');
      const wizardMiniTitleEl = document.getElementById('wizardMiniTitle');
      const wizardMiniProgressFillEl = document.getElementById('wizardMiniProgressFill');
      const stepMeta = {
        'event-type-step': { num: 1, label: 'Event Type' },
        'core-details-step': { num: 2, label: 'Core Details' },
        'schedule-step': { num: 3, label: 'Schedule' },
        'location-virtual-step': { num: 4, label: 'Location / Virtual' },
        'race-categories-step': { num: 5, label: 'Race Categories' },
        'rewards-step': { num: 6, label: 'Rewards' },
        'pricing-step': { num: 7, label: 'Pricing' },
        'payment-setup-step': { num: 8, label: 'Payment' },
        'event-details-step': { num: 9, label: 'Event Details' },
        'media-step': { num: 10, label: 'Media' },
        'waiver-step': { num: 11, label: 'Waiver' },
        'review-step': { num: 12, label: 'Review' }
      };

      function setActiveWizardStep(stepId) {
        progressLinks.forEach((link) => link.classList.toggle('is-active', link.dataset.stepLink === stepId));
        pillLinks.forEach((link) => {
          link.classList.toggle('is-active', link.dataset.pillStep === stepId);
          if (link.dataset.pillStep === stepId) {
            link.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
          }
        });
        overlayLinks.forEach((link) => link.classList.toggle('is-active', link.dataset.overlayStep === stepId));
        const meta = stepMeta[stepId];
        if (meta) {
          if (wizardMiniStepEl) wizardMiniStepEl.textContent = 'Step ' + meta.num + ' of ' + WIZARD_TOTAL_STEPS;
          if (wizardMiniTitleEl) wizardMiniTitleEl.textContent = meta.label;
          if (wizardMiniProgressFillEl) wizardMiniProgressFillEl.style.width = ((meta.num / WIZARD_TOTAL_STEPS) * 100).toFixed(2) + '%';
        }
        if (stepId === 'review-step') buildReadinessChecklist();
      }

      if (wizardSections.length) {
        const observer = new IntersectionObserver((entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (visible?.target?.dataset?.wizardStep) {
            setActiveWizardStep(visible.target.dataset.wizardStep);
          }
        }, { rootMargin: '-20% 0px -65% 0px', threshold: [0.15, 0.35, 0.6] });
        wizardSections.forEach((section) => observer.observe(section));
      }

      const wizardMiniToggleBtn = document.getElementById('wizardMiniToggle');
      const wizardNavOverlayEl = document.getElementById('wizardNavOverlay');
      const wizardNavOverlayCloseBtn = document.getElementById('wizardNavOverlayClose');
      const wizardNavOverlayBackdropEl = document.getElementById('wizardNavOverlayBackdrop');
      function openWizardNavOverlay() {
        if (!wizardNavOverlayEl) return;
        wizardNavOverlayEl.classList.add('is-open');
        wizardNavOverlayEl.setAttribute('aria-hidden', 'false');
        if (wizardMiniToggleBtn) wizardMiniToggleBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
      function closeWizardNavOverlay() {
        if (!wizardNavOverlayEl) return;
        wizardNavOverlayEl.classList.remove('is-open');
        wizardNavOverlayEl.setAttribute('aria-hidden', 'true');
        if (wizardMiniToggleBtn) wizardMiniToggleBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
      wizardMiniToggleBtn?.addEventListener('click', openWizardNavOverlay);
      wizardNavOverlayCloseBtn?.addEventListener('click', closeWizardNavOverlay);
      wizardNavOverlayBackdropEl?.addEventListener('click', closeWizardNavOverlay);
      overlayLinks.forEach((link) => link.addEventListener('click', closeWizardNavOverlay));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && wizardNavOverlayEl?.classList.contains('is-open')) closeWizardNavOverlay();
      });

      const eventTypeSection = document.querySelector('.form-section-event-type');
      if (eventTypeSection && !window.location.hash) {
        eventTypeSection.focus({ preventScroll: true });
        setActiveWizardStep('event-type-step');
      }

      // ---------- CONDITIONAL SECTIONS ----------
      const eventTypeSelect = document.getElementById('eventType');
      const virtualCompletionModeSelect = document.getElementById('virtualCompletionMode');
      const locationSection = document.querySelector('.location-section');
      const virtualSection = document.querySelector('.virtual-section');
      const accumulatedSettings = document.querySelector('.accumulated-settings');
      const targetDistanceInput = document.getElementById('targetDistanceKm');
      const targetDistanceHint = document.getElementById('targetDistanceHint');
      const eventStartInput = document.getElementById('eventStartAt');
      const eventEndInput = document.getElementById('eventEndAt');
      const virtualStartInput = document.getElementById('virtualStartAt');
      const virtualEndInput = document.getElementById('virtualEndAt');
      const finalSubmissionDeadlineInput = document.getElementById('finalSubmissionDeadlineAt');
      const finalSubmissionDeadlineHint = document.getElementById('finalSubmissionDeadlineHint');
      const raceDistanceCustomInput = document.getElementById('raceDistanceCustom');
      const raceDistancePresetInputs = Array.from(document.querySelectorAll('input[name="raceDistancePresets"]'));
      const feeModeSelect = document.getElementById('feeMode');
      const paymentFields = Array.from(document.querySelectorAll('.payment-fields'));
      const physicalRewardsEnabledInput = document.getElementById('physicalRewardsEnabled');
      const physicalRewardFields = Array.from(document.querySelectorAll('.physical-reward-fields'));
      let targetDistanceWasAutoFilled = !targetDistanceInput?.value;
      let virtualStartWasAutoFilled = !virtualStartInput?.value;
      let virtualEndWasAutoFilled = !virtualEndInput?.value;
      let finalSubmissionDeadlineWasAutoFilled = !finalSubmissionDeadlineInput?.value;

      function togglePaymentFields() {
        const isPaid = feeModeSelect?.value === 'paid';
        paymentFields.forEach((field) => {
          field.style.display = isPaid ? '' : 'none';
        });
        const paymentFreeNote = document.querySelector('.payment-free-note');
        if (paymentFreeNote) paymentFreeNote.style.display = isPaid ? 'none' : '';
        const pricingModeInput = document.getElementById('pricingMode');
        if (pricingModeInput) {
          if (!isPaid) {
            pricingModeInput.value = 'free';
          } else if (pricingModeInput.value === 'free') {
            const periodsChecked = document.getElementById('enablePricingPeriods')?.checked;
            pricingModeInput.value = periodsChecked ? 'per_distance_period' : 'per_distance';
          }
        }
        const perDistanceFieldsEl = document.querySelector('.per-distance-fields');
        if (perDistanceFieldsEl) perDistanceFieldsEl.style.display = isPaid ? '' : 'none';
        const pricingFreeNote = document.querySelector('.pricing-free-note');
        if (pricingFreeNote) pricingFreeNote.style.display = isPaid ? 'none' : '';
        if (isPaid) rebuildPerDistanceFeeRows();
      }
      feeModeSelect?.addEventListener('change', togglePaymentFields);
      togglePaymentFields();

      const enablePricingPeriodsCheckbox = document.getElementById('enablePricingPeriods');
      function onEnablePricingPeriodsChange() {
        const pricingModeInput = document.getElementById('pricingMode');
        if (!pricingModeInput) return;
        const isPaid = feeModeSelect?.value === 'paid';
        if (!isPaid) return;
        pricingModeInput.value = enablePricingPeriodsCheckbox?.checked ? 'per_distance_period' : 'per_distance';
        rebuildPerDistanceFeeRows();
      }
      enablePricingPeriodsCheckbox?.addEventListener('change', onEnablePricingPeriodsChange);

      const EXISTING_DISTANCE_PRICING = <%- JSON.stringify((formData.distancePricing || []).map(function(d) { return { distance: d.distance, amount: d.amount, earlyBirdAmount: d.earlyBirdAmount, regularAmount: d.regularAmount, lateAmount: d.lateAmount }; })) %>;

      function getActiveDistances() {
        const presets = Array.from(document.querySelectorAll('input[name="raceDistancePresets"]:checked'))
          .map((cb) => cb.value.trim().toUpperCase().replace(/\s+/g, ''));
        const customRaw = document.getElementById('raceDistanceCustom')?.value || '';
        const customs = customRaw.split(',').map((v) => v.trim().toUpperCase().replace(/\s+/g, '')).filter(Boolean);
        const seen = new Set();
        return [...presets, ...customs].filter((d) => { if (seen.has(d)) return false; seen.add(d); return Boolean(d); });
      }

      function rebuildPerDistanceFeeRows() {
        const container = document.getElementById('perDistanceFeeRows');
        if (!container) return;
        const periodsToggle = document.querySelector('.pricing-periods-toggle');
        const distances = getActiveDistances();
        if (!distances.length) {
          container.innerHTML = '<p class="field-hint per-distance-empty-hint">No race distances selected yet. Add distances in Step 5, then come back here to set fees per distance.</p>';
          if (periodsToggle) periodsToggle.style.display = 'none';
          return;
        }
        if (periodsToggle) periodsToggle.style.display = '';
        const usePeriods = document.getElementById('enablePricingPeriods')?.checked;
        const currency = document.getElementById('feeCurrency')?.value?.trim() || 'PHP';
        const saved = {};
        container.querySelectorAll('.per-distance-fee-row[data-dist]').forEach((row) => {
          const d = row.dataset.dist;
          saved[d] = {
            amount: row.querySelector('input[name="distancePricingAmount"]')?.value ?? '',
            earlyBird: row.querySelector('input[name="distancePricingEarlyBirdAmount"]')?.value ?? '',
            regular: row.querySelector('input[name="distancePricingRegularAmount"]')?.value ?? '',
            late: row.querySelector('input[name="distancePricingLateAmount"]')?.value ?? ''
          };
        });

        container.innerHTML = '';
        if (usePeriods) {
          const header = document.createElement('div');
          header.className = 'per-distance-fee-header';
          header.innerHTML = '<span></span><span>Early Bird</span><span>Regular</span><span>Late <span class="field-help-icon" tabindex="0" aria-label="Optional - leave blank if you do not offer late registration pricing.">?</span></span><span></span>';
          container.appendChild(header);
        }
        distances.forEach((dist) => {
          const existing = EXISTING_DISTANCE_PRICING.find((d) => d.distance === dist) || {};
          const cur = saved[dist] || {};
          const val = (curVal, savedVal) => curVal !== undefined && curVal !== ''
            ? curVal
            : (savedVal !== null && savedVal !== undefined ? savedVal : '');
          const row = document.createElement('div');
          row.className = usePeriods ? 'per-distance-fee-row has-periods' : 'per-distance-fee-row';
          row.dataset.dist = dist;
          if (usePeriods) {
            row.innerHTML = `
              <label>${dist}</label>
              <input type="hidden" name="distancePricingLabel" value="${dist}">
              <input type="hidden" name="distancePricingAmount" value="">
              <input type="number" name="distancePricingEarlyBirdAmount" min="0" step="0.01" value="${val(cur.earlyBird, existing.earlyBirdAmount)}" placeholder="0.00" aria-label="Early bird fee for ${dist}">
              <input type="number" name="distancePricingRegularAmount" min="0" step="0.01" value="${val(cur.regular || cur.amount, existing.regularAmount)}" placeholder="0.00" aria-label="Regular fee for ${dist}">
              <input type="number" name="distancePricingLateAmount" min="0" step="0.01" value="${val(cur.late, existing.lateAmount)}" placeholder="0.00" aria-label="Late fee for ${dist}">
              <span class="per-distance-fee-currency">${currency}</span>
            `;
          } else {
            row.innerHTML = `
              <label>${dist}</label>
              <input type="hidden" name="distancePricingLabel" value="${dist}">
              <input type="number" name="distancePricingAmount" min="0" step="0.01" value="${val(cur.amount || cur.regular, existing.amount)}" placeholder="0.00" aria-label="Fee for ${dist}">
              <input type="hidden" name="distancePricingEarlyBirdAmount" value="">
              <input type="hidden" name="distancePricingRegularAmount" value="">
              <input type="hidden" name="distancePricingLateAmount" value="">
              <span class="per-distance-fee-currency">${currency}</span>
            `;
          }
          container.appendChild(row);
        });
      }

      document.querySelectorAll('input[name="raceDistancePresets"]').forEach((cb) => {
        cb.addEventListener('change', () => { if (feeModeSelect?.value === 'paid') rebuildPerDistanceFeeRows(); });
      });
      document.getElementById('raceDistanceCustom')?.addEventListener('input', () => {
        if (feeModeSelect?.value === 'paid') rebuildPerDistanceFeeRows();
      });

      function togglePhysicalRewardFields() {
        const showPhysicalRewardFields = Boolean(physicalRewardsEnabledInput?.checked);
        physicalRewardFields.forEach((field) => {
          field.style.display = showPhysicalRewardFields ? '' : 'none';
        });
      }
      physicalRewardsEnabledInput?.addEventListener('change', togglePhysicalRewardFields);
      togglePhysicalRewardFields();

      document.getElementById('customMerchandiseEnabled')?.addEventListener('change', function () {
        const fields = document.getElementById('customMerchandiseFields');
        if (fields) fields.style.display = this.checked ? '' : 'none';
      });

      document.getElementById('claimingMethod')?.addEventListener('change', function () {
        const hasDelivery = this.value === 'delivery' || this.value === 'both';
        const feeGroup = document.getElementById('deliveryFeeAmountGroup');
        const addressFields = document.getElementById('deliveryAddressFields');
        if (feeGroup) feeGroup.style.display = hasDelivery ? '' : 'none';
        if (addressFields) addressFields.style.display = hasDelivery ? '' : 'none';
      });
      const isPublishedEdit = <%= event.status === 'published' ? 'true' : 'false' %>;
      const isPendingReviewEdit = <%= event.status === 'pending_review' ? 'true' : 'false' %>;
      const actionOverlay = document.getElementById('actionConfirmOverlay');
      const actionIconWrap = document.getElementById('actionConfirmIconWrap');
      const actionTitleEl = document.getElementById('actionConfirmTitle');
      const actionDescEl = document.getElementById('actionConfirmDesc');
      const actionCancelBtn = document.getElementById('actionConfirmCancelBtn');
      const actionOkBtn = document.getElementById('actionConfirmOkBtn');
      let actionConfirmResolve = null;
      let confirmedSubmitButton = null;

      function openActionDialog({ icon, variant, title, desc, cancelText, okText, okClass }) {
        if (!actionOverlay) return Promise.resolve(window.confirm(title || 'Continue?'));
        if (actionIconWrap) {
          actionIconWrap.innerHTML = '<i data-lucide="' + (icon || 'help-circle') + '"></i>';
          actionIconWrap.dataset.variant = variant || '';
        }
        if (actionTitleEl) actionTitleEl.textContent = title || '';
        if (actionDescEl) actionDescEl.textContent = desc || '';
        if (actionCancelBtn) actionCancelBtn.textContent = cancelText || 'Cancel';
        if (actionOkBtn) {
          actionOkBtn.textContent = okText || 'Confirm';
          actionOkBtn.className = 'draft-confirm-btn ' + (okClass || 'draft-confirm-btn--primary');
        }
        actionOverlay.hidden = false;
        if (window.lucide) lucide.createIcons();
        actionOverlay.querySelector('.draft-confirm-dialog')?.focus();
        return new Promise((resolve) => { actionConfirmResolve = resolve; });
      }

      function closeActionDialog(result) {
        if (actionOverlay) actionOverlay.hidden = true;
        if (actionConfirmResolve) {
          actionConfirmResolve(result);
          actionConfirmResolve = null;
        }
      }

      if (actionCancelBtn) actionCancelBtn.addEventListener('click', () => closeActionDialog(false));
      if (actionOkBtn) actionOkBtn.addEventListener('click', () => closeActionDialog(true));
      if (actionOverlay) {
        actionOverlay.addEventListener('click', (event) => {
          if (event.target === actionOverlay) closeActionDialog(false);
        });
      }
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && actionOverlay && !actionOverlay.hidden) closeActionDialog(false);
      });

      function toggleSections() {
        const val = eventTypeSelect.value;
        locationSection.style.display = (val === 'onsite' || val === 'hybrid') ? 'block' : 'none';
        virtualSection.style.display = (val === 'virtual' || val === 'hybrid') ? 'block' : 'none';
        document.querySelectorAll('[data-event-type-card]').forEach((card) => {
          card.classList.toggle('is-active', card.dataset.eventTypeCard === val);
        });
        const raceCategoryHelper = document.getElementById('raceCategoryHelper');
        if (raceCategoryHelper) {
          raceCategoryHelper.textContent = val === 'virtual'
            ? 'Select the challenge distance labels runners can join.'
            : val === 'onsite'
              ? 'Select the onsite race categories runners can register for.'
              : val === 'hybrid'
                ? 'Select the categories available across onsite and virtual participation.'
                : 'Select the distances or categories runners can join.';
        }
        if (accumulatedSettings && virtualCompletionModeSelect) {
          const showAccumulated = (val === 'virtual' || val === 'hybrid') && virtualCompletionModeSelect.value === 'accumulated_distance';
          accumulatedSettings.style.display = showAccumulated ? 'block' : 'none';
          if (val === 'virtual' || val === 'hybrid') {
            syncVirtualWindowFromEventDates();
          }
          if (showAccumulated) {
            syncTargetDistanceFromRaceDistance();
            syncFinalSubmissionDeadlineFromEventEnd();
          }
        }
      }

      if (eventTypeSelect) {
        eventTypeSelect.addEventListener('change', toggleSections);
        toggleSections();
      }
      if (virtualCompletionModeSelect) {
        virtualCompletionModeSelect.addEventListener('change', toggleSections);
      }

      function parseRaceDistanceKm(label) {
        const value = String(label || '').trim().toUpperCase().replace(/\s+/g, '');
        const match = value.match(/^(\d+(?:\.\d+)?)(K|KM)$/);
        if (!match) return null;
        const distance = Number(match[1]);
        return Number.isFinite(distance) && distance > 0 ? distance : null;
      }

      function getSelectedRaceDistanceTargets() {
        const values = [];
        raceDistancePresetInputs.forEach((input) => {
          if (input.checked) values.push(input.value);
        });
        String(raceDistanceCustomInput?.value || '')
          .split(',')
          .map((item) => item.trim())
          .filter(Boolean)
          .forEach((item) => values.push(item));
        return Array.from(new Set(values.map(parseRaceDistanceKm).filter((item) => item !== null)));
      }

      function syncTargetDistanceFromRaceDistance() {
        if (!targetDistanceInput || !targetDistanceHint) return;
        const targets = getSelectedRaceDistanceTargets();
        if (targets.length === 1 && (!targetDistanceInput.value || targetDistanceWasAutoFilled)) {
          targetDistanceInput.value = String(targets[0]);
          targetDistanceWasAutoFilled = true;
          targetDistanceHint.textContent = `Auto-filled from the selected race distance (${targets[0]} km). Adjust if this event uses a different completion target.`;
          targetDistanceHint.classList.add('is-autofilled');
          targetDistanceHint.classList.remove('is-manual');
          return;
        }
        if (targets.length > 1) {
          targetDistanceHint.textContent = 'Multiple race distances are selected, so set one event-level target manually. Per-distance targets need a future setup model.';
          targetDistanceHint.classList.add('is-manual');
          targetDistanceHint.classList.remove('is-autofilled');
          return;
        }
        targetDistanceHint.textContent = 'If exactly one race distance is selected, this can be auto-filled from that distance.';
        targetDistanceHint.classList.remove('is-autofilled', 'is-manual');
      }

      if (targetDistanceInput) {
        targetDistanceInput.addEventListener('input', () => {
          targetDistanceWasAutoFilled = false;
        });
      }
      raceDistancePresetInputs.forEach((input) => input.addEventListener('change', syncTargetDistanceFromRaceDistance));
      if (raceDistanceCustomInput) {
        raceDistanceCustomInput.addEventListener('input', syncTargetDistanceFromRaceDistance);
      }
      syncTargetDistanceFromRaceDistance();

      function parseDateTimeLocalValue(value) {
        if (!value) return null;
        const parsed = new Date(value);
        return Number.isNaN(parsed.getTime()) ? null : parsed;
      }

      function formatDateTimeLocalValue(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        const hours = String(date.getHours()).padStart(2, '0');
        const minutes = String(date.getMinutes()).padStart(2, '0');
        return `${year}-${month}-${day}T${hours}:${minutes}`;
      }

      function syncVirtualWindowFromEventDates() {
        const eventType = eventTypeSelect?.value;
        if (eventType !== 'virtual' && eventType !== 'hybrid') return;
        if (virtualStartInput && eventStartInput && virtualStartWasAutoFilled) {
          const eventStart = parseDateTimeLocalValue(eventStartInput.value);
          if (eventStart) virtualStartInput.value = formatDateTimeLocalValue(eventStart);
        }
        if (virtualEndInput && eventEndInput && virtualEndWasAutoFilled) {
          const eventEnd = parseDateTimeLocalValue(eventEndInput.value);
          if (eventEnd) virtualEndInput.value = formatDateTimeLocalValue(eventEnd);
        }
      }

      if (virtualStartInput) {
        virtualStartInput.addEventListener('input', () => {
          virtualStartWasAutoFilled = false;
        });
      }
      if (virtualEndInput) {
        virtualEndInput.addEventListener('input', () => {
          virtualEndWasAutoFilled = false;
        });
      }
      if (eventStartInput) {
        eventStartInput.addEventListener('input', syncVirtualWindowFromEventDates);
        eventStartInput.addEventListener('change', syncVirtualWindowFromEventDates);
      }
      if (eventEndInput) {
        eventEndInput.addEventListener('input', syncVirtualWindowFromEventDates);
        eventEndInput.addEventListener('change', syncVirtualWindowFromEventDates);
      }
      syncVirtualWindowFromEventDates();

      function syncFinalSubmissionDeadlineFromEventEnd() {
        if (!finalSubmissionDeadlineInput || !eventEndInput || !finalSubmissionDeadlineWasAutoFilled) return;
        const eventEnd = parseDateTimeLocalValue(eventEndInput.value);
        if (!eventEnd) return;
        const deadline = new Date(eventEnd.getTime());
        deadline.setDate(deadline.getDate() + 14);
        finalSubmissionDeadlineInput.value = formatDateTimeLocalValue(deadline);
        if (finalSubmissionDeadlineHint) {
          finalSubmissionDeadlineHint.textContent = 'Auto-filled from Event End plus 14 days. Edit this field to use a different upload deadline.';
          finalSubmissionDeadlineHint.classList.add('is-autofilled');
          finalSubmissionDeadlineHint.classList.remove('is-manual');
        }
      }

      if (finalSubmissionDeadlineInput) {
        finalSubmissionDeadlineInput.addEventListener('input', () => {
          finalSubmissionDeadlineWasAutoFilled = false;
          if (finalSubmissionDeadlineHint) {
            finalSubmissionDeadlineHint.textContent = 'Custom submission deadline set.';
            finalSubmissionDeadlineHint.classList.add('is-manual');
            finalSubmissionDeadlineHint.classList.remove('is-autofilled');
          }
        });
      }
      if (eventEndInput) {
        eventEndInput.addEventListener('input', syncFinalSubmissionDeadlineFromEventEnd);
        eventEndInput.addEventListener('change', syncFinalSubmissionDeadlineFromEventEnd);
      }
      syncFinalSubmissionDeadlineFromEventEnd();

      function getIndexedInput(name, index) {
        return Array.from(document.querySelectorAll(`input[name="${name}"]`))[Number(index)] || null;
      }

      function setIndexedDateInput(name, index, date) {
        const input = getIndexedInput(name, index);
        if (!input || !date) return;
        input.value = formatDateTimeLocalValue(date);
        input.dispatchEvent(new Event('input', { bubbles: true }));
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }

      function applySuggestedPricingDates(packageIndex) {
        const registrationOpen = parseDateTimeLocalValue(document.getElementById('registrationOpenAt')?.value);
        const registrationClose = parseDateTimeLocalValue(document.getElementById('registrationCloseAt')?.value);
        if (!registrationOpen || !registrationClose || registrationOpen >= registrationClose) {
          alert('Set a valid Registration Open and Registration Close before using suggested pricing dates.');
          return;
        }

        const dayMs = 24 * 60 * 60 * 1000;
        if (registrationClose.getTime() - registrationOpen.getTime() <= 21 * dayMs) {
          alert('Suggested Early Bird, Regular, and Late Registration periods need more than 21 days between registration open and close.');
          return;
        }

        const earlyEnd = new Date(registrationOpen.getTime() + 14 * dayMs);
        const lateStart = new Date(registrationClose.getTime() - 7 * dayMs);
        setIndexedDateInput('registrationPackageEarlyBirdStartAt', packageIndex, registrationOpen);
        setIndexedDateInput('registrationPackageEarlyBirdEndAt', packageIndex, earlyEnd);
        setIndexedDateInput('registrationPackageRegularStartAt', packageIndex, earlyEnd);
        setIndexedDateInput('registrationPackageRegularEndAt', packageIndex, lateStart);
        setIndexedDateInput('registrationPackageLateStartAt', packageIndex, lateStart);
        setIndexedDateInput('registrationPackageLateEndAt', packageIndex, registrationClose);
      }

      document.querySelectorAll('.btn-suggest-pricing-dates').forEach((button) => {
        button.addEventListener('click', () => applySuggestedPricingDates(button.dataset.packageIndex));
      });

      // ---------- "NOW" BUTTONS ----------
      document.querySelectorAll('.btn-now').forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.dataset.target;
          const input = document.getElementById(targetId);
          if (!input) return;
          const now = new Date();
          const year = now.getFullYear();
          const month = String(now.getMonth() + 1).padStart(2, '0');
          const day = String(now.getDate()).padStart(2, '0');
          const hours = String(now.getHours()).padStart(2, '0');
          const minutes = String(now.getMinutes()).padStart(2, '0');
          input.value = `${year}-${month}-${day}T${hours}:${minutes}`;
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.dispatchEvent(new Event('change', { bubbles: true }));
        });
      });

      // ---------- REAL-TIME VALIDATION ----------
      const form = document.querySelector('.create-event-form');
      if (form) {
        form.addEventListener('submit', (event) => {
          const submitter = event.submitter;
          if (!submitter || submitter === confirmedSubmitButton) {
            confirmedSubmitButton = null;
            return;
          }
          if (submitter.id !== 'saveBtn' && submitter.id !== 'submitReviewBtn') return;

          event.preventDefault();
          const isSubmitReview = submitter.value === 'publish';
          openActionDialog({
            icon: isSubmitReview ? 'send' : 'save',
            variant: isSubmitReview ? 'submit' : 'save',
            title: isSubmitReview ? 'Submit changes for review?' : 'Save changes?',
            desc: isSubmitReview
              ? 'This will save your edits and move this draft to admin review. Make sure the details are ready.'
              : 'This will update the event with the current form values and keep its current status.',
            cancelText: 'Cancel',
            okText: isSubmitReview ? 'Submit for Review' : 'Save Changes',
            okClass: isSubmitReview ? 'draft-confirm-btn--success' : 'draft-confirm-btn--primary'
          }).then((confirmed) => {
            if (!confirmed) return;
            confirmedSubmitButton = submitter;
            submitter.click();
          });
        }, true);
      }
      const requiredFields = [
        { id: 'title', message: 'Event title is required.' },
        { id: 'description', message: 'Description is required.' },
        { id: 'eventType', message: 'Please select an event type.' },
        { id: 'registrationOpenAt', message: 'Registration open date is required.' },
        { id: 'registrationCloseAt', message: 'Registration close date is required.' },
        { id: 'eventStartAt', message: 'Event start date is required.' },
        { id: 'eventEndAt', message: 'Event end date is required.' }
      ];

      function buildReadinessChecklist() {
        const checklist = document.getElementById('submitReadinessChecklist');
        if (!checklist) return;
        const items = [
          { label: 'Event title', ok: Boolean(document.getElementById('title')?.value.trim()) },
          { label: 'Short description', ok: (document.getElementById('description')?.value.trim() || '').length >= 20 },
          { label: 'Event type', ok: Boolean(eventTypeSelect?.value) },
          { label: 'Schedule dates', ok: requiredFields.slice(3).every((field) => Boolean(document.getElementById(field.id)?.value)) },
          { label: 'Race distance', ok: raceDistancePresetInputs.some((input) => input.checked) || Boolean(raceDistanceCustomInput?.value.trim()) },
          { label: 'Payment QR for paid event', ok: feeModeSelect?.value !== 'paid' || Boolean(document.getElementById('paymentQrImageUrl')?.value || document.getElementById('paymentQrImageFile')?.files?.length) }
        ];
        checklist.innerHTML = items.map((item) => (
          `<div class="readiness-item ${item.ok ? 'is-ready' : 'is-missing'}"><span>${item.ok ? 'Ready' : 'Missing'}</span>${item.label}</div>`
        )).join('');
      }

      function validateField(field) {
        const input = typeof field === 'string' ? document.getElementById(field) : field;
        if (!input) return true;

        const fieldId = input.id;
        const value = input.value.trim();
        let error = '';

        if (input.required && !value) {
          const found = requiredFields.find(f => f.id === fieldId);
          error = found ? found.message : 'This field is required.';
        } else if (fieldId === 'description' && value.length < 20) {
          error = 'Description must be at least 20 characters.';
        } else if (fieldId === 'eventType' && !value) {
          error = 'Please select an event type.';
        } else if (fieldId === 'title' && value.length < 3) {
          error = 'Title must be at least 3 characters.';
        }

        const formGroup = input.closest('.form-group');
        const existingError = formGroup.querySelector('.error-text');
        if (error) {
          if (!existingError) {
            const errorEl = document.createElement('small');
            errorEl.className = 'error-text';
            errorEl.textContent = error;
            formGroup.appendChild(errorEl);
          }
          formGroup.classList.add('has-error');
          return false;
        } else {
          existingError?.remove();
          formGroup.classList.remove('has-error');
          return true;
        }
      }

      document.querySelectorAll('input, select, textarea').forEach(field => {
        field.addEventListener('blur', () => validateField(field));
        field.addEventListener('input', () => validateField(field));
      });

      const previewBtn = document.getElementById('previewBtn');
      if (previewBtn && form) {
        previewBtn.addEventListener('click', () => {
          openActionDialog({
            icon: 'eye',
            variant: 'leave',
            title: 'Preview current changes?',
            desc: 'A preview will open in a new tab using the current form values. Unsaved image file uploads may not appear until saved.',
            cancelText: 'Cancel',
            okText: 'Preview',
            okClass: 'draft-confirm-btn--primary'
          }).then((confirmed) => {
            if (!confirmed) return;
          const data = new FormData(form);
          data.set('actionType', 'publish');
          data.delete('_csrf');
          for (const key of Array.from(data.keys())) {
            const value = data.get(key);
            if (value instanceof File) data.delete(key);
          }
          const params = new URLSearchParams();
          for (const [key, value] of data.entries()) {
            params.append(key, value);
          }
          window.open('/organizer/preview-event?' + params.toString(), '_blank', 'noopener,noreferrer');
          });
        });
      }

      // ---------- LOADING STATE ON SUBMIT ----------
      form.addEventListener('submit', (e) => {
        let isValid = true;
        const actionType = e.submitter?.value;
        const fieldsToValidate = (isPublishedEdit || isPendingReviewEdit || actionType === 'publish') ? requiredFields : [{ id: 'title', message: 'Event title is required.' }];
        fieldsToValidate.forEach(f => {
          const field = document.getElementById(f.id);
          if (!validateField(field)) isValid = false;
        });
        if (!isValid) {
          e.preventDefault();
          alert('Please fix the highlighted errors before saving.');
          return;
        }

        // Disable all submit buttons
        document.querySelectorAll('button[type="submit"]').forEach(btn => {
          btn.disabled = true;
          btn.classList.add('loading');
          const spinner = btn.querySelector('.spinner');
          if (spinner) spinner.style.display = 'inline-block';
        });
      });

      // ---------- FILE UPLOAD HANDLER (same as create) ----------
      function setupUploadArea(areaId, previewContainerId, previewImgId, fileInputId, urlInputId, removeBtnSelector) {
        const area = document.getElementById(areaId);
        const fileInput = document.getElementById(fileInputId);
        const previewContainer = document.getElementById(previewContainerId);
        const previewImg = document.getElementById(previewImgId);
        const urlInput = urlInputId ? document.getElementById(urlInputId) : null;
        const removeBtn = removeBtnSelector ? document.querySelector(removeBtnSelector) : null;

        if (!area || !fileInput) return;

        area.addEventListener('dragover', (e) => {
          e.preventDefault();
          area.classList.add('dragover');
        });
        area.addEventListener('dragleave', () => area.classList.remove('dragover'));
        area.addEventListener('drop', (e) => {
          e.preventDefault();
          area.classList.remove('dragover');
          if (e.dataTransfer.files.length) {
            fileInput.files = e.dataTransfer.files;
            handleFileSelect(fileInput, previewContainer, previewImg, urlInput);
          }
        });

        area.addEventListener('click', () => fileInput.click());

        fileInput.addEventListener('change', () => {
          handleFileSelect(fileInput, previewContainer, previewImg, urlInput);
        });

        if (removeBtn) {
          removeBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            fileInput.value = '';
            previewContainer.style.display = 'none';
            // For edit mode, we also need to mark removal if it's a new upload area (no existing image)
            // But this remove button is for the preview of a new upload, not the existing image.
            // Existing image removal is handled separately.
          });
        }
      }

      function handleFileSelect(input, previewContainer, previewImg, urlInput) {
        const file = input.files[0];
        if (!file) return;

        if (!allowedImageTypes.has(file.type)) {
          alert('Invalid file type. Only JPG and PNG files are allowed.');
          input.value = '';
          return;
        }
        if (file.size > maxBrandingSizeBytes) {
          alert('Image exceeds 5MB limit.');
          input.value = '';
          return;
        }

        const reader = new FileReader();
        reader.onload = (e) => {
          previewImg.src = e.target.result;
          previewContainer.style.display = 'inline-block';
          if (urlInput) urlInput.value = '';
        };
        reader.readAsDataURL(file);
      }

      const allowedImageTypes = new Set(['image/jpeg', 'image/png', 'image/webp']);
      const maxBrandingSizeBytes = 5 * 1024 * 1024;

      // Setup upload areas (note: remove buttons for new uploads)
      setupUploadArea('logoUploadArea', 'logoPreviewContainer', 'logoPreviewImg', 'logoFile', 'logoUrl', '.remove-upload[data-for="logo"]');
      setupUploadArea('bannerUploadArea', 'bannerPreviewContainer', 'bannerPreviewImg', 'bannerFile', 'bannerImageUrl', '.remove-upload[data-for="banner"]');
      setupUploadArea('posterUploadArea', 'posterPreviewContainer', 'posterPreviewImg', 'posterFile', 'posterImageUrl', '.remove-upload[data-for="poster"]');
      setupUploadArea('qrUploadArea', 'qrPreviewContainer', 'qrPreviewImg', 'paymentQrImageFile', null, '.remove-upload[data-for="qr"]');

      // Gallery (multiple files)
      const galleryInput = document.getElementById('galleryFiles');
      const galleryPreview = document.getElementById('galleryPreviewGrid');
      const galleryUrlsText = document.getElementById('galleryImageUrlsText');

      if (galleryInput) {
        galleryInput.addEventListener('change', () => {
          const files = Array.from(galleryInput.files);
          if (files.length > 12) {
            alert('You can upload up to 12 gallery images.');
            galleryInput.value = '';
            return;
          }
          for (const file of files) {
            if (!allowedImageTypes.has(file.type)) {
              alert('Invalid file type. Only JPG and PNG files are allowed.');
              galleryInput.value = '';
              return;
            }
            if (file.size > maxBrandingSizeBytes) {
              alert('One or more images exceed 5MB limit.');
              galleryInput.value = '';
              return;
            }
          }
          // Append new previews to existing grid (without removing existing ones)
          files.forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = (e) => {
              const wrap = document.createElement('div');
              wrap.className = 'gallery-thumb-wrap';
              // For new uploads we don't have a remove button that calls server; we'll just show preview.
              // They will be submitted with the form. If user wants to remove, they must clear file input.
              const img = document.createElement('img');
              img.src = e.target.result;
              img.alt = `New gallery preview ${index+1}`;
              img.className = 'gallery-preview-thumb';
              wrap.appendChild(img);
              galleryPreview.appendChild(wrap);
            };
            reader.readAsDataURL(file);
          });
        });
      }

      // ---------- REMOVE EXISTING MEDIA (edit mode) ----------
      async function removeEventMediaNow(payload) {
        const body = new URLSearchParams(payload);
        body.set('_csrf', '<%= locals.csrfToken || '' %>');
        const response = await fetch(`<%= typeof mediaRemovePath !== 'undefined' ? mediaRemovePath : `/organizer/events/${event._id}/media/remove` %>`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
          body: body.toString()
        });
        let data = null;
        try { data = await response.json(); } catch (e) {}
        if (!response.ok || !data?.success) {
          throw new Error(data?.message || 'Failed to remove media.');
        }
        return data;
      }

      // Logo remove
      const removeLogoBtn = document.getElementById('removeLogoBtn');
      const removeLogoInput = document.getElementById('removeLogoImage');
      if (removeLogoBtn && removeLogoInput) {
        removeLogoBtn.addEventListener('click', async () => {
          if (!confirm('Remove current logo image?')) return;
          removeLogoBtn.disabled = true;
          try {
            await removeEventMediaNow({ kind: 'logo' });
            removeLogoInput.value = '1';
            document.getElementById('logoPreviewWrap').style.display = 'none';
            // Also clear any URL input
            document.getElementById('logoUrl').value = '';
          } catch (error) {
            alert(error.message);
          } finally {
            removeLogoBtn.disabled = false;
          }
        });
      }

      // Banner remove
      const removeBannerBtn = document.getElementById('removeBannerBtn');
      const removeBannerInput = document.getElementById('removeBannerImage');
      if (removeBannerBtn && removeBannerInput) {
        removeBannerBtn.addEventListener('click', async () => {
          if (!confirm('Remove current banner image?')) return;
          removeBannerBtn.disabled = true;
          try {
            await removeEventMediaNow({ kind: 'banner' });
            removeBannerInput.value = '1';
            document.getElementById('bannerPreviewWrap').style.display = 'none';
            document.getElementById('bannerImageUrl').value = '';
          } catch (error) {
            alert(error.message);
          } finally {
            removeBannerBtn.disabled = false;
          }
        });
      }

      // Poster remove
      const removePosterBtn = document.getElementById('removePosterBtn');
      const removePosterInput = document.getElementById('removePosterImage');
      if (removePosterBtn && removePosterInput) {
        removePosterBtn.addEventListener('click', async () => {
          if (!confirm('Remove current promotional poster?')) return;
          removePosterBtn.disabled = true;
          try {
            await removeEventMediaNow({ kind: 'poster' });
            removePosterInput.value = '1';
            document.getElementById('posterPreviewWrap').style.display = 'none';
            document.getElementById('posterImageUrl').value = '';
          } catch (error) {
            alert(error.message);
          } finally {
            removePosterBtn.disabled = false;
          }
        });
      }

      // Payment QR remove
      const removeQrBtn = document.getElementById('removeQrBtn');
      const removeQrInput = document.getElementById('removePaymentQrImage');
      if (removeQrBtn && removeQrInput) {
        removeQrBtn.addEventListener('click', async () => {
          if (!confirm('Remove current payment QR image?')) return;
          removeQrBtn.disabled = true;
          try {
            await removeEventMediaNow({ kind: 'paymentQr' });
            removeQrInput.value = '1';
            document.getElementById('qrPreviewWrap').style.display = 'none';
            document.getElementById('paymentQrImageUrl').value = '';
            document.getElementById('paymentQrImageKey').value = '';
          } catch (error) {
            alert(error.message);
          } finally {
            removeQrBtn.disabled = false;
          }
        });
      }

      // Gallery remove individual
      const removeAllGalleryBtn = document.getElementById('removeAllGalleryBtn');
      const removeGalleryInput = document.getElementById('removeGalleryImages');
      if (removeAllGalleryBtn && removeGalleryInput) {
        removeAllGalleryBtn.addEventListener('click', async () => {
          if (!confirm('Remove all current gallery images?')) return;
          removeAllGalleryBtn.disabled = true;
          try {
            await removeEventMediaNow({ kind: 'gallery', all: '1' });
            removeGalleryInput.value = '1';
            document.getElementById('galleryPreviewGrid').innerHTML = '';
            removeAllGalleryBtn.style.display = 'none';
            galleryUrlsText.value = '';
          } catch (error) {
            alert(error.message);
          } finally {
            removeAllGalleryBtn.disabled = false;
          }
        });
      }

      // Individual gallery remove buttons (existing images)
      document.querySelectorAll('.gallery-remove-btn[data-gallery-url]').forEach(btn => {
        btn.addEventListener('click', async () => {
          const url = btn.dataset.galleryUrl;
          if (!url) return;
          if (!confirm('Remove this gallery image?')) return;
          btn.disabled = true;
          try {
            await removeEventMediaNow({ kind: 'gallery', url: url });
            const wrap = btn.closest('.gallery-thumb-wrap');
            if (wrap) wrap.remove();

            // Update hidden URLs textarea
            const currentUrls = galleryUrlsText.value.split(/\r?\n|,/).map(s => s.trim()).filter(Boolean);
            const newUrls = currentUrls.filter(u => u !== url);
            galleryUrlsText.value = newUrls.join('\n');
            removeGalleryInput.value = newUrls.length ? '0' : '1';
            if (!newUrls.length && removeAllGalleryBtn) removeAllGalleryBtn.style.display = 'none';
          } catch (error) {
            alert(error.message);
          } finally {
            btn.disabled = false;
          }
        });
      });

      // ---------- WAIVER PREVIEW (same as create) ----------
      // (copy the entire waiver script from create-event.ejs, adjusting initialWaiverTemplate as needed)
      const waiverEditorRoot = document.getElementById('waiverEditor');
      const waiverTemplateInput = document.getElementById('waiverTemplate');
      const organiserNameInput = document.getElementById('organiserName');
      const titleInput = document.getElementById('title');
      const waiverPreview = document.getElementById('waiverPreview');
      const resetWaiverBtn = document.getElementById('resetWaiverBtn');
      const insertOrganizerPlaceholderBtn = document.getElementById('insertOrganizerPlaceholderBtn');
      const insertEventPlaceholderBtn = document.getElementById('insertEventPlaceholderBtn');
      const defaultWaiverTemplate = <%- JSON.stringify(defaultWaiverTemplate || '') %>;
      const initialWaiverTemplate = <%- JSON.stringify(formData.waiverTemplate || '') %>;
      let waiverQuill = null;

      function getWaiverTemplateValue() {
        if (waiverQuill) return waiverQuill.root.innerHTML || '';
        return waiverTemplateInput?.value || '';
      }

      function setWaiverTemplateValue(value) {
        const safeValue = String(value || '');
        if (waiverQuill) {
          waiverQuill.clipboard.dangerouslyPasteHTML(safeValue);
        }
        if (waiverTemplateInput) {
          waiverTemplateInput.value = safeValue;
        }
      }

      function insertWaiverPlaceholder(token) {
        if (!token || !waiverTemplateInput) return;
        if (waiverQuill) {
          const range = waiverQuill.getSelection(true);
          const index = range ? range.index : waiverQuill.getLength();
          waiverQuill.insertText(index, token, 'user');
          waiverQuill.setSelection(index + token.length, 0, 'user');
          waiverTemplateInput.value = waiverQuill.root.innerHTML || '';
          renderWaiverPreview();
          waiverQuill.focus();
          return;
        }
        waiverTemplateInput.value = `${waiverTemplateInput.value || ''}${token}`;
        renderWaiverPreview();
      }

      function sanitizePreviewHtml(input) {
        const raw = String(input || '');
        let safe = raw;
        safe = safe.replace(/<script[\s\S]*?>[\s\S]*?<\/script>/gi, '');
        safe = safe.replace(/<style[\s\S]*?>[\s\S]*?<\/style>/gi, '');
        safe = safe.replace(/<iframe[\s\S]*?>[\s\S]*?<\/iframe>/gi, '');
        safe = safe.replace(/<object[\s\S]*?>[\s\S]*?<\/object>/gi, '');
        safe = safe.replace(/<embed[\s\S]*?>[\s\S]*?<\/embed>/gi, '');
        safe = safe.replace(/\son[a-z]+\s*=\s*(['"]).*?\1/gi, '');
        safe = safe.replace(/\son[a-z]+\s*=\s*[^\s>]+/gi, '');
        safe = safe.replace(/(href|src)\s*=\s*(['"])\s*javascript:[\s\S]*?\2/gi, '$1="#"');
        safe = safe.replace(/(href|src)\s*=\s*javascript:[^\s>]+/gi, '$1="#"');
        return safe;
      }

      function initializeWaiverEditor() {
        if (!waiverEditorRoot || !waiverTemplateInput || !window.Quill) {
          if (waiverTemplateInput) {
            waiverTemplateInput.value = initialWaiverTemplate || defaultWaiverTemplate;
          }
          renderWaiverPreview();
          return;
        }

        if (waiverQuill) {
          renderWaiverPreview();
          return;
        }

        waiverEditorRoot.innerHTML = '';

        try {
          waiverQuill = new Quill('#waiverEditor', {
            theme: 'snow',
            modules: {
              toolbar: [
                [{ header: [2, 3, false] }],
                ['bold', 'italic'],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['blockquote', 'link'],
                ['clean']
              ]
            },
            placeholder: 'Enter waiver text here...'
          });

          const initialValue = initialWaiverTemplate || defaultWaiverTemplate;
          if (initialValue) {
            waiverQuill.clipboard.dangerouslyPasteHTML(initialValue);
          }
          waiverTemplateInput.value = initialValue;

          waiverQuill.on('text-change', () => {
            waiverTemplateInput.value = waiverQuill.root.innerHTML || '';
            renderWaiverPreview();
          });

          renderWaiverPreview();
        } catch (error) {
          console.error('Failed to initialize Quill:', error);
          waiverTemplateInput.value = initialWaiverTemplate || defaultWaiverTemplate;
          renderWaiverPreview();
        }
      }

      function renderWaiverPreview() {
        if (!waiverPreview) return;
        const organizerName = (organiserNameInput?.value || '').trim() || 'the organizer';
        const eventTitle = (titleInput?.value || '').trim() || 'this event';
        const template = getWaiverTemplateValue();
        const renderedTemplate = template
          .replace(/\{\{\s*ORGANIZER_NAME\s*\}\}/g, organizerName)
          .replace(/\{\{\s*EVENT_TITLE\s*\}\}/g, eventTitle);
        waiverPreview.innerHTML = sanitizePreviewHtml(renderedTemplate);
      }

      [organiserNameInput, titleInput].forEach((el) => {
        if (el) el.addEventListener('input', renderWaiverPreview);
      });
      if (resetWaiverBtn) {
        resetWaiverBtn.addEventListener('click', () => {
          if (!confirm('Reset waiver template to the default version?')) return;
          setWaiverTemplateValue(defaultWaiverTemplate);
          renderWaiverPreview();
        });
      }
      if (insertOrganizerPlaceholderBtn) {
        insertOrganizerPlaceholderBtn.addEventListener('click', () => insertWaiverPlaceholder('{{ORGANIZER_NAME}}'));
      }
      if (insertEventPlaceholderBtn) {
        insertEventPlaceholderBtn.addEventListener('click', () => insertWaiverPlaceholder('{{EVENT_TITLE}}'));
      }
      if (form && waiverTemplateInput) {
        form.addEventListener('submit', () => {
          waiverTemplateInput.value = getWaiverTemplateValue();
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeWaiverEditor, { once: true });
      } else {
        initializeWaiverEditor();
      }

      // ---------- EVENT DETAILS RICH EDITOR ----------
      const eventDetailsEditorRoot = document.getElementById('eventDetailsEditor');
      const eventDetailsInput = document.getElementById('eventDetailsMarkdown');
      const eventDetailsPreview = document.getElementById('eventDetailsPreview');
      const clearEventDetailsBtn = document.getElementById('clearEventDetailsBtn');
      const initialEventDetails = <%- JSON.stringify(formData.eventDetailsMarkdown || '') %>;
      let eventDetailsQuill = null;

      function renderEventDetailsPreview() {
        if (!eventDetailsPreview) return;
        const html = eventDetailsQuill ? (eventDetailsQuill.root.innerHTML || '') : (eventDetailsInput?.value || '');
        eventDetailsPreview.innerHTML = sanitizePreviewHtml(html);
      }

      function initializeEventDetailsEditor() {
        if (!eventDetailsEditorRoot || !eventDetailsInput || !window.Quill) {
          if (eventDetailsInput) eventDetailsInput.value = initialEventDetails || '';
          renderEventDetailsPreview();
          return;
        }
        if (eventDetailsQuill) { renderEventDetailsPreview(); return; }
        eventDetailsEditorRoot.innerHTML = '';
        try {
          eventDetailsQuill = new Quill('#eventDetailsEditor', {
            theme: 'snow',
            modules: {
              toolbar: [
                [{ header: [2, 3, false] }],
                ['bold', 'italic'],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['blockquote', 'link'],
                ['clean']
              ]
            },
            placeholder: 'Add event rules, inclusions, FAQs, and proof instructions...'
          });
          if (initialEventDetails) {
            eventDetailsQuill.clipboard.dangerouslyPasteHTML(initialEventDetails);
          }
          eventDetailsInput.value = initialEventDetails || '';
          eventDetailsQuill.on('text-change', () => {
            eventDetailsInput.value = eventDetailsQuill.root.innerHTML || '';
            renderEventDetailsPreview();
          });
          eventDetailsQuill.blur();
          renderEventDetailsPreview();
        } catch (error) {
          console.error('Failed to initialize event details editor:', error);
          eventDetailsInput.value = initialEventDetails || '';
          renderEventDetailsPreview();
        }
      }

      if (clearEventDetailsBtn) {
        clearEventDetailsBtn.addEventListener('click', () => {
          if (!confirm('Clear all event details content?')) return;
          if (eventDetailsQuill) { eventDetailsQuill.setContents([]); }
          if (eventDetailsInput) eventDetailsInput.value = '';
          renderEventDetailsPreview();
        });
      }
      if (form && eventDetailsInput) {
        form.addEventListener('submit', () => {
          if (eventDetailsQuill) eventDetailsInput.value = eventDetailsQuill.root.innerHTML || '';
        });
      }
      initializeEventDetailsEditor();
    })();
  </script>
</body>
</html>
