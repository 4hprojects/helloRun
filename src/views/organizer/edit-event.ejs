      function toMinuteFloor(date) {
        const minuteMs = 60 * 1000;
        return new Date(Math.floor(date.getTime() / minuteMs) * minuteMs);
      }

      function buildSuggestedPricingWindows(registrationOpen, registrationClose) {
        const minuteMs = 60 * 1000;
        const dayMs = 24 * 60 * 60 * 1000;
        const totalMs = registrationClose.getTime() - registrationOpen.getTime();
        if (totalMs < 3 * dayMs) return null;

        let earlyMs = Math.round(totalMs * 0.4);
        let lateMs = Math.round(totalMs * 0.2);
        let regularMs = totalMs - earlyMs - lateMs;
        const minBucketMs = dayMs;

        earlyMs = Math.max(minBucketMs, earlyMs);
        lateMs = Math.max(minBucketMs, lateMs);
        regularMs = totalMs - earlyMs - lateMs;

        if (regularMs < minBucketMs) {
          const deficit = minBucketMs - regularMs;
          const earlySpare = Math.max(0, earlyMs - minBucketMs);
          const lateSpare = Math.max(0, lateMs - minBucketMs);
          const takeEarly = Math.min(deficit, earlySpare);
          const takeLate = Math.min(deficit - takeEarly, lateSpare);
          earlyMs -= takeEarly;
          lateMs -= takeLate;
          regularMs = totalMs - earlyMs - lateMs;
        }

        let regularStart = toMinuteFloor(new Date(registrationOpen.getTime() + earlyMs));
        let lateStart = toMinuteFloor(new Date(registrationClose.getTime() - lateMs));

        if (lateStart.getTime() <= regularStart.getTime()) {
          regularStart = toMinuteFloor(new Date(registrationOpen.getTime() + totalMs / 3));
          lateStart = toMinuteFloor(new Date(registrationOpen.getTime() + (2 * totalMs) / 3));
        }

        const earlyEnd = toMinuteFloor(new Date(regularStart.getTime() - minuteMs));
        const regularEnd = toMinuteFloor(new Date(lateStart.getTime() - minuteMs));

        if (earlyEnd.getTime() <= registrationOpen.getTime() || regularEnd.getTime() <= regularStart.getTime() || registrationClose.getTime() <= lateStart.getTime()) {
          return null;
        }

        return {
          earlyStart: toMinuteFloor(registrationOpen),
          earlyEnd,
          regularStart,
          regularEnd,
          lateStart,
          lateEnd: toMinuteFloor(registrationClose)
        };
      }

      function applySuggestedPricingDates(packageIndex) {
        const registrationOpen = parseDateTimeLocalValue(document.getElementById('registrationOpenAt')?.value);
        const registrationClose = parseDateTimeLocalValue(document.getElementById('registrationCloseAt')?.value);
