<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: 'Application Status - helloRun' }) %>
  <link rel="stylesheet" href="/css/application-status.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="org-app-page">
    <section class="org-app-shell" data-application-status="<%= application.status %>">
      <header class="org-app-header">
        <div>
          <p class="eyebrow">Organizer Application</p>
          <h1>Application Status</h1>
          <p class="subtitle">Track your verification progress and next steps.</p>
        </div>
        <div class="id-group">
          <span class="id-label">Application ID</span>
          <div class="id-row">
            <code class="application-id"><%= application.applicationId %></code>
            <button type="button" class="nav-login-btn app-copy-btn" data-copy-application-id>Copy</button>
          </div>
        </div>
      </header>

      <%
        const statusMap = {
          pending: { label: 'Pending Review', icon: 'clock3', tone: 'pending' },
          under_review: { label: 'Under Review', icon: 'scan-search', tone: 'review' },
          approved: { label: 'Approved', icon: 'badge-check', tone: 'approved' },
          rejected: { label: 'Rejected', icon: 'octagon-alert', tone: 'rejected' }
        };
        const statusInfo = statusMap[application.status] || statusMap.pending;
      %>

      <section class="status-hero status-hero-<%= statusInfo.tone %>">
        <div class="status-pill status-pill-<%= statusInfo.tone %>">
          <svg data-lucide="<%= statusInfo.icon %>" width="18" height="18"></svg>
          <span><%= statusInfo.label %></span>
        </div>
        <div class="status-copy">
          <% if (application.status === 'approved') { %>
            <h2>Application Approved</h2>
            <p>Your organizer account is verified. You can now create and manage events.</p>
          <% } else if (application.status === 'rejected') { %>
            <h2>Application Not Approved</h2>
            <p>Your submission did not pass verification. Review the feedback and submit an updated application.</p>
          <% } else if (application.status === 'under_review') { %>
            <h2>Application Under Review</h2>
            <p>Our team is reviewing your documents. Typical review time is <strong><%= reviewDays %> business days</strong>.</p>
          <% } else { %>
            <h2>Application Submitted</h2>
            <p>Your documents are queued for review. We will notify you when your status changes.</p>
          <% } %>
        </div>
      </section>

      <section class="stat-grid" aria-label="Application summary">
        <article class="stat-card">
          <p>Submitted On</p>
          <strong><%= submittedDate %></strong>
          <span><%= daysAgo %> day<%= daysAgo !== 1 ? 's' : '' %> ago</span>
        </article>
        <article class="stat-card">
          <p>Target Decision Date</p>
          <strong><%= estimatedDate %></strong>
          <span>Based on a <%= reviewDays %>-business-day review window</span>
        </article>
        <article class="stat-card">
          <p>Current Status</p>
          <strong><%= statusInfo.label %></strong>
          <span>Updated <%= application.reviewedAt ? new Date(application.reviewedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'automatically' %></span>
        </article>
      </section>

      <section class="panel">
        <div class="panel-head">
          <h3>Review Timeline</h3>
        </div>
        <ol class="timeline">
          <li class="timeline-item done">
            <div class="timeline-marker"><svg data-lucide="check" width="16" height="16"></svg></div>
            <div>
              <h4>Submission Received</h4>
              <p><%= submittedDate %></p>
            </div>
          </li>
          <li class="timeline-item <%= application.status !== 'pending' ? 'done' : 'active' %>">
            <div class="timeline-marker">
              <% if (application.status !== 'pending') { %>
                <svg data-lucide="check" width="16" height="16"></svg>
              <% } else { %>
                <span class="dot"></span>
              <% } %>
            </div>
            <div>
              <h4>Admin Review</h4>
              <p>Verification is in progress by the helloRun team.</p>
            </div>
          </li>
          <li class="timeline-item <%= (application.status === 'approved' || application.status === 'rejected') ? 'done' : '' %>">
            <div class="timeline-marker">
              <% if (application.status === 'approved') { %>
                <svg data-lucide="badge-check" width="16" height="16"></svg>
              <% } else if (application.status === 'rejected') { %>
                <svg data-lucide="x" width="16" height="16"></svg>
              <% } else { %>
                <span class="dot"></span>
              <% } %>
            </div>
            <div>
              <h4>Final Decision</h4>
              <p>
                <% if (application.status === 'approved') { %>
                  Approved on <%= application.reviewedAt ? new Date(application.reviewedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'recently' %>.
                <% } else if (application.status === 'rejected') { %>
                  Rejected on <%= application.reviewedAt ? new Date(application.reviewedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'recently' %>.
                <% } else { %>
                  Awaiting final review.
                <% } %>
              </p>
            </div>
          </li>
        </ol>
      </section>

      <section class="panel">
        <div class="panel-head">
          <h3>Application Details</h3>
        </div>
        <dl class="detail-grid">
          <div class="detail-item">
            <dt>Business Name</dt>
            <dd><%= application.businessName %></dd>
          </div>
          <div class="detail-item">
            <dt>Business Type</dt>
            <dd>
              <%
                const typeMap = {
                  individual: 'Individual / Solo Organizer',
                  company: 'Company / Commercial',
                  ngo: 'Non-Profit / NGO',
                  sports_club: 'Sports Club / Association'
                };
              %>
              <%= typeMap[application.businessType] || application.businessType %>
            </dd>
          </div>
          <div class="detail-item">
            <dt>Contact Phone</dt>
            <dd><a href="tel:<%= application.contactPhone %>"><%= application.contactPhone %></a></dd>
          </div>
          <div class="detail-item">
            <dt>Registration Number</dt>
            <dd><%= application.businessRegistrationNumber || 'Not provided' %></dd>
          </div>
          <div class="detail-item detail-item-full">
            <dt>Business Address</dt>
            <dd><%= application.businessAddress || 'Not provided' %></dd>
          </div>
          <div class="detail-item detail-item-full">
            <dt>Additional Information</dt>
            <dd><%= application.additionalInfo || 'Not provided' %></dd>
          </div>
        </dl>
      </section>

      <% if (application.status === 'rejected' && application.rejectionReason) { %>
        <section class="panel panel-alert">
          <div class="panel-head">
            <h3>Review Feedback</h3>
          </div>
          <p><%= application.rejectionReason %></p>
        </section>
      <% } %>

      <section class="action-row">
        <% if (application.status === 'approved') { %>
          <a href="/organizer/create-event" class="nav-signup-btn"><svg data-lucide="plus" width="16" height="16"></svg>Create New Event</a>
          <a href="/organizer/dashboard" class="nav-login-btn"><svg data-lucide="layout-dashboard" width="16" height="16"></svg>Go to Dashboard</a>
        <% } else if (application.status === 'rejected') { %>
          <a href="/organizer/complete-profile" class="nav-signup-btn"><svg data-lucide="refresh-cw" width="16" height="16"></svg>Submit Updated Application</a>
          <a href="/" class="nav-login-btn"><svg data-lucide="house" width="16" height="16"></svg>Back to Home</a>
        <% } else { %>
          <button type="button" class="nav-signup-btn" data-refresh-status><svg data-lucide="refresh-cw" width="16" height="16"></svg>Refresh Page</button>
          <a href="/" class="nav-login-btn"><svg data-lucide="house" width="16" height="16"></svg>Back to Home</a>
        <% } %>
      </section>

      <aside class="support-note">
        <svg data-lucide="info" width="18" height="18"></svg>
        <p>Need help with your application? Contact <a href="mailto:<%= adminEmail %>"><%= adminEmail %></a>.</p>
      </aside>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/application-status.js"></script>
</body>
</html>
