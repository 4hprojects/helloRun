<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/organizer-dashboard.css">
  <meta name="description" content="Manage your running events on HelloRun.">
</head>
<body>
  <%- include('../layouts/nav') %>

  <%
    const approvedOrganizer = Boolean(isApprovedOrganizer || user.organizerStatus === 'approved');
    const earnedOrganiserBadges = Array.isArray(organiserBadges) ? organiserBadges : [];
    const statusLabel = user.organizerStatus === 'not_applied'
      ? 'Application Not Started'
      : String(user.organizerStatus || 'not_applied').replace(/_/g, ' ');
    const hasPendingCreateEventAck = Boolean(user.organizerEventCreationAcknowledgement && user.organizerEventCreationAcknowledgement.agreedAt);
    const displayName = [user.firstName, user.lastName].filter(Boolean).join(' ') || 'Organizer';
    const initials = `${(user.firstName || 'O').charAt(0)}${(user.lastName || 'R').charAt(0)}`.toUpperCase();
  %>

  <main class="organizer-dashboard-page" id="main-content" data-organizer-dashboard>
    <div class="organizer-dashboard-shell">
      <header class="organizer-dashboard-hero">
        <div class="organizer-dashboard-identity">
          <span class="organizer-dashboard-avatar" aria-hidden="true"><%= initials %></span>
          <div>
            <p class="organizer-dashboard-kicker">Organiser workspace</p>
            <h1>Welcome back, <%= user.firstName || 'Organizer' %>!</h1>
            <p class="organizer-dashboard-status-line">
              <span class="organizer-status organizer-status-<%= user.organizerStatus || 'not_applied' %>">
                <i data-lucide="<%= approvedOrganizer ? 'shield-check' : user.organizerStatus === 'rejected' ? 'x-circle' : 'clock' %>" aria-hidden="true"></i>
                <%= approvedOrganizer ? 'Verified Organizer' : statusLabel %>
              </span>
              <% if (approvedDate) { %><span><%= user.organizerStatus === 'approved' ? 'Approved' : 'Submitted' %> <%= approvedDate %></span><% } %>
            </p>
          </div>
        </div>

        <div class="organizer-dashboard-hero-actions" aria-label="Primary organiser actions">
          <% if (approvedOrganizer) { %>
            <a href="/organizer/create-event" class="btn organizer-primary-action"><i data-lucide="plus" aria-hidden="true"></i><span>Create Event</span></a>
            <a href="/organizer/events" class="btn btn-secondary"><i data-lucide="calendar" aria-hidden="true"></i><span>My Events</span></a>
          <% } else { %>
            <button type="button" class="btn organizer-primary-action" id="pendingCreateEventTrigger" data-pending-create-event-trigger>
              <i data-lucide="plus" aria-hidden="true"></i><span>Create Event</span>
            </button>
            <a href="<%= applicationAction.href %>" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
              <i data-lucide="clipboard-list" aria-hidden="true"></i><span><%= applicationAction.label %></span>
            </a>
          <% } %>
        </div>
      </header>

      <% if (approvedOrganizer) { %>
        <section class="organizer-dashboard-card organizer-analytics" aria-labelledby="analytics-heading">
          <div class="organizer-section-heading organizer-analytics-heading">
            <div>
              <p class="organizer-section-kicker">Performance</p>
              <h2 id="analytics-heading">Analytics overview</h2>
            </div>
            <form method="GET" action="/organizer/dashboard" class="organizer-range-form">
              <label for="dashboardRange">Analytics range</label>
              <select id="dashboardRange" name="range">
                <option value="7d" <%= analytics?.range === '7d' ? 'selected' : '' %>>Last 7 days</option>
                <option value="30d" <%= analytics?.range === '30d' ? 'selected' : '' %>>Last 30 days</option>
                <option value="all" <%= analytics?.range === 'all' ? 'selected' : '' %>>All time</option>
              </select>
              <button type="submit" class="btn btn-secondary">Apply</button>
            </form>
          </div>

          <div class="organizer-primary-metrics" aria-label="Selected range metrics">
            <% [
              { label: 'Registrations', value: analytics?.registrationsInRange || 0, trend: analytics?.trends?.registrations },
              { label: 'Submissions', value: analytics?.submissionsInRange || 0, trend: analytics?.trends?.submissions },
              { label: 'Approved Results', value: analytics?.approvalsInRange || 0, trend: analytics?.trends?.approvals }
            ].forEach((metric) => { %>
              <article class="organizer-metric-card">
                <small><%= metric.label %> (<%= analytics?.rangeLabel || 'Last 30 days' %>)</small>
                <strong><%= metric.value %></strong>
                <span class="organizer-trend organizer-trend-<%= metric.trend?.direction || 'flat' %>"><%= metric.trend?.label || '0 vs previous period' %></span>
              </article>
            <% }); %>
          </div>

          <dl class="organizer-lifetime-strip" aria-label="Lifetime organiser totals">
            <div><dt>Total Events</dt><dd><%= stats.totalEvents %></dd></div>
            <div><dt>Active Events</dt><dd><%= stats.activeEvents %></dd></div>
            <div><dt>Upcoming Events</dt><dd><%= stats.upcomingEvents %></dd></div>
            <div><dt>Total Registrations</dt><dd><%= stats.totalRegistrations %></dd></div>
          </dl>

          <div class="organizer-ranked-events" aria-labelledby="top-events-heading">
            <h3 id="top-events-heading">Top Events</h3>
            <div class="organizer-ranked-grid">
              <% [
                { label: 'Registrations', items: reviewQueue?.topEvents?.registrations, empty: 'No registration data in this range.' },
                { label: 'Approvals', items: reviewQueue?.topEvents?.approvals, empty: 'No approval data in this range.' },
                { label: 'Pending Queue', items: reviewQueue?.topEvents?.pending, empty: 'No pending queue items.' }
              ].forEach((group) => { %>
                <article class="organizer-ranked-card">
                  <h4><%= group.label %></h4>
                  <% if (group.items?.length) { %>
                    <ol>
                      <% group.items.forEach((item) => { %>
                        <li><a href="<%= item.href %>"><span><%= item.eventTitle %></span><strong><%= item.count %></strong></a></li>
                      <% }); %>
                    </ol>
                  <% } else { %><p><%= group.empty %></p><% } %>
                </article>
              <% }); %>
            </div>
          </div>
        </section>

        <section class="organizer-operations" aria-labelledby="operations-heading">
          <div class="organizer-section-heading organizer-section-heading-wide">
            <div><p class="organizer-section-kicker">Operations</p><h2 id="operations-heading">Work requiring attention</h2></div>
            <a href="/organizer/submissions" class="organizer-text-link">All submissions <i data-lucide="arrow-right" aria-hidden="true"></i></a>
          </div>

          <div class="organizer-operations-grid">
            <article class="organizer-dashboard-card organizer-queue-card">
              <div class="organizer-card-heading"><h3><i data-lucide="inbox" aria-hidden="true"></i>Review Queue</h3><span><%= (reviewQueue?.pendingPaymentReviews || 0) + (reviewQueue?.pendingResultReviews || 0) %> pending</span></div>
              <% if (reviewQueue?.byEvent?.length) { %>
                <ul class="organizer-queue-list">
                  <% reviewQueue.byEvent.forEach((item) => { %>
                    <li>
                      <div class="organizer-queue-copy">
                        <a href="/organizer/events/<%= item.eventId %>"><%= item.eventTitle %></a>
                        <span><%= item.totalPending %> total pending</span>
                      </div>
                      <dl class="organizer-queue-counts">
                        <div><dt>Payments</dt><dd><%= item.paymentPending %></dd></div>
                        <div><dt>Results</dt><dd><%= item.resultPending %></dd></div>
                      </dl>
                      <div class="organizer-queue-actions">
                        <a href="<%= item.paymentHref %>" class="btn btn-secondary" target="_blank" rel="noopener noreferrer"><i data-lucide="receipt" aria-hidden="true"></i>Payments</a>
                        <a href="<%= item.resultHref %>" class="btn btn-secondary" target="_blank" rel="noopener noreferrer"><i data-lucide="flag" aria-hidden="true"></i>Results</a>
                      </div>
                    </li>
                  <% }); %>
                </ul>
              <% } else { %>
                <div class="organizer-compact-empty"><i data-lucide="check-circle-2" aria-hidden="true"></i><div><strong>Queue clear</strong><p>No pending payment or result reviews right now.</p></div></div>
              <% } %>
              <% if (reviewQueue?.unpaidRegistrations > 0) { %>
                <a href="/organizer/events" class="organizer-inline-notice"><i data-lucide="clock" aria-hidden="true"></i><span><strong><%= reviewQueue.unpaidRegistrations %></strong> unpaid registrations need participant follow-up.</span></a>
              <% } %>
            </article>

            <article class="organizer-dashboard-card organizer-drafts-card">
              <div class="organizer-card-heading"><h3><i data-lucide="file-pen-line" aria-hidden="true"></i>Draft Events</h3><a href="/organizer/events?status=draft">Manage drafts</a></div>
              <% if (draftEvents?.length) { %>
                <ul class="organizer-draft-list">
                  <% draftEvents.forEach((item) => { %>
                    <li>
                      <div><strong><%= item.name %></strong><p>Updated <%= item.updatedAt ? new Date(item.updatedAt).toLocaleDateString('en-US') : 'N/A' %><% if (item.eventStartAt) { %> · Starts <%= new Date(item.eventStartAt).toLocaleDateString('en-US') %><% } %></p></div>
                      <a href="/organizer/events/<%= item.id %>/edit" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">Edit</a>
                    </li>
                  <% }); %>
                </ul>
              <% } else { %>
                <div class="organizer-compact-empty"><i data-lucide="file-check-2" aria-hidden="true"></i><div><strong>No drafts</strong><p>New and unfinished events will appear here.</p></div></div>
              <% } %>
            </article>
          </div>
        </section>

        <section class="organizer-dashboard-card organizer-events-section" aria-labelledby="events-heading">
          <div class="organizer-card-heading organizer-events-heading">
            <div><p class="organizer-section-kicker">Event management</p><h2 id="events-heading">My Events</h2></div>
            <% if (recentEvents.length) { %><a href="/organizer/events">View all <i data-lucide="arrow-right" aria-hidden="true"></i></a><% } %>
          </div>
          <% if (recentEvents.length) { %>
            <div class="organizer-event-list">
              <% recentEvents.forEach((event) => { const pendingResults = Number(event.pendingRunProofSubmissions || 0); %>
                <article class="organizer-event-card">
                  <div class="organizer-event-media">
                    <% if (event.bannerImageUrl) { %><img src="<%= event.bannerImageUrl %>" alt="" loading="lazy"><% } else { %><i data-lucide="calendar" aria-hidden="true"></i><% } %>
                  </div>
                  <div class="organizer-event-copy">
                    <div class="organizer-event-title-row"><h3><%= event.name %></h3><span class="organizer-event-status organizer-event-status-<%= event.status %>"><%= event.status %></span></div>
                    <p><span><i data-lucide="calendar-days" aria-hidden="true"></i><%= new Date(event.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span><span><i data-lucide="map-pin" aria-hidden="true"></i><%= event.location %></span></p>
                    <dl><div><dt>Registrations</dt><dd><%= event.registrations || 0 %></dd></div><div><dt>Pending results</dt><dd><%= pendingResults %></dd></div></dl>
                  </div>
                  <div class="organizer-event-actions">
                    <a href="/organizer/events/<%= event.id %>" class="btn btn-secondary">Manage</a>
                    <a href="/organizer/events/<%= event.id %>/registrants" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">Registrants</a>
                    <a href="/organizer/events/<%= event.id %>/run-proofs/review" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">Review Results<% if (pendingResults) { %><span class="organizer-count-badge"><%= pendingResults %></span><% } %></a>
                  </div>
                </article>
              <% }); %>
            </div>
          <% } else { %>
            <div class="organizer-empty-state"><i data-lucide="calendar-plus" aria-hidden="true"></i><h3>No events yet</h3><p>Create your first running event and begin preparing registration.</p><a href="/organizer/create-event" class="btn organizer-primary-action">Create Your First Event</a></div>
          <% } %>
        </section>

        <nav class="organizer-quick-actions" aria-label="Organiser tools">
          <% quickActions.forEach((action) => { %>
            <a href="<%= action.href %>"><i data-lucide="<%= action.icon %>" aria-hidden="true"></i><span><strong><%= action.label %></strong><small><%= action.description %></small></span></a>
          <% }); %>
        </nav>
      <% } else { %>
        <section class="organizer-dashboard-card organizer-application-workspace" aria-labelledby="application-heading">
          <div class="organizer-application-icon"><i data-lucide="<%= user.organizerStatus === 'rejected' ? 'file-warning' : 'clipboard-check' %>" aria-hidden="true"></i></div>
          <div class="organizer-application-copy">
            <p class="organizer-section-kicker">Organizer access</p>
            <h2 id="application-heading"><%= statusLabel %></h2>
            <% if (application) { %>
              <p>Your organizer application is <strong><%= String(application.status || user.organizerStatus).replace(/_/g, ' ') %></strong>. Follow the status page for review updates and requested changes.</p>
            <% } else { %>
              <p>Complete your business information and required documents so the HelloRun team can review your organiser account.</p>
            <% } %>
            <div class="organizer-application-actions">
              <a href="<%= applicationAction.href %>" class="btn organizer-primary-action" target="_blank" rel="noopener noreferrer"><%= applicationAction.label %></a>
              <button type="button" class="btn btn-secondary" data-pending-create-event-trigger>Create a limited free event</button>
            </div>
          </div>
          <aside><strong>Limited event access</strong><p>Pending organisers may create free virtual events after accepting the current access terms. Publication still requires review.</p></aside>
        </section>
      <% } %>

      <details class="organizer-dashboard-card organizer-utilities" <%= utilitiesOpen ? 'open' : '' %>>
        <summary><span><i data-lucide="settings" aria-hidden="true"></i><strong>Organizer tools &amp; account</strong><small>Profile, onboarding, badges, and help</small></span><i data-lucide="chevron-down" class="organizer-utilities-chevron" aria-hidden="true"></i></summary>
        <div class="organizer-utilities-grid">
          <section aria-labelledby="account-utility-heading">
            <h2 id="account-utility-heading">Account</h2>
            <div class="organizer-profile-summary"><span class="organizer-dashboard-avatar" aria-hidden="true"><%= initials %></span><div><strong><%= displayName %></strong><span><%= user.email %></span></div></div>
            <% if (application) { %><p><strong><%= application.businessName || 'Organizer application' %></strong><br><%= application.contactPhone || 'No contact phone' %><% if (application.applicationId) { %><br>ID: <%= application.applicationId %><% } %></p><% } %>
            <a href="/organizer/application-status">View application status</a>
          </section>
          <section aria-labelledby="onboarding-utility-heading">
            <h2 id="onboarding-utility-heading">Getting Started</h2>
            <ul class="organizer-checklist" id="gettingStartedChecklist">
              <% [
                ['Create your account', true], ['Verify your email', Boolean(user.emailVerified)],
                ['Complete organizer application', Boolean(application)], ['Get approved', approvedOrganizer],
                ['Create your first event', stats.totalEvents > 0], ['Get your first registration', stats.totalRegistrations > 0]
              ].forEach(([label, complete]) => { %><li class="<%= complete ? 'is-complete' : '' %>"><i data-lucide="<%= complete ? 'check-circle-2' : 'circle' %>" aria-hidden="true"></i><span><%= label %></span></li><% }); %>
            </ul>
          </section>
          <section aria-labelledby="badges-utility-heading">
            <h2 id="badges-utility-heading">Organizer Badges</h2>
            <% if (earnedOrganiserBadges.length) { %><ul class="organizer-utility-badges"><% earnedOrganiserBadges.forEach((badge) => { %><li><a href="/badges/<%= badge.userBadgeId %>" target="_blank" rel="noopener noreferrer"><i data-lucide="award" aria-hidden="true"></i><span><strong><%= badge.name %></strong><small><%= badge.description %></small></span></a></li><% }); %></ul><% } else { %><p>Organizer badges appear after verification and eligible event milestones.</p><% } %>
          </section>
          <section aria-labelledby="help-utility-heading">
            <h2 id="help-utility-heading">Help &amp; Resources</h2>
            <nav class="organizer-resource-links"><a href="/blog/how-to-organize-a-virtual-run-a-practical-guide-for-event-organizers">Event creation guide</a><a href="/faq">FAQ</a><a href="/contact?source=organizer-dashboard" target="_blank" rel="noopener noreferrer">Contact Support</a></nav>
          </section>
        </div>
      </details>
    </div>
  </main>

  <%- include('../layouts/footer') %>

  <div id="pendingCreateEventModal" class="pce-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="pceModalTitle" aria-describedby="pceModalIntro" data-account-name="<%= displayName %>" hidden>
    <div class="pce-modal-card" tabindex="-1">
      <div class="pce-modal-header">
        <div class="pce-modal-icon-wrap"><i data-lucide="alert-triangle" aria-hidden="true"></i></div>
        <div><span class="pce-modal-kicker">Unverified Account</span><h2 class="pce-modal-title" id="pceModalTitle">Create New Event with Limited Access</h2></div>
        <button type="button" class="pce-modal-close" id="pceModalClose" aria-label="Close"><i data-lucide="x" aria-hidden="true"></i></button>
      </div>
      <div class="pce-modal-body">
        <p class="pce-modal-intro" id="pceModalIntro">Your organizer identity is <strong>not yet verified</strong>. You can create and manage <strong>free virtual events</strong>; identity verification unlocks paid and onsite tools.</p>
        <div class="pce-modal-limitations"><h3 class="pce-modal-limitations-title"><i data-lucide="info" aria-hidden="true"></i>What remains limited</h3><ul class="pce-modal-limitations-list"><li>Events are limited to free, virtual-only runs.</li><li>Each event undergoes admin review before becoming publicly visible.</li><li>Paid registration, physical rewards, delivery, and onsite logistics stay locked.</li></ul></div>
        <div class="pce-modal-requirements"><h3 class="pce-modal-requirements-title"><i data-lucide="clipboard-check" aria-hidden="true"></i>Want full access?</h3><p>Complete identity verification through your <a href="/organizer/complete-profile" target="_blank" rel="noopener noreferrer">organizer profile</a>.</p></div>
        <% if (hasPendingCreateEventAck) { %>
          <div class="pce-modal-requirements"><h3 class="pce-modal-requirements-title"><i data-lucide="check-circle-2" aria-hidden="true"></i>Acknowledgement already recorded</h3><p>You agreed on <strong><%= new Date(user.organizerEventCreationAcknowledgement.agreedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong> using <strong><%= user.organizerEventCreationAcknowledgement.signatureName || 'Recorded signature' %></strong>.</p></div>
          <div class="pce-modal-actions"><button type="button" class="pce-modal-btn pce-modal-btn-cancel" data-pce-cancel>Cancel</button><a href="/organizer/create-event" class="pce-modal-btn pce-modal-btn-confirm"><i data-lucide="arrow-right" aria-hidden="true"></i>Continue to Create Event</a></div>
        <% } else { %>
          <form id="pceAckForm" method="POST" action="/organizer/acknowledge-event-creation">
            <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
            <div class="pce-modal-agree-row"><label class="pce-modal-checkbox-label"><input type="checkbox" name="agreedCheckbox" id="pceAgreeCheckbox" value="1"><span>I understand the limitations and agree to the <a href="/organiser-terms#event-creation-access" target="_blank" rel="noopener noreferrer">event-creation access and Organiser Terms</a>.</span></label></div>
            <div class="pce-modal-signature"><label for="pceSignatureName" class="pce-modal-signature-label">Electronic Signature<span class="pce-modal-signature-hint">Type your full account name exactly: <strong><%= displayName %></strong></span></label><input type="text" id="pceSignatureName" name="signatureName" class="pce-modal-signature-input" placeholder="<%= displayName %>" autocomplete="name" maxlength="160"><p class="pce-modal-signature-note">Your signature, timestamp, and acceptance will be recorded on your account.</p></div>
            <p id="pceValidationMsg" class="pce-modal-validation-msg" role="alert" hidden></p>
            <div class="pce-modal-actions"><button type="button" class="pce-modal-btn pce-modal-btn-cancel" data-pce-cancel>Cancel</button><button type="submit" class="pce-modal-btn pce-modal-btn-confirm" id="pceModalConfirmBtn" disabled><i data-lucide="check" aria-hidden="true"></i>Agree &amp; Create Event</button></div>
          </form>
        <% } %>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/organizer-dashboard.js"></script>
</body>
</html>
