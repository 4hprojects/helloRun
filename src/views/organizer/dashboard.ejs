<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/organizer-dashboard.css">
  <meta name="description" content="Manage your running events on helloRun.">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="dashboard-page" id="main-content">
    <div class="dashboard-container">

      <!-- Welcome Header -->
      <header class="dashboard-header">
        <div class="header-left">
          <h1>Welcome back, <%= user.firstName || 'Organizer' %>!</h1>
          <p class="header-subtitle">
            <% if (user.organizerStatus === 'approved') { %>
              <span class="verified-badge">
                <i data-lucide="shield-check"></i>
                Verified Organizer
              </span>
              <span class="header-separator">•</span>
              <span>Approved on <%= approvedDate %></span>
            <% } else if (user.organizerStatus === 'pending') { %>
              <span class="pending-badge">
                <i data-lucide="clock"></i>
                Pending Approval
              </span>
              <span class="header-separator">•</span>
              <span>Submitted on <%= approvedDate %></span>
            <% } else if (user.organizerStatus === 'rejected') { %>
              <span class="rejected-badge">
                <i data-lucide="x-circle"></i>
                Application Rejected
              </span>
            <% } %>
          </p>
        </div>
        <div class="header-right">
          <a href="/organizer/create-event" class="btn btn-create">
            <i data-lucide="plus"></i>
            Create Event
          </a>
        </div>
      </header>

      <!-- Stats Cards -->
      <section class="stats-section" aria-label="Dashboard Statistics">
        <form method="GET" action="/organizer/dashboard" class="analytics-range-form">
          <label for="dashboardRange">Analytics range</label>
          <select id="dashboardRange" name="range">
            <option value="7d" <%= analytics?.range === '7d' ? 'selected' : '' %>>Last 7 days</option>
            <option value="30d" <%= analytics?.range === '30d' ? 'selected' : '' %>>Last 30 days</option>
            <option value="all" <%= analytics?.range === 'all' ? 'selected' : '' %>>All time</option>
          </select>
          <button type="submit" class="event-link-btn">Apply</button>
        </form>

        <div class="analytics-summary-grid">
          <article class="analytics-summary-card">
            <small>Registrations (<%= analytics?.rangeLabel || 'Last 30 days' %>)</small>
            <strong><%= analytics?.registrationsInRange || 0 %></strong>
            <p class="trend-chip trend-<%= analytics?.trends?.registrations?.direction || 'flat' %>">
              <%= analytics?.trends?.registrations?.label || '0 vs previous period' %>
            </p>
          </article>
          <article class="analytics-summary-card">
            <small>Submissions (<%= analytics?.rangeLabel || 'Last 30 days' %>)</small>
            <strong><%= analytics?.submissionsInRange || 0 %></strong>
            <p class="trend-chip trend-<%= analytics?.trends?.submissions?.direction || 'flat' %>">
              <%= analytics?.trends?.submissions?.label || '0 vs previous period' %>
            </p>
          </article>
          <article class="analytics-summary-card">
            <small>Approved Results (<%= analytics?.rangeLabel || 'Last 30 days' %>)</small>
            <strong><%= analytics?.approvalsInRange || 0 %></strong>
            <p class="trend-chip trend-<%= analytics?.trends?.approvals?.direction || 'flat' %>">
              <%= analytics?.trends?.approvals?.label || '0 vs previous period' %>
            </p>
          </article>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon stat-icon-events">
              <i data-lucide="calendar"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value"><%= stats.totalEvents %></span>
              <span class="stat-label">Total Events</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon-active">
              <i data-lucide="activity"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value"><%= stats.activeEvents %></span>
              <span class="stat-label">Active Events</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon-registrations">
              <i data-lucide="users"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value"><%= stats.totalRegistrations %></span>
              <span class="stat-label">Total Registrations</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon-upcoming">
              <i data-lucide="clock"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value"><%= stats.upcomingEvents %></span>
              <span class="stat-label">Upcoming Events</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon-payment-review">
              <i data-lucide="receipt"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value"><%= stats.pendingPaymentReviews || 0 %></span>
              <span class="stat-label">Pending Payment Reviews</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon-result-review">
              <i data-lucide="flag"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value"><%= stats.pendingResultReviews || 0 %></span>
              <span class="stat-label">Pending Result Reviews</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Main Content Grid -->
      <div class="dashboard-grid">

        <!-- Left Column -->
        <div class="dashboard-main">

          <!-- Quick Actions -->
          <section class="dashboard-section" aria-labelledby="actions-heading">
            <h2 id="actions-heading" class="section-heading">
              <i data-lucide="zap"></i>
              Quick Actions
            </h2>
            <div class="queue-quick-links">
              <a href="<%= reviewQueue?.paymentReviewHref || '/organizer/events' %>" class="event-link-btn">Open Next Pending Payment</a>
              <a href="<%= reviewQueue?.resultReviewHref || '/organizer/events' %>" class="event-link-btn">Open Next Pending Result</a>
            </div>
            <div class="actions-grid">
              <% quickActions.forEach(action => { %>
                <a href="<%= action.href %>" class="action-card">
                  <div class="action-icon">
                    <i data-lucide="<%= action.icon %>"></i>
                  </div>
                  <div class="action-info">
                    <h3><%= action.label %></h3>
                    <p><%= action.description %></p>
                  </div>
                  <i data-lucide="chevron-right" class="action-arrow"></i>
                </a>
              <% }); %>
            </div>
          </section>

          <section class="dashboard-section" aria-labelledby="queue-breakdown-heading">
            <div class="section-header">
              <h2 id="queue-breakdown-heading" class="section-heading">
                <i data-lucide="inbox"></i>
                Queue by Event
              </h2>
            </div>
            <% if (reviewQueue?.byEvent && reviewQueue.byEvent.length) { %>
              <ul class="queue-breakdown-list">
                <% reviewQueue.byEvent.forEach(item => { %>
                  <li class="queue-breakdown-item">
                    <div>
                      <strong><a href="/organizer/events/<%= item.eventId %>/registrants"><%= item.eventTitle %></a></strong>
                      <p>Payment: <%= item.paymentPending %> | Result: <%= item.resultPending %> | Total: <%= item.totalPending %></p>
                    </div>
                    <div class="queue-breakdown-actions">
                      <a href="<%= item.paymentHref %>" class="event-link-btn">Payment</a>
                      <a href="<%= item.resultHref %>" class="event-link-btn">Result</a>
                    </div>
                  </li>
                <% }); %>
              </ul>
            <% } else { %>
              <p class="queue-breakdown-empty">No pending payment or result reviews right now.</p>
            <% } %>
          </section>

          <section class="dashboard-section" aria-labelledby="draft-events-heading">
            <div class="section-header">
              <h2 id="draft-events-heading" class="section-heading">
                <i data-lucide="file-pen-line"></i>
                Draft Events
              </h2>
              <a href="/organizer/events?status=draft" class="view-all-link">
                Manage Drafts <i data-lucide="arrow-right"></i>
              </a>
            </div>
            <% if (draftEvents && draftEvents.length) { %>
              <ul class="draft-events-list">
                <% draftEvents.forEach((item) => { %>
                  <li class="draft-events-item">
                    <div>
                      <strong><%= item.name %></strong>
                      <p>
                        Updated: <%= item.updatedAt ? new Date(item.updatedAt).toLocaleDateString('en-US') : 'N/A' %>
                        <% if (item.eventStartAt) { %>
                          <span class="meta-separator">&bull;</span>
                          Start: <%= new Date(item.eventStartAt).toLocaleDateString('en-US') %>
                        <% } %>
                      </p>
                    </div>
                    <a href="/organizer/events/<%= item.id %>/edit" class="event-link-btn">Continue Editing</a>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="queue-breakdown-empty">No draft events right now.</p>
            <% } %>
          </section>

          <section class="dashboard-section" aria-labelledby="top-events-heading">
            <div class="section-header">
              <h2 id="top-events-heading" class="section-heading">
                <i data-lucide="trending-up"></i>
                Top Events
              </h2>
            </div>
            <div class="top-events-grid">
              <article class="top-events-card">
                <h3>Registrations</h3>
                <% if (reviewQueue?.topEvents?.registrations?.length) { %>
                  <ul class="top-events-list">
                    <% reviewQueue.topEvents.registrations.forEach(item => { %>
                      <li>
                        <a href="<%= item.href %>"><%= item.eventTitle %></a>
                        <span><%= item.count %></span>
                      </li>
                    <% }); %>
                  </ul>
                <% } else { %>
                  <p class="top-events-empty">No registration data in this range.</p>
                <% } %>
              </article>

              <article class="top-events-card">
                <h3>Approvals</h3>
                <% if (reviewQueue?.topEvents?.approvals?.length) { %>
                  <ul class="top-events-list">
                    <% reviewQueue.topEvents.approvals.forEach(item => { %>
                      <li>
                        <a href="<%= item.href %>"><%= item.eventTitle %></a>
                        <span><%= item.count %></span>
                      </li>
                    <% }); %>
                  </ul>
                <% } else { %>
                  <p class="top-events-empty">No approval data in this range.</p>
                <% } %>
              </article>

              <article class="top-events-card">
                <h3>Pending Queue</h3>
                <% if (reviewQueue?.topEvents?.pending?.length) { %>
                  <ul class="top-events-list">
                    <% reviewQueue.topEvents.pending.forEach(item => { %>
                      <li>
                        <a href="<%= item.href %>"><%= item.eventTitle %></a>
                        <span><%= item.count %></span>
                      </li>
                    <% }); %>
                  </ul>
                <% } else { %>
                  <p class="top-events-empty">No pending queue items.</p>
                <% } %>
              </article>
            </div>
          </section>

          <!-- Recent Events -->
          <section class="dashboard-section" aria-labelledby="events-heading">
            <div class="section-header">
              <h2 id="events-heading" class="section-heading">
                <i data-lucide="calendar"></i>
                My Events
              </h2>
              <% if (recentEvents.length > 0) { %>
                <a href="/organizer/events" class="view-all-link">
                  View All <i data-lucide="arrow-right"></i>
                </a>
              <% } %>
            </div>

            <% if (recentEvents.length > 0) { %>
              <div class="events-list">
                <% recentEvents.forEach(event => { %>
                  <div class="event-card">
                    <div class="event-date-badge">
                      <span class="event-month"><%= new Date(event.date).toLocaleDateString('en-US', { month: 'short' }) %></span>
                      <span class="event-day"><%= new Date(event.date).getDate() %></span>
                    </div>
                    <div class="event-info">
                      <h3><%= event.name %></h3>
                      <div class="event-branding">
                        <% if (event.bannerImageUrl) { %>
                          <a href="<%= event.bannerImageUrl %>" target="_blank" rel="noopener noreferrer" aria-label="Open banner image for <%= event.name %>">
                            <img src="<%= event.bannerImageUrl %>" alt="<%= event.name %> banner" class="event-banner-thumb">
                          </a>
                        <% } else { %>
                          <div class="event-banner-thumb event-banner-thumb-empty">No Banner</div>
                        <% } %>
                        <% if (event.logoUrl) { %>
                          <a href="<%= event.logoUrl %>" target="_blank" rel="noopener noreferrer" aria-label="Open logo image for <%= event.name %>">
                            <img src="<%= event.logoUrl %>" alt="<%= event.name %> logo" class="event-logo-thumb">
                          </a>
                        <% } %>
                      </div>
                      <p class="event-meta">
                        <i data-lucide="map-pin"></i> <%= event.location %>
                        <span class="meta-separator">&bull;</span>
                        <i data-lucide="users"></i> <%= event.registrations || 0 %> registered
                      </p>
                      <div class="event-meta-links">
                        <% if (event.bannerImageUrl) { %>
                          <a href="<%= event.bannerImageUrl %>" target="_blank" rel="noopener noreferrer">Open Banner URL</a>
                        <% } %>
                        <% if (event.logoUrl) { %>
                          <a href="<%= event.logoUrl %>" target="_blank" rel="noopener noreferrer">Open Logo URL</a>
                        <% } %>
                      </div>
                      <div class="event-card-actions">
                        <a href="/organizer/events/<%= event.id %>/registrants" class="event-link-btn">View Registrants</a>
                      </div>
                    </div>
                    <span class="event-status event-status-<%= event.status %>"><%= event.status %></span>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="empty-state">
                <div class="empty-icon">
                  <i data-lucide="calendar-plus"></i>
                </div>
                <h3>No events yet</h3>
                <p>Create your first running event and start accepting registrations!</p>
                <a href="/organizer/create-event" class="btn btn-create-sm">
                  <i data-lucide="plus"></i>
                  Create Your First Event
                </a>
              </div>
            <% } %>
          </section>
        </div>

        <!-- Right Column - Sidebar -->
        <aside class="dashboard-sidebar">

          <!-- Organizer Profile Card -->
          <div class="sidebar-card profile-card">
            <div class="profile-avatar">
              <span class="avatar-initials"><%= (user.firstName || 'O').charAt(0).toUpperCase() %><%= (user.lastName || 'R').charAt(0).toUpperCase() %></span>
            </div>
            <h3><%= user.firstName %> <%= user.lastName %></h3>
            <p class="profile-email"><%= user.email %></p>
            <div class="profile-details">
              <% if (application) { %>
                <div class="profile-detail-item">
                  <i data-lucide="briefcase"></i>
                  <span><%= application.businessName %></span>
                </div>
                <div class="profile-detail-item">
                  <i data-lucide="phone"></i>
                  <span><%= application.contactPhone %></span>
                </div>
                <div class="profile-detail-item">
                  <i data-lucide="hash"></i>
                  <span>ID: <%= application.applicationId %></span>
                </div>
              <% } else { %>
                <div class="profile-detail-item">
                  <span>No organizer application found. <a href="/organizer/complete-profile">Start Application</a></span>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Getting Started Checklist -->
          <div class="sidebar-card checklist-card">
            <h3>
              <i data-lucide="list-checks"></i>
              Getting Started
            </h3>
            <ul class="checklist">
              <li class="checklist-item completed">
                <i data-lucide="check-circle-2"></i>
                <span>Create your account</span>
              </li>
              <li class="checklist-item completed">
                <i data-lucide="check-circle-2"></i>
                <span>Verify your email</span>
              </li>
              <li class="checklist-item completed">
                <i data-lucide="check-circle-2"></i>
                <span>Complete organizer application</span>
              </li>
              <li class="checklist-item completed">
                <i data-lucide="check-circle-2"></i>
                <span>Get approved</span>
              </li>
              <li class="checklist-item <%= stats.totalEvents > 0 ? 'completed' : '' %>">
                <i data-lucide="<%= stats.totalEvents > 0 ? 'check-circle-2' : 'circle' %>"></i>
                <span>Create your first event</span>
              </li>
              <li class="checklist-item <%= stats.totalRegistrations > 0 ? 'completed' : '' %>">
                <i data-lucide="<%= stats.totalRegistrations > 0 ? 'check-circle-2' : 'circle' %>"></i>
                <span>Get your first registration</span>
              </li>
            </ul>
          </div>

          <!-- Help & Resources -->
          <div class="sidebar-card resources-card">
            <h3>
              <i data-lucide="life-buoy"></i>
              Help & Resources
            </h3>
            <ul class="resource-links">
              <li>
                <a href="/about">
                  <i data-lucide="book-open"></i>
                  Event Creation Guide
                </a>
              </li>
              <li>
                <a href="/about">
                  <i data-lucide="help-circle"></i>
                  FAQ
                </a>
              </li>
              <li>
                <a href="mailto:<%= typeof adminEmail !== 'undefined' ? adminEmail : 'hellorunonline@gmail.com' %>">
                  <i data-lucide="mail"></i>
                  Contact Support
                </a>
              </li>
            </ul>
          </div>

          <div class="sidebar-card review-queue-card">
            <h3>
              <i data-lucide="inbox"></i>
              Review Queue
            </h3>
            <div class="review-queue-items">
              <div class="review-queue-item">
                <div>
                  <strong><%= reviewQueue?.pendingPaymentReviews || 0 %></strong>
                  <p>Payment proofs awaiting review</p>
                </div>
                <a href="<%= reviewQueue?.paymentReviewHref || '/organizer/events' %>" class="event-link-btn">Review</a>
              </div>
              <div class="review-queue-item">
                <div>
                  <strong><%= reviewQueue?.pendingResultReviews || 0 %></strong>
                  <p>Result submissions awaiting review</p>
                </div>
                <a href="<%= reviewQueue?.resultReviewHref || '/organizer/events' %>" class="event-link-btn">Review</a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <%- include('../layouts/footer') %>

  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>



