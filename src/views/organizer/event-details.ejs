<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title }) %>
  <link rel="stylesheet" href="/css/event-manage.css">
  <link rel="stylesheet" href="/css/organizer-event-detail.css">
</head>
<body>
  <%- include('../layouts/nav') %>
  <% const p = presentation; %>

  <main class="organizer-event-detail-page" id="main-content" data-organizer-event-detail>
    <div class="organizer-event-detail-shell">
      <nav class="organizer-event-detail-breadcrumb" aria-label="Breadcrumb">
        <a href="/organizer/events"><i data-lucide="arrow-left" aria-hidden="true"></i> My Events</a>
        <span aria-hidden="true">/</span><span aria-current="page"><%= p.referenceCode %></span>
      </nav>

      <header class="organizer-event-detail-header">
        <div class="organizer-event-detail-identity">
          <div class="organizer-event-detail-title-meta">
            <span class="status status-<%= event.status %>"><%= p.statusLabel %></span>
            <span><i data-lucide="route" aria-hidden="true"></i><%= p.formatLabel %></span>
            <span><i data-lucide="map-pin" aria-hidden="true"></i><%= p.locationLabel %></span>
          </div>
          <h1><%= event.title %></h1>
          <p><code><%= p.referenceCode %></code> · Updated <%= event.updatedAt ? new Date(event.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'Asia/Manila' }) : 'date unavailable' %></p>
        </div>
        <nav class="organizer-event-detail-header-actions organizer-event-detail-header-actions-<%= p.canEdit ? 3 : 2 %>" aria-label="Event actions">
          <a href="/organizer/events" class="nav-login-btn"><i data-lucide="list" aria-hidden="true"></i><span>Events</span></a>
          <% if (p.canEdit) { %><a href="/organizer/events/<%= event._id %>/edit" class="nav-signup-btn"><i data-lucide="pencil" aria-hidden="true"></i><span>Edit Event</span></a><% } %>
          <a href="<%= p.publicVisibleNow ? p.publicHref : p.previewHref %>" class="nav-login-btn" aria-label="<%= p.publicVisibleNow ? 'View Public Event Page' : 'Preview Saved Event' %>"><i data-lucide="<%= p.publicVisibleNow ? 'globe' : 'eye' %>" aria-hidden="true"></i><span><%= p.publicVisibleNow ? 'Public Page' : 'Preview' %></span></a>
        </nav>
      </header>

      <% if (message) { %><div class="page-message page-message-<%= message.type %>" role="status"><%= message.text %></div><% } %>

      <section class="organizer-event-detail-overview" aria-labelledby="eventOverviewTitle">
        <h2 id="eventOverviewTitle" class="visually-hidden">Event operations overview</h2>
        <% p.metrics.forEach((metric) => { %>
          <% if (metric.actionable && metric.href) { %>
            <a href="<%= metric.href %>" class="organizer-event-detail-metric metric-<%= metric.key %> <%= metric.value && ['payments', 'results'].includes(metric.key) ? 'has-work' : '' %>">
              <span><%= metric.label %></span><strong><%= metric.value %></strong><small>Open <i data-lucide="arrow-right" aria-hidden="true"></i></small>
            </a>
          <% } else { %>
            <article class="organizer-event-detail-metric metric-<%= metric.key %>"><span><%= metric.label %></span><strong><%= metric.value %></strong><small>No review needed</small></article>
          <% } %>
        <% }); %>
      </section>

      <div class="organizer-event-detail-layout">
        <div class="organizer-event-detail-main">
          <section class="organizer-event-detail-section organizer-event-readiness <%= p.readinessTasks.length ? 'needs-attention' : 'is-ready' %>" aria-labelledby="eventReadinessTitle">
            <div class="organizer-event-detail-section-heading">
              <div><span>Operational readiness</span><h2 id="eventReadinessTitle"><%= p.readinessTasks.length ? `${p.readinessTasks.length} task${p.readinessTasks.length === 1 ? '' : 's'} need attention` : 'Core event setup is ready' %></h2></div>
              <span class="status status-<%= p.readinessTasks.length ? 'pending_review' : 'published' %>"><%= p.readinessTasks.length ? 'Needs attention' : 'Ready' %></span>
            </div>
            <% if (p.readinessTasks.length) { %>
              <div class="organizer-event-readiness-list">
                <% p.readinessTasks.forEach((item) => { %><article><div><strong><%= item.title %></strong><p><%= item.impact %></p></div><a href="<%= item.href %>" class="nav-login-btn"><%= item.action %></a></article><% }); %>
              </div>
            <% } else { %><p class="organizer-event-detail-helper">Current publishing, payment, certificate, and badge requirements are complete.</p><% } %>
          </section>

          <section class="organizer-event-detail-section" aria-labelledby="eventSetupTitle">
            <div class="organizer-event-detail-section-heading"><div><span>Essential configuration</span><h2 id="eventSetupTitle">Event setup</h2></div></div>
            <div class="organizer-event-fact-grid">
              <article class="organizer-event-fact-card">
                <h3><i data-lucide="calendar-days" aria-hidden="true"></i>Schedule</h3>
                <dl><% p.schedule.forEach((item) => { %><div><dt><%= item.label %></dt><dd><%= item.value %></dd></div><% }); %></dl>
                <small>Dates are shown in Asia/Manila.</small>
              </article>

              <article class="organizer-event-fact-card">
                <h3><i data-lucide="map" aria-hidden="true"></i>Format and location</h3>
                <dl>
                  <div><dt>Format</dt><dd><%= p.formatLabel %></dd></div>
                  <div><dt>Allowed modes</dt><dd><%= (event.eventTypesAllowed || []).join(', ') || event.eventType || 'Not configured' %></dd></div>
                  <div><dt>Location</dt><dd><%= p.locationLabel %></dd></div>
                  <div><dt>Distance mode</dt><dd><%= event.virtualCompletionMode === 'accumulated_distance' ? 'Accumulated distance' : 'Single activity' %></dd></div>
                </dl>
              </article>

              <article class="organizer-event-fact-card organizer-event-category-card">
                <h3><i data-lucide="milestone" aria-hidden="true"></i>Categories</h3>
                <% if (p.categories.length) { %><ul><% p.categories.forEach((category) => { %><li><strong><%= category.name %></strong><span><%= category.summary %></span><% if (category.rewards) { %><small><%= category.rewards %></small><% } %></li><% }); %></ul>
                <% } else { %><p>No categories configured.</p><% } %>
              </article>

              <article class="organizer-event-fact-card">
                <h3><i data-lucide="wallet-cards" aria-hidden="true"></i>Pricing</h3>
                <dl>
                  <div><dt>Registration fee</dt><dd><%= p.pricing.feeLabel %></dd></div>
                  <div><dt>Pricing mode</dt><dd class="capitalize"><%= p.pricing.modeLabel %></dd></div>
                  <div><dt>Payment account</dt><dd><%= p.pricing.paymentAccount %></dd></div>
                  <div><dt>Packages</dt><dd><%= (event.registrationPackages || []).length %></dd></div>
                </dl>
              </article>

              <article class="organizer-event-fact-card organizer-event-runner-experience">
                <h3><i data-lucide="person-standing" aria-hidden="true"></i>Runner experience</h3>
                <dl>
                  <div><dt>Proof types</dt><dd><%= p.runnerExperience.proofTypes %></dd></div>
                  <div><dt>Digital badge</dt><dd><%= p.runnerExperience.digitalBadge %></dd></div>
                  <div><dt>Certificate</dt><dd><%= p.runnerExperience.digitalCertificate %></dd></div>
                  <div><dt>Leaderboard</dt><dd><%= p.runnerExperience.leaderboard %></dd></div>
                  <div><dt>Physical rewards</dt><dd><%= p.runnerExperience.physicalRewards %></dd></div>
                  <div><dt>Waiver</dt><dd><%= p.runnerExperience.waiver %></dd></div>
                </dl>
              </article>
            </div>
          </section>

          <section class="organizer-event-detail-disclosures" aria-label="Detailed event configuration">
            <details class="organizer-event-detail-disclosure">
              <summary><span><i data-lucide="file-text" aria-hidden="true"></i><strong>Public content</strong><small>Description and full event details</small></span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
              <div class="organizer-event-detail-disclosure-body"><h3>Description</h3><p><%= event.description || 'No description configured.' %></p><% if (eventDetailsHtml) { %><h3>Full event details</h3><div class="event-rich-details"><%- eventDetailsHtml %></div><% } %></div>
            </details>

            <details class="organizer-event-detail-disclosure">
              <summary><span><i data-lucide="images" aria-hidden="true"></i><strong>Media</strong><small>Banner, logo, poster, and gallery</small></span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
              <div class="organizer-event-detail-disclosure-body">
                <% if (p.mediaItems.length || p.galleryItems.length) { %>
                  <div class="organizer-event-media-grid">
                    <% p.mediaItems.forEach((item) => { %>
                      <% if (item.kind === 'poster') { %><button type="button" class="detail-poster-thumb-btn" data-poster-src="<%= item.url %>" aria-label="Open promotional poster"><img src="<%= item.url %>" alt="<%= item.label %> for <%= event.title %>" loading="lazy"><span><%= item.label %></span></button>
                      <% } else { %><figure><img src="<%= item.url %>" alt="<%= item.label %> for <%= event.title %>" loading="lazy"><figcaption><%= item.label %></figcaption></figure><% } %>
                    <% }); %>
                    <% p.galleryItems.forEach((item, index) => { %><button type="button" class="detail-gallery-thumb-btn" data-gallery-index="<%= index %>" data-gallery-src="<%= item.url %>" aria-label="Open <%= item.label %>"><img src="<%= item.url %>" alt="<%= item.label %> for <%= event.title %>" loading="lazy"><span><%= item.label %></span></button><% }); %>
                  </div>
                <% } else { %><p>No event media uploaded.</p><% } %>
              </div>
            </details>

            <details class="organizer-event-detail-disclosure">
              <summary><span><i data-lucide="shield-check" aria-hidden="true"></i><strong>Payment and waiver details</strong><small>Receipt instructions, QR, and accepted waiver version</small></span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
              <div class="organizer-event-detail-disclosure-body organizer-event-detail-two-col">
                <article><h3>Payment acceptance</h3><dl><div><dt>Mode</dt><dd><%= event.feeMode === 'paid' ? 'Paid' : 'Free' %></dd></div><% if (event.feeMode === 'paid') { %><div><dt>Account</dt><dd><%= event.paymentAccountName || 'Not configured' %></dd></div><div><dt>Instructions</dt><dd><%= event.paymentInstructions || 'Not configured' %></dd></div><div><dt>Payment QR</dt><dd><%= event.paymentQrImageUrl ? 'Configured' : 'Missing' %></dd></div><% } %></dl></article>
                <article><h3>Waiver</h3><dl><div><dt>Version</dt><dd><%= event.waiverVersion || 1 %></dd></div><div><dt>Template</dt><dd><%= event.waiverTemplate ? 'Configured' : 'Missing' %></dd></div></dl></article>
              </div>
            </details>

            <details class="organizer-event-detail-disclosure">
              <summary><span><i data-lucide="database" aria-hidden="true"></i><strong>Event record</strong><small>Reference, public path, and technical identifiers</small></span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
              <div class="organizer-event-detail-disclosure-body">
                <dl class="organizer-event-record-list"><div><dt>Reference code</dt><dd><code><%= p.referenceCode %></code></dd></div><div><dt>Organiser</dt><dd><%= event.organiserName || 'HelloRun Organiser' %></dd></div><div><dt>Public path</dt><dd><code><%= p.publicHref %></code></dd></div></dl>
                <div class="organizer-event-record-actions"><button type="button" class="nav-login-btn copy-btn" data-copy-text="<%= p.referenceCode %>">Copy reference</button><button type="button" class="nav-login-btn copy-btn" data-copy-path="<%= p.publicHref %>">Copy event link</button></div>
                <details class="organizer-event-technical-details"><summary>Technical identifiers</summary><p><strong>Event ID:</strong> <code><%= event._id %></code></p><p><strong>Organiser ID:</strong> <code><%= event.organizerId %></code></p></details>
              </div>
            </details>
          </section>

          <details class="organizer-event-tools">
            <summary><span><i data-lucide="wrench" aria-hidden="true"></i><strong>Management Tools</strong><small>Recognition, commerce, publishing, and records</small></span><i data-lucide="chevron-down" aria-hidden="true"></i></summary>
            <div class="organizer-event-tools-grid">
              <% p.tools.forEach((group) => { %><section><h3><%= group.group %></h3><div><% group.items.forEach((item) => { %>
                <% if (item.label === 'Audit trail') { %><a href="/organizer/events/<%= event._id %>/audit"><i data-lucide="<%= item.icon %>" aria-hidden="true"></i><span><%= item.label %></span><i data-lucide="arrow-right" aria-hidden="true"></i></a>
                <% } else { %><a href="<%= item.href %>"><i data-lucide="<%= item.icon %>" aria-hidden="true"></i><span><%= item.label %></span><i data-lucide="arrow-right" aria-hidden="true"></i></a><% } %>
              <% }); %></div></section><% }); %>
            </div>
          </details>
        </div>

        <aside class="organizer-event-lifecycle" aria-labelledby="eventLifecycleTitle">
          <section class="organizer-event-lifecycle-card">
            <span><%= p.lifecycle.eyebrow %></span><h2 id="eventLifecycleTitle"><%= p.lifecycle.title %></h2><p><%= p.lifecycle.description %></p>
            <% if (p.lifecycle.action) { %>
              <% if (p.lifecycle.action.method === 'post') { %>
                <form method="POST" action="<%= p.lifecycle.action.href %>" data-high-risk-confirm data-confirm-title="Submit event for review" data-confirm-target="<%= event.title %>" data-confirm-impact="Moves this event into the administrator review queue." data-confirm-reversibility="The event cannot be edited normally while review is pending." data-confirm-privilege="Event organiser" data-confirm-button="Submit for Review">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="nextStatus" value="<%= p.lifecycle.action.nextStatus %>"><button type="submit" class="nav-signup-btn"><%= p.lifecycle.action.label %></button>
                </form>
              <% } else { %><a href="<%= p.lifecycle.action.href %>" class="nav-signup-btn"><%= p.lifecycle.action.label %></a><% } %>
            <% } %>
            <div class="organizer-event-lifecycle-flow"><strong>Lifecycle</strong><p><%= 'Draft -> Pending Review -> Published -> Closed' %></p></div>
            <% if (event.status === 'published') { %>
              <form method="POST" action="/organizer/events/<%= event._id %>/status" class="organizer-event-close-form" data-high-risk-confirm data-confirm-title="Close event" data-confirm-target="<%= event.title %>" data-confirm-impact="Closes the event and stops its active lifecycle." data-confirm-reversibility="This action is final in the current organiser workflow." data-confirm-privilege="Event organiser" data-confirm-button="Close Event">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="nextStatus" value="closed"><button type="submit" class="nav-login-btn">Close Event</button>
              </form>
            <% } %>
          </section>
        </aside>
      </div>
    </div>
  </main>

  <% if (p.galleryItems.length) { %>
    <div id="organizerGalleryLightbox" class="gallery-lightbox hidden organizer-event-media-dialog" aria-hidden="true">
      <div class="gallery-lightbox-backdrop" data-close-lightbox="1"></div><div class="gallery-lightbox-dialog" role="dialog" aria-modal="true" aria-label="Gallery viewer" tabindex="-1"><button type="button" class="gallery-lightbox-close" id="organizerGalleryCloseBtn" aria-label="Close gallery">&times;</button><button type="button" class="gallery-lightbox-nav gallery-lightbox-prev" id="organizerGalleryPrevBtn" aria-label="Previous image">&#10094;</button><img id="organizerGalleryLightboxImage" class="gallery-lightbox-image" src="" alt=""><button type="button" class="gallery-lightbox-nav gallery-lightbox-next" id="organizerGalleryNextBtn" aria-label="Next image">&#10095;</button><p id="organizerGalleryLightboxCounter" class="gallery-lightbox-counter"></p></div>
    </div>
  <% } %>
  <% if (event.posterImageUrl) { %>
    <div id="organizerPosterLightbox" class="gallery-lightbox hidden organizer-event-media-dialog" aria-hidden="true">
      <div class="gallery-lightbox-backdrop" data-close-poster-lightbox="1"></div><div class="gallery-lightbox-dialog" role="dialog" aria-modal="true" aria-label="Promotional poster viewer" tabindex="-1"><button type="button" class="gallery-lightbox-close" id="organizerPosterCloseBtn" aria-label="Close poster">&times;</button><div class="poster-zoom-controls"><button type="button" class="poster-zoom-btn" id="organizerPosterZoomOutBtn" aria-label="Zoom out">-</button><button type="button" class="poster-zoom-btn" id="organizerPosterZoomInBtn" aria-label="Zoom in">+</button><button type="button" class="poster-zoom-btn" id="organizerPosterResetBtn" aria-label="Reset zoom">Reset</button></div><img id="organizerPosterLightboxImage" class="gallery-lightbox-image" src="" alt=""></div>
    </div>
  <% } %>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script src="/js/organizer-event-detail.js"></script>
</body>
</html>
