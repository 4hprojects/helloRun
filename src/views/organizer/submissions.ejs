<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title || 'Run Submissions - HelloRun Organizer' }) %>
  <link rel="stylesheet" href="/css/submission-hub.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="organizer-submission-page" id="main-content" data-organizer-submissions>
    <div class="organizer-submission-shell">
      <header class="organizer-submission-header">
        <div>
          <p class="organizer-submission-kicker">Result moderation</p>
          <h1>Run Submissions</h1>
          <p>Review activity proof across your events, with the oldest pending work first.</p>
        </div>
        <nav class="organizer-submission-header-actions" aria-label="Submission workspace actions">
          <a href="<%= links.dashboard %>" class="nav-login-btn"><i data-lucide="layout-dashboard" aria-hidden="true"></i><span><%= isAdminViewer ? 'Admin Dashboard' : 'Dashboard' %></span></a>
          <% if (!isAdminViewer) { %><a href="<%= links.events %>" class="nav-login-btn"><i data-lucide="calendar-days" aria-hidden="true"></i><span>My Events</span></a><% } %>
        </nav>
      </header>

      <% if (message) { %><div class="page-message page-message-<%= message.type %>" role="status"><%= message.text %></div><% } %>
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" data-submission-csrf>

      <nav class="organizer-submission-status-strip" aria-label="Filter submissions by status">
        <% [
          { label: 'Pending', count: counts.submitted, href: links.submitted, selected: filters.status === 'submitted' },
          { label: 'Approved', count: counts.approved, href: links.approved, selected: filters.status === 'approved' },
          { label: 'Rejected', count: counts.rejected, href: links.rejected, selected: filters.status === 'rejected' },
          { label: 'Total', count: counts.total, href: links.all, selected: filters.status === 'all' }
        ].forEach((item) => { %>
          <a href="<%= item.href %>" class="<%= item.selected ? 'is-selected' : '' %>" aria-current="<%= item.selected ? 'page' : 'false' %>">
            <span><%= item.label %></span><strong><%= item.count %></strong>
          </a>
        <% }); %>
      </nav>

      <section class="organizer-submission-discovery" aria-labelledby="submission-discovery-heading">
        <h2 id="submission-discovery-heading" class="visually-hidden">Find and filter run submissions</h2>
        <form method="GET" action="/organizer/submissions" class="organizer-submission-filter-form">
          <input type="hidden" name="status" value="<%= filters.status %>">
          <div class="organizer-submission-search">
            <label for="submissionSearch">Search submissions</label>
            <div>
              <input id="submissionSearch" name="q" type="search" placeholder="Runner, email, event, or confirmation code" value="<%= filters.q || '' %>">
              <button type="submit" class="nav-signup-btn"><i data-lucide="search" aria-hidden="true"></i><span>Search</span></button>
            </div>
          </div>

          <details class="organizer-submission-filter-details" <%= hasAdvancedFilters ? 'open' : '' %>>
            <summary><span><i data-lucide="sliders-horizontal" aria-hidden="true"></i>Filters &amp; sort</span><i data-lucide="chevron-down" class="organizer-submission-filter-chevron" aria-hidden="true"></i></summary>
            <div class="organizer-submission-filter-grid">
              <div>
                <label for="submissionEvent">Event</label>
                <select id="submissionEvent" name="eventId">
                  <option value="">All events</option>
                  <% events.forEach((event) => { %><option value="<%= event.id %>" <%= filters.eventId === event.id ? 'selected' : '' %>><%= event.title %></option><% }); %>
                </select>
              </div>
              <div>
                <label for="submissionType">Submission type</label>
                <select id="submissionType" name="type">
                  <option value="all" <%= filters.type === 'all' ? 'selected' : '' %>>All types</option>
                  <option value="standard" <%= filters.type === 'standard' ? 'selected' : '' %>>Standard result</option>
                  <option value="accumulated" <%= filters.type === 'accumulated' ? 'selected' : '' %>>Accumulated activity</option>
                </select>
              </div>
              <div>
                <label for="submissionSort">Sort</label>
                <select id="submissionSort" name="sort">
                  <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest first</option>
                  <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest first</option>
                </select>
              </div>
              <div>
                <label for="submissionPageSize">Per page</label>
                <select id="submissionPageSize" name="pageSize">
                  <% [25, 50, 100].forEach((size) => { %><option value="<%= size %>" <%= filters.pageSize === size ? 'selected' : '' %>><%= size %></option><% }); %>
                </select>
              </div>
              <div class="organizer-submission-filter-actions">
                <button type="submit" class="nav-signup-btn">Apply</button>
                <a href="<%= links.reset %>" class="nav-login-btn">Clear</a>
              </div>
            </div>
          </details>
        </form>
      </section>

      <div class="organizer-submission-results-heading">
        <% const resultStart = pagination.totalItems ? ((pagination.page - 1) * pagination.pageSize) + 1 : 0; %>
        <% const resultEnd = pagination.totalItems ? resultStart + submissions.length - 1 : 0; %>
        <p>Showing <strong><%= resultStart %>–<%= resultEnd %></strong> of <strong><%= pagination.totalItems %></strong> matching submissions</p>
        <p><%= counts.standard %> standard · <%= counts.accumulated %> accumulated</p>
      </div>

      <% const eligibleSubmissions = (submissions || []).filter((item) => item.quickApprovalEligible); %>
      <% if (!isAdminViewer && eligibleSubmissions.length) { %>
        <form method="POST" action="/organizer/submissions/bulk-approve" id="organizerBulkApproveForm" class="organizer-submission-bulk-bar" data-bulk-approval-form>
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
          <input type="hidden" name="returnStatus" value="<%= filters.status %>">
          <input type="hidden" name="returnType" value="<%= filters.type %>">
          <input type="hidden" name="returnEventId" value="<%= filters.eventId %>">
          <input type="hidden" name="returnSort" value="<%= filters.sort %>">
          <input type="hidden" name="returnQ" value="<%= filters.q %>">
          <input type="hidden" name="returnPageSize" value="<%= filters.pageSize %>">
          <input type="hidden" name="returnPage" value="<%= filters.page %>">
          <label><input type="checkbox" data-select-all-eligible> Select clean results on this page</label>
          <span data-selected-count aria-live="polite">0 selected</span>
          <textarea name="reviewNotes" rows="1" maxlength="1200" placeholder="Optional shared approval note"></textarea>
          <button type="submit" class="nav-signup-btn" disabled data-bulk-approve-button>Approve selected</button>
        </form>
      <% } %>

      <% if (submissions && submissions.length) { %>
        <div class="organizer-submission-table-wrap">
          <table class="organizer-submission-table <%= isAdminViewer ? 'is-admin-viewer' : '' %>">
            <thead><tr>
              <% if (!isAdminViewer) { %><th class="organizer-submission-check-column"><span class="visually-hidden">Select</span></th><% } %>
              <th>Runner &amp; event</th><th>Result</th><th>Evidence</th><th>Submitted</th><th>Status</th><th>Actions</th>
            </tr></thead>
            <tbody>
              <% submissions.forEach((item) => { %>
                <tr data-submission-id="<%= item.id %>" data-status="<%= item.status %>">
                  <% if (!isAdminViewer) { %>
                    <td class="organizer-submission-check-column" data-label="Select">
                      <% if (item.quickApprovalEligible) { %><input type="checkbox" name="submissionIds" value="<%= item.id %>" form="organizerBulkApproveForm" data-eligible-submission aria-label="Select <%= item.participantName %> for approval"><% } else { %><span aria-hidden="true">—</span><% } %>
                    </td>
                  <% } %>
                  <td data-label="Runner & event" class="organizer-submission-identity">
                    <strong><%= item.participantName %></strong>
                    <span><%= item.participantEmail %> · <span class="mono"><%= item.confirmationCode %></span></span>
                    <a href="<%= item.eventQueueHref %>"><%= item.eventTitle %></a>
                    <small><%= item.raceDistance %> · <%= item.submissionTypeLabel %></small>
                  </td>
                  <td data-label="Result"><strong><%= item.distanceLabel %></strong><span><%= item.elapsedLabel %></span></td>
                  <td data-label="Evidence"><strong><%= item.sourceLabel %></strong><span><%= item.proofTypeLabel %></span></td>
                  <td data-label="Submitted"><strong><%= item.submittedAtLabel %></strong><span class="organizer-submission-waiting"><%= item.waitingLabel %></span></td>
                  <td data-label="Status">
                    <span class="status-badge status-badge-<%= item.statusClass %>"><%= item.statusLabel %></span>
                    <% if (item.suspiciousFlag || item.reviewSignal?.label) { %><span class="organizer-submission-warning" title="<%= item.reviewSignal?.description || item.suspiciousFlagReason %>"><i data-lucide="triangle-alert" aria-hidden="true"></i><%= item.reviewSignal?.label || 'Integrity review required' %></span><% } %>
                  </td>
                  <td data-label="Actions" class="organizer-submission-actions">
                    <% const reviewActionLabel = item.status === 'submitted' ? 'Review submission' : 'View submission details'; %>
                    <a href="<%= item.actionHref %>" class="nav-signup-btn organizer-submission-icon-action" data-submission-modal-link data-submission-id="<%= item.id %>" aria-label="<%= reviewActionLabel %>" aria-describedby="submission-action-<%= item.id %>">
                      <i data-lucide="<%= item.status === 'submitted' ? 'clipboard-check' : 'eye' %>" aria-hidden="true"></i>
                      <span class="organizer-submission-action-tooltip" id="submission-action-<%= item.id %>" role="tooltip"><%= reviewActionLabel %></span>
                    </a>
                    <% if (!isAdminViewer && item.quickApprovalEligible) { %>
                      <form method="POST" action="/organizer/submissions/<%= item.id %>/quick-approve" data-quick-approval-form data-runner="<%= item.participantName %>" data-event="<%= item.eventTitle %>" data-result="<%= item.distanceLabel %>">
                        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
                        <input type="hidden" name="returnStatus" value="<%= filters.status %>"><input type="hidden" name="returnType" value="<%= filters.type %>"><input type="hidden" name="returnEventId" value="<%= filters.eventId %>"><input type="hidden" name="returnSort" value="<%= filters.sort %>"><input type="hidden" name="returnQ" value="<%= filters.q %>"><input type="hidden" name="returnPageSize" value="<%= filters.pageSize %>"><input type="hidden" name="returnPage" value="<%= filters.page %>">
                        <button type="submit" class="nav-login-btn organizer-submission-icon-action" aria-label="Quick approve submission" aria-describedby="quick-approve-action-<%= item.id %>">
                          <i data-lucide="circle-check-big" aria-hidden="true"></i>
                          <span class="organizer-submission-action-tooltip" id="quick-approve-action-<%= item.id %>" role="tooltip">Quick approve</span>
                        </button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <% if (pagination.totalPages > 1) { %>
          <nav class="organizer-submission-pagination" aria-label="Submission pagination">
            <% if (links.prev) { %><a href="<%= links.prev %>" class="nav-login-btn"><i data-lucide="chevron-left" aria-hidden="true"></i>Previous</a><% } else { %><span></span><% } %>
            <p>Page <strong><%= pagination.page %></strong> of <strong><%= pagination.totalPages %></strong></p>
            <% if (links.next) { %><a href="<%= links.next %>" class="nav-login-btn">Next<i data-lucide="chevron-right" aria-hidden="true"></i></a><% } else { %><span></span><% } %>
          </nav>
        <% } %>
      <% } else { %>
        <section class="organizer-submission-empty">
          <i data-lucide="clipboard-check" aria-hidden="true"></i>
          <% if (filters.status === 'submitted' && !filters.q && !filters.eventId && filters.type === 'all') { %><h2>No pending reviews</h2><p>Your cross-event result queue is clear.</p><a href="<%= links.all %>" class="nav-login-btn">View submission history</a>
          <% } else { %><h2>No matching submissions</h2><p>Try another search or clear the current filters.</p><a href="<%= links.reset %>" class="nav-login-btn">Clear filters</a><% } %>
        </section>
      <% } %>
    </div>
  </main>

  <div class="organizer-approval-dialog-backdrop" data-approval-dialog hidden>
    <section class="organizer-approval-dialog" role="dialog" aria-modal="true" aria-labelledby="approvalDialogTitle" aria-describedby="approvalDialogDescription" tabindex="-1">
      <div class="organizer-approval-dialog-icon"><i data-lucide="circle-check" aria-hidden="true"></i></div>
      <h2 id="approvalDialogTitle" data-approval-title>Approve submission?</h2>
      <p id="approvalDialogDescription" data-approval-description>Confirm that you reviewed the selected result.</p>
      <div class="organizer-approval-selection" data-approval-selection></div>
      <p class="organizer-approval-error" data-approval-error role="alert" hidden></p>
      <div class="organizer-approval-dialog-actions">
        <button type="button" class="nav-login-btn" data-approval-cancel>Cancel</button>
        <button type="button" class="nav-signup-btn" data-approval-confirm>Confirm approval</button>
      </div>
    </section>
  </div>

  <%- include('../layouts/footer') %>
  <%- include('../partials/submission-link-modal') %>
  <script src="/js/main.js"></script>
  <script src="/js/submission-link-modal.js"></script>
  <script src="/js/organizer-submissions.js"></script>
</body>
</html>
