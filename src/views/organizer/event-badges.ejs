<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/event-manage.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="manage-page organizer-badge-manager-page">
    <section class="manage-shell">
      <header class="manage-header">
        <div class="manage-header-copy">
          <p class="manage-eyebrow">Badge Manager</p>
          <h1><%= event.title %></h1>
          <p>Control the badge names, descriptions, images, and event-page visibility for this event.</p>
        </div>
        <div class="header-actions">
          <a href="/organizer/events/<%= event._id %>" class="nav-login-btn detail-nav-btn">Back to Event</a>
          <a href="/events/<%= event.slug %>" class="nav-login-btn detail-nav-btn" target="_blank" rel="noopener noreferrer">Public Page</a>
        </div>
      </header>

      <% if (message) { %>
        <div class="page-message page-message-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <section class="badge-manager-summary detail-card detail-card-full">
        <div>
          <h3>Event Badges</h3>
          <p><strong>Status:</strong> <span class="status status-<%= event.status %>"><%= event.status %></span></p>
          <p><strong>Digital Badges:</strong> <%= event.digitalBadgeEnabled ? 'Enabled' : 'Disabled' %></p>
        </div>
        <div class="badge-manager-count">
          <strong><%= badges.length %></strong>
          <span>configured badge<%= badges.length === 1 ? '' : 's' %></span>
        </div>
      </section>

      <%
        const BADGE_ICONS_ORG = {
          participant: 'user-check', finisher: 'trophy',
          distance_finisher: 'medal', mode_finisher: 'zap',
          challenge_progress: 'trending-up', challenge_finisher: 'award',
          category_winner: 'crown', top_rank: 'star',
          distance_winner: 'flag', mode_winner: 'shield-check'
        };
        const getBadgeIconOrg = (type) => BADGE_ICONS_ORG[type] || 'award';
      %>
      <% if (badges.length) { %>
        <div class="organizer-badge-grid" data-organizer-badge-manager>
          <% badges.forEach((badge) => { %>
            <article class="organizer-badge-card">
              <div class="organizer-badge-preview">
                <span class="organizer-badge-art">
                  <% if (badge.imageUrl) { %>
                    <img src="<%= badge.imageUrl %>" alt="" loading="lazy">
                  <% } else { %>
                    <i data-lucide="<%= getBadgeIconOrg(badge.badgeType) %>"></i>
                  <% } %>
                </span>
                <div class="organizer-badge-preview-copy">
                  <h3><%= badge.name %></h3>
                  <p><%= badge.description || 'No badge description set.' %></p>
                  <div class="organizer-badge-tags">
                    <span><%= badge.badgeType.replace(/_/g, ' ') %></span>
                    <span><%= badge.requirementType.replace(/_/g, ' ') %></span>
                    <% if (!badge.isVisibleOnEventPage) { %><span>Hidden</span><% } %>
                    <% if (!badge.isActive) { %><span>Inactive</span><% } %>
                  </div>
                </div>
              </div>

              <form method="POST" action="/organizer/events/<%= event._id %>/badges/<%= badge.eventBadgeId %>" class="organizer-badge-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="badge-form-grid">
                  <label>
                    <span>Name</span>
                    <input type="text" name="name" value="<%= badge.name %>" maxlength="120">
                  </label>
                  <label>
                    <span>Image URL</span>
                    <div class="badge-image-url-row">
                      <input type="url" name="imageUrl" id="badgeImageUrl-<%= badge.eventBadgeId %>" value="<%= badge.imageUrl || '' %>" placeholder="https://...">
                      <label class="badge-upload-btn" title="Upload image to HelloRun CDN">
                        <input type="file" accept="image/jpeg,image/png,image/webp" class="badge-image-file-input" data-badge-id="<%= badge.eventBadgeId %>" data-event-id="<%= event._id %>" style="display:none">
                        <i data-lucide="upload"></i>
                      </label>
                    </div>
                  </label>
                  <label class="badge-form-description">
                    <span>Description</span>
                    <textarea name="description" rows="3" maxlength="300"><%= badge.description || '' %></textarea>
                  </label>
                </div>

                <div class="badge-form-toggles">
                  <label class="badge-toggle">
                    <input type="hidden" name="isVisible" value="0">
                    <input type="checkbox" name="isVisible" value="1" <%= badge.isVisibleOnEventPage ? 'checked' : '' %>>
                    <span>Show on event page</span>
                  </label>
                  <label class="badge-toggle">
                    <input type="hidden" name="isActive" value="0">
                    <input type="checkbox" name="isActive" value="1" <%= badge.isActive ? 'checked' : '' %>>
                    <span>Allow future awards</span>
                  </label>
                </div>

                <div class="badge-form-footer">
                  <div>
                    <code><%= badge.badgeCode %></code>
                    <% const earnedCount = (typeof earnedCountByBadgeId !== 'undefined' && earnedCountByBadgeId[badge.badgeDefinitionId]) || 0; %>
                    <% if (earnedCount > 0) { %>
                      <span class="badge-earned-count"><%= earnedCount %> runner<%= earnedCount === 1 ? '' : 's' %> earned</span>
                    <% } else { %>
                      <span class="badge-earned-count badge-earned-count-zero">Not yet earned</span>
                    <% } %>
                  </div>
                  <button type="submit" class="nav-signup-btn detail-status-btn">Save Badge</button>
                </div>
              </form>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <section class="detail-card detail-card-full badge-manager-empty">
          <h3>No badges configured</h3>
          <p>Badges are generated for published events with digital badges enabled. If this event was recently published, refresh this page after the event badge job completes.</p>
          <a href="/organizer/events/<%= event._id %>" class="nav-login-btn detail-nav-btn">Back to Event</a>
        </section>
      <% } %>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>
    if (window.lucide) lucide.createIcons();

    // Badge image upload handlers
    document.querySelectorAll('.badge-image-file-input').forEach(function(input) {
      input.addEventListener('change', async function() {
        const file = input.files[0];
        if (!file) return;
        const badgeId = input.dataset.badgeId;
        const eventId = input.dataset.eventId;
        const urlInput = document.getElementById('badgeImageUrl-' + badgeId);
        const csrfToken = document.querySelector('[name="_csrf"]')?.value || '';

        const formData = new FormData();
        formData.append('badgeImageFile', file);
        formData.append('_csrf', csrfToken);

        try {
          const res = await fetch('/organizer/events/' + eventId + '/badges/' + badgeId + '/image', {
            method: 'POST',
            body: formData
          });
          const data = await res.json();
          if (res.ok && data.success) {
            if (urlInput) urlInput.value = data.imageUrl;
          } else {
            alert(data.message || 'Image upload failed.');
          }
        } catch {
          alert('Network error — image upload failed.');
        }
        input.value = '';
      });
    });
  </script>
</body>
</html>
