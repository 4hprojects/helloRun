<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../layouts/head', { title: title }) %>
  <link rel="stylesheet" href="/css/event-manage.css">
</head>
<body>
  <%- include('../layouts/nav') %>

  <main class="manage-page organizer-event-preview-page">
    <section class="manage-shell">
      <header class="manage-header">
        <div class="manage-header-copy">
          <p class="manage-eyebrow">Event Workspace</p>
          <h1>Event Preview</h1>
          <p>Preview only. This event has not been saved yet.</p>
        </div>
        <div class="header-actions">
          <a href="/organizer/create-event" class="nav-login-btn preview-nav-btn">Back to Create</a>
          <button type="button" class="nav-signup-btn preview-nav-btn" onclick="window.close()">Close Preview</button>
        </div>
      </header>

      <% const errorMessages = Object.values(errors || {}); %>
      <% if (errorMessages.length) { %>
        <div class="page-message page-message-error">
          <strong>This preview has validation issues:</strong>
          <ul>
            <% errorMessages.forEach((errorText) => { %>
              <li><%= errorText %></li>
            <% }); %>
          </ul>
        </div>
      <% } else { %>
        <div class="page-message page-message-success">
          <strong>Looks good:</strong> this event is valid based on current create-event rules.
        </div>
      <% } %>

      <div class="detail-grid">
        <article class="detail-card">
          <h3>Basic</h3>
          <p><strong>Status on Save:</strong> <span class="status status-<%= previewEvent.actionType === 'publish' ? 'published' : 'draft' %>"><%= previewEvent.actionType === 'publish' ? 'published' : 'draft' %></span></p>
          <p><strong>Title:</strong> <%= previewEvent.title || 'N/A' %></p>
          <p><strong>Organizer:</strong> <%= previewEvent.organiserName || 'Will use account name' %></p>
          <p><strong>Event Type:</strong> <%= previewEvent.eventType || 'N/A' %></p>
          <p><strong>Allowed Modes:</strong> <%= (previewEvent.eventTypesAllowed || []).join(', ') || 'N/A' %></p>
          <p><strong>Race Distances:</strong> <%= (previewEvent.raceDistances || []).join(', ') || 'N/A' %></p>
          <p><strong>Fee:</strong> <%= previewEvent.feeMode === 'paid' ? `${previewEvent.feeCurrency || 'PHP'} ${Number(previewEvent.feeAmount || 0).toFixed(2)}` : 'Free' %></p>
          <p><strong>Pricing Mode:</strong> <%= previewEvent.pricingMode || 'free' %></p>
        </article>

        <article class="detail-card">
          <h3>Dates</h3>
          <p><strong>Registration Open:</strong> <%= previewEvent.registrationOpenAt ? new Date(previewEvent.registrationOpenAt).toLocaleString('en-US') : 'N/A' %></p>
          <p><strong>Registration Close:</strong> <%= previewEvent.registrationCloseAt ? new Date(previewEvent.registrationCloseAt).toLocaleString('en-US') : 'N/A' %></p>
          <p><strong>Event Start:</strong> <%= previewEvent.eventStartAt ? new Date(previewEvent.eventStartAt).toLocaleString('en-US') : 'N/A' %></p>
          <p><strong>Event End:</strong> <%= previewEvent.eventEndAt ? new Date(previewEvent.eventEndAt).toLocaleString('en-US') : 'N/A' %></p>
        </article>

        <article class="detail-card">
          <h3>Location</h3>
          <p><strong>Venue:</strong> <%= previewEvent.venueName || 'N/A' %></p>
          <p><strong>Address:</strong> <%= previewEvent.venueAddress || 'N/A' %></p>
          <p><strong>City/Province:</strong> <%= [previewEvent.city, previewEvent.province].filter(Boolean).join(', ') || 'N/A' %></p>
          <p><strong>Country:</strong> <%= previewEvent.country || 'N/A' %></p>
          <p><strong>Geo:</strong> <%= previewEvent.geo && Number.isFinite(previewEvent.geo.lat) && Number.isFinite(previewEvent.geo.lng) ? `${previewEvent.geo.lat}, ${previewEvent.geo.lng}` : 'N/A' %></p>
        </article>

        <article class="detail-card">
          <h3>Virtual Rules</h3>
          <p><strong>Virtual Window Start:</strong> <%= previewEvent.virtualWindow?.startAt ? new Date(previewEvent.virtualWindow.startAt).toLocaleString('en-US') : 'N/A' %></p>
          <p><strong>Virtual Window End:</strong> <%= previewEvent.virtualWindow?.endAt ? new Date(previewEvent.virtualWindow.endAt).toLocaleString('en-US') : 'N/A' %></p>
          <p><strong>Proof Types:</strong> <%= (previewEvent.proofTypesAllowed || []).join(', ') || 'N/A' %></p>
          <p><strong>Event Format:</strong> <%= previewEvent.virtualCompletionMode === 'accumulated_distance' ? 'Accumulated distance challenge' : 'Single activity' %></p>
          <% if (previewEvent.virtualCompletionMode === 'accumulated_distance') { %>
            <p><strong>Target Distance:</strong> <%= previewEvent.targetDistanceKm || 'N/A' %> km</p>
            <p><strong>Final Submission Deadline:</strong> <%= previewEvent.finalSubmissionDeadlineAt ? new Date(previewEvent.finalSubmissionDeadlineAt).toLocaleString('en-US') : 'N/A' %></p>
            <p><strong>Accepted Activities:</strong> <%= (previewEvent.acceptedRunTypes || []).join(', ') || 'N/A' %></p>
          <% } %>
        </article>

        <article class="detail-card detail-card-full">
          <h3>Description</h3>
          <p><%= previewEvent.description || 'N/A' %></p>
        </article>

        <article class="detail-card">
          <h3>Payment Acceptance</h3>
          <p><strong>Mode:</strong> <%= previewEvent.feeMode === 'paid' ? 'Paid' : 'Free' %></p>
          <p><strong>Suggested Setup Total:</strong> <%= previewEvent.feeCurrency || 'PHP' %> <%= Number(previewEvent.suggestedEventFee || 0).toFixed(2) %></p>
          <p><strong>Organizer Final Fee:</strong> <%= previewEvent.finalEventFee !== null && previewEvent.finalEventFee !== undefined ? `${previewEvent.feeCurrency || 'PHP'} ${Number(previewEvent.finalEventFee || 0).toFixed(2)}` : 'N/A' %></p>
          <% if (previewEvent.feeMode === 'paid') { %>
            <p><strong>Account:</strong> <%= previewEvent.paymentAccountName || 'N/A' %></p>
            <p><strong>Payment QR:</strong> <%= previewEvent.paymentQrImageUrl ? 'Configured' : 'Missing' %></p>
            <p><strong>Instructions:</strong> <%= previewEvent.paymentInstructions || 'N/A' %></p>
          <% } %>
        </article>

        <article class="detail-card">
          <h3>Rewards and Packages</h3>
          <% const previewPhysicalRewardItems = [
            previewEvent.physicalRewardMedalEnabled ? `Medal (${previewEvent.feeCurrency || 'PHP'} ${Number(previewEvent.physicalRewardMedalAmount || 0).toFixed(2)})` : '',
            previewEvent.physicalRewardShirtEnabled ? `Shirt (${previewEvent.feeCurrency || 'PHP'} ${Number(previewEvent.physicalRewardShirtAmount || 0).toFixed(2)})` : '',
            previewEvent.physicalRewardPatchEnabled ? `Patch (${previewEvent.feeCurrency || 'PHP'} ${Number(previewEvent.physicalRewardPatchAmount || 0).toFixed(2)})` : '',
            previewEvent.physicalRewardTowelEnabled ? `Towel (${previewEvent.feeCurrency || 'PHP'} ${Number(previewEvent.physicalRewardTowelAmount || 0).toFixed(2)})` : '',
            previewEvent.physicalRewardFinisherKitEnabled ? `Finisher Kit (${previewEvent.feeCurrency || 'PHP'} ${Number(previewEvent.physicalRewardFinisherKitAmount || 0).toFixed(2)})` : ''
          ].filter(Boolean); %>
          <p><strong>Digital Badge:</strong> <%= previewEvent.digitalBadgeEnabled ? 'Enabled' : 'Disabled' %></p>
          <p><strong>Digital Certificate:</strong> <%= previewEvent.digitalCertificateEnabled === false ? 'Disabled' : 'Enabled' %></p>
          <p><strong>Leaderboard Recognition:</strong> <%= previewEvent.leaderboardRecognitionEnabled === false ? 'Disabled' : 'Enabled' %></p>
          <p><strong>Physical Rewards:</strong> <%= previewEvent.physicalRewardsEnabled ? 'Enabled' : 'Disabled' %></p>
          <% if (previewEvent.physicalRewardsEnabled && previewPhysicalRewardItems.length) { %>
            <p><strong>Included Items:</strong> <%= previewPhysicalRewardItems.join(', ') %></p>
          <% } %>
          <% if (previewEvent.physicalRewardsEnabled && previewEvent.physicalRewardsDescription) { %>
            <p><%= previewEvent.physicalRewardsDescription %></p>
          <% } %>
          <% if ((previewEvent.physicalRewardOtherItems || []).length) { %>
            <p><strong>Custom Merchandise:</strong> <%= previewEvent.physicalRewardOtherItems.map((item) => `${item.name || 'Unnamed'} (${previewEvent.feeCurrency || 'PHP'} ${Number(item.amount || 0).toFixed(2)})`).join(', ') %></p>
          <% } %>
          <% if ((previewEvent.registrationPackages || []).length) { %>
            <p><strong>Packages:</strong> <%= previewEvent.registrationPackages.map((packageOption) => packageOption.name || 'Unnamed package').join(', ') %></p>
          <% } %>
          <% if (previewEvent.deliveryFeeEnabled) { %>
            <p><strong>Delivery/Claiming:</strong> <%= previewEvent.claimingMethod || 'delivery' %>, <%= previewEvent.feeCurrency || 'PHP' %> <%= Number(previewEvent.deliveryFeeAmount || 0).toFixed(2) %></p>
          <% } %>
          <% if ((previewEvent.specialRewardBenefits || []).length) { %>
            <p><strong>Special Benefits:</strong> <%= previewEvent.specialRewardBenefits.map((benefit) => benefit.title || 'Untitled benefit').join(', ') %></p>
          <% } %>
        </article>

        <% if (eventDetailsHtml) { %>
          <article class="detail-card detail-card-full">
            <h3>Event Details</h3>
            <div class="event-rich-details"><%- eventDetailsHtml %></div>
          </article>
        <% } %>

        <article class="detail-card">
          <h3>Branding</h3>
          <p><strong>Banner URL:</strong> <%= previewEvent.bannerImageUrl || 'N/A' %></p>
          <p><strong>Logo URL:</strong> <%= previewEvent.logoUrl || 'N/A' %></p>
          <p><strong>Poster URL:</strong> <%= previewEvent.posterImageUrl || 'N/A' %></p>
          <p><strong>Gallery Images:</strong> <%= (previewEvent.galleryImageUrls || []).length %></p>
        </article>
      </div>
    </section>
  </main>

  <%- include('../layouts/footer') %>
  <script src="/js/main.js"></script>
  <script>if (window.lucide) lucide.createIcons();</script>
</body>
</html>
