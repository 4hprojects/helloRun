{
  "name": "hellorun",
  "version": "1.0.0",
  "description": "Running event management platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "setup": "node src/scripts/setup-uploads.js",
    "backfill:event-reference-codes": "node src/scripts/backfill-event-reference-codes.js",
    "certificates:reconcile-accumulated": "node src/scripts/reconcile-accumulated-certificates.js",
    "mark-test-events": "node src/scripts/mark-test-events.js",
    "seed:policies": "node src/scripts/seed-policies.js",
    "adsense:blocker-cleanup": "node src/scripts/adsense-blocker-cleanup.js",
    "seed:adsense-blog": "node src/scripts/seed-adsense-blog-posts.js",
    "seed:privacy-policy": "node src/scripts/seed-privacy-policy.js",
    "seed:terms-policy": "node src/scripts/seed-terms-policy.js",
    "seed:cookie-policy": "node src/scripts/seed-cookie-policy.js",
    "supabase:migrate": "node src/scripts/run-supabase-migrations.js",
    "supabase:backfill:app-users": "node src/scripts/backfill-app-users.js",
    "supabase:verify:app-users": "node src/scripts/verify-app-users-bridge.js",
    "supabase:backfill:policy-consents": "node src/scripts/backfill-policy-consents.js",
    "supabase:verify:policy-consents": "node src/scripts/verify-policy-consents.js",
    "supabase:backfill:event-core": "node src/scripts/backfill-event-core-shadow.js",
    "supabase:verify:event-core": "node src/scripts/verify-event-core-shadow.js",
    "supabase:backfill:registrations": "node src/scripts/backfill-registration-payment-shadow.js",
    "supabase:verify:registrations": "node src/scripts/verify-registration-payment-shadow.js",
    "supabase:repair:registrations": "node src/scripts/repair-registration-references.js",
    "supabase:backfill:missing-references": "node src/scripts/backfill-missing-references.js",
    "supabase:backfill:submissions": "node src/scripts/backfill-submission-certificate-shadow.js",
    "supabase:verify:submissions": "node src/scripts/verify-submission-certificate-shadow.js",
    "supabase:backfill:rankings": "node src/scripts/backfill-rankings.js",
    "supabase:verify:rankings": "node src/scripts/verify-rankings.js",
    "supabase:verify:phase7": "node src/scripts/verify-phase7-onsite.js",
    "supabase:smoke:live-sync": "node src/scripts/smoke-supabase-live-sync.js",
    "smoke:cleanup": "node src/scripts/cleanup-smoke-tests.js",
    "smoke:cleanup:dry": "node src/scripts/cleanup-smoke-tests.js --dry-run --expired",
    "smoke:report:legacy": "node src/scripts/report-legacy-smoke-candidates.js",
    "smoke:tag:legacy": "node src/scripts/tag-legacy-smoke-candidates.js",
    "smoke:full": "node src/scripts/run-smoke-tests.js",
    "copy-tesseract-assets": "node src/scripts/copy-tesseract-assets.js",
    "download-tessdata": "node src/scripts/download-tessdata.js",
    "postinstall": "npm run setup && npm run copy-tesseract-assets && npm run download-tessdata",
    "test": "node src/scripts/run-test-group.js",
    "test:parallel": "node -e \"const { spawnSync } = require('node:child_process'); const env = { ...process.env, CSRF_PROTECTION: '0' }; const result = spawnSync(process.execPath, ['--test', 'tests/*.test.js'], { stdio: 'inherit', env }); process.exit(result.status ?? 1);\"",
    "test:audit": "npm audit --omit=dev",
    "test:unit": "node src/scripts/run-test-group.js tests/*.unit.test.js",
    "test:integration": "node src/scripts/run-test-group.js tests/*.integration.test.js",
    "test:auth": "node src/scripts/run-test-group.js tests/*auth*.test.js tests/*csrf*.test.js tests/*security*.test.js tests/privacy-signup-consent.integration.test.js tests/google-oauth-routes.integration.test.js tests/rate-limiter-enforcement.integration.test.js",
    "test:shop": "node src/scripts/run-test-group.js tests/*shop*.test.js tests/registration-addons-read.integration.test.js",
    "test:runner": "node src/scripts/run-test-group.js tests/runner*.test.js tests/running-group*.test.js tests/submission*.test.js tests/run-proof-integrity.unit.test.js tests/ocr*.test.js tests/strava-integration.integration.test.js",
    "test:organizer": "node src/scripts/run-test-group.js tests/organizer*.test.js tests/organiser*.test.js tests/onsite*.test.js tests/phase7*.test.js tests/payment*.test.js",
    "test:admin": "node src/scripts/run-test-group.js tests/admin*.test.js tests/blog-admin-workflow.integration.test.js tests/organiser-application-review.integration.test.js",
    "test:services": "node src/scripts/run-test-group.js tests/*.service.unit.test.js tests/*.service.integration.test.js tests/*shadow*.test.js tests/*bridge*.test.js",
    "test:smoke": "npm run test:audit && node src/scripts/run-test-group.js tests/*.smoke.test.js"
  },
  "keywords": [
    "running",
    "events",
    "race",
    "marathon"
  ],
  "author": "Henson M. Sagorsor <hensonsagorsor@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.998.0",
    "@sentry/node": "^10.60.0",
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "exceljs": "3.10.0",
    "express": "4.22.2",
    "express-session": "^1.18.0",
    "feed": "^5.2.1",
    "ioredis": "^5.10.0",
    "mongoose": "8.24.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "resend": "^3.2.0",
    "sanitize-html": "^2.13.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.0.0",
    "tesseract.js-core": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
