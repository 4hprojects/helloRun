{
  "name": "@hellorun/threaded-comments",
  "version": "0.1.0",
  "description": "Storage-neutral threaded comments workflow, Express integration, and Shadow DOM widget",
  "private": true,
  "type": "commonjs",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./src/index.js"
    },
    "./widget": "./web/threaded-comments.js",
