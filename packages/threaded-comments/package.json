    "./express": "./src/express.js",
    "./testing": "./src/testing.js"
  },
  "files": ["src", "types", "web", "docs", "examples", "README.md", "CHANGELOG.md"],
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "peerDependencies": {
    "express": ">=4",
    "mongoose": ">=7"
  },
  "peerDependenciesMeta": {
